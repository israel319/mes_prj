@namespace KCCMaterialFlow.Host.Components.Shared.Base
@using Radzen
@using Radzen.Blazor
@using KCCMaterialFlow.Domain.Constants
@using KCCMaterialFlow.Host.Helpers

@* Badge coloré selon le statut du bon - Accepte string *@

<RadzenBadge BadgeStyle="@GetBadgeStyle()" Style="font-size: 0.85em;">
    @if (ShowIcon)
    {
        <RadzenIcon Icon="@BonStatutUiHelper.GetIcon(Statut)" Style="font-size: 0.9em; margin-right: 4px;" />
    }
    @(CustomText ?? BonStatuts.GetLabel(Statut))
</RadzenBadge>

@code {
    [Parameter] public string Statut { get; set; } = "Draft";
    [Parameter] public bool ShowIcon { get; set; } = true;
    [Parameter] public string? CustomText { get; set; }

    private BadgeStyle GetBadgeStyle() => Statut switch
    {
        "Draft" => BadgeStyle.Light,
        "PendingSup" or "PendingGM" or "PendingOPJ" or "PendingIT" or "PendingEnv"
            or "PendingSuperviseur" or "PendingIdentification" => BadgeStyle.Warning,
        "Approved" => BadgeStyle.Success,
        "InTransit" => BadgeStyle.Info,
        "Completed" => BadgeStyle.Primary,
        "Rejected" or "Cancelled" => BadgeStyle.Danger,
        "Returned" => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };
}
