@namespace KCCMaterialFlow.Host.Components.Shared.Base
@using Radzen
@using Radzen.Blazor

@* Titre de page avec breadcrumb *@

<RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="mb-3">
    <RadzenStack Gap="0.25rem">
        @if (BreadcrumbItems != null && BreadcrumbItems.Any())
        {
            <RadzenBreadCrumb>
                @foreach (var item in BreadcrumbItems)
                {
                    @if (item == BreadcrumbItems.Last())
                    {
                        <RadzenBreadCrumbItem Text="@item.Text" />
                    }
                    else
                    {
                        <RadzenBreadCrumbItem Text="@item.Text" Path="@item.Url" />
                    }
                }
            </RadzenBreadCrumb>
        }
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            @if (!string.IsNullOrEmpty(Icon))
            {
                <RadzenIcon Icon="@Icon" />
            }
            <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H2" Style="margin: 0;">@Title</RadzenText>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); margin: 0;">@Subtitle</RadzenText>
            }
        </RadzenStack>
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
        @Actions
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public List<BreadcrumbItem>? BreadcrumbItems { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}
