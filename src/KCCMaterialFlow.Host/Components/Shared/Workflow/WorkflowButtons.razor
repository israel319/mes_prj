@namespace KCCMaterialFlow.Host.Components.Shared.Workflow
@using Radzen
@using Radzen.Blazor
@using KCCMaterialFlow.Domain.Constants

@* Boutons d'approbation/rejet - Accepte string pour statut *@

<div class="workflow-buttons d-flex gap-2 @CssClass">
    @if (CanApprove)
    {
        <RadzenButton Text="@ApproveText"
                      ButtonStyle="ButtonStyle.Success"
                      Icon="check_circle"
                      Click="@HandleApprove"
                      IsBusy="@IsProcessing"
                      Disabled="@IsProcessing" />
    }

    @if (CanReject)
    {
        <RadzenButton Text="@RejectText"
                      ButtonStyle="ButtonStyle.Danger"
                      Icon="cancel"
                      Click="@HandleReject"
                      Disabled="@IsProcessing" />
    }

    @if (CanReturn)
    {
        <RadzenButton Text="@ReturnText"
                      ButtonStyle="ButtonStyle.Warning"
                      Icon="undo"
                      Click="@HandleReturn"
                      Disabled="@IsProcessing" />
    }

    @AdditionalButtons
</div>

@code {
    [Parameter] public string CurrentStatut { get; set; } = "Draft";
    [Parameter] public string UserRole { get; set; } = "";
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public RenderFragment? AdditionalButtons { get; set; }
    [Parameter] public bool IsProcessing { get; set; }

    [Parameter] public string ApproveText { get; set; } = "Approuver";
    [Parameter] public string RejectText { get; set; } = "Rejeter";
    [Parameter] public string ReturnText { get; set; } = "Retourner";

    [Parameter] public bool? CanApproveOverride { get; set; }
    [Parameter] public bool? CanRejectOverride { get; set; }
    [Parameter] public bool? CanReturnOverride { get; set; }

    [Parameter] public EventCallback OnApprove { get; set; }
    [Parameter] public EventCallback OnReject { get; set; }
    [Parameter] public EventCallback OnReturn { get; set; }

    private bool CanApprove => CanApproveOverride ?? CalculateCanApprove();
    private bool CanReject => CanRejectOverride ?? CalculateCanReject();
    private bool CanReturn => CanReturnOverride ?? CalculateCanReturn();

    private bool CalculateCanApprove()
    {
        if (UserRole == "Admin") return BonStatuts.IsPending(CurrentStatut);

        return (CurrentStatut, UserRole) switch
        {
            (BonStatuts.PendingSup, "Superviseur") => true,
            (BonStatuts.PendingGM, "GM") => true,
            (BonStatuts.PendingOPJ, "OPJ") => true,
            _ => false
        };
    }

    private bool CalculateCanReject() => CalculateCanApprove();

    private bool CalculateCanReturn()
    {
        if (UserRole == "Admin") return BonStatuts.IsPending(CurrentStatut);
        return CalculateCanApprove();
    }

    private async Task HandleApprove() => await OnApprove.InvokeAsync();
    private async Task HandleReject() => await OnReject.InvokeAsync();
    private async Task HandleReturn() => await OnReturn.InvokeAsync();
}
