@inject IBarriereService BarriereService

<RadzenDropDown @bind-Value="@Value"
                Data="@_barrieres"
                TextProperty="NomBarriere"
                ValueProperty="Id"
                Placeholder="@Placeholder"
                AllowClear="@AllowClear"
                Disabled="@Disabled"
                Style="@Style"
                Class="@Class"
                Change="@OnValueChanged"
                LoadData="@LoadData"
                AllowFiltering="true"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                FilterOperator="StringFilterOperator.Contains">
    <Template Context="barriere">
        <div>
            <strong>@((barriere as Barriere)?.NomBarriere)</strong>
            <div class="rz-text-caption rz-color-secondary">
                @((barriere as Barriere)?.Localisation)
            </div>
        </div>
    </Template>
</RadzenDropDown>

@if (_selectedBarriere != null && ShowSelectedInfo)
{
    <div class="mt-2 p-2 rz-background-color-base-200 rz-border-radius">
        <div class="d-flex align-items-center gap-2">
            <RadzenIcon Icon="location_on" Style="color: var(--rz-primary);" />
            <div>
                <div class="rz-text-body2"><strong>@_selectedBarriere.NomBarriere</strong></div>
                <div class="rz-text-caption">@_selectedBarriere.Localisation</div>
                @if (!string.IsNullOrEmpty(_selectedBarriere.HorairesOuverture))
                {
                    <div class="rz-text-caption rz-color-secondary">
                        <RadzenIcon Icon="schedule" Style="font-size: 12px;" /> @_selectedBarriere.HorairesOuverture
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<Barriere> _barrieres = [];
    private Barriere? _selectedBarriere;
    private bool _isLoading;

    /// <summary>
    /// Valeur sélectionnée (IdBarriere)
    /// </summary>
    [Parameter]
    public int? Value { get; set; }

    /// <summary>
    /// Callback quand la valeur change
    /// </summary>
    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    /// <summary>
    /// Placeholder affiché quand aucune valeur n'est sélectionnée
    /// </summary>
    [Parameter]
    public string Placeholder { get; set; } = "Sélectionner une barrière...";

    /// <summary>
    /// Permet d'effacer la sélection
    /// </summary>
    [Parameter]
    public bool AllowClear { get; set; } = true;

    /// <summary>
    /// Désactive le composant
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Style CSS inline
    /// </summary>
    [Parameter]
    public string? Style { get; set; } = "width: 100%";

    /// <summary>
    /// Classes CSS additionnelles
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Filtre par type de barrière (Entrée, Sortie, Mixte)
    /// </summary>
    [Parameter]
    public string? FilterByType { get; set; }

    /// <summary>
    /// Affiche les informations de la barrière sélectionnée
    /// </summary>
    [Parameter]
    public bool ShowSelectedInfo { get; set; }

    /// <summary>
    /// Callback appelé quand la sélection change
    /// </summary>
    [Parameter]
    public EventCallback<Barriere?> OnSelectionChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadBarrieres();
        UpdateSelectedBarriere();
    }

    protected override void OnParametersSet()
    {
        UpdateSelectedBarriere();
    }

    private void UpdateSelectedBarriere()
    {
        _selectedBarriere = Value.HasValue
            ? _barrieres.FirstOrDefault(b => b.Id == Value.Value)
            : null;
    }

    private async Task LoadBarrieres()
    {
        if (_isLoading) return;

        _isLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(FilterByType))
            {
                _barrieres = await BarriereService.GetByTypeAsync(FilterByType);
            }
            else
            {
                _barrieres = await BarriereService.GetAllAsync();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadData(Radzen.LoadDataArgs args)
    {
        if (!_barrieres.Any())
        {
            await LoadBarrieres();
        }
    }

    private async Task OnValueChanged(object value)
    {
        var newValue = value as int?;
        Value = newValue;
        UpdateSelectedBarriere();

        await ValueChanged.InvokeAsync(newValue);
        await OnSelectionChanged.InvokeAsync(_selectedBarriere);
    }

    /// <summary>
    /// Récupère la barrière actuellement sélectionnée
    /// </summary>
    public Barriere? GetSelectedBarriere() => _selectedBarriere;

    /// <summary>
    /// Force le rechargement des données
    /// </summary>
    public async Task RefreshAsync()
    {
        BarriereService.InvalidateCache();
        await LoadBarrieres();
        UpdateSelectedBarriere();
        StateHasChanged();
    }

    /// <summary>
    /// Filtre les barrières par type
    /// </summary>
    public async Task SetFilterByTypeAsync(string? type)
    {
        FilterByType = type;
        await LoadBarrieres();

        // Réinitialiser la sélection si la barrière actuelle n'est plus dans la liste
        if (Value.HasValue && !_barrieres.Any(b => b.Id == Value.Value))
        {
            Value = null;
            _selectedBarriere = null;
            await ValueChanged.InvokeAsync(null);
            await OnSelectionChanged.InvokeAsync(null);
        }

        StateHasChanged();
    }
}
