@namespace KCCMaterialFlow.Host.Components.Layout
@using KCCMaterialFlow.Host.Services
@using KCCMaterialFlow.Module.Shared.Entities
@using KCCMaterialFlow.Module.Shared.Services
@using KCCMaterialFlow.Infrastructure.Services
@implements IDisposable
@inject DevRoleSwitcherService RoleSwitcher
@inject IUtilisateurService UtilisateurService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager Navigation

@* Composant de changement de rôle pour le développement *@
@* Visible uniquement pour les administrateurs *@

@if (CurrentUserService.IsInRole("Admin"))
{
<div class="dev-role-switcher @(isExpanded ? "expanded" : "collapsed")">
    <button class="toggle-btn" @onclick="ToggleExpand" title="Changer de rôle (DEV)">
        <RadzenIcon Icon="@(RoleSwitcher.IsSimulationActive ? "swap_horiz" : "engineering")" />
        @if (RoleSwitcher.IsSimulationActive)
        {
            <span class="badge">@GetCurrentBadge()</span>
        }
    </button>

    @if (isExpanded)
    {
        <div class="role-panel">
            <div class="panel-header">
                <RadzenIcon Icon="engineering" />
                <span>Mode Développeur</span>
                <button class="close-btn" @onclick="ToggleExpand">×</button>
            </div>

            <div class="panel-content">
                @* Tabs pour switcher entre les modes *@
                <div class="tab-buttons">
                    <button class="tab-btn @(activeTab == "users" ? "active" : "")" @onclick="@(() => SetActiveTab("users"))">
                        <RadzenIcon Icon="people" /> Utilisateurs
                    </button>
                    <button class="tab-btn @(activeTab == "roles" ? "active" : "")" @onclick="@(() => SetActiveTab("roles"))">
                        <RadzenIcon Icon="badge" /> Rôles
                    </button>
                </div>

                @if (RoleSwitcher.IsSimulationActive)
                {
                    <div class="current-simulation">
                        @if (!string.IsNullOrEmpty(RoleSwitcher.SimulatedUserName))
                        {
                            <div class="simulated-user">
                                <RadzenIcon Icon="person" />
                                <span><strong>@RoleSwitcher.SimulatedUserName</strong></span>
                            </div>
                        }
                        <div class="simulated-roles">
                            @foreach (var role in RoleSwitcher.SimulatedRoles)
                            {
                                <RadzenBadge Text="@role" BadgeStyle="@GetRoleBadgeStyle(role)" IsPill="true" />
                            }
                        </div>
                        <button class="reset-btn" @onclick="ClearSimulation">
                            <RadzenIcon Icon="refresh" /> Réinitialiser
                        </button>
                    </div>
                }

                @if (activeTab == "users")
                {
                    @* Recherche d'utilisateurs *@
                    <div class="search-box">
                        <RadzenIcon Icon="search" />
                        <input type="text" placeholder="Rechercher un utilisateur..." 
                               @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                        @if (isSearching)
                        {
                            <RadzenIcon Icon="hourglass_empty" class="spin" />
                        }
                    </div>

                    @if (searchResults.Any())
                    {
                        <div class="user-list">
                            @foreach (var user in searchResults)
                            {
                                <div class="user-item @(IsUserActive(user) ? "active" : "")" 
                                     @onclick="() => SelectUser(user)">
                                    <div class="user-avatar">
                                        @GetInitials(user.NomComplet)
                                    </div>
                                    <div class="user-info">
                                        <span class="user-name">@user.NomComplet</span>
                                        <span class="user-login">@user.Login</span>
                                        <div class="user-role-badges">
                                            <RadzenBadge Text="@(user.RolePrincipal?.CodeRole ?? "-")" BadgeStyle="@GetRoleBadgeStyle(user.RolePrincipal?.CodeRole ?? "")" 
                                                        IsPill="true" Style="font-size: 0.65rem;" />
                                            @if (!string.IsNullOrEmpty(user.Departement))
                                            {
                                                <span class="user-dept">@user.Departement</span>
                                            }
                                        </div>
                                    </div>
                                    @if (IsUserActive(user))
                                    {
                                        <RadzenIcon Icon="check_circle" class="check-icon" />
                                    }
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(searchTerm) && searchTerm.Length >= 2 && !isSearching)
                    {
                        <div class="no-results">
                            <RadzenIcon Icon="search_off" />
                            <span>Aucun utilisateur trouvé</span>
                        </div>
                    }
                    else
                    {
                        <div class="search-hint">
                            <RadzenIcon Icon="info" />
                            <span>Tapez au moins 2 caractères pour rechercher</span>
                        </div>
                    }
                }
                else
                {
                    @* Liste des rôles (mode manuel) *@
                    <p class="info-text">
                        <RadzenIcon Icon="info" /> Simulez un rôle spécifique
                    </p>
                    <div class="role-list">
                        @foreach (var role in DevRoleSwitcherService.AvailableRoles.Values)
                        {
                            <div class="role-item @(IsRoleActive(role.Code) ? "active" : "")" 
                                 @onclick="() => SelectRole(role.Code)">
                                <RadzenIcon Icon="@role.Icon" />
                                <div class="role-info">
                                    <span class="role-name">@role.Name</span>
                                    <span class="role-desc">@role.Description</span>
                                </div>
                                @if (IsRoleActive(role.Code))
                                {
                                    <RadzenIcon Icon="check_circle" class="check-icon" />
                                }
                            </div>
                        }
                    </div>
                }

                <div class="panel-footer">
                    <small>⚠️ Visible uniquement en mode DEBUG</small>
                </div>
            </div>
        </div>
    }
</div>
}

@code {
    private bool isExpanded = false;
    private string activeTab = "users";
    private string searchTerm = "";
    private List<Utilisateur> searchResults = new();
    private bool isSearching = false;
    private System.Timers.Timer? searchTimer;
    private bool _disposed;

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private void ToggleExpand()
    {
        isExpanded = !isExpanded;
        if (isExpanded && !searchResults.Any())
        {
            _ = LoadDefaultUsers();
        }
    }

    private async Task LoadDefaultUsers()
    {
        try
        {
            isSearching = true;
            if (!_disposed) StateHasChanged();
            
            var users = await UtilisateurService.GetAllAsync();
            searchResults = users.Where(u => u.EstActif).Take(10).ToList();
        }
        finally
        {
            isSearching = false;
            if (!_disposed) StateHasChanged();
        }
    }

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        searchTimer?.Stop();
        searchTimer?.Dispose();
        
        searchTimer = new System.Timers.Timer(300);
        searchTimer.Elapsed += async (s, args) =>
        {
            searchTimer?.Stop();
            if (_disposed) return;
            try
            {
                await InvokeAsync(async () =>
                {
                    if (!_disposed) await SearchUsers();
                });
            }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
        };
        searchTimer.AutoReset = false;
        searchTimer.Start();
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 2)
        {
            await LoadDefaultUsers();
            return;
        }

        try
        {
            isSearching = true;
            if (!_disposed) StateHasChanged();
            
            var results = await UtilisateurService.SearchAsync(searchTerm);
            searchResults = results.ToList();
        }
        finally
        {
            isSearching = false;
            if (!_disposed) StateHasChanged();
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length >= 2 ? name[..2].ToUpper() : name.ToUpper();
    }

    private string GetCurrentBadge()
    {
        if (!string.IsNullOrEmpty(RoleSwitcher.SimulatedUserName))
        {
            var parts = RoleSwitcher.SimulatedUserName.Split(' ');
            return parts.Length > 0 ? parts[0] : RoleSwitcher.SimulatedUserName;
        }
        return string.Join(", ", RoleSwitcher.SimulatedRoles);
    }

    private bool IsRoleActive(string roleCode)
    {
        return RoleSwitcher.SimulatedRoles.Contains(roleCode);
    }

    private bool IsUserActive(Utilisateur user)
    {
        return RoleSwitcher.SimulatedUserLogin == user.Login;
    }

    private void SelectUser(Utilisateur user)
    {
        // Mettre à jour le DevRoleSwitcherService
        RoleSwitcher.SetSimulatedUser(user.Login, user.NomComplet, new[] { user.RolePrincipal?.CodeRole ?? "Demandeur" });

        // Mettre à jour le CurrentUserService pour que les infos affichées soient celles de l'utilisateur simulé
        CurrentUserService.SetSimulatedUser(
            user.Login,
            user.NomComplet,
            user.Email,
            user.Departement,
            new[] { user.RolePrincipal?.CodeRole ?? "Demandeur" });

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void SelectRole(string roleCode)
    {
        RoleSwitcher.SetSingleRole(roleCode);

        // Pour le mode rôle manuel, on garde le login réel mais on change les rôles
        CurrentUserService.ClearSimulation();

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void ClearSimulation()
    {
        RoleSwitcher.ClearSimulation();

        CurrentUserService.ClearSimulation();

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private static BadgeStyle GetRoleBadgeStyle(string role) => role switch
    {
        "Admin" or "ADMIN" => BadgeStyle.Danger,
        "Superviseur" or "SUPERVISEUR" => BadgeStyle.Warning,
        "GM" => BadgeStyle.Primary,
        "IT" => BadgeStyle.Info,
        "Security" or "AGENT_SECURITE" => BadgeStyle.Secondary,
        "Investigation" => BadgeStyle.Dark,
        "Environnement" => BadgeStyle.Success,
        "OPJ" => BadgeStyle.Warning,
        "Identification" => BadgeStyle.Info,
        _ => BadgeStyle.Light
    };

    public void Dispose()
    {
        _disposed = true;
        searchTimer?.Dispose();
    }
}
