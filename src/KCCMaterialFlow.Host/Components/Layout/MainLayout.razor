@inherits LayoutComponentBase
@inject ICurrentUserService CurrentUserService
@inject NavigationManager Navigation
@using KCCMaterialFlow.Module.Shared.Services
@using KCCMaterialFlow.Module.Shared.Entities
@inject IUtilisateurService UtilisateurService

<RadzenComponents @rendermode="InteractiveServer" />

@* ============ LAYOUT PRINCIPAL ============ *@
<RadzenLayout>
    <RadzenHeader>
        <div class="kcc-header @(IsDemandeurOnly ? "kcc-header--demandeur" : "")">
            @if (IsDemandeurOnly)
            {
                @* ── Mode Demandeur : topbar complète ── *@
                <a href="/" class="kcc-brand">
                    <img src="/images/kcc-logo.png" alt="KCC" style="height: 36px; width: auto;" />
                    <div class="kcc-brand-text">
                        <span class="kcc-brand-name">KCC Flow</span>
                    </div>
                </a>

                <div class="kcc-divider-v"></div>

                <nav class="kcc-topnav">
                    <NavLink href="/" class="kcc-topnav-link" Match="NavLinkMatch.All">
                        <span>Accueil</span>
                    </NavLink>
                    <NavLink href="/liste-bons" class="kcc-topnav-link" Match="NavLinkMatch.Prefix">
                        <span>Mes Bons</span>
                    </NavLink>
                    <NavLink href="/historique" class="kcc-topnav-link" Match="NavLinkMatch.All">
                        <span>Historique</span>
                    </NavLink>
                </nav>

                @* Bouton "Nouveau" avec dropdown *@
                <div class="kcc-new-dropdown">
                    <button class="kcc-new-btn">
                        Nouveau
                        <svg class="kcc-new-chevron" width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M7 10l5 5 5-5z"/>
                        </svg>
                    </button>
                    <div class="kcc-new-menu">
                        <span class="kcc-new-menu-label">Créer un bon</span>
                        @if (CurrentUserService.HasActivite("BEM_CREER"))
                        {
                        <button class="kcc-new-item" @onclick="@(() => CreateBon("BEM"))">
                            <div class="kcc-new-item-icon bem">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 19V5M5 12l7-7 7 7"/>
                                </svg>
                            </div>
                            <div class="kcc-new-item-text">
                                <span class="kcc-new-item-title">Bon d'Entrée</span>
                                <span class="kcc-new-item-desc">Matériel entrant sur le site</span>
                            </div>
                        </button>
                        }
                        @if (CurrentUserService.HasActivite("BSM_CREER"))
                        {
                        <button class="kcc-new-item" @onclick="@(() => CreateBon("BSM"))">
                            <div class="kcc-new-item-icon bsm">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 5v14M5 12l7 7 7-7"/>
                                </svg>
                            </div>
                            <div class="kcc-new-item-text">
                                <span class="kcc-new-item-title">Bon de Sortie</span>
                                <span class="kcc-new-item-desc">Matériel sortant du site</span>
                            </div>
                        </button>
                        }
                    </div>
                </div>

                @* Spacer *@
                <div style="flex: 1;"></div>

                @* Recherche *@
                <div class="kcc-search">
                    <input type="text" placeholder="Rechercher un bon..."
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @onkeydown="HandleSearchKeyDown" />
                </div>

                @* Actions *@
                <div class="kcc-actions">
                    <NotificationPanel />

                    <div class="kcc-divider-v"></div>

                    <RadzenProfileMenu>
                        <Template>
                            <div class="kcc-user">
                                <div class="kcc-avatar" title="@displayName">
                                    @userInitials
                                </div>
                                <div class="kcc-user-info">
                                    <span class="kcc-username">@GetGreeting()</span>
                                    <span class="kcc-userrole">@displayName</span>
                                </div>
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#94a3b8">
                                    <path d="M7 10l5 5 5-5z"/>
                                </svg>
                            </div>
                        </Template>
                        <ChildContent>
                            <RadzenProfileMenuItem Text="Mon profil" Icon="person" Path="/profil" />
                            <RadzenProfileMenuItem Text="Préférences" Icon="settings" Path="/preferences" />
                            <hr style="margin: 0.5rem 0; border-color: #e5e7eb;" />
                            <RadzenProfileMenuItem Text="Déconnexion" Icon="logout" />
                        </ChildContent>
                    </RadzenProfileMenu>
                </div>
            }
            else
            {
                @* Mode complet: Toggle sidebar *@
                <button class="kcc-toggle" @onclick="@(() => sidebarExpanded = !sidebarExpanded)">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="2" stroke-linecap="round">
                        <path d="M3 12h18M3 6h18M3 18h18"/>
                    </svg>
                </button>

                @* Recherche fonctionnelle *@
                <div class="kcc-search">
                    <input type="text" placeholder="Rechercher un bon (ex: BEM-2026-001)..."
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @onkeydown="HandleSearchKeyDown" />
                </div>

                @* Actions *@
                <div class="kcc-actions">
                    <NotificationPanel />

                    <RadzenProfileMenu>
                        <Template>
                            <div class="kcc-user">
                                <div class="kcc-avatar" title="@displayName">
                                    @userInitials
                                </div>
                                <div class="kcc-user-info">
                                    <span class="kcc-username">@displayName</span>
                                    <span class="kcc-userrole">@userRole</span>
                                </div>
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="#94a3b8">
                                    <path d="M7 10l5 5 5-5z"/>
                                </svg>
                            </div>
                        </Template>
                        <ChildContent>
                            <RadzenProfileMenuItem Text="Mon profil" Icon="person" Path="/profil" />
                            <RadzenProfileMenuItem Text="Préférences" Icon="settings" Path="/preferences" />
                            <hr style="margin: 0.5rem 0; border-color: #e5e7eb;" />
                            <RadzenProfileMenuItem Text="Déconnexion" Icon="logout" />
                        </ChildContent>
                    </RadzenProfileMenu>
                </div>
            }
        </div>
    </RadzenHeader>

    @if (!IsDemandeurOnly)
    {
        @* Sidebar simple pour les rôles avancés *@
        <RadzenSidebar @bind-Expanded="@sidebarExpanded">
            <div class="sidebar-simple">
                <RadzenPanelMenu>
                    <NavMenu />
                </RadzenPanelMenu>
            </div>
        </RadzenSidebar>
    }

    <RadzenBody>
        @Body
    </RadzenBody>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

<DevRoleSwitcher />

@code {
    private bool sidebarExpanded = true;
    private string searchQuery = "";
    private string displayName = "";
    private string userRole = "";
    private string userInitials = "";
    private Utilisateur? currentDbUser;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserFromDatabase();
    }

    private async Task LoadUserFromDatabase()
    {
        try
        {
            var login = CurrentUserService.GetUserLogin();
            if (!string.IsNullOrEmpty(login) && login != "Anonyme")
            {
                currentDbUser = await UtilisateurService.GetByLoginAsync(login);
            }

            if (currentDbUser != null)
            {
                displayName = currentDbUser.NomComplet;
                userRole = currentDbUser.RolePrincipal?.NomRole ?? currentDbUser.RolePrincipal?.CodeRole ?? "Utilisateur";
            }
            else
            {
                displayName = CurrentUserService.GetUserDisplayName();
                userRole = GetPrimaryRole();
            }

            userInitials = GetInitials(displayName);
        }
        catch
        {
            displayName = CurrentUserService.GetUserDisplayName();
            userRole = GetPrimaryRole();
            userInitials = GetInitials(displayName);
        }
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}";
        return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
    }

    private string GetGreeting()
    {
        var hour = DateTime.Now.Hour;
        var firstName = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? displayName;
        if (hour < 12) return $"Bonjour";
        if (hour < 18) return $"Bon après-midi";
        return $"Bonsoir";
    }

    /// <summary>
    /// Vérifie si l'utilisateur a uniquement le rôle Demandeur (sans autres rôles avancés)
    /// </summary>
    private bool IsDemandeurOnly
    {
        get
        {
            var roles = CurrentUserService.GetUserRoles();
            var advancedRoles = new[] { "Admin", "Superviseur", "GM", "IT", "Environnement",
                                        "OPJ", "Identification", "Barriere", "Investigation" };
            return !roles.Any(r => advancedRoles.Contains(r, StringComparer.OrdinalIgnoreCase));
        }
    }

    private string GetPrimaryRole()
    {
        var roles = CurrentUserService.GetUserRoles();
        if (!roles.Any()) return "Demandeur";

        var priority = new[] { "Admin", "GM", "Superviseur", "OPJ", "IT", "Environnement",
                               "Identification", "Investigation", "Barriere", "Demandeur" };

        foreach (var p in priority)
        {
            if (roles.Contains(p, StringComparer.OrdinalIgnoreCase))
                return p;
        }

        return roles.First();
    }

    private void CreateBon(string type)
    {
        var url = type == "BEM" ? "/bon-entree/nouveau" : "/bon-sortie/nouveau";
        Navigation.NavigateTo(url);
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            // Naviguer vers la page de liste avec le filtre de recherche
            Navigation.NavigateTo($"/liste-bons?search={Uri.EscapeDataString(searchQuery.Trim())}");
        }
    }
}
