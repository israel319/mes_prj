@inject ICurrentUserService CurrentUserService
@inject IStringLocalizer<SharedResource> L

<RadzenPanelMenuItem Text="@L["Nav_Dashboard"]" Icon="dashboard" Path="/" />
<RadzenPanelMenuItem Text="@L["Nav_AllVouchers"]" Icon="list_alt" Path="/liste-bons" />

@if (CanApprove)
{
    <RadzenPanelMenuItem Text="@L["Nav_Approvals"]" Icon="rule" Path="/mes-approbations" />
}

@if (CanCreateBEM)
{
    <RadzenPanelMenuItem Text="@L["Nav_NewBEM"]" Icon="input" Path="/bon-entree/nouveau" />
}
@if (CanCreateBSM)
{
    <RadzenPanelMenuItem Text="@L["Nav_NewBSM"]" Icon="output" Path="/bon-sortie/nouveau" />
}
@if (CanScan)
{
    <RadzenPanelMenuItem Text="@L["Nav_Scanner"]" Icon="qr_code_scanner" Path="/securite/scanner" />
}

@if (IsAdmin)
{
    <RadzenPanelMenuItem Text="@L["Nav_Admin"]" Icon="settings" Path="/admin/utilisateurs" />
    <RadzenPanelMenuItem Text="@L["AdmNav_Workflows"]" Icon="route" Path="/admin/workflows" />
    <RadzenPanelMenuItem Text="@L["Nav_DeptMotifs"]" Icon="account_tree" Path="/admin/departement-motifs" />
}

@code {
    private bool CanApprove => CurrentUserService.HasAnyActivite("BEM_APPROUVER", "BEM_REJETER", "BEM_RETOURNER", "BSM_APPROUVER", "BSM_REJETER", "BSM_RETOURNER");
    private bool CanCreateBEM => CurrentUserService.HasActivite("BEM_CREER");
    private bool CanCreateBSM => CurrentUserService.HasActivite("BSM_CREER");
    private bool CanScan => CurrentUserService.HasActivite("SEC_SCANNER");
    private bool IsAdmin => CurrentUserService.IsInRole("Admin");
}

