@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager Navigation
@implements IDisposable

<div class="notification-wrapper">
    <button class="kcc-notif" title="Notifications" @onclick="TogglePanel">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="1.8">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        @if (notifications?.TotalCount > 0)
        {
            <span class="kcc-notif-badge">@notifications.TotalCount</span>
        }
    </button>
    
    @if (showPanel)
    {
        <div class="notification-overlay" @onclick="ClosePanel"></div>
        <div class="notification-panel">
            <div class="notification-header">
                <h4>Notifications</h4>
                <button class="close-btn" @onclick="ClosePanel">×</button>
            </div>
            
            <div class="notification-content">
                @if (isLoading)
                {
                    <div class="loading-state">
                        <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Small" />
                        <span>Chargement...</span>
                    </div>
                }
                else if (notifications?.TotalCount == 0)
                {
                    <div class="empty-state">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        <p>Aucune notification</p>
                    </div>
                }
                else
                {
                    @* Bons retournés *@
                    @if (notifications?.ReturnedBons.Count > 0)
                    {
                        <div class="notification-section">
                            <h5><RadzenIcon Icon="replay" /> Bons retournés</h5>
                            @foreach (var bon in notifications.ReturnedBons.Take(5))
                            {
                                <div class="notification-item returned" @onclick="@(() => NavigateToBon(bon))">
                                    <div class="notification-icon">
                                        <RadzenIcon Icon="replay" />
                                    </div>
                                    <div class="notification-details">
                                        <div class="notification-title">
                                            <span class="bon-type @(bon.TypeBon == "BEM" ? "bem" : "bsm")">@bon.TypeBon</span>
                                            <strong>@bon.NumeroReference</strong>
                                        </div>
                                        <p class="notification-reason">@TruncateText(bon.RaisonRetour, 60)</p>
                                        <span class="notification-meta">
                                            @bon.DateRetour.ToString("dd/MM à HH:mm") par @bon.AuteurRetour
                                        </span>
                                    </div>
                                </div>
                            }
                            @if (notifications.ReturnedBons.Count > 5)
                            {
                                <div class="show-more">
                                    <button @onclick="@(() => Navigation.NavigateTo("/mes-bons"))">
                                        Voir tous mes bons (@notifications.ReturnedBons.Count)
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    
                    @* Approbations en attente *@
                    @if (notifications?.PendingApprovals > 0)
                    {
                        <div class="notification-section">
                            <h5><RadzenIcon Icon="pending_actions" /> Approbations en attente</h5>
                            <div class="notification-item pending" @onclick="@(() => Navigation.NavigateTo("/mes-approbations"))">
                                <div class="notification-icon pending">
                                    <RadzenIcon Icon="pending_actions" />
                                </div>
                                <div class="notification-details">
                                    <strong>@notifications.PendingApprovals bon(s) en attente</strong>
                                    <p class="notification-reason">Cliquez pour voir les bons à approuver</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private KCCMaterialFlow.Host.Services.UserNotifications? notifications;
    private bool showPanel = false;
    private bool isLoading = false;
    private Timer? refreshTimer;
    private CancellationTokenSource _cts = new();
    private bool _disposed;

    protected override void OnInitialized()
    {
        // Ne pas charger les notifications immédiatement pour éviter les conflits DbContext
        // Elles seront chargées après un délai ou au clic
        _ = DelayedInitialLoad();
    }

    private async Task DelayedInitialLoad()
    {
        try
        {
            // Attendre que la page principale soit chargée
            await Task.Delay(2000, _cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        
        if (_disposed) return;

        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                await LoadNotificationsAsync();
                if (!_disposed) StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { }
        catch (TaskCanceledException) { }
        
        if (_disposed) return;

        // Démarrer le timer de rafraîchissement après le premier chargement
        refreshTimer = new Timer(async _ => 
        {
            if (_disposed) return;
            try
            {
                await InvokeAsync(async () =>
                {
                    if (_disposed) return;
                    await LoadNotificationsAsync();
                    if (!_disposed) StateHasChanged();
                });
            }
            catch (ObjectDisposedException) { }
            catch (TaskCanceledException) { }
        }, null, TimeSpan.FromMinutes(2), TimeSpan.FromMinutes(2));
    }

    private async Task LoadNotificationsAsync()
    {
        try
        {
            // Créer un nouveau scope pour éviter les problèmes de DbContext disposé
            using var scope = ScopeFactory.CreateScope();
            var notificationService = scope.ServiceProvider.GetRequiredService<KCCMaterialFlow.Host.Services.IUserNotificationService>();
            notifications = await notificationService.GetNotificationsAsync();
        }
        catch
        {
            notifications = new KCCMaterialFlow.Host.Services.UserNotifications();
        }
    }

    private async Task TogglePanel()
    {
        showPanel = !showPanel;
        if (showPanel)
        {
            isLoading = true;
            StateHasChanged();
            
            await LoadNotificationsAsync();
            isLoading = false;
            if (!_disposed) StateHasChanged();
        }
    }

    private void ClosePanel()
    {
        showPanel = false;
    }

    private void NavigateToBon(KCCMaterialFlow.Module.BonSortie.Services.ReturnedBonInfo bon)
    {
        ClosePanel();
        var path = bon.TypeBon == "BEM" 
            ? $"/bon-entree/{bon.IdBon}" 
            : $"/bon-sortie/{bon.IdBon}";
        Navigation.NavigateTo(path);
    }

    private static string TruncateText(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text[..maxLength] + "...";
    }

    public void Dispose()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
        refreshTimer?.Dispose();
    }
}
