@inject ICurrentUserService CurrentUserService

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
    @* Notification bell *@
    <RadzenButton Icon="notifications" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" 
        Click="@(() => { })" title="Notifications" />
    
    @* User info dropdown *@
    <RadzenProfileMenu>
        <Template>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenGravatar Email="@UserEmail" Size="32" />
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-0">@UserDisplayName</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">@UserRole</RadzenText>
                </RadzenStack>
                <RadzenIcon Icon="expand_more" />
            </RadzenStack>
        </Template>
        <ChildContent>
            <RadzenProfileMenuItem Text="Mon profil" Icon="person" Path="/profil" />
            <RadzenProfileMenuItem Text="Préférences" Icon="settings" Path="/preferences" />
            <hr class="rz-my-2" />
            <RadzenProfileMenuItem Text="Déconnexion" Icon="logout" Click="@(() => Logout())" />
        </ChildContent>
    </RadzenProfileMenu>
</RadzenStack>

@code {
    private string UserDisplayName => CurrentUserService.GetUserDisplayName();
    private string? UserEmail => CurrentUserService.GetUserEmail();
    private string UserRole => CurrentUserService.GetUserRoles().FirstOrDefault() ?? "Utilisateur";

    private void Logout()
    {
        // Windows Auth n'a pas de déconnexion explicite
        // On peut rediriger vers une page d'information
    }
}
