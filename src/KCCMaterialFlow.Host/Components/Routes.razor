@using KCCMaterialFlow.Host.Components.Layout
@using Microsoft.AspNetCore.Components.Authorization
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
                <NotAuthorized>
                    <div style="padding: 3rem; text-align: center;">
                        <RadzenIcon Icon="lock" Style="font-size: 3rem; color: var(--kcc-accent); margin-bottom: 1rem;" />
                        <RadzenText TextStyle="TextStyle.H5" Style="margin-bottom: 0.5rem;">@L["Err_Unauthorized"]</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin-bottom: 1.5rem;">
                            @L["Err_UnauthorizedDesc"]
                        </RadzenText>
                        <RadzenButton Text="@L["Btn_BackHome"].Value" Icon="home" ButtonStyle="ButtonStyle.Primary"
                                      Click="@(() => Navigation.NavigateTo("/"))" />
                    </div>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Page non trouvée</PageTitle>
            <LayoutView Layout="typeof(MainLayout)">
                <div class="rz-p-4 rz-text-align-center">
                    <h1>@L["Err_404"]</h1>
                    <p>@L["Err_404Desc"]</p>
                    <a href="/" class="rz-button rz-button-md rz-variant-filled rz-primary">
                        @L["Btn_BackHome"]
                    </a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

