@page "/"
@attribute [Authorize]
@using BonEntreeEntity = KCCMaterialFlow.Domain.Entities.BonEntree
@using BonSortieEntity = KCCMaterialFlow.Domain.Entities.BonSortie
@using BonSortieExterneEntity = KCCMaterialFlow.Domain.Entities.BonSortieExterne
@using BonSortieInterneEntity = KCCMaterialFlow.Domain.Entities.BonSortieInterne
@using PretEntity = KCCMaterialFlow.Domain.Entities.Pret
@inject NavigationManager Navigation
@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject INotificationRejetService NotificationRejetService

<PageTitle>Tableau de bord - KCC Material</PageTitle>

<RadzenStack Gap="1.5rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">

    @* === PAGE HEADER === *@
    <RadzenStack Gap="0.25rem">
        <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-text-title); margin: 0;">Tableau de bord</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin: 0;">Vue d'ensemble des bons d'entrée et de sortie</RadzenText>
    </RadzenStack>

    @* === STATS GRID === *@
    <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="1rem">
        @* Bons d'entrée *@
        <RadzenCard Style="flex: 1 1 200px; min-width: 200px; cursor: pointer; background: var(--kcc-info-light);" @onclick="@(() => NavigateTo("/liste-bons/bem"))">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); font-weight: 500; margin: 0;">Bons d'entrée</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-info); margin: 0;">@stats.TotalBEM</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">Total des entrées</RadzenText>
                </RadzenStack>
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="width: 40px; height: 40px; background: rgba(255,255,255,0.6); color: var(--kcc-info);">
                    <RadzenIcon Icon="input" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* Bons de sortie *@
        <RadzenCard Style="flex: 1 1 200px; min-width: 200px; cursor: pointer; background: var(--kcc-primary-light);" @onclick="@(() => NavigateTo("/liste-bons/bsm"))">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); font-weight: 500; margin: 0;">Bons de sortie</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-primary); margin: 0;">@stats.TotalBSM</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">Total des sorties</RadzenText>
                </RadzenStack>
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="width: 40px; height: 40px; background: rgba(255,255,255,0.6); color: var(--kcc-primary);">
                    <RadzenIcon Icon="output" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* En attente *@
        <RadzenCard Style="flex: 1 1 200px; min-width: 200px; cursor: pointer; background: var(--kcc-warning-light);" @onclick="@(() => NavigateTo(isApprover ? "/mes-approbations" : "/suivi-bons"))">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); font-weight: 500; margin: 0;">En attente</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-warning); margin: 0;">@stats.EnAttente</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">@(isApprover ? "À traiter" : "Mes demandes")</RadzenText>
                </RadzenStack>
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="width: 40px; height: 40px; background: rgba(255,255,255,0.6); color: var(--kcc-warning);">
                    <RadzenIcon Icon="pending_actions" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* Approuvés *@
        <RadzenCard Style="flex: 1 1 200px; min-width: 200px; cursor: pointer; background: rgba(5,150,105,0.08);" @onclick="@(() => NavigateTo("/liste-bons?statut=approuve"))">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); font-weight: 500; margin: 0;">Approuvés</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: #059669; margin: 0;">@stats.Approuves</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">Ce mois</RadzenText>
                </RadzenStack>
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="width: 40px; height: 40px; background: rgba(255,255,255,0.6); color: #059669;">
                    <RadzenIcon Icon="check_circle" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* Rejets *@
        <RadzenCard Style="flex: 1 1 200px; min-width: 200px; cursor: pointer; background: var(--kcc-accent-light);" @onclick="@(() => NavigateTo("/liste-rejets"))">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); font-weight: 500; margin: 0;">Rejets</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-accent); margin: 0;">@stats.Rejetes</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">@(stats.RejetsNonLus > 0 ? $"{stats.RejetsNonLus} non lu(s)" : "Tous lus")</RadzenText>
                </RadzenStack>
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="width: 40px; height: 40px; background: rgba(255,255,255,0.6); color: var(--kcc-accent);">
                    <RadzenIcon Icon="cancel" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* Prêts actifs *@
        <RadzenCard Style="flex: 1 1 200px; min-width: 200px; cursor: pointer; background: rgba(139,92,246,0.08);" @onclick="@(() => NavigateTo("/liste-bons/prets"))">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); font-weight: 500; margin: 0;">Prêts</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: #8B5CF6; margin: 0;">@stats.PretsActifs</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">
                        @(stats.PretsEnRetard > 0 ? $"{stats.PretsEnRetard} en retard" : "Aucun retard")
                    </RadzenText>
                </RadzenStack>
                <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center"
                             Style="width: 40px; height: 40px; background: rgba(255,255,255,0.6); color: #8B5CF6;">
                    <RadzenIcon Icon="swap_horiz" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>
    </RadzenStack>

    @* === ACTIONS RAPIDES === *@
    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0 0 0.25rem 0;">Actions rapides</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin: 0 0 1rem 0;">Créer un nouveau bon d'entrée ou de sortie</RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Wrap="FlexWrap.Wrap">
            <RadzenButton Text="Nouveau bon d'entrée" Icon="add" ButtonStyle="ButtonStyle.Primary"
                          Click="@(() => NavigateTo("/bon-entree/nouveau"))" />
            <RadzenButton Text="Nouveau bon de sortie" Icon="add" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined"
                          Click="@(() => NavigateTo("/bon-sortie/nouveau"))" />
        </RadzenStack>
    </RadzenCard>

    @* === 2 COLONNES: Entrées / Sorties récentes === *@
    <RadzenRow Gap="1.5rem">
        @* Colonne 1: Entrées récentes *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start" class="rz-mb-3">
                    <RadzenStack Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Entrées récentes</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin: 0;">Derniers bons d'entrée créés</RadzenText>
                    </RadzenStack>
                    <RadzenButton Text="Voir tout" Icon="arrow_forward" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                  Size="ButtonSize.Small" Click="@(() => NavigateTo("/liste-bons/bem"))" class="kcc-link-button" />
                </RadzenStack>

                @if (isLoading)
                {
                    <RadzenStack AlignItems="AlignItems.Center" Style="padding: 2rem;">
                        <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Small" />
                    </RadzenStack>
                }
                else if (entreesRecentes.Any())
                {
                    <RadzenStack Gap="0">
                        @foreach (var entree in entreesRecentes)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                         JustifyContent="JustifyContent.SpaceBetween"
                                         Style="padding: 0.75rem 0; border-bottom: 1px solid var(--kcc-border); cursor: pointer;"
                                         @onclick="() => NavigateTo(entree.Url)">
                                <RadzenStack Gap="0.125rem">
                                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500; margin: 0;">@entree.Reference</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">@entree.NomEntreprise</RadzenText>
                                </RadzenStack>
                                <RadzenBadge Text="@entree.StatutLibelle" BadgeStyle="@GetBadgeStyleFromCode(entree.StatutCode)" />
                            </RadzenStack>
                        }
                    </RadzenStack>
                }
                else
                {
                    <RadzenStack AlignItems="AlignItems.Center" Style="padding: 2rem;">
                        <RadzenIcon Icon="inbox" Style="font-size: 2.5rem; opacity: 0.5; color: var(--kcc-text-muted);" />
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin: 0;">Aucune entrée récente</RadzenText>
                    </RadzenStack>
                }
            </RadzenCard>
        </RadzenColumn>

        @* Colonne 2: Sorties récentes *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start" class="rz-mb-3">
                    <RadzenStack Gap="0.125rem">
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0;">Sorties récentes</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin: 0;">Derniers bons de sortie créés</RadzenText>
                    </RadzenStack>
                    <RadzenButton Text="Voir tout" Icon="arrow_forward" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                  Size="ButtonSize.Small" Click="@(() => NavigateTo("/liste-bons/bsm"))" class="kcc-link-button" />
                </RadzenStack>

                @if (isLoading)
                {
                    <RadzenStack AlignItems="AlignItems.Center" Style="padding: 2rem;">
                        <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Small" />
                    </RadzenStack>
                }
                else if (sortiesRecentes.Any())
                {
                    <RadzenStack Gap="0">
                        @foreach (var sortie in sortiesRecentes)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                         JustifyContent="JustifyContent.SpaceBetween"
                                         Style="padding: 0.75rem 0; border-bottom: 1px solid var(--kcc-border); cursor: pointer;"
                                         @onclick="() => NavigateTo(sortie.Url)">
                                <RadzenStack Gap="0.125rem">
                                    <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 500; margin: 0;">@sortie.Reference</RadzenText>
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin: 0;">@sortie.NomEntreprise</RadzenText>
                                </RadzenStack>
                                <RadzenBadge Text="@sortie.StatutLibelle" BadgeStyle="@GetBadgeStyleFromCode(sortie.StatutCode)" />
                            </RadzenStack>
                        }
                    </RadzenStack>
                }
                else
                {
                    <RadzenStack AlignItems="AlignItems.Center" Style="padding: 2rem;">
                        <RadzenIcon Icon="outbox" Style="font-size: 2.5rem; opacity: 0.5; color: var(--kcc-text-muted);" />
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-muted); margin: 0;">Aucune sortie récente</RadzenText>
                    </RadzenStack>
                }
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    // ============ MODELE DE DONNEES ============
    private class DashboardStats
    {
        public int TotalBEM { get; set; }
        public int TotalBSM { get; set; }
        public int EnAttente { get; set; }
        public int Approuves { get; set; }
        public int Rejetes { get; set; }
        public int RejetsNonLus { get; set; }
        public int PretsActifs { get; set; }
        public int PretsEnRetard { get; set; }
    }
    
    private class BonItem
    {
        public string Reference { get; set; } = string.Empty;
        public string NomEntreprise { get; set; } = string.Empty;
        public string StatutCode { get; set; } = string.Empty;
        public string StatutLibelle { get; set; } = string.Empty;
        public string Url { get; set; } = string.Empty;
    }
    
    // ============ DONNEES ============
    private bool isLoading = true;
    private DashboardStats stats = new();
    private List<BonItem> entreesRecentes = new();
    private List<BonItem> sortiesRecentes = new();
    private bool canSeeAll = false;
    private bool isApprover = false;
    private List<string> approverRoles = new();
    
    // Liste des rôles qui peuvent approuver
    private static readonly string[] AllApproverRoles = new[] 
    { 
        "Superviseur", "GM", "OPJ", "IT", "Environnement", "Identification", "Investigation", "Barriere" 
    };
    
    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            // Récupérer les rôles de l'utilisateur
            var roles = CurrentUserService.GetUserRoles().ToList();
            canSeeAll = roles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));
            
            // Vérifier si l'utilisateur est un approbateur
            approverRoles = roles.Where(r => AllApproverRoles.Contains(r, StringComparer.OrdinalIgnoreCase)).ToList();
            isApprover = approverRoles.Any();
            
            await Task.WhenAll(LoadStatsAsync(), LoadRecentBonsAsync());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur dashboard: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            var currentLogin = CurrentUserService.GetUserLogin();
            var currentName = CurrentUserService.GetUserDisplayName();
            
            if (canSeeAll)
            {
                // Admins : lancer tous les appels en parallèle
                var bemStatsTask = BonEntreeService.GetStatsAsync();
                var bsmStatsTask = BonSortieService.GetStatsAsync();
                var pendingBEMTask = BonEntreeService.GetPendingApprovalsAsync();
                var pendingBSMTask = BonSortieService.GetPendingApprovalsAsync();
                var allRejetsTask = NotificationRejetService.GetNotificationsAsync();
                var rejetsNonLusTask = NotificationRejetService.CompterNotificationsNonLuesAsync();
                var activeLoansTask = BonSortieService.GetActiveLoansAsync();
                var overdueLoansTask = BonSortieService.GetOverdueLoansAsync();

                await Task.WhenAll(bemStatsTask, bsmStatsTask, pendingBEMTask, pendingBSMTask, allRejetsTask, rejetsNonLusTask, activeLoansTask, overdueLoansTask);

                var bemStats = bemStatsTask.Result;
                var bsmStats = bsmStatsTask.Result;

                stats = new DashboardStats
                {
                    TotalBEM = bemStats.TotalBons,
                    TotalBSM = bsmStats.TotalBons,
                    EnAttente = pendingBEMTask.Result.Count + pendingBSMTask.Result.Count,
                    Approuves = bemStats.BonsApprouves + bsmStats.BonsApprouves,
                    Rejetes = allRejetsTask.Result.Count(),
                    RejetsNonLus = rejetsNonLusTask.Result,
                    PretsActifs = activeLoansTask.Result.Count,
                    PretsEnRetard = overdueLoansTask.Result.Count
                };
            }
            else if (isApprover)
            {
                // Approbateurs : bons propres (server-side) + pending approvals en parallèle
                // BEM: NomDemandeur stores display name → use currentName
                // BSM: filter checks both NomDemandeur and CreatedByLogin → use currentLogin
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 100 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 100 });
                var pendingBEMTask = BonEntreeService.GetPendingApprovalsAsync();
                var pendingBSMTask = BonSortieService.GetPendingApprovalsAsync();
                var allRejetsTask = NotificationRejetService.GetNotificationsAsync();
                var activeLoansTask = BonSortieService.GetActiveLoansAsync();
                var overdueLoansTask = BonSortieService.GetOverdueLoansAsync();

                await Task.WhenAll(myBEMTask, myBSMTask, pendingBEMTask, pendingBSMTask, allRejetsTask, activeLoansTask, overdueLoansTask);

                var myBEM = myBEMTask.Result;
                var myBSM = myBSMTask.Result;
                var pendingBEM = pendingBEMTask.Result;
                var pendingBSM = pendingBSMTask.Result;

                var userBEM = myBEM.Items.ToList();
                var userBSM = myBSM.Items.ToList();

                // Calculer les totaux visibles (propres + pending, dédupliqués)
                var allVisibleBEMIds = new HashSet<int>(userBEM.Select(b => b.Id));
                foreach (var bon in pendingBEM) allVisibleBEMIds.Add(bon.Id);

                var allVisibleBSMIds = new HashSet<int>(userBSM.Select(b => b.Id));
                foreach (var bon in pendingBSM) allVisibleBSMIds.Add(bon.Id);

                // Tous les bons visibles pour compter les approuvés
                var allVisibleBEM = userBEM.Concat(pendingBEM.Where(b => !userBEM.Any(u => u.Id == b.Id))).ToList();
                var allVisibleBSM = userBSM.Concat(pendingBSM.Where(b => !userBSM.Any(u => u.Id == b.Id))).ToList();

                // Filtrer les rejets liés à l'utilisateur
                var allRejets = allRejetsTask.Result;
                var userRejets = allRejets.Where(r =>
                    (r.DemandeurNom?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.DemandeurNom?.Equals(currentName, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.ApprobateurLogin?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true)).ToList();

                // Filtrer les prêts : uniquement ceux liés aux BSM visibles (propres + pending)
                var userActiveLoans = activeLoansTask.Result.Where(p => allVisibleBSMIds.Contains(p.Id)).ToList();
                var userOverdueLoans = overdueLoansTask.Result.Where(p => allVisibleBSMIds.Contains(p.Id)).ToList();

                stats = new DashboardStats
                {
                    TotalBEM = allVisibleBEMIds.Count,
                    TotalBSM = allVisibleBSMIds.Count,
                    EnAttente = pendingBEM.Count + pendingBSM.Count,
                    Approuves = allVisibleBEM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)) +
                                allVisibleBSM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)),
                    Rejetes = userRejets.Count,
                    RejetsNonLus = userRejets.Count(r => !r.EstLue),
                    PretsActifs = userActiveLoans.Count,
                    PretsEnRetard = userOverdueLoans.Count
                };
            }
            else
            {
                // Utilisateurs normaux : filtrage server-side par demandeur
                // BEM: NomDemandeur stores display name → use currentName
                // BSM: filter checks both NomDemandeur and CreatedByLogin → use currentLogin
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 100 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 100 });
                var allRejetsTask = NotificationRejetService.GetNotificationsAsync();
                var activeLoansTask = BonSortieService.GetActiveLoansAsync();
                var overdueLoansTask = BonSortieService.GetOverdueLoansAsync();

                await Task.WhenAll(myBEMTask, myBSMTask, allRejetsTask, activeLoansTask, overdueLoansTask);

                var userBEM = myBEMTask.Result.Items.ToList();
                var userBSM = myBSMTask.Result.Items.ToList();

                // Filtrer les rejets : uniquement ceux où l'utilisateur est le demandeur
                var allRejets = allRejetsTask.Result;
                var userRejets = allRejets.Where(r =>
                    (r.DemandeurNom?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.DemandeurNom?.Equals(currentName, StringComparison.OrdinalIgnoreCase) == true)).ToList();

                // Filtrer les prêts : uniquement ceux liés aux BSM de l'utilisateur
                var userBSMIds = new HashSet<int>(userBSM.Select(b => b.Id));
                var userActiveLoans = activeLoansTask.Result.Where(p => userBSMIds.Contains(p.Id)).ToList();
                var userOverdueLoans = overdueLoansTask.Result.Where(p => userBSMIds.Contains(p.Id)).ToList();

                stats = new DashboardStats
                {
                    TotalBEM = userBEM.Count,
                    TotalBSM = userBSM.Count,
                    EnAttente = userBEM.Count(b => b.StatutActuel.StartsWith("Pending", StringComparison.OrdinalIgnoreCase)) +
                                userBSM.Count(b => b.StatutActuel.StartsWith("Pending", StringComparison.OrdinalIgnoreCase)),
                    Approuves = userBEM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)) +
                                userBSM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)),
                    Rejetes = userRejets.Count,
                    RejetsNonLus = userRejets.Count(r => !r.EstLue),
                    PretsActifs = userActiveLoans.Count,
                    PretsEnRetard = userOverdueLoans.Count
                };
            }
        }
        catch { }
    }

    private async Task LoadRecentBonsAsync()
    {
        try
        {
            var currentLogin = CurrentUserService.GetUserLogin();
            var currentName = CurrentUserService.GetUserDisplayName();
            
            if (canSeeAll)
            {
                // Admins : les 5 derniers bons en parallèle
                var allBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Take = 5 });
                var allBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Take = 5 });
                await Task.WhenAll(allBEMTask, allBSMTask);

                entreesRecentes = allBEMTask.Result.Items.Select(b => new BonItem
                {
                    Reference = b.NumeroReference,
                    NomEntreprise = b.NomCompagnie ?? "N/A",
                    StatutCode = MapStatutCode(b.StatutActuel),
                    StatutLibelle = GetStatutDisplay(b.StatutActuel),
                    Url = $"/bon-entree/{b.Id}"
                }).ToList();

                sortiesRecentes = allBSMTask.Result.Items.Select(b => new BonItem
                {
                    Reference = b.NumeroReference,
                    NomEntreprise = GetBSMType(b),
                    StatutCode = MapStatutCode(b.StatutActuel),
                    StatutLibelle = GetStatutDisplay(b.StatutActuel),
                    Url = $"/bon-sortie/{b.Id}"
                }).ToList();
            }
            else if (isApprover)
            {
                // Approbateurs : bons propres + pending à mon niveau, triés par date, top 5
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 20 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 20 });
                var pendingBEMTask = BonEntreeService.GetPendingApprovalsAsync();
                var pendingBSMTask = BonSortieService.GetPendingApprovalsAsync();
                await Task.WhenAll(myBEMTask, myBSMTask, pendingBEMTask, pendingBSMTask);

                var bemIds = new HashSet<int>();
                var allBEM = new List<BonEntreeEntity>();
                foreach (var b in myBEMTask.Result.Items) { if (bemIds.Add(b.Id)) allBEM.Add(b); }
                foreach (var b in pendingBEMTask.Result) { if (bemIds.Add(b.Id)) allBEM.Add(b); }

                entreesRecentes = allBEM
                    .OrderByDescending(b => b.DateCreation)
                    .Take(5)
                    .Select(b => new BonItem
                    {
                        Reference = b.NumeroReference,
                        NomEntreprise = b.NomCompagnie ?? "N/A",
                        StatutCode = MapStatutCode(b.StatutActuel),
                        StatutLibelle = GetStatutDisplay(b.StatutActuel),
                        Url = $"/bon-entree/{b.Id}"
                    }).ToList();

                var bsmIds = new HashSet<int>();
                var allBSM = new List<BonSortieEntity>();
                foreach (var b in myBSMTask.Result.Items) { if (bsmIds.Add(b.Id)) allBSM.Add(b); }
                foreach (var b in pendingBSMTask.Result) { if (bsmIds.Add(b.Id)) allBSM.Add(b); }

                sortiesRecentes = allBSM
                    .OrderByDescending(b => b.DateCreation)
                    .Take(5)
                    .Select(b => new BonItem
                    {
                        Reference = b.NumeroReference,
                        NomEntreprise = GetBSMType(b),
                        StatutCode = MapStatutCode(b.StatutActuel),
                        StatutLibelle = GetStatutDisplay(b.StatutActuel),
                        Url = $"/bon-sortie/{b.Id}"
                    }).ToList();
            }
            else
            {
                // Utilisateurs normaux : uniquement leurs propres bons
                // BEM: NomDemandeur stores display name → use currentName
                // BSM: filter checks both NomDemandeur and CreatedByLogin → use currentLogin
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 5 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 5 });
                await Task.WhenAll(myBEMTask, myBSMTask);

                entreesRecentes = myBEMTask.Result.Items
                    .Select(b => new BonItem
                    {
                        Reference = b.NumeroReference,
                        NomEntreprise = b.NomCompagnie ?? "N/A",
                        StatutCode = MapStatutCode(b.StatutActuel),
                        StatutLibelle = GetStatutDisplay(b.StatutActuel),
                        Url = $"/bon-entree/{b.Id}"
                    }).ToList();

                sortiesRecentes = myBSMTask.Result.Items
                    .Select(b => new BonItem
                    {
                        Reference = b.NumeroReference,
                        NomEntreprise = GetBSMType(b),
                        StatutCode = MapStatutCode(b.StatutActuel),
                        StatutLibelle = GetStatutDisplay(b.StatutActuel),
                        Url = $"/bon-sortie/{b.Id}"
                    }).ToList();
            }
        }
        catch { }
    }

    private static string GetBSMType(BonSortieEntity bon) => bon switch
    {
        PretEntity => "Prêt",
        BonSortieInterneEntity => "Interne",
        BonSortieExterneEntity => "Externe",
        _ => "N/A"
    };

    private static string MapStatutCode(string? statut) => statut?.ToUpperInvariant() switch
    {
        "DRAFT" => "brouillon",
        "APPROVED" => "approuve",
        "REJECTED" => "rejete",
        var s when s != null && s.StartsWith("PENDING") => "en_attente",
        _ => "brouillon"
    };

    private static string GetStatutDisplay(string? statut) => statut?.ToUpperInvariant() switch
    {
        "DRAFT" => "Brouillon",
        "APPROVED" => "Approuvé",
        "REJECTED" => "Rejeté",
        "COMPLETED" => "Complété",
        "CANCELLED" => "Annulé",
        var s when s != null && s.StartsWith("PENDING") => "En attente",
        _ => statut ?? "N/A"
    };
    
    // ============ HELPERS ============
    private BadgeStyle GetBadgeStyleFromCode(string statutCode)
    {
        return statutCode switch
        {
            "approuve" => BadgeStyle.Success,
            "en_attente" => BadgeStyle.Warning,
            "rejete" => BadgeStyle.Danger,
            "brouillon" => BadgeStyle.Light,
            _ => BadgeStyle.Light
        };
    }
    
    private void NavigateTo(string url)
    {
        Navigation.NavigateTo(url);
    }
}
