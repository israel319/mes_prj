@page "/"
@attribute [Authorize]
@implements IDisposable
@inject NavigationManager Navigation
@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject INotificationRejetService NotificationRejetService
@inject KCCMaterialFlow.Host.Services.UserRoleCacheService RoleCacheService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Dash_Title"] — KCC Material Flow</PageTitle>

@* ====== Design system : transposition fidèle du Lovable "simple-status-board" en couleurs KCC ====== *@
<style>
    /* ── Full-bleed : supprime le padding rz-body (1rem Radzen) et le max-width
       du wrapper kcc-content quand le dashboard est rendu. ──────────────────── */
    .rz-body:has(.kcc-dash) {
        padding: 0 !important;
    }
    .kcc-content:has(.kcc-dash) {
        max-width: none !important;
    }

    .kcc-dash {
        --kdash-bg: var(--kcc-bg, #f0f2f5);
        --kdash-card: var(--kcc-bg-card, #ffffff);
        --kdash-text: var(--kcc-text-title, #1a1a1a);
        --kdash-muted: var(--kcc-text-muted, #6b7280);
        --kdash-border: var(--kcc-border, rgba(0,0,0,0.08));
        --kdash-hero: var(--kcc-bg-elevated, #253C45);  /* identique au topbar → raccord sans couture */
        --kdash-primary: var(--kcc-primary, #00B193);
        --kdash-primary-dark: var(--kcc-primary-dark, #008F76);
        --kdash-blue: var(--kcc-blue-brand, #003468);
        --kdash-info: var(--kcc-info, #3B82F6);
        --kdash-warning: var(--kcc-warning, #F59E0B);
        --kdash-accent: var(--kcc-accent, #A61B0C);
        --kdash-copper: var(--kcc-copper, #BB8748);

        background: var(--kdash-bg);
        color: var(--kdash-text);
        min-height: 100%;
        font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    }

    /* ==== HERO DARK ==== */
    .kdash-hero {
        position: relative;
        overflow: hidden;
        background: var(--kdash-hero);
        color: #fff;
    }

    .kdash-hero-pattern {
        pointer-events: none;
        position: absolute;
        inset: 0 0 0 auto;
        width: 66%;
        opacity: 0.22;
        background-image: radial-gradient(rgba(0, 177, 147, 0.55) 1px, transparent 1px);
        background-size: 14px 14px;
        -webkit-mask-image: radial-gradient(ellipse at right, black 35%, transparent 75%);
                mask-image: radial-gradient(ellipse at right, black 35%, transparent 75%);
    }

    .kdash-hero-glow-1 {
        pointer-events: none;
        position: absolute;
        top: -10rem;
        left: -8rem;
        height: 24rem;
        width: 24rem;
        border-radius: 9999px;
        filter: blur(60px);
        background: rgba(0, 177, 147, 0.40);
    }

    .kdash-hero-glow-2 {
        pointer-events: none;
        position: absolute;
        top: 0;
        right: 33%;
        height: 18rem;
        width: 18rem;
        border-radius: 9999px;
        filter: blur(60px);
        background: rgba(0, 52, 104, 0.45);
    }

    .kdash-hero-inner {
        position: relative;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .kdash-welcome {
        padding-top: 2.25rem;
        padding-bottom: 6rem;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.5rem;
    }

    .kdash-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.10);
        padding: 0.25rem 0.65rem;
        border-radius: 9999px;
        font-size: 11px;
        color: rgba(255, 255, 255, 0.72);
        margin-bottom: 0.75rem;
    }

    .kdash-pill-dot {
        height: 6px;
        width: 6px;
        border-radius: 9999px;
        background: var(--kdash-primary);
        animation: kdash-pulse 1.8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @@keyframes kdash-pulse {
        0%, 100% { opacity: 1; }
        50%      { opacity: 0.45; }
    }

    .kdash-title {
        font-size: 1.75rem;
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.1;
        margin: 0;
    }

    @@media (min-width: 768px) {
        .kdash-title { font-size: 1.9rem; }
    }

    .kdash-subtitle {
        margin: 0.4rem 0 0 0;
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.62);
    }

    .kdash-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .kdash-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border-radius: 0.5rem;
        padding: 0.55rem 0.85rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: filter 0.18s, background 0.18s, transform 0.18s;
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: rgba(255, 255, 255, 0.07);
        color: rgba(255, 255, 255, 0.85);
        white-space: nowrap;
    }

    .kdash-btn:hover {
        background: rgba(255, 255, 255, 0.12);
        text-decoration: none;
        color: #fff;
    }

    .kdash-btn-primary {
        background: var(--kdash-primary);
        color: #fff;
        border-color: transparent;
        font-weight: 600;
    }

    .kdash-btn-primary:hover {
        background: var(--kdash-primary);
        filter: brightness(1.10);
        color: #fff;
    }

    /* ==== STATS PANEL FLOTTANT ==== */
    .kdash-main {
        position: relative;
        z-index: 10;
        max-width: 1400px;
        margin: -4rem auto 0;
        padding: 0 1.5rem 4rem;
    }

    .kdash-panel {
        background: var(--kdash-card);
        border: 1px solid var(--kdash-border);
        border-radius: 0;
        padding: 1.5rem;
        box-shadow: 0 20px 60px -20px rgba(30, 48, 56, 0.35);
    }

    @@media (min-width: 768px) {
        .kdash-panel { padding: 1.75rem; }
    }

    .kdash-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .kdash-panel-title {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        color: var(--kdash-text);
    }

    .kdash-panel-sub {
        font-size: 0.75rem;
        color: var(--kdash-muted);
        margin: 0.15rem 0 0 0;
    }

    .kdash-segmented {
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
        border: 1px solid var(--kdash-border);
        border-radius: 0.5rem;
        padding: 0.15rem;
        font-size: 0.75rem;
    }

    .kdash-seg {
        padding: 0.25rem 0.6rem;
        border-radius: 0.35rem;
        cursor: pointer;
        color: var(--kdash-muted);
        background: transparent;
        border: 0;
        font-weight: 500;
    }

    .kdash-seg.is-active {
        background: #f3f4f6;
        color: var(--kdash-text);
        font-weight: 600;
    }

    /* ==== KPI GRID : séparateurs 1px style tableau ==== */
    .kdash-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1px;
        background: var(--kdash-border);
    }

    @@media (max-width: 767px) {
        .kdash-grid { grid-template-columns: 1fr; }
    }
    @@media (min-width: 768px) and (max-width: 1023px) {
        .kdash-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    .kdash-kpi {
        background: var(--kdash-card);
        padding: 1.25rem 1.5rem;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        transition: background 0.15s;
    }

    .kdash-kpi:hover {
        background: #fafafa;
    }

    /* ligne 1 : valeur+label à gauche, icône à droite */
    .kdash-kpi-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .kdash-kpi-icon {
        flex-shrink: 0;
        height: 3.25rem;
        width: 3.25rem;
        border-radius: 0.75rem;
        display: grid;
        place-items: center;
        background: var(--kdash-tone-bg);
        color: var(--kdash-tone);
    }

    .kdash-kpi-icon .rzi { font-size: 1.6rem; }

    .kdash-kpi-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--kdash-muted);
        margin: 0.2rem 0 0 0;
    }

    /* ligne 2 : valeur */
    .kdash-kpi-value {
        font-size: 2rem;
        line-height: 1;
        font-weight: 800;
        color: var(--kdash-tone);
        font-variant-numeric: tabular-nums;
    }

    /* ligne 3 : sous-titre */
    .kdash-kpi-caption {
        font-size: 0.75rem;
        color: var(--kdash-muted);
        margin: 0;
    }

    /* ==== FOOTER PANEL ==== */
    .kdash-foot {
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--kdash-border);
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: center;
        justify-content: space-between;
    }

    .kdash-foot small {
        font-size: 0.75rem;
        color: var(--kdash-muted);
    }

    .kdash-foot strong {
        color: var(--kdash-text);
        font-weight: 600;
    }

    .kdash-foot-link {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--kdash-primary);
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .kdash-foot-link:hover {
        text-decoration: underline;
        color: var(--kdash-primary-dark);
    }

    /* ==== TONES (mapping KCC) ==== */
    .tone-primary { --kdash-tone: var(--kdash-primary); --kdash-tone-bg: color-mix(in oklab, var(--kdash-primary) 12%, white); --kdash-tone-soft: color-mix(in oklab, var(--kdash-primary) 30%, transparent); }
    .tone-info    { --kdash-tone: var(--kdash-info);    --kdash-tone-bg: color-mix(in oklab, var(--kdash-info) 12%, white);    --kdash-tone-soft: color-mix(in oklab, var(--kdash-info) 30%, transparent); }
    .tone-warning { --kdash-tone: var(--kdash-warning); --kdash-tone-bg: color-mix(in oklab, var(--kdash-warning) 14%, white); --kdash-tone-soft: color-mix(in oklab, var(--kdash-warning) 30%, transparent); }
    .tone-accent  { --kdash-tone: var(--kdash-accent);  --kdash-tone-bg: color-mix(in oklab, var(--kdash-accent) 10%, white);  --kdash-tone-soft: color-mix(in oklab, var(--kdash-accent) 28%, transparent); }
    .tone-blue    { --kdash-tone: var(--kdash-blue);    --kdash-tone-bg: color-mix(in oklab, var(--kdash-blue) 10%, white);    --kdash-tone-soft: color-mix(in oklab, var(--kdash-blue) 28%, transparent); }
    .tone-copper  { --kdash-tone: var(--kdash-copper);  --kdash-tone-bg: color-mix(in oklab, var(--kdash-copper) 14%, white);  --kdash-tone-soft: color-mix(in oklab, var(--kdash-copper) 28%, transparent); }
</style>

<div class="kcc-dash">
    @* === HERO DARK === *@
    <div class="kdash-hero">
        <div class="kdash-hero-pattern" aria-hidden="true"></div>
        <div class="kdash-hero-glow-1"  aria-hidden="true"></div>
        <div class="kdash-hero-glow-2"  aria-hidden="true"></div>

        <div class="kdash-hero-inner">
            <div class="kdash-welcome">
                <div>
                    <div class="kdash-pill">
                        <span class="kdash-pill-dot"></span>
                        @L["Dash_LivePortal"]
                    </div>
                    <h1 class="kdash-title">@GetGreeting() @CurrentUserService.GetUserFirstName()</h1>
                    <p class="kdash-subtitle">@L["Dash_Subtitle"]</p>
                </div>
                <div class="kdash-actions">
                    <a class="kdash-btn" href="/bon-sortie/nouveau">
                        @L["Dash_NewBSM"]
                        <RadzenIcon Icon="north_east" Style="font-size:1rem;" />
                    </a>
                    <a class="kdash-btn kdash-btn-primary" href="/bon-entree/nouveau">
                        @L["Dash_NewBEM"]
                        <RadzenIcon Icon="north_east" Style="font-size:1rem;" />
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* === STATS PANEL FLOTTANT === *@
    <main class="kdash-main">
        <div class="kdash-panel">
            <div class="kdash-panel-head">
                <div>
                    <h2 class="kdash-panel-title">@L["Dash_LiveIndicators"]</h2>
                    <p class="kdash-panel-sub">@L["Dash_VolumeTotal"] : @TotalVolume @L["Dash_Operations"]</p>
                </div>
            
            </div>

            @* === KPI GRID === *@
            <div class="kdash-grid">
                @{
                    var kpis = new[]
                    {
                        new KpiDef(L["Dash_EntryVouchers"], stats.TotalBEM,    L["Dash_TotalEntries"].Value,                                                                                "login",        "tone-info",    "/liste-bons/bem"),
                        new KpiDef(L["Dash_ExitVouchers"],  stats.TotalBSM,    L["Dash_TotalExits"].Value,                                                                                  "logout",       "tone-copper",  "/liste-bons/bsm"),
                        new KpiDef(L["Dash_Pending"],       stats.EnAttente,   isApprover ? L["Dash_ToProcess"].Value : L["Dash_MyRequests"].Value,                                         "assignment",   "tone-warning", isApprover ? "/mes-approbations" : "/suivi-bons",
                                   stats.EnAttente > 0 ? $"↗ +{stats.EnAttente}" : "↗ —"),
                        new KpiDef(L["Dash_Approved"],      stats.Approuves,   L["Dash_ThisMonth"].Value,                                                                                   "check_circle", "tone-primary", "/liste-bons?statut=approuve"),
                        new KpiDef(L["Dash_Rejections"],    stats.Rejetes,     stats.RejetsNonLus > 0 ? $"{stats.RejetsNonLus} {L["Dash_Unread"]}" : L["Dash_AllRead"].Value,              "cancel",       "tone-accent",  "/liste-rejets",
                                   stats.RejetsNonLus > 0 ? $"↘ {stats.RejetsNonLus}" : "↗ 0"),
                        new KpiDef(L["Dash_Loans"],         stats.PretsActifs, stats.PretsEnRetard > 0 ? $"{stats.PretsEnRetard} {L["Dash_Overdue"]}" : L["Dash_NoOverdue"].Value,         "swap_horiz",   "tone-blue",    "/liste-bons/prets",
                                   stats.PretsEnRetard > 0 ? $"↘ {stats.PretsEnRetard}" : "↗ —"),
                    };
                }
                @foreach (var k in kpis)
                {
                    <div class="kdash-kpi @k.Tone" @onclick="@(() => Navigation.NavigateTo(k.Url))">
                        <div class="kdash-kpi-head">
                            <div>
                                <span class="kdash-kpi-value">@k.Value</span>
                                <p class="kdash-kpi-label">@k.Label</p>
                            </div>
                            <div class="kdash-kpi-icon"><RadzenIcon Icon="@k.Icon" /></div>
                        </div>
                        <p class="kdash-kpi-caption">@k.Sublabel</p>
                    </div>
                }
            </div>

            <div class="kdash-foot">
                <small>@L["Dash_LiveIndicators"] · <strong>@now.ToString("HH:mm")</strong></small>
                
            </div>
        </div>
    </main>
</div>

@code {
    private string GetGreeting()
    {
        var h = DateTime.Now.Hour;
        if (h < 5)  return L["Dash_GoodEvening"];
        if (h < 12) return L["Dash_GoodMorning"];
        if (h < 18) return L["Dash_GoodAfternoon"];
        return L["Dash_GoodEvening"];
    }

    private record KpiDef(LocalizedString Label, int Value, string Sublabel, string Icon, string Tone, string Url, string Badge = "↗ —");

    private class DashboardStats
    {
        public int TotalBEM { get; set; }
        public int TotalBSM { get; set; }
        public int EnAttente { get; set; }
        public int Approuves { get; set; }
        public int Rejetes { get; set; }
        public int RejetsNonLus { get; set; }
        public int PretsActifs { get; set; }
        public int PretsEnRetard { get; set; }
    }

    private DashboardStats stats = new();
    private bool canSeeAll = false;
    private bool isApprover = false;
    private DateTime now = DateTime.Now;
    private System.Threading.Timer? clockTimer;

    // TotalBEM et TotalBSM représentent déjà tous les bons (approuvés, en attente, etc.)
    // EnAttente/Approuvés sont des sous-ensembles → ne pas les additionner pour éviter le double comptage
    private int TotalVolume => stats.TotalBEM + stats.TotalBSM;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // canSeeAll : Admin / SuperAdmin (vue globale).
            // isApprover : Admin/SuperAdmin OU manager (subordonnés) OU approbateur spécial.
            var niveau = CurrentUserService.NiveauAdmin;
            canSeeAll = niveau >= KCCMaterialFlow.Domain.Enums.NiveauAdmin.Admin;
            isApprover = canSeeAll || RoleCacheService.IsApprover(CurrentUserService.GetUserLogin());

            await LoadStatsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur dashboard: {ex.Message}");
        }

        clockTimer = new System.Threading.Timer(_ =>
        {
            now = DateTime.Now;
            InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    public void Dispose()
    {
        clockTimer?.Dispose();
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            var currentLogin = CurrentUserService.GetUserLogin();
            var currentName = CurrentUserService.GetUserDisplayName();

            if (canSeeAll)
            {
                var bemStatsTask = BonEntreeService.GetStatsAsync();
                var bsmStatsTask = BonSortieService.GetStatsAsync();
                var pendingBEMTask = BonEntreeService.GetPendingApprovalsAsync();
                var pendingBSMTask = BonSortieService.GetPendingApprovalsAsync();
                var allRejetsTask = NotificationRejetService.GetNotificationsAsync();
                var rejetsNonLusTask = NotificationRejetService.CompterNotificationsNonLuesAsync();
                var activeLoansTask = BonSortieService.GetActiveLoansAsync();
                var overdueLoansTask = BonSortieService.GetOverdueLoansAsync();

                await Task.WhenAll(bemStatsTask, bsmStatsTask, pendingBEMTask, pendingBSMTask, allRejetsTask, rejetsNonLusTask, activeLoansTask, overdueLoansTask);

                var bemStats = bemStatsTask.Result;
                var bsmStats = bsmStatsTask.Result;

                stats = new DashboardStats
                {
                    TotalBEM = bemStats.TotalBons,
                    TotalBSM = bsmStats.TotalBons,
                    EnAttente = pendingBEMTask.Result.Count + pendingBSMTask.Result.Count,
                    Approuves = bemStats.BonsApprouves + bsmStats.BonsApprouves,
                    Rejetes = allRejetsTask.Result.Count(),
                    RejetsNonLus = rejetsNonLusTask.Result,
                    PretsActifs = activeLoansTask.Result.Count,
                    PretsEnRetard = overdueLoansTask.Result.Count
                };
            }
            else if (isApprover)
            {
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 100 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 100 });
                var pendingBEMTask = BonEntreeService.GetPendingApprovalsAsync();
                var pendingBSMTask = BonSortieService.GetPendingApprovalsAsync();
                var allRejetsTask = NotificationRejetService.GetNotificationsAsync();
                var activeLoansTask = BonSortieService.GetActiveLoansAsync();
                var overdueLoansTask = BonSortieService.GetOverdueLoansAsync();

                await Task.WhenAll(myBEMTask, myBSMTask, pendingBEMTask, pendingBSMTask, allRejetsTask, activeLoansTask, overdueLoansTask);

                var userBEM = myBEMTask.Result.Items.ToList();
                var userBSM = myBSMTask.Result.Items.ToList();
                var pendingBEM = pendingBEMTask.Result;
                var pendingBSM = pendingBSMTask.Result;

                var allVisibleBEMIds = new HashSet<int>(userBEM.Select(b => b.Id));
                foreach (var bon in pendingBEM) allVisibleBEMIds.Add(bon.Id);

                var allVisibleBSMIds = new HashSet<int>(userBSM.Select(b => b.Id));
                foreach (var bon in pendingBSM) allVisibleBSMIds.Add(bon.Id);

                var allVisibleBEM = userBEM.Concat(pendingBEM.Where(b => !userBEM.Any(u => u.Id == b.Id))).ToList();
                var allVisibleBSM = userBSM.Concat(pendingBSM.Where(b => !userBSM.Any(u => u.Id == b.Id))).ToList();

                var allRejets = allRejetsTask.Result;
                var userRejets = allRejets.Where(r =>
                    (r.DemandeurNom?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.DemandeurNom?.Equals(currentName, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.ApprobateurLogin?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true)).ToList();

                var userActiveLoans = activeLoansTask.Result.Where(p => allVisibleBSMIds.Contains(p.Id)).ToList();
                var userOverdueLoans = overdueLoansTask.Result.Where(p => allVisibleBSMIds.Contains(p.Id)).ToList();

                stats = new DashboardStats
                {
                    TotalBEM = allVisibleBEMIds.Count,
                    TotalBSM = allVisibleBSMIds.Count,
                    EnAttente = pendingBEM.Count + pendingBSM.Count,
                    Approuves = allVisibleBEM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)) +
                                allVisibleBSM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)),
                    Rejetes = userRejets.Count,
                    RejetsNonLus = userRejets.Count(r => !r.EstLue),
                    PretsActifs = userActiveLoans.Count,
                    PretsEnRetard = userOverdueLoans.Count
                };
            }
            else
            {
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 100 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 100 });
                var allRejetsTask = NotificationRejetService.GetNotificationsAsync();
                var activeLoansTask = BonSortieService.GetActiveLoansAsync();
                var overdueLoansTask = BonSortieService.GetOverdueLoansAsync();

                await Task.WhenAll(myBEMTask, myBSMTask, allRejetsTask, activeLoansTask, overdueLoansTask);

                var userBEM = myBEMTask.Result.Items.ToList();
                var userBSM = myBSMTask.Result.Items.ToList();

                var allRejets = allRejetsTask.Result;
                var userRejets = allRejets.Where(r =>
                    (r.DemandeurNom?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true) ||
                    (r.DemandeurNom?.Equals(currentName, StringComparison.OrdinalIgnoreCase) == true)).ToList();

                var userBSMIds = new HashSet<int>(userBSM.Select(b => b.Id));
                var userActiveLoans = activeLoansTask.Result.Where(p => userBSMIds.Contains(p.Id)).ToList();
                var userOverdueLoans = overdueLoansTask.Result.Where(p => userBSMIds.Contains(p.Id)).ToList();

                stats = new DashboardStats
                {
                    TotalBEM = userBEM.Count,
                    TotalBSM = userBSM.Count,
                    EnAttente = userBEM.Count(b => b.StatutActuel.StartsWith("Pending", StringComparison.OrdinalIgnoreCase)) +
                                userBSM.Count(b => b.StatutActuel.StartsWith("Pending", StringComparison.OrdinalIgnoreCase)),
                    Approuves = userBEM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)) +
                                userBSM.Count(b => b.StatutActuel.Equals("Approved", StringComparison.OrdinalIgnoreCase)),
                    Rejetes = userRejets.Count,
                    RejetsNonLus = userRejets.Count(r => !r.EstLue),
                    PretsActifs = userActiveLoans.Count,
                    PretsEnRetard = userOverdueLoans.Count
                };
            }
        }
        catch { }
    }
}
