    private async Task ExportExcel()
    {
        try
        {
            using var workbook = new XLWorkbook();
            string fileName;

            if (selectedTabIndex == 0)
            {
                var data = filteredBEMSummary;
                var ws = workbook.Worksheets.Add("Bons Entrée");
                var headers = new[] { "Référence", "Compagnie", "Demandeur", "Statut", "Dernière action", "Par", "Date", "Nb Actions" };
                WriteHeaders(ws, headers, "#00B193");

                int row = 2;
                foreach (var bon in data)
                {
                    ws.Cell(row, 1).Value = bon.NumeroReference;
                    ws.Cell(row, 2).Value = bon.NomCompagnie;
                    ws.Cell(row, 3).Value = bon.NomDemandeur;
                    ws.Cell(row, 4).Value = GetStatutLabel(bon.StatutActuel);
                    ws.Cell(row, 5).Value = GetActionLabel(bon.DerniereAction);
                    ws.Cell(row, 6).Value = bon.DernierActionPar;
                    ws.Cell(row, 7).Value = bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm");
                    ws.Cell(row, 8).Value = bon.NbActions;
                    if (row % 2 == 0)
                        ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#F0FFF8");
                    row++;
                }
                ws.Columns().AdjustToContents();
                ws.RangeUsed()?.SetAutoFilter();
                fileName = $"BonsEntree_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            }
            else
            {
                var data = filteredBSMSummary;
                var ws = workbook.Worksheets.Add("Bons Sortie");
                var headers = new[] { "Référence", "Type", "Demandeur", "Statut", "Dernière action", "Par", "Date", "Nb Actions" };
                WriteHeaders(ws, headers, "#253C45");

                int row = 2;
                foreach (var bon in data)
                {
                    ws.Cell(row, 1).Value = bon.NumeroReference;
                    ws.Cell(row, 2).Value = bon.TypeBon;
                    ws.Cell(row, 3).Value = bon.NomDemandeur;
                    ws.Cell(row, 4).Value = GetStatutLabel(bon.StatutActuel);
                    ws.Cell(row, 5).Value = GetActionLabel(bon.DerniereAction);
                    ws.Cell(row, 6).Value = bon.DernierActionPar;
                    ws.Cell(row, 7).Value = bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm");
                    ws.Cell(row, 8).Value = bon.NbActions;
                    if (row % 2 == 0)
                        ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#F0F4FF");
                    row++;
                }
                ws.Columns().AdjustToContents();
                ws.RangeUsed()?.SetAutoFilter();
                fileName = $"BonsSortie_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            }

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            stream.Position = 0;

            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur export", ex.Message);
        }
    }

    private static void WriteHeaders(IXLWorksheet ws, string[] headers, string colorHex)
    {
        for (int i = 0; i < headers.Length; i++)
        {
            var cell = ws.Cell(1, i + 1);
            cell.Value = headers[i];
            cell.Style.Font.Bold = true;
            cell.Style.Fill.BackgroundColor = XLColor.FromHtml(colorHex);
            cell.Style.Font.FontColor = XLColor.White;
            cell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
        }
    }

    private static string GetCompagnieBSM(BonSortieEntity? bon) => bon switch
    {
        PretEntity pret => pret.NomDestinataire ?? "Prêt",
        BonSortieExterneEntity ext => ext.NomDestinataire ?? "N/A",
        BonSortieInterneEntity => "Interne",
        _ => "N/A"
    };

    private static string GetTypeBSM(BonSortieEntity? bon) => bon switch
    {
        PretEntity => "Prêt",
        BonSortieExterneEntity => "Externe",
        BonSortieInterneEntity => "Interne",
        _ => "Sortie"
    };

    private string GetStatutLabel(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "-";
        var upper = s.ToUpperInvariant();

        foreach (var dbStatut in allDbStatuts)
        {
            if (CodeStatutToActuelMap.TryGetValue(dbStatut.CodeStatut, out var prefixes))
            {
                if (prefixes.Any(p => upper.StartsWith(p.ToUpperInvariant())))
                {
                    if (isAdmin && upper.StartsWith("PENDING") && dbStatut.CodeStatut.Equals("EN_ATTENTE_APPROBATION", StringComparison.OrdinalIgnoreCase))
                    {
                        return upper switch
                        {
                            "PENDINGSUP" or "PENDINGSUPERVISEUR" => "Chez Superviseur",
                            "PENDINGGM" => "Chez GM",
                            "PENDINGOPJ" => "Chez OPJ",
                            "PENDINGIDENTIFICATION" => "Chez Identification",
                            "PENDINGIT" => "Chez IT",
                            "PENDINGENV" => "Chez Environnement",
                            _ => $"Chez {s.Replace("Pending", "")}"
                        };
                    }
                    return dbStatut.LibelleStatut;
                }
            }
        }
        return s;
    }

    private string GetStatutColor(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "#6c757d";
        var upper = s.ToUpperInvariant();

        foreach (var dbStatut in allDbStatuts)
        {
            if (CodeStatutToActuelMap.TryGetValue(dbStatut.CodeStatut, out var prefixes))
            {
                if (prefixes.Any(p => upper.StartsWith(p.ToUpperInvariant())))
                    return dbStatut.CouleurFond;
            }
        }
        return "#6c757d";
    }

    private static string GetActionLabel(string action)
    {
        var lower = action.ToLowerInvariant();
        if (lower.Contains("créat") || lower.Contains("creat") || lower == "nouveau") return "Nouveau";
        if (lower.Contains("soumis") || lower.Contains("submit") || lower.Contains("envoyé")) return "Envoyé";
        if (lower.Contains("appro") || lower.Contains("validé")) return "Validé";
        if (lower.Contains("rejet") || lower.Contains("reject") || lower.Contains("refus")) return "Refusé";
        if (lower.Contains("retour") || lower.Contains("renvoyé")) return "Renvoyé";
        if (lower.Contains("modif")) return "Modifié";
        if (lower.Contains("annul")) return "Annulé";
        if (lower.Contains("qr")) return "QR Code";
        if (lower.Contains("scan")) return "Scanné";
        return action;
    }

    private static string GetTimelineDotStyle(string action)
    {
        var label = GetActionLabel(action);
        return label switch
        {
            "Validé" => "background: #28a745;",
            "Refusé" => "background: #dc3545;",
            "Envoyé" => "background: #fd7e14;",
            "Nouveau" => "background: #6c757d;",
            "Renvoyé" => "background: #fd7e14;",
            "QR Code" or "Scanné" => "background: #28a745;",
            "Annulé" => "background: #dc3545;",
            "Modifié" => "background: #6c757d;",
            _ => "background: #adb5bd;"
        };
    }

    private static string GetActionResultText(string action)
    {
        var label = GetActionLabel(action);
        return label switch
        {
            "Validé" => "✓ Approuvé",
            "Refusé" => "✗ Rejeté",
            "Envoyé" => "→ Transmis",
            "Nouveau" => "● Créé",
            "Renvoyé" => "↩ Retourné",
            "Modifié" => "✎ Mis à jour",
            "Annulé" => "✗ Annulé",
            "QR Code" => "✓ QR Généré",
            "Scanné" => "✓ Scanné",
            _ => "● Traité"
        };
    }

    private static string GetActionResultColor(string action)
    {
        var label = GetActionLabel(action);
        return label switch
        {
            "Validé" => "#28a745",
            "Refusé" => "#dc3545",
            "Envoyé" => "#fd7e14",
            "Nouveau" => "#6c757d",
            "Renvoyé" => "#fd7e14",
            "Modifié" => "#6c757d",
            "Annulé" => "#dc3545",
            "QR Code" or "Scanné" => "#28a745",
            _ => "#6c757d"
