@page "/liste-bons"
@page "/liste-bons/{TabName?}"
@page "/mes-bons"
@attribute [Authorize]
@using ClosedXML.Excel
@using BonEntreeEntity = KCCMaterialFlow.Domain.Entities.BonEntree
@using BonSortieEntity = KCCMaterialFlow.Domain.Entities.BonSortie
@using BonSortieExterneEntity = KCCMaterialFlow.Domain.Entities.BonSortieExterne
@using BonSortieInterneEntity = KCCMaterialFlow.Domain.Entities.BonSortieInterne
@using PretEntity = KCCMaterialFlow.Domain.Entities.Pret

@using BonSortiePages = KCCMaterialFlow.Host.Components.Pages.BonSortie

@inject ICurrentUserService CurrentUserService
@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject IStatutService StatutService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime

<PageTitle>Gestion des Bons - KCC Material Flow</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    @* === PAGE HEADER === *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
                @(selectedTabIndex switch { 0 => "Bons d'entrée", 1 => "Bons de sortie", 2 => "Prêts", _ => "Bons" })
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-light); margin-top: 0.25rem;">
                Traçabilité complète des bons de matériel • @CurrentUserService.GetUserDisplayName()
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            @if (CanExport)
            {
                <RadzenButton Text="Exporter Excel" Icon="download"
                              ButtonStyle="ButtonStyle.Success" Variant="Variant.Outlined"
                              Click="@ExportExcel" />
            }
            <RadzenButton Icon="refresh" Text="Actualiser" Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Secondary" Click="@LoadDataAsync" />
            <RadzenButton Text="@(selectedTabIndex == 0 ? "Nouveau bon d'entrée" : "Nouveau bon de sortie")"
                          Icon="add_circle" ButtonStyle="ButtonStyle.Primary"
                          Click="@(() => NavigateTo(selectedTabIndex == 0 ? "/bon-entree/nouveau" : "/bon-sortie/nouveau"))" />
        </RadzenStack>
    </RadzenStack>

    @* === FILTRES === *@
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Style="padding: 0.5rem 0;">
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Rechercher</RadzenText>
                <RadzenTextBox @bind-Value="@searchTerm" Placeholder="Référence, compagnie, demandeur..."
                               Style="min-width: 250px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Statut</RadzenText>
                <RadzenDropDown @bind-Value="@selectedStatut" Data="@statutOptions"
                                TextProperty="Text" ValueProperty="Value"
                                Placeholder="Tous" AllowClear="true"
                                Style="min-width: 150px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Date début</RadzenText>
                <RadzenDatePicker @bind-Value="@dateDebut" DateFormat="dd/MM/yyyy" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Date fin</RadzenText>
                <RadzenDatePicker @bind-Value="@dateFin" DateFormat="dd/MM/yyyy" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenButton Icon="search" Text="Filtrer" Click="@ApplyFilter" ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton Icon="clear" Text="Effacer" Click="@ResetFilter"
                          ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" class="kcc-btn-clear" />
        </RadzenStack>
    </RadzenCard>

    @* === TABS BEM / BSM === *@
    <RadzenCard>
        <RadzenTabs @bind-SelectedIndex="@selectedTabIndex" Change="@OnTabChange">
            <Tabs>
                @* === TAB BEM === *@
                <RadzenTabsItem Text="@($"Entrées ({filteredBEMSummary.Count})")">
                    <RadzenDataGrid Data="@filteredBEMSummary" TItem="BonSummary"
                                    AllowPaging="true" PageSize="15" PagerHorizontalAlign="HorizontalAlign.Center"
                                    AllowSorting="true" AllowColumnResize="true"
                                    Style="margin-top: 0.5rem;"
                                    EmptyText="Aucun bon d'entrée trouvé"
                                    Density="Density.Compact">
                        <Template Context="bon">
                            <div style="padding: 0.5rem 1rem; background: var(--rz-base-100, #f8f9fa);">
                                <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                    <thead>
                                        <tr style="border-bottom: 1px solid #dee2e6; color: #6c757d; font-size: 0.78rem;">
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 130px;">Date</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 110px;">Action</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Par</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Commentaire</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 150px;">Résultat</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (bon.Details.Any())
                                        {
                                            @foreach (var detail in bon.Details)
                                            {
                                                <tr style="border-bottom: 1px solid #f0f0f0;">
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; white-space: nowrap;">@detail.DateAction.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(detail.Action)"></span>
                                                        <span style="font-weight: 500;">@GetActionLabel(detail.Action)</span>
                                                    </td>
                                                    <td style="padding: 0.3rem 0.5rem;">@detail.ActionPar</td>
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; font-style: italic;">@(string.IsNullOrEmpty(detail.Commentaire) ? "—" : detail.Commentaire)</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="font-size: 0.8rem; color: @GetActionResultColor(detail.Action); font-weight: 500;">@GetActionResultText(detail.Action)</span>
                                                        @if (!string.IsNullOrEmpty(detail.StatutApres))
                                                        {
                                                            <span style="font-size: 0.75rem; color: #6c757d; margin-left: 0.25rem;">→ @GetStatutLabel(detail.StatutApres)</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="5" style="padding: 0.5rem; color: #999; font-style: italic;">Aucun historique enregistré.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </Template>
                        <Columns>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NumeroReference" Title="Référence" Width="160px">
                                <Template Context="bon">
                                    <a href="@($"/bon-entree/{bon.BonId}")" style="font-weight: 600; text-decoration: none; color: var(--kcc-primary);">
                                        @bon.NumeroReference
                                    </a>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NomCompagnie" Title="Compagnie" />
                            <RadzenDataGridColumn TItem="BonSummary" Property="NomDemandeur" Title="Demandeur" Width="160px" />
                            <RadzenDataGridColumn TItem="BonSummary" Property="StatutActuel" Title="Statut" Width="160px">
                                <Template Context="bon">
                                    <span style="font-weight: 500; color: @GetStatutColor(bon.StatutActuel);">@GetStatutLabel(bon.StatutActuel)</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DerniereAction" Title="Dernière action" Width="200px">
                                <Template Context="bon">
                                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(bon.DerniereAction)"></span>
                                    <span style="font-weight: 500;">@GetActionLabel(bon.DerniereAction)</span>
                                    <span style="margin-left: 0.25rem; font-size: 0.83rem; color: #6c757d;">par @bon.DernierActionPar</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DateDerniereAction" Title="Date" Width="145px"
                                                  SortOrder="SortOrder.Descending">
                                <Template Context="bon">
                                    @bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm")
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NbActions" Title="Actions" Width="80px" TextAlign="TextAlign.Center">
                                <Template Context="bon">
                                    <RadzenBadge Text="@bon.NbActions.ToString()" BadgeStyle="BadgeStyle.Light" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* === TAB BSM === *@
                <RadzenTabsItem Text="@($"Sorties ({filteredBSMSummary.Count})")">
                    <RadzenDataGrid Data="@filteredBSMSummary" TItem="BonSummary"
                                    AllowPaging="true" PageSize="15" PagerHorizontalAlign="HorizontalAlign.Center"
                                    AllowSorting="true" AllowColumnResize="true"
                                    Style="margin-top: 0.5rem;"
                                    EmptyText="Aucun bon de sortie trouvé"
                                    Density="Density.Compact">
                        <Template Context="bon">
                            <div style="padding: 0.5rem 1rem; background: var(--rz-base-100, #f8f9fa);">
                                <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                    <thead>
                                        <tr style="border-bottom: 1px solid #dee2e6; color: #6c757d; font-size: 0.78rem;">
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 130px;">Date</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 110px;">Action</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Par</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Commentaire</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 150px;">Résultat</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (bon.Details.Any())
                                        {
                                            @foreach (var detail in bon.Details)
                                            {
                                                <tr style="border-bottom: 1px solid #f0f0f0;">
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; white-space: nowrap;">@detail.DateAction.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(detail.Action)"></span>
                                                        <span style="font-weight: 500;">@GetActionLabel(detail.Action)</span>
                                                    </td>
                                                    <td style="padding: 0.3rem 0.5rem;">@detail.ActionPar</td>
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; font-style: italic;">@(string.IsNullOrEmpty(detail.Commentaire) ? "—" : detail.Commentaire)</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="font-size: 0.8rem; color: @GetActionResultColor(detail.Action); font-weight: 500;">@GetActionResultText(detail.Action)</span>
                                                        @if (!string.IsNullOrEmpty(detail.StatutApres))
                                                        {
                                                            <span style="font-size: 0.75rem; color: #6c757d; margin-left: 0.25rem;">→ @GetStatutLabel(detail.StatutApres)</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="5" style="padding: 0.5rem; color: #999; font-style: italic;">Aucun historique enregistré.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </Template>
                        <Columns>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NumeroReference" Title="Référence" Width="160px">
                                <Template Context="bon">
                                    <a href="@($"/bon-sortie/{bon.BonId}")" style="font-weight: 600; text-decoration: none; color: var(--kcc-primary);">
                                        @bon.NumeroReference
                                    </a>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="TypeBon" Title="Type" Width="100px">
                                <Template Context="bon">
                                    <RadzenBadge Text="@bon.TypeBon" BadgeStyle="BadgeStyle.Secondary" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NomDemandeur" Title="Demandeur" Width="150px" />
                            <RadzenDataGridColumn TItem="BonSummary" Property="StatutActuel" Title="Statut" Width="160px">
                                <Template Context="bon">
                                    <span style="font-weight: 500; color: @GetStatutColor(bon.StatutActuel);">@GetStatutLabel(bon.StatutActuel)</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DerniereAction" Title="Dernière action" Width="200px">
                                <Template Context="bon">
                                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(bon.DerniereAction)"></span>
                                    <span style="font-weight: 500;">@GetActionLabel(bon.DerniereAction)</span>
                                    <span style="margin-left: 0.25rem; font-size: 0.83rem; color: #6c757d;">par @bon.DernierActionPar</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DateDerniereAction" Title="Date" Width="145px"
                                                  SortOrder="SortOrder.Descending">
                                <Template Context="bon">
                                    @bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm")
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NbActions" Title="Actions" Width="80px" TextAlign="TextAlign.Center">
                                <Template Context="bon">
                                    <RadzenBadge Text="@bon.NbActions.ToString()" BadgeStyle="BadgeStyle.Light" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* === TAB PRÊTS === *@
                <RadzenTabsItem Text="@($"Prêts ({filteredPretsSummary.Count})")">
                    <RadzenDataGrid Data="@filteredPretsSummary" TItem="PretSummary"
                                    AllowPaging="true" PageSize="15" PagerHorizontalAlign="HorizontalAlign.Center"
                                    AllowSorting="true" AllowColumnResize="true"
                                    Style="margin-top: 0.5rem;"
                                    EmptyText="Aucun prêt trouvé"
                                    Density="Density.Compact">
                        <Columns>
                            @* Indicateur échéance *@
                            <RadzenDataGridColumn TItem="PretSummary" Width="50px" Sortable="false" Filterable="false">
                                <Template Context="pret">
                                    @{
                                        var (couleur, icon, tooltip) = GetIndicateurEcheance(pret);
                                    }
                                    <div title="@tooltip" style="text-align: center;">
                                        <RadzenIcon Icon="@icon" Style="@($"color: {couleur}; font-size: 1.4rem;")" />
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="PretSummary" Property="NumeroReference" Title="Référence" Width="160px">
                                <Template Context="pret">
                                    <a href="@($"/bon-sortie/{pret.BonId}")" style="font-weight: 600; text-decoration: none; color: var(--kcc-primary);">
                                        @pret.NumeroReference
                                    </a>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="PretSummary" Property="NomDemandeur" Title="Demandeur" Width="160px" />
                            <RadzenDataGridColumn TItem="PretSummary" Property="NomDestinataire" Title="Destinataire" Width="140px" />

                            <RadzenDataGridColumn TItem="PretSummary" Property="DateCreation" Title="Date sortie" Width="110px">
                                <Template Context="pret">@pret.DateCreation.ToString("dd/MM/yyyy")</Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="PretSummary" Property="DateRetourPrevue" Title="Retour prévu" Width="120px" SortOrder="SortOrder.Ascending">
                                <Template Context="pret">
                                    <span style="@GetDateRetourStyle(pret)">@pret.DateRetourPrevue.ToString("dd/MM/yyyy")</span>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="PretSummary" Title="Échéance" Width="120px" Sortable="false">
                                <Template Context="pret">
                                    @{
                                        var (badgeStyle, text) = GetEcheanceBadge(pret);
                                    }
                                    <RadzenBadge BadgeStyle="@badgeStyle" Text="@text" />
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="PretSummary" Property="NbMateriels" Title="Mat." Width="60px" TextAlign="TextAlign.Center" />

                            <RadzenDataGridColumn TItem="PretSummary" Property="StatutActuel" Title="Statut" Width="120px">
                                <Template Context="pret">
                                    <span style="font-weight: 500; color: @GetStatutColor(pret.StatutActuel);">@GetStatutLabel(pret.StatutActuel)</span>
                                </Template>
                            </RadzenDataGridColumn>

                            <RadzenDataGridColumn TItem="PretSummary" Title="" Width="140px" TextAlign="TextAlign.Center" Sortable="false">
                                <Template Context="pret">
                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                                        <RadzenButton Icon="visibility" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info"
                                            Click="@(() => NavigateTo($"/bon-sortie/{pret.BonId}"))" title="Voir" />
                                        @if (!pret.EstRetourne && pret.StatutActuel == "Approved")
                                        {
                                            <RadzenButton Icon="assignment_return" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success"
                                                Click="@(() => EnregistrerRetourPret(pret))" title="Retour" />
                                            <RadzenButton Icon="event" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Warning"
                                                Click="@(() => DemanderExtensionPret(pret))" title="Extension" />
                                        }
                                    </RadzenStack>
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </RadzenCard>
</RadzenStack>

@code {
    [Parameter] public string? TabName { get; set; }
    [SupplyParameterFromQuery(Name = "search")] public string? SearchQuery { get; set; }
    [SupplyParameterFromQuery(Name = "statut")] public string? StatutQuery { get; set; }
    [SupplyParameterFromQuery(Name = "filter")] public string? FilterQuery { get; set; }

    private int selectedTabIndex = 0;
    #pragma warning disable CS0414
    private bool isLoading = true;
    #pragma warning restore CS0414
    private string searchTerm = "";
    private string selectedStatut = "";
    private DateTime? dateDebut;
    private DateTime? dateFin;
    private bool isAdmin;
    private List<string> userRoles = new();

    private bool CanExport => userRoles.Any(r => r.Equals("Identification", StringComparison.OrdinalIgnoreCase));

    private List<BonSummary> bemSummaryItems = new();
    private List<BonSummary> bsmSummaryItems = new();
    private List<PretSummary> pretsSummaryItems = new();

    private List<BonSummary> filteredBEMSummary => ApplyFilters(bemSummaryItems);
    private List<BonSummary> filteredBSMSummary => ApplyFilters(bsmSummaryItems);
    private List<PretSummary> filteredPretsSummary => ApplyPretFilters(pretsSummaryItems);

    private List<StatutOption> statutOptions = new();
    private List<Statut> allDbStatuts = new();

    private static readonly Dictionary<string, string[]> CodeStatutToActuelMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["BROUILLON"] = new[] { "Draft" },
        ["EN_ATTENTE_APPROBATION"] = new[] { "Pending" },
        ["APPROUVE"] = new[] { "Approved" },
        ["REJETE"] = new[] { "Rejected" },
        ["EN_COURS"] = new[] { "InTransit" },
        ["TERMINE"] = new[] { "Completed" },
        ["EXPIRE"] = new[] { "Expired" },
        ["ANNULE"] = new[] { "Cancelled" },
        ["RETOURNE"] = new[] { "Returned" },
        ["ARCHIVE"] = new[] { "Archived" },
        ["INVESTIGATION"] = new[] { "Investigation" }
    };

    protected override async Task OnInitializedAsync()
    {
        selectedTabIndex = TabName?.ToLowerInvariant() switch { "bsm" => 1, "prets" => 2, _ => 0 };

        if (!string.IsNullOrWhiteSpace(SearchQuery))
            searchTerm = SearchQuery;

        if (!string.IsNullOrWhiteSpace(StatutQuery))
        {
            selectedStatut = StatutQuery.ToLowerInvariant() switch
            {
                "approuve" or "approved" => "APPROUVE",
                "rejete" or "rejected" => "REJETE",
                "brouillon" or "draft" => "BROUILLON",
                "pending" or "en-attente" => "EN_ATTENTE_APPROBATION",
                _ => selectedStatut
            };
        }

        userRoles = CurrentUserService.GetUserRoles().ToList();
        isAdmin = userRoles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));

        allDbStatuts = (await StatutService.GetAllAsync()).ToList();
        statutOptions = allDbStatuts
            .Select(s => new StatutOption { Text = s.LibelleStatut, Value = s.CodeStatut })
            .ToList();

        await LoadDataAsync();
    }

    private void OnTabChange(int index)
    {
        selectedTabIndex = index;
        var tab = index switch { 1 => "bsm", 2 => "prets", _ => "bem" };
        NavigationManager.NavigateTo($"/liste-bons/{tab}", replace: true);
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            var currentLogin = CurrentUserService.GetUserLogin();
            var currentName = CurrentUserService.GetUserDisplayName();

            var approverRoles = new[] { "Superviseur", "GM", "OPJ", "IT", "Environnement", "Identification", "Investigation", "Barriere" };
            var canSeeAll = isAdmin;
            var isApprover = userRoles.Any(r => approverRoles.Contains(r, StringComparer.OrdinalIgnoreCase));
            var isIdentification = userRoles.Any(r => r.Equals("Identification", StringComparison.OrdinalIgnoreCase));

            IEnumerable<BonEntreeEntity> visibleBEM;
            IEnumerable<BonSortieEntity> visibleBSM;

            if (canSeeAll)
            {
                // Admin : tout voir
                var bemResultTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Take = 5000 });
                var bsmResultTask = BonSortieService.GetListAsync(new BonSortieFilter { Take = 5000 });
                await Task.WhenAll(bemResultTask, bsmResultTask);

                visibleBEM = bemResultTask.Result.Items;
                visibleBSM = bsmResultTask.Result.Items;
            }
            else if (isApprover || isIdentification)
            {
                // Approbateurs : bons créés par moi + bons en attente à mon niveau d'approbation
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 5000 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 5000 });
                var pendingBEMTask = BonEntreeService.GetPendingApprovalsAsync();
                var pendingBSMTask = BonSortieService.GetPendingApprovalsAsync();
                await Task.WhenAll(myBEMTask, myBSMTask, pendingBEMTask, pendingBSMTask);

                // BEM : mes bons + pending à mon niveau (dédupliqué)
                var myBEMIds = new HashSet<int>();
                var myBEM = myBEMTask.Result.Items.ToList();
                foreach (var b in myBEM) myBEMIds.Add(b.Id);
                foreach (var bon in pendingBEMTask.Result)
                {
                    if (myBEMIds.Add(bon.Id))
                        myBEM.Add(bon);
                }
                visibleBEM = myBEM;

                // BSM : mes bons + pending à mon niveau (dédupliqué)
                var myBSMIds = new HashSet<int>();
                var myBSM = myBSMTask.Result.Items.ToList();
                foreach (var b in myBSM) myBSMIds.Add(b.Id);
                foreach (var bon in pendingBSMTask.Result)
                {
                    if (myBSMIds.Add(bon.Id))
                        myBSM.Add(bon);
                }
                visibleBSM = myBSM;
            }
            else
            {
                // Demandeur simple : uniquement ses propres bons (server-side)
                var myBEMTask = BonEntreeService.GetListAsync(new BonEntreeFilter { Demandeur = currentName, Take = 5000 });
                var myBSMTask = BonSortieService.GetListAsync(new BonSortieFilter { Demandeur = currentLogin, Take = 5000 });
                await Task.WhenAll(myBEMTask, myBSMTask);

                visibleBEM = myBEMTask.Result.Items;
                visibleBSM = myBSMTask.Result.Items;
            }

            bemSummaryItems = visibleBEM.Select(bon =>
            {
                var details = bon.Historiques
                    .OrderByDescending(h => h.ActionDate)
                    .Select(h => new HistoriqueDetail
                    {
                        Action = h.ActionDescription,
                        ActionPar = h.ActionByNom ?? h.ActionBy,
                        DateAction = h.ActionDate,
                        Commentaire = h.Comment ?? "",
                        StatutAvant = h.StatutAvant,
                        StatutApres = h.StatutApres
                    })
                    .ToList();

                if (!details.Any())
                {
                    details.Add(new HistoriqueDetail
                    {
                        Action = "Nouveau",
                        ActionPar = bon.NomDemandeur,
                        DateAction = bon.DateCreation,
                        Commentaire = $"Bon d'entrée {bon.NumeroReference}",
                        StatutApres = bon.StatutActuel
                    });
                }

                var derniere = details.First();
                return new BonSummary
                {
                    BonId = bon.Id,
                    NumeroReference = bon.NumeroReference,
                    TypeBon = "BEM",
                    NomCompagnie = bon.NomCompagnie,
                    NomDemandeur = bon.NomDemandeur,
                    StatutActuel = bon.StatutActuel,
                    DerniereAction = derniere.Action,
                    DernierActionPar = derniere.ActionPar,
                    DateDerniereAction = derniere.DateAction,
                    NbActions = details.Count,
                    Details = details
                };
            })
            .OrderByDescending(x => x.DateDerniereAction)
            .ToList();

            bsmSummaryItems = visibleBSM.Select(bon =>
            {
                var details = bon.Historiques
                    .OrderByDescending(h => h.ActionDate)
                    .Select(h => new HistoriqueDetail
                    {
                        Action = h.ActionDescription,
                        ActionPar = h.ActionByNom ?? h.ActionBy,
                        DateAction = h.ActionDate,
                        Commentaire = h.Comment ?? "",
                        StatutAvant = h.StatutAvant,
                        StatutApres = h.StatutApres
                    })
                    .ToList();

                if (!details.Any())
                {
                    details.Add(new HistoriqueDetail
                    {
                        Action = "Nouveau",
                        ActionPar = bon.NomDemandeur,
                        DateAction = bon.DateCreation,
                        Commentaire = $"Bon de sortie {bon.NumeroReference}",
                        StatutApres = bon.StatutActuel
                    });
                }

                var derniere = details.First();
                return new BonSummary
                {
                    BonId = bon.Id,
                    NumeroReference = bon.NumeroReference,
                    TypeBon = GetTypeBSM(bon),
                    NomCompagnie = GetCompagnieBSM(bon),
                    NomDemandeur = bon.NomDemandeur,
                    StatutActuel = bon.StatutActuel,
                    DerniereAction = derniere.Action,
                    DernierActionPar = derniere.ActionPar,
                    DateDerniereAction = derniere.DateAction,
                    NbActions = details.Count,
                    Details = details
                };
            })
            .OrderByDescending(x => x.DateDerniereAction)
            .ToList();

            // === PRÊTS ===
            try
            {
                var activeLoans = await BonSortieService.GetActiveLoansAsync();
                var allPrets = activeLoans.ToList();
                // Include returned loans from visible BSM
                var returnedPrets = visibleBSM.OfType<PretEntity>().Where(p => p.EstRetourne);
                var pretIds = new HashSet<int>(allPrets.Select(p => p.Id));
                foreach (var rp in returnedPrets)
                {
                    if (pretIds.Add(rp.Id)) allPrets.Add(rp);
                }

                pretsSummaryItems = allPrets.Select(p => new PretSummary
                {
                    BonId = p.Id,
                    NumeroReference = p.NumeroReference,
                    NomDemandeur = p.NomDemandeur,
                    NomDestinataire = p.NomDestinataire ?? "",
                    DateCreation = p.DateCreation,
                    DateRetourPrevue = p.DateRetourPrevue,
                    DateRetourEffective = p.DateRetourEffective,
                    EstRetourne = p.EstRetourne,
                    NbMateriels = p.Materiels.Count,
                    StatutActuel = p.StatutActuel,
                    JoursRetard = p.JoursRetard
                })
                .OrderBy(p => p.EstRetourne)
                .ThenBy(p => p.DateRetourPrevue)
                .ToList();
            }
            catch { pretsSummaryItems = new(); }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<BonSummary> ApplyFilters(List<BonSummary> items)
    {
        var result = items.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var search = searchTerm.ToLowerInvariant();
            result = result.Where(i =>
                i.NumeroReference.ToLowerInvariant().Contains(search) ||
                i.NomDemandeur.ToLowerInvariant().Contains(search) ||
                i.NomCompagnie.ToLowerInvariant().Contains(search) ||
                i.DernierActionPar.ToLowerInvariant().Contains(search));
        }

        if (!string.IsNullOrWhiteSpace(selectedStatut))
        {
            if (CodeStatutToActuelMap.TryGetValue(selectedStatut, out var prefixes))
            {
                result = result.Where(i => i.StatutActuel != null &&
                    prefixes.Any(p => i.StatutActuel.StartsWith(p, StringComparison.OrdinalIgnoreCase)));
            }
            else
            {
                result = result.Where(i => i.StatutActuel != null &&
                    i.StatutActuel.Equals(selectedStatut, StringComparison.OrdinalIgnoreCase));
            }
        }

        if (dateDebut.HasValue)
            result = result.Where(i => i.DateDerniereAction >= dateDebut.Value.Date);

        if (dateFin.HasValue)
            result = result.Where(i => i.DateDerniereAction <= dateFin.Value.Date.AddDays(1));

        return result.OrderByDescending(i => i.DateDerniereAction).ToList();
    }

