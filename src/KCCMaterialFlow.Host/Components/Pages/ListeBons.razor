    private string GetStatutLabel(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "-";
        var upper = s.ToUpperInvariant();

        // Tout statut "Pending*" → libellé localisé
        if (upper.StartsWith("PENDING")) return L["Status_Pending"].Value;

        // Mapper le code statut interne vers une clé de ressource localisée
        return upper switch
        {
            "DRAFT"         => L["Status_Draft"].Value,
            "APPROVED"      => L["Status_Approved"].Value,
            "REJECTED"      => L["Status_Rejected"].Value,
            "INTRANSIT"     => L["Status_InProgress"].Value,
            "COMPLETED"     => L["Status_Completed"].Value,
            "CANCELLED"     => L["Status_Cancelled"].Value,
            "RETURNED"      => L["Status_Returned"].Value,
            _               => s
        };
    }

    private string GetStatutLabelByCode(string? code, string fallback)
    {
        if (string.IsNullOrEmpty(code)) return fallback;
        return code.ToUpperInvariant() switch
        {
            "BROUILLON"              => L["Status_Draft"].Value,
            "EN_ATTENTE_APPROBATION" => L["Status_Pending"].Value,
            "APPROUVE"               => L["Status_Approved"].Value,
            "REJETE"                 => L["Status_Rejected"].Value,
            "EN_COURS"               => L["Status_InProgress"].Value,
            "TERMINE"                => L["Status_Completed"].Value,
            "ANNULE"                 => L["Status_Cancelled"].Value,
            "RETOURNE"               => L["Status_Returned"].Value,
            _                        => fallback
        };
    }

    private static BadgeStyle GetStatutBadgeStyle(string? s)
    {
        if (string.IsNullOrEmpty(s)) return BadgeStyle.Light;
        var upper = s.ToUpperInvariant();
        if (upper.StartsWith("PENDING")) return BadgeStyle.Warning;
        return upper switch
        {
            "DRAFT" => BadgeStyle.Light,
            "APPROVED" => BadgeStyle.Success,
            "REJECTED" => BadgeStyle.Danger,
            "INTRANSIT" => BadgeStyle.Info,
            "COMPLETED" => BadgeStyle.Success,
            "EXPIRED" => BadgeStyle.Danger,
            "CANCELLED" => BadgeStyle.Secondary,
            "RETURNED" => BadgeStyle.Info,
            "ARCHIVED" => BadgeStyle.Secondary,
            "INVESTIGATION" => BadgeStyle.Warning,
            _ => BadgeStyle.Light
        };
    }

    private string GetStatutColor(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "#6c757d";
        var upper = s.ToUpperInvariant();

        foreach (var dbStatut in allDbStatuts)
        {
            if (CodeStatutToActuelMap.TryGetValue(dbStatut.CodeStatut, out var prefixes))
            {
                if (prefixes.Any(p => upper.StartsWith(p.ToUpperInvariant())))
                    return dbStatut.CouleurFond;
            }
        }
        return "#6c757d";
    }

    // Retourne une clé stable (EN) indépendante de la langue de la DB
    private static string GetActionKey(string action)
    {
        var lower = action.ToLowerInvariant();
        if (lower.Contains("créat") || lower.Contains("creat") || lower == "nouveau") return "Created";
        if (lower.Contains("soumis") || lower.Contains("submit") || lower.Contains("envoyé")) return "Submitted";
        if (lower.Contains("appro") || lower.Contains("validé")) return "Approved";
        if (lower.Contains("rejet") || lower.Contains("reject") || lower.Contains("refus")) return "Rejected";
        if (lower.Contains("retour") || lower.Contains("renvoyé")) return "Returned";
        if (lower.Contains("modif")) return "Modified";
        if (lower.Contains("annul")) return "Cancelled";
        if (lower.Contains("qr")) return "QRCode";
        if (lower.Contains("scan")) return "Scanned";
        return action;
    }

    private string GetActionLabel(string action)
    {
        return GetActionKey(action) switch
        {
            "Created"   => L["Action_Created"].Value,
            "Submitted" => L["Action_Submitted"].Value,
            "Approved"  => L["Action_Approved"].Value,
            "Rejected"  => L["Action_Rejected"].Value,
            "Returned"  => L["Action_Returned"].Value,
            "Modified"  => L["Action_Modified"].Value,
            "Cancelled" => L["Action_Cancelled"].Value,
            "QRCode"    => L["Action_QRCode"].Value,
            "Scanned"   => L["Action_Scanned"].Value,
            var other   => other
        };
    }

