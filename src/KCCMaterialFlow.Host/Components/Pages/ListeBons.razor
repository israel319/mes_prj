        public string NumeroReference { get; set; } = "";
        public string NomDemandeur { get; set; } = "";
        public string NomDestinataire { get; set; } = "";
        public DateTime DateCreation { get; set; }
        public DateTime DateRetourPrevue { get; set; }
        public DateTime? DateRetourEffective { get; set; }
        public bool EstRetourne { get; set; }
        public int NbMateriels { get; set; }
        public string StatutActuel { get; set; } = "";
        public int JoursRetard { get; set; }
    }

    private List<PretSummary> ApplyPretFilters(List<PretSummary> items)
    {
        var result = items.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var search = searchTerm.ToLowerInvariant();
            result = result.Where(p =>
                p.NumeroReference.ToLowerInvariant().Contains(search) ||
                p.NomDemandeur.ToLowerInvariant().Contains(search) ||
                p.NomDestinataire.ToLowerInvariant().Contains(search));
        }

        if (!string.IsNullOrWhiteSpace(selectedStatut))
        {
            if (CodeStatutToActuelMap.TryGetValue(selectedStatut, out var prefixes))
                result = result.Where(p => prefixes.Any(pfx => p.StatutActuel.StartsWith(pfx, StringComparison.OrdinalIgnoreCase)));
        }

        if (dateDebut.HasValue)
            result = result.Where(p => p.DateCreation >= dateDebut.Value.Date);
        if (dateFin.HasValue)
            result = result.Where(p => p.DateCreation <= dateFin.Value.Date.AddDays(1));

        return result.OrderBy(p => p.EstRetourne).ThenBy(p => p.DateRetourPrevue).ToList();
    }

    private static int GetJoursRestants(PretSummary pret) => (pret.DateRetourPrevue.Date - DateTime.Today).Days;

    private static (string Couleur, string Icon, string Tooltip) GetIndicateurEcheance(PretSummary pret)
    {
        if (pret.EstRetourne)
            return ("#059669", "check_circle", "Retourné");

        var jours = GetJoursRestants(pret);
        if (jours <= -7) return ("#721c24", "error", $"Retard critique: {-jours} jours");
        if (jours < 0) return ("#A61B0C", "warning", $"En retard de {-jours} jour(s)");
        if (jours == 0) return ("#F59E0B", "today", "Retour aujourd'hui");
        if (jours <= 3) return ("#F59E0B", "schedule", $"Expire dans {jours} jour(s)");
        if (jours <= 7) return ("#3B82F6", "event", $"Expire dans {jours} jours");
        return ("#6c757d", "event_available", $"Expire dans {jours} jours");
    }

    private static (BadgeStyle Style, string Text) GetEcheanceBadge(PretSummary pret)
    {
        if (pret.EstRetourne) return (BadgeStyle.Success, "Retourné");
        var jours = GetJoursRestants(pret);
        if (jours < 0) return (BadgeStyle.Danger, $"Retard {-jours}j");
        if (jours == 0) return (BadgeStyle.Warning, "Aujourd'hui");
        if (jours == 1) return (BadgeStyle.Warning, "Demain");
        if (jours <= 7) return (BadgeStyle.Info, $"{jours} jours");
        return (BadgeStyle.Light, $"{jours} jours");
    }

    private static string GetDateRetourStyle(PretSummary pret)
    {
        if (pret.EstRetourne) return "";
        var jours = GetJoursRestants(pret);
        if (jours < 0) return "color: var(--kcc-accent); font-weight: bold;";
        if (jours <= 3) return "color: var(--kcc-warning); font-weight: bold;";
        return "";
    }

    private async Task EnregistrerRetourPret(PretSummary pret)
    {
        var result = await DialogService.OpenAsync<BonSortiePages.ReturnLoanDialog>("Enregistrer le Retour",
            options: new DialogOptions { Width = "400px" });

        if (result is BonSortiePages.ReturnLoanDialog.ReturnData returnData)
        {
            try
            {
                var request = new ReturnLoanRequest
                {
                    IdBon = pret.BonId,
                    EtatRetour = returnData.EtatRetour,
                    Commentaire = returnData.Commentaire
                };

                var response = await BonSortieService.ReturnLoanAsync(request);
                if (response.Success)
                {
                    NotificationService.Notify(NotificationSeverity.Success, "Succès", "Retour enregistré");
                    await LoadDataAsync();
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Erreur", response.Message ?? "Erreur");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }

    private async Task DemanderExtensionPret(PretSummary pret)
    {
        var result = await DialogService.OpenAsync<BonSortiePages.PretExtension>("Demander une Extension",
            new Dictionary<string, object> { { "PretId", pret.BonId }, { "CurrentDate", pret.DateRetourPrevue } },
            new DialogOptions { Width = "450px" });

        if (result == true)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Extension enregistrée");
            await LoadDataAsync();
        }
    }
