@page "/securite/admin/agents"
@attribute [Authorize(Roles = "Admin,Security")]
@inject IBarriereService BarriereService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Affectation Agents aux Barrières - Admin - KCC Material Flow</PageTitle>

<div style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">

    @* === EN-TÊTE === *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="1rem" class="rz-mb-6">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-grey); margin: 0;">
                <RadzenIcon Icon="badge" Style="vertical-align: middle; margin-right: 0.5rem; color: #805ad5;" />
                Affectation des Agents aux Barrières
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500); margin: 0;">
                Gestion des plannings et affectations des agents de sécurité
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="@L["Sec_BtnNewAssign"].Value" Icon="person_add" ButtonStyle="ButtonStyle.Primary" Click="@CreateNew" />
            <RadzenButton Icon="refresh" Text="@L["Btn_Refresh"].Value" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Dark" Click="@LoadDataAsync" />
        </RadzenStack>
    </RadzenStack>


    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            Filtre actif : <strong>@L["Sec_FilterOnDuty"]</strong>
        </RadzenAlert>
    }

    @* === RECHERCHE === *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" class="rz-mb-4">
        <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
        <RadzenTextBox @bind-Value="searchTerm" Placeholder="@L["Sec_PlSearchAgent"].Value"
                       Style="flex: 1; min-width: 200px;" Change="@(_ => StateHasChanged())" />
        <RadzenDropDown @bind-Value="filterBarriereId" Data="@barrieres" TextProperty="NomBarriere" ValueProperty="Id"
                        Placeholder="@L["Sec_PlAllBarrieres"].Value" AllowClear="true" Style="min-width: 180px;" Change="@(_ => StateHasChanged())" />
        <RadzenDropDown @bind-Value="filterVacation" Data="@vacationOptions"
                        Placeholder="@L["Sec_PlAllVacations"].Value" AllowClear="true" Style="min-width: 150px;" Change="@(_ => StateHasChanged())" />
        <RadzenDatePicker @bind-Value="filterDate" DateFormat="dd/MM/yyyy" Placeholder="@L["Lbl_Date"].Value"
                          ShowTime="false" Style="min-width: 140px;" Change="@(_ => StateHasChanged())" />
        @if (HasAnyFilter)
        {
            <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ClearSearch" />
        }
    </RadzenStack>

    @* === GRID === *@
    @if (isLoading)
    {
        <RadzenCard>
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="padding: 4rem;">
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        <RadzenDataGrid @ref="grid" Data="@filteredAffectations" TItem="AgentAffectation"
                        AllowPaging="true" PageSize="10" PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowSorting="true" AllowFiltering="false"
                        Density="Density.Compact"
                        GridLines="DataGridGridLines.Horizontal"
                        ExpandMode="DataGridExpandMode.Single">
            <Template Context="a">
                <div style="padding: 0.75rem 1rem; background: var(--rz-base-200); border-radius: 8px; margin: 0.25rem 0;">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap">
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Login :</strong> @a.AgentLogin</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Matricule :</strong> @a.AgentMatricule</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Barrière :</strong> @a.BarriereNom</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Vacation :</strong> @a.Vacation</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Du :</strong> @a.DateDebut.ToString("dd/MM/yyyy")</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Au :</strong> @(a.DateFin?.ToString("dd/MM/yyyy") ?? "Permanent")</span>
                    </RadzenStack>
                </div>
            </Template>
            <Columns>
                <RadzenDataGridColumn TItem="AgentAffectation" Property="AgentNom" Title="@L["Sec_ColAgent"]" Sortable="true">
                    <Template Context="a">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <div style="background: #805ad5; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                <RadzenIcon Icon="person" Style="color: white; font-size: 1rem;" />
                            </div>
                            <RadzenStack Gap="0">
                                <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0;">@a.AgentNom</RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500); font-family: monospace; margin: 0;">@a.AgentMatricule</RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AgentAffectation" Property="BarriereNom" Title="@L["Sec_ColBarriere"]" Width="180px" Sortable="true">
                    <Template Context="a">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                            <RadzenIcon Icon="security" Style="color: #e31b23; font-size: 1rem;" />
                            <span>@a.BarriereNom</span>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AgentAffectation" Property="Vacation" Title="@L["Sec_ColVacation"]" Width="110px" Sortable="true">
                    <Template Context="a">
                        <RadzenBadge Text="@a.Vacation" BadgeStyle="@GetVacationStyle(a.Vacation)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AgentAffectation" Property="DateDebut" Title="@L["Sec_ColStart"]" Width="110px" Sortable="true" FormatString="{0:dd/MM/yyyy}" />
                <RadzenDataGridColumn TItem="AgentAffectation" Property="DateFin" Title="@L["Sec_ColFin"]" Width="120px" Sortable="true">
                    <Template Context="a">
                        @if (a.DateFin.HasValue)
                        {
                            <span style="font-size: 0.9rem;">@a.DateFin.Value.ToString("dd/MM/yyyy")</span>
                        }
                        else
                        {
                            <RadzenBadge Text="@L["Sec_BadgePermanent"].Value" BadgeStyle="BadgeStyle.Light" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AgentAffectation" Property="EstActif" Title="@L["Sec_ColStatus"]" Width="120px" Sortable="true">
                    <Template Context="a">
                        @if (a.EstActif && IsCurrentlyActive(a))
                        {
                            <RadzenBadge Text="@L["Sec_BadgeOnDuty"].Value" BadgeStyle="BadgeStyle.Success" />
                        }
                        else if (a.EstActif)
                        {
                            <RadzenBadge Text="@L["Sec_BadgeScheduled"].Value" BadgeStyle="BadgeStyle.Info" />
                        }
                        else
                        {
                            <RadzenBadge Text="@L["Sec_BadgeInactive"].Value" BadgeStyle="BadgeStyle.Light" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AgentAffectation" Title="@L["Col_Actions"]" Width="170px" TextAlign="TextAlign.Right" Sortable="false">
                    <Template Context="a">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                            <RadzenButton Icon="edit" Text="@L["Btn_Edit"].Value" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Dark" Click="@(() => EditAffectation(a))" />
                            <RadzenButton Icon="delete" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Danger" Click="@(() => DeleteAffectation(a))" title="@L["Tt_Delete"].Value" />
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</div>

@code {
    private RadzenDataGrid<AgentAffectation>? grid;
    private List<AgentAffectation> allAffectations = new();
    private List<Barriere> barrieres = new();
    private bool isLoading = true;
    private string? searchTerm;
    private int? filterBarriereId;
    private string? filterVacation;
    private DateTime? filterDate;
    private string? activeFilter; // null | "active"
    private StatsData stats = new();

    private readonly List<string> vacationOptions = new() { "Jour", "Nuit", "Mixte" };

    private bool HasAnyFilter => !string.IsNullOrWhiteSpace(searchTerm)
        || filterBarriereId.HasValue || !string.IsNullOrEmpty(filterVacation) || filterDate.HasValue;

    private IEnumerable<AgentAffectation> filteredAffectations
    {
        get
        {
            IEnumerable<AgentAffectation> q = allAffectations;
            if (activeFilter == "active") q = q.Where(a => a.EstActif && IsCurrentlyActive(a));
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var s = searchTerm.Trim();
                q = q.Where(a =>
                    a.AgentNom.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    a.AgentMatricule.Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            if (filterBarriereId.HasValue) q = q.Where(a => a.BarriereId == filterBarriereId.Value);
            if (!string.IsNullOrEmpty(filterVacation)) q = q.Where(a => a.Vacation == filterVacation);
            if (filterDate.HasValue) q = q.Where(a => a.DateDebut <= filterDate.Value && (!a.DateFin.HasValue || a.DateFin.Value >= filterDate.Value));
            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUserService.HasActivite("SEC_GERER_AGENTS"))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }
        barrieres = (await BarriereService.GetAllAsync()).ToList();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            allAffectations = new List<AgentAffectation>
            {
                new() { Id = 1, AgentLogin = "jdupont", AgentNom = "Jean Dupont", AgentMatricule = "SEC-001", BarriereId = 1, BarriereNom = "Barrière Principale", Vacation = "Jour", DateDebut = DateTime.Today, EstActif = true },
                new() { Id = 2, AgentLogin = "mmartin", AgentNom = "Marie Martin", AgentMatricule = "SEC-002", BarriereId = 1, BarriereNom = "Barrière Principale", Vacation = "Nuit", DateDebut = DateTime.Today, EstActif = true },
                new() { Id = 3, AgentLogin = "pdurand", AgentNom = "Pierre Durand", AgentMatricule = "SEC-003", BarriereId = 2, BarriereNom = "Entrée Nord", Vacation = "Jour", DateDebut = DateTime.Today.AddDays(-30), EstActif = true },
                new() { Id = 4, AgentLogin = "lbernard", AgentNom = "Luc Bernard", AgentMatricule = "SEC-004", BarriereId = 2, BarriereNom = "Entrée Nord", Vacation = "Nuit", DateDebut = DateTime.Today.AddDays(-30), EstActif = true },
            };

            foreach (var aff in allAffectations)
            {
                var b = barrieres.FirstOrDefault(x => x.Id == aff.BarriereId);
                if (b != null) aff.BarriereNom = b.NomBarriere;
            }

            UpdateStats();
        }
        finally
        {
            isLoading = false;
        }
        await Task.CompletedTask;
    }

    private void UpdateStats()
    {
        var activeNow = allAffectations.Where(a => a.EstActif && IsCurrentlyActive(a)).ToList();
        stats = new StatsData
        {
            TotalAgents = allAffectations.Select(a => a.AgentLogin).Distinct().Count(),
            AgentsEnService = activeNow.Count,
            BarrieresCouvertes = activeNow.Select(a => a.BarriereId).Distinct().Count(),
            TotalBarrieres = barrieres.Count,
            AffectationsActives = allAffectations.Count(a => a.EstActif)
        };
    }

    private void SetFilter(string? f) { activeFilter = f; StateHasChanged(); }
    private void ClearSearch() { searchTerm = null; filterBarriereId = null; filterVacation = null; filterDate = null; StateHasChanged(); }

    private bool IsCurrentlyActive(AgentAffectation a)
    {
        var now = DateTime.Now;
        return a.DateDebut <= now && (!a.DateFin.HasValue || a.DateFin.Value >= now);
    }

    private async Task CreateNew()
    {
        var result = await DialogService.OpenAsync<AgentAffectationDialog>(L["Sec_DlgNewAssignment"].Value,
            new Dictionary<string, object> { { "Affectation", null! }, { "Barrieres", barrieres } },
            new DialogOptions { Width = "550px" });
        if (result is AgentAffectation)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Sec_NotifAssignCreated"].Value);
            await LoadDataAsync();
        }
    }

    private async Task EditAffectation(AgentAffectation affectation)
    {
        var result = await DialogService.OpenAsync<AgentAffectationDialog>(L["Sec_DlgEditAssignment"].Value,
            new Dictionary<string, object> { { "Affectation", affectation }, { "Barrieres", barrieres } },
            new DialogOptions { Width = "550px" });
        if (result is AgentAffectation)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Sec_NotifAssignUpdated"].Value);
            await LoadDataAsync();
        }
    }

    private async Task DeleteAffectation(AgentAffectation affectation)
    {
        var confirm = await DialogService.Confirm(
            $"Voulez-vous vraiment supprimer l'affectation de \"{affectation.AgentNom}\" à \"{affectation.BarriereNom}\" ?",
            "Confirmer la suppression",
            new ConfirmOptions { OkButtonText = "Supprimer", CancelButtonText = "Annuler" });
        if (confirm == true)
        {
            allAffectations.Remove(affectation);
            NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Sec_NotifAssignDeleted"].Value);
            UpdateStats();
            StateHasChanged();
        }
    }

    private BadgeStyle GetVacationStyle(string vacation) => vacation switch
    {
        "Jour" => BadgeStyle.Warning,
        "Nuit" => BadgeStyle.Info,
        "Mixte" => BadgeStyle.Light,
        _ => BadgeStyle.Secondary
    };

    public class AgentAffectation
    {
        public int Id { get; set; }
        public string AgentLogin { get; set; } = "";
        public string AgentNom { get; set; } = "";
        public string AgentMatricule { get; set; } = "";
        public int BarriereId { get; set; }
        public string BarriereNom { get; set; } = "";
        public string Vacation { get; set; } = "Jour";
        public DateTime DateDebut { get; set; }
        public DateTime? DateFin { get; set; }
        public bool EstActif { get; set; } = true;
    }

    private class StatsData
    {
        public int TotalAgents { get; set; }
        public int AgentsEnService { get; set; }
        public int BarrieresCouvertes { get; set; }
        public int TotalBarrieres { get; set; }
        public int AffectationsActives { get; set; }
    }
}
