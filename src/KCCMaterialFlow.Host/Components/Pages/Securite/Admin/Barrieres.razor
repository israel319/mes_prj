@page "/securite/admin/barrieres"
@attribute [Authorize(Roles = "Admin,Security")]
@inject IBarriereService BarriereService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Gestion des Barrières - KCC Material Flow</PageTitle>

<div style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">

    @* === EN-TÊTE === *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="1rem" class="rz-mb-6">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-grey); margin: 0;">
                <RadzenIcon Icon="security" Style="vertical-align: middle; margin-right: 0.5rem; color: #e31b23;" />
                Gestion des Barrières
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500); margin: 0;">
                Configuration des points de contrôle de sécurité
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="@L["Sec_BtnNewBarriere"].Value" Icon="add_circle" ButtonStyle="ButtonStyle.Primary" Click="@CreateNew" />
            <RadzenButton Icon="refresh" Text="@L["Btn_Refresh"].Value" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Dark" Click="@LoadDataAsync" />
        </RadzenStack>
    </RadzenStack>


    @* Filtre actif *@
    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            Filtre actif : <strong>@(activeFilter == "active" ? L["Sec_FilterActives"].Value : L["Sec_FilterInactives"].Value)</strong>
        </RadzenAlert>
    }

    @* === RECHERCHE === *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" class="rz-mb-4">
        <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
        <RadzenTextBox @bind-Value="searchTerm" Placeholder="@L["Sec_PlSearchBarriere"].Value"
                       Style="flex: 1; min-width: 220px;" Change="@(_ => StateHasChanged())" />
        <RadzenDropDown @bind-Value="filterType" Data="@typeOptions"
                        Placeholder="@L["Sec_PlAllTypes"].Value" AllowClear="true" Style="min-width: 150px;" Change="@(_ => StateHasChanged())" />
        @if (!string.IsNullOrWhiteSpace(searchTerm) || !string.IsNullOrEmpty(filterType))
        {
            <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ClearSearch" />
        }
    </RadzenStack>

    @* === GRID === *@
    @if (isLoading)
    {
        <RadzenCard>
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="padding: 4rem;">
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        <RadzenDataGrid @ref="grid" Data="@filteredBarrieres" TItem="Barriere"
                        AllowPaging="true" PageSize="10" PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowSorting="true" AllowFiltering="false"
                        Density="Density.Compact"
                        GridLines="DataGridGridLines.Horizontal"
                        ExpandMode="DataGridExpandMode.Single">
            <Template Context="b">
                <div style="padding: 0.75rem 1rem; background: var(--rz-base-200); border-radius: 8px; margin: 0.25rem 0;">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap" Style="margin-bottom: 0.5rem;">
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Code :</strong> @b.CodeBarriere</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Localisation :</strong> @b.Localisation</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Horaires :</strong> @(b.HorairesOuverture ?? "N/A")</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">Type :</strong> @b.TypeBarriere</span>
                    </RadzenStack>
                    <div style="text-align: right; margin-top: 0.5rem;">
                        <RadzenButton Text="@L["Btn_Edit"].Value" Icon="edit" Variant="Variant.Outlined"
                                      ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Small"
                                      Click="@(() => EditBarriere(b))" />
                    </div>
                </div>
            </Template>
            <Columns>
                <RadzenDataGridColumn TItem="Barriere" Property="CodeBarriere" Title="@L["Sec_ColCode"]" Width="130px" Sortable="true">
                    <Template Context="b">
                        <span style="font-family: monospace; font-weight: 600; color: #e31b23;">@b.CodeBarriere</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Barriere" Property="NomBarriere" Title="@L["Lbl_Name"]" Sortable="true">
                    <Template Context="b">
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0;">@b.NomBarriere</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500); margin: 0;">
                                <RadzenIcon Icon="location_on" Style="font-size: 0.85rem; vertical-align: middle;" /> @b.Localisation
                            </RadzenText>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Barriere" Property="TypeBarriere" Title="@L["Col_Type"]" Width="110px" Sortable="true">
                    <Template Context="b">
                        <RadzenBadge Text="@b.TypeBarriere" BadgeStyle="@GetTypeBadgeStyle(b.TypeBarriere)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Barriere" Property="HorairesOuverture" Title="@L["Sec_ColHours"]" Width="140px" Sortable="true">
                    <Template Context="b">
                        <span style="font-size: 0.9rem; color: var(--gray-600);">@(b.HorairesOuverture ?? "N/A")</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Barriere" Property="EstActive" Title="@L["Sec_ColStatus"]" Width="120px" Sortable="true">
                    <Template Context="b">
                        @if (b.EstActive)
                        {
                            <RadzenBadge Text="@L["Sec_BadgeActive"].Value" BadgeStyle="BadgeStyle.Success" />
                        }
                        else
                        {
                            <RadzenBadge Text="@L["Sec_BadgeInactiveF"].Value" BadgeStyle="BadgeStyle.Light" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Barriere" Title="@L["Col_Actions"]" Width="200px" TextAlign="TextAlign.Right" Sortable="false">
                    <Template Context="b">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                            <RadzenButton Icon="edit" Text="@L["Btn_Edit"].Value" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Dark" Click="@(() => EditBarriere(b))" />
                            <RadzenButton Icon="@(b.EstActive ? "block" : "check_circle")" Size="ButtonSize.Small"
                                          Variant="Variant.Outlined"
                                          ButtonStyle="@(b.EstActive ? ButtonStyle.Warning : ButtonStyle.Success)"
                                          Click="@(() => ToggleActive(b))" title="@(b.EstActive ? "Désactiver" : "Activer")" />
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</div>

@code {
    private RadzenDataGrid<Barriere>? grid;
    private List<Barriere> allBarrieres = new();
    private bool isLoading = true;
    private string? searchTerm;
    private string? filterType;
    private string? activeFilter; // null | "active" | "inactive"
    private int activeCount;
    private int inactiveCount;

    private readonly List<string> typeOptions = new() { "Entrée", "Sortie", "Mixte" };

    private IEnumerable<Barriere> filteredBarrieres
    {
        get
        {
            IEnumerable<Barriere> q = allBarrieres;
            if (activeFilter == "active") q = q.Where(b => b.EstActive);
            else if (activeFilter == "inactive") q = q.Where(b => !b.EstActive);

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var s = searchTerm.Trim();
                q = q.Where(b =>
                    (b.CodeBarriere ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (b.NomBarriere ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (b.Localisation ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrEmpty(filterType))
                q = q.Where(b => b.TypeBarriere == filterType);
            return q;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUserService.HasActivite("SEC_GERER_BARRIERES"))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            allBarrieres = (await BarriereService.GetAllAsync()).ToList();
            activeCount = allBarrieres.Count(b => b.EstActive);
            inactiveCount = allBarrieres.Count(b => !b.EstActive);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, string.Format(L["Sec_NotifLoadFailed"].Value, ex.Message));
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(string? f)
    {
        activeFilter = f;
        StateHasChanged();
    }

    private void ClearSearch()
    {
        searchTerm = null;
        filterType = null;
        StateHasChanged();
    }

    private async Task CreateNew()
    {
        var result = await DialogService.OpenAsync<BarriereEditDialog>(L["Sec_DlgNewBarriere"].Value,
            new Dictionary<string, object> { { "Barriere", null! } },
            new DialogOptions { Width = "600px" });

        if (result is Barriere)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Sec_NotifBarriereCreated"].Value);
            await LoadDataAsync();
        }
    }

    private async Task EditBarriere(Barriere barriere)
    {
        var result = await DialogService.OpenAsync<BarriereEditDialog>(L["Sec_DlgEditBarriere"].Value,
            new Dictionary<string, object> { { "Barriere", barriere } },
            new DialogOptions { Width = "600px" });

        if (result is Barriere)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Sec_NotifBarriereUpdated"].Value);
            await LoadDataAsync();
        }
    }

    private async Task ToggleActive(Barriere barriere)
    {
        var action = barriere.EstActive ? "désactiver" : "activer";
        var confirm = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} la barrière \"{barriere.NomBarriere}\" ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });

        if (confirm == true)
        {
            try
            {
                barriere.EstActive = !barriere.EstActive;
                await BarriereService.UpdateAsync(barriere);
                NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, $"{(barriere.EstActive ? L["Sec_NotifBarriereActivated"].Value : L["Sec_NotifBarriereDeactivated"].Value)}");
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, ex.Message);
            }
        }
    }

    private BadgeStyle GetTypeBadgeStyle(string type) => type switch
    {
        "Entrée" => BadgeStyle.Success,
        "Sortie" => BadgeStyle.Info,
        "Mixte" => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };
}
