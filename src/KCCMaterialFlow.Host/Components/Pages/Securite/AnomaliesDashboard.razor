@page "/securite/anomalies/dashboard"
@attribute [Authorize(Roles = "Admin,Security,OPJ,Identification,Superviseur")]
@inject IAnomalieService AnomalieService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<PageTitle>Dashboard Anomalies - Investigation - KCC Material Flow</PageTitle>

<div style="background-color: #f4f7fa; min-height: 100vh; padding: 2rem;">
    <RadzenStack Gap="1.5rem">
        
        @* En-tête *@
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn Size="12" SizeMD="8">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                    <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" 
                                  Click="@GoBack" Style="border-radius: 50%;" />
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.H4" FontWeight="FontWeight.Bold" Style="color: #1a202c;">
                            <RadzenIcon Icon="dashboard" Style="vertical-align: middle; margin-right: 0.5rem; color: #4299e1;" />
                            @L["Adb_Title"]
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: #718096;">
                            @(L["Adb_LastUpdate"].Value + " " + DateTime.Now.ToString("HH:mm"))
                        </RadzenText>
                    </RadzenStack>
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4" class="rz-text-align-right">
                <RadzenButton Text="@L["Adb_Btn_ViewAll"].Value" Icon="list" ButtonStyle="ButtonStyle.Dark" 
                              Style="border-radius: 8px;" 
                              Click="@(() => Navigation.NavigateTo("/securite/anomalies"))" />
            </RadzenColumn>
        </RadzenRow>

        @if (isLoading)
        {
            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 300px;">
                <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Large" />
            </RadzenStack>
        }
        else if (dashboard != null)
        {
            @* Métriques principales *@
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; background: linear-gradient(135deg, #fff5f5 0%, #fed7d7 100%);">
                        <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                            <div style="background: #e31b23; border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                <RadzenIcon Icon="error" Style="color: white; font-size: 1.75rem;" />
                            </div>
                            <RadzenText TextStyle="TextStyle.H3" FontWeight="FontWeight.Bold" Style="color: #e31b23;">
                                @dashboard.TotalNonTraitees
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #c53030;">@L["Adb_Card_NonTraitees"]</RadzenText>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);">
                        <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                            <div style="background: #d97706; border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                <RadzenIcon Icon="warning" Style="color: white; font-size: 1.75rem;" />
                            </div>
                            <RadzenText TextStyle="TextStyle.H3" FontWeight="FontWeight.Bold" Style="color: #d97706;">
                                @dashboard.CritiquesNonTraitees
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #92400e;">@L["Adb_Card_Critiques"]</RadzenText>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; background: linear-gradient(135deg, #f0fff4 0%, #c6f6d5 100%);">
                        <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                            <div style="background: #38a169; border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                <RadzenIcon Icon="trending_up" Style="color: white; font-size: 1.75rem;" />
                            </div>
                            <RadzenText TextStyle="TextStyle.H3" FontWeight="FontWeight.Bold" Style="color: #38a169;">
                                @dashboard.TauxResolution.ToString("0.0")%
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #276749;">@L["Adb_Card_TauxResolution"]</RadzenText>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; background: linear-gradient(135deg, #ebf8ff 0%, #bee3f8 100%);">
                        <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                            <div style="background: #3182ce; border-radius: 50%; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                                <RadzenIcon Icon="schedule" Style="color: white; font-size: 1.75rem;" />
                            </div>
                            <RadzenText TextStyle="TextStyle.H3" FontWeight="FontWeight.Bold" Style="color: #3182ce;">
                                @(dashboard.DelaiMoyenResolution.HasValue ? $"{dashboard.DelaiMoyenResolution.Value.TotalHours:0.0}h" : "-")
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #2c5282;">@L["Adb_Card_DelaiMoyen"]</RadzenText>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>

            @* Graphiques *@
            <RadzenRow Gap="1rem">
                @* Répartition par Type *@
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; border: 1px solid #eee;">
                        <RadzenText TextStyle="TextStyle.H6" FontWeight="FontWeight.Bold" Style="color: #1a202c; margin-bottom: 1rem;">
                            <RadzenIcon Icon="pie_chart" Style="vertical-align: middle; margin-right: 0.5rem;" />
                            @L["Adb_Chart_ByType"]
                        </RadzenText>
                        @if (dashboard.ParType.Any())
                        {
                            <RadzenChart Style="height: 250px;">
                                <RadzenDonutSeries Data="@typeChartData" CategoryProperty="Label" ValueProperty="Value">
                                    <RadzenSeriesDataLabels Visible="true" />
                                </RadzenDonutSeries>
                            </RadzenChart>
                        }
                        else
                        {
                            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height: 250px;">
                                <RadzenText Style="color: #a0aec0;">@L["Adb_NoData"]</RadzenText>
                            </RadzenStack>
                        }
                    </RadzenCard>
                </RadzenColumn>

                @* Répartition par Gravité *@
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; border: 1px solid #eee;">
                        <RadzenText TextStyle="TextStyle.H6" FontWeight="FontWeight.Bold" Style="color: #1a202c; margin-bottom: 1rem;">
                            <RadzenIcon Icon="bar_chart" Style="vertical-align: middle; margin-right: 0.5rem;" />
                            @L["Adb_Chart_ByGravity"]
                        </RadzenText>
                        @if (dashboard.ParGravite.Any())
                        {
                            <RadzenChart Style="height: 250px;">
                                <RadzenColumnSeries Data="@graviteChartData" CategoryProperty="Label" ValueProperty="Value">
                                    <RadzenSeriesDataLabels Visible="true" />
                                </RadzenColumnSeries>
                                <RadzenCategoryAxis>
                                    <RadzenAxisTitle Text="" />
                                </RadzenCategoryAxis>
                                <RadzenValueAxis>
                                    <RadzenAxisTitle Text="@L["Adb_Chart_Count"].Value" />
                                </RadzenValueAxis>
                            </RadzenChart>
                        }
                        else
                        {
                            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height: 250px;">
                                <RadzenText Style="color: #a0aec0;">Aucune donnée disponible</RadzenText>
                            </RadzenStack>
                        }
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>

            @* Anomalies récentes *@
            <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; border: 1px solid #eee;">
                <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1rem;">
                    <RadzenColumn>
                        <RadzenText TextStyle="TextStyle.H6" FontWeight="FontWeight.Bold" Style="color: #1a202c;">
                            <RadzenIcon Icon="schedule" Style="vertical-align: middle; margin-right: 0.5rem;" />
                            @L["Adb_Recent"]
                        </RadzenText>
                    </RadzenColumn>
                    <RadzenColumn class="rz-text-align-right">
                        <RadzenBadge Text="@dashboard.AnomaliesRecentes.Count.ToString()" BadgeStyle="BadgeStyle.Info" />
                    </RadzenColumn>
                </RadzenRow>

                @if (dashboard.AnomaliesRecentes.Any())
                {
                    <RadzenDataList Data="@dashboard.AnomaliesRecentes" TItem="Anomalie">
                        <Template Context="anomalie">
                            <RadzenCard Variant="Variant.Flat" Style="border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 0.5rem; padding: 1rem; cursor: pointer;"
                                        @onclick="@(() => VoirDetail(anomalie))">
                                <RadzenRow AlignItems="AlignItems.Center">
                                    <RadzenColumn Size="1">
                                        <RadzenIcon Icon="@GetGraviteIcon(anomalie.NiveauGravite)" 
                                                    Style="@($"color: {GetGraviteColor(anomalie.NiveauGravite)}; font-size: 1.5rem;")" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="2">
                                        <RadzenText TextStyle="TextStyle.Caption" Style="color: #718096;">
                                            @anomalie.DateSignalement.ToString("HH:mm")
                                        </RadzenText>
                                    </RadzenColumn>
                                    <RadzenColumn Size="3">
                                        <RadzenBadge Text="@GetGraviteLabel(anomalie.NiveauGravite)" 
                                                     BadgeStyle="@GetGraviteStyle(anomalie.NiveauGravite)" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="4">
                                        <RadzenText Style="font-size: 0.9rem;">
                                            @GetTypeLabel(anomalie.TypeAnomalie)
                                        </RadzenText>
                                    </RadzenColumn>
                                    <RadzenColumn Size="2" class="rz-text-align-right">
                                        @if (!string.IsNullOrEmpty(anomalie.NumeroReferenceBon))
                                        {
                                            <RadzenText Style="font-family: monospace; color: #e31b23; font-size: 0.85rem;">
                                                @anomalie.NumeroReferenceBon
                                            </RadzenText>
                                        }
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenCard>
                        </Template>
                    </RadzenDataList>
                }
                else
                {
                    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="padding: 2rem;">
                        <RadzenIcon Icon="check_circle" Style="font-size: 3rem; color: #48bb78;" />
                        <RadzenText Style="color: #718096;">@L["Adb_NoRecent"]</RadzenText>
                    </RadzenStack>
                }
            </RadzenCard>

            @* Alertes Critiques *@
            @if (dashboard.CritiquesNonTraitees > 0)
            {
                <RadzenCard Variant="Variant.Flat" Style="border-radius: 12px; padding: 1.5rem; background: #fff5f5; border: 2px solid #fc8181;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenIcon Icon="error" Style="font-size: 2rem; color: #e31b23;" />
                        <RadzenStack Gap="0.25rem" Style="flex: 1;">
                            <RadzenText FontWeight="FontWeight.Bold" Style="color: #c53030;">
                                @(dashboard.CritiquesNonTraitees + " " + L["Adb_Alert_CriticalPending"].Value)
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: #9b2c2c;">
                                @L["Adb_Alert_CriticalMsg"]
                            </RadzenText>
                        </RadzenStack>
                        <RadzenButton Text="@L["Adb_Btn_Process"].Value" Icon="arrow_forward" ButtonStyle="ButtonStyle.Danger" 
                                      Click="@VoirCritiques" />
                    </RadzenStack>
                </RadzenCard>
            }
        }
    </RadzenStack>
</div>

@code {
    private AnomalieDashboard? dashboard;
    private bool isLoading = true;
    private List<ChartDataItem> typeChartData = new();
    private List<ChartDataItem> graviteChartData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            dashboard = await AnomalieService.GetDashboardAsync();
            
            // Préparer les données pour les graphiques
            if (dashboard != null)
            {
                typeChartData = dashboard.ParType
                    .Select(kv => new ChartDataItem { Label = GetTypeLabel(kv.Key), Value = kv.Value })
                    .ToList();

                graviteChartData = dashboard.ParGravite
                    .OrderByDescending(kv => GetGraviteOrder(kv.Key))
                    .Select(kv => new ChartDataItem { Label = GetGraviteLabel(kv.Key), Value = kv.Value })
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, L["Msg_LoadFailed"].Value + " : " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    // Navigation retour via historique
    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    private void VoirDetail(Anomalie anomalie)
    {
        Navigation.NavigateTo($"/securite/anomalies/{anomalie.Id}");
    }

    private void VoirCritiques()
    {
        Navigation.NavigateTo("/securite/anomalies?gravite=Critique&statut=false");
    }

    private int GetGraviteOrder(string gravite) => gravite switch
    {
        "Critique" => 4,
        "Eleve" => 3,
        "Moyen" => 2,
        "Faible" => 1,
        _ => 0
    };

    private string GetGraviteLabel(string gravite) => gravite switch
    {
        "Critique" => L["Grav_Critique"].Value,
        "Eleve" => L["Grav_Eleve"].Value,
        "Moyen" => L["Grav_Moyen"].Value,
        "Faible" => L["Grav_Faible"].Value,
        _ => gravite
    };

    private string GetGraviteColor(string gravite) => gravite switch
    {
        "Critique" => "#e31b23",
        "Eleve" => "#ed8936",
        "Moyen" => "#4299e1",
        "Faible" => "#a0aec0",
        _ => "#718096"
    };

    private string GetGraviteIcon(string gravite) => gravite switch
    {
        "Critique" => "error",
        "Eleve" => "warning",
        "Moyen" => "info",
        "Faible" => "help_outline",
        _ => "help"
    };

    private BadgeStyle GetGraviteStyle(string gravite) => gravite switch
    {
        "Critique" => BadgeStyle.Danger,
        "Eleve" => BadgeStyle.Warning,
        "Moyen" => BadgeStyle.Info,
        "Faible" => BadgeStyle.Light,
        _ => BadgeStyle.Secondary
    };

    private string GetTypeLabel(string type) => type switch
    {
        "BarriereNonAutorisee" => L["Ano_BarriereNonAutorisee"].Value,
        "DocumentExpire" => L["Ano_DocumentExpire"].Value,
        "DocumentInexistant" => L["Ano_DocumentInexistant"].Value,
        "ScanDuplique" => L["Ano_ScanDuplique"].Value,
        "QRCodeInvalide" => L["Ano_QRCodeInvalide"].Value,
        "ItineraireNonRespectee" => L["Ano_ItineraireNonRespectee"].Value,
        "SignalementManuel" => L["Ano_SignalementManuel"].Value,
        _ => type
    };

    private class ChartDataItem
    {
        public string Label { get; set; } = "";
        public int Value { get; set; }
    }
}
