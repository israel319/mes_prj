@page "/securite/historique"
@attribute [Authorize]
@inject IScanService ScanService
@inject IBarriereService BarriereService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Historique des Scans - KCC Material Flow</PageTitle>

<div style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">

    @* === EN-TÊTE === *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="1rem" class="rz-mb-6">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-grey); margin: 0;">
                <RadzenIcon Icon="history" Style="vertical-align: middle; margin-right: 0.5rem;" />
                @L["Hsc_Title"]
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500); margin: 0;">
                @L["Hsc_Subtitle"]
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="@L["Hsc_Btn_Scan"].Value" Icon="qr_code_scanner" ButtonStyle="ButtonStyle.Danger"
                          Click="@(() => NavigationManager.NavigateTo("/securite/scan"))" />
            <RadzenButton Icon="refresh" Text="@L["Btn_Refresh"].Value" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Dark" Click="@LoadDataAsync" />
        </RadzenStack>
    </RadzenStack>


    @* Filtre actif *@
    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            Filtre actif : <strong>@GetFilterLabel(activeFilter)</strong>
        </RadzenAlert>
    }

    @* === BARRE DE RECHERCHE + FILTRES === *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" class="rz-mb-4">
        <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
        <RadzenTextBox @bind-Value="filter.SearchTerm" Placeholder="@L["Hsc_SearchPlaceholder"].Value"
                       Style="flex: 1; min-width: 220px;" />
        <RadzenDropDown @bind-Value="filter.BarriereId" Data="@barrieres" TextProperty="NomBarriere" ValueProperty="Id"
                        Placeholder="@L["Hsc_PlaceholderBarriere"].Value" AllowClear="true" Style="min-width: 180px;" />
        <RadzenDatePicker @bind-Value="filter.DateDebut" DateFormat="dd/MM/yyyy" Placeholder="@L["Filter_DateFrom"].Value" Style="width: 140px;" />
        <RadzenDatePicker @bind-Value="filter.DateFin" DateFormat="dd/MM/yyyy" Placeholder="@L["Filter_DateTo"].Value" Style="width: 140px;" />
        <RadzenButton Text="@L["Btn_Filter"].Value" Icon="search" ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Small" Click="@LoadDataAsync" />
        <RadzenButton Icon="restart_alt" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ResetFilter" />
    </RadzenStack>

    @* === GRID === *@
    <RadzenDataGrid @ref="grid" Data="@items" TItem="ScanEvenement" IsLoading="@isLoading"
                    AllowPaging="true" PageSize="10" PagerHorizontalAlign="HorizontalAlign.Center"
                    AllowSorting="true" AllowFiltering="false" Count="@totalCount"
                    Density="Density.Compact"
                    GridLines="DataGridGridLines.Horizontal"
                    LoadData="@LoadDataGrid">
        <Columns>
            <RadzenDataGridColumn TItem="ScanEvenement" Title="@L["Hsc_Col_Type"]" Width="100px" Property="TypeBon" Sortable="true">
                <Template Context="scan">
                    <RadzenBadge Text="@scan.TypeBon" BadgeStyle="@(scan.TypeBon == "BEM" ? BadgeStyle.Info : BadgeStyle.Secondary)" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Property="NumeroReferenceBon" Title="@L["Hsc_Col_Reference"]" Width="180px" Sortable="true">
                <Template Context="scan">
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0;">@scan.NumeroReferenceBon</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500); margin: 0;">
                            @scan.DateHeureScan.ToString("dd/MM/yyyy HH:mm")
                        </RadzenText>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Title="@L["Hsc_Col_Movement"]" Width="120px" Property="TypeMouvement" Sortable="true">
                <Template Context="scan">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                        <RadzenIcon Icon="@(scan.TypeMouvement == "Entree" ? "login" : "logout")"
                                    Style="@($"color: {(scan.TypeMouvement == "Entree" ? "#16a34a" : "#d97706")};")" />
                        <span>@scan.TypeMouvement</span>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Title="@L["Hsc_Col_Barrier"]" Width="160px">
                <Template Context="scan">@(scan.Barriere?.NomBarriere ?? "N/A")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Property="AgentNom" Title="@L["Hsc_Col_Agent"]" Width="180px" Sortable="true">
                <Template Context="scan">@(scan.AgentNom ?? scan.AgentLogin)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Title="@L["Hsc_Col_Statut"]" Width="120px" Property="StatutScan" Sortable="true">
                <Template Context="scan">
                    <RadzenBadge Text="@GetStatutLabel(scan.StatutScan)" BadgeStyle="@GetStatutStyle(scan.StatutScan)" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Title="@L["Hsc_Col_Anomaly"]" Width="80px" TextAlign="TextAlign.Center" Sortable="false">
                <Template Context="scan">
                    @if (scan.AnomalieSignalee)
                    {
                        <RadzenIcon Icon="warning" Style="color: #d97706;" title="@L["Sec_AnomalieTooltip"].Value" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ScanEvenement" Title="@L["Col_Actions"]" Width="120px" TextAlign="TextAlign.Right" Sortable="false">
                <Template Context="scan">
                    <RadzenButton Icon="visibility" Text="@L["Btn_Detail"].Value" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                  ButtonStyle="ButtonStyle.Dark" Click="@(() => ShowScanDetails(scan))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    private RadzenDataGrid<ScanEvenement>? grid;
    private IEnumerable<ScanEvenement> items = Enumerable.Empty<ScanEvenement>();
    private int totalCount = 0;
    private bool isLoading = false;
    private ScanHistoryFilter filter = new();
    private ScanStats stats = new();
    private List<Barriere> barrieres = new();
    private string? activeFilter;

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUserService.HasActivite("SEC_VOIR_HISTORIQUE"))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        filter.DateDebut = DateTime.Today;
        filter.DateFin = DateTime.Today.AddDays(1).AddSeconds(-1);

        await LoadBarrieres();
        await LoadStatsAsync();
    }

    private void SetFilter(string? f)
    {
        activeFilter = f;
        filter.StatutScan = f switch
        {
            "valid" => StatutScanValues.Valid,
            "invalid" => StatutScanValues.Invalid,
            _ => null
        };
        // "anomalie" est filtré côté grid via filter dédié si dispo, sinon on rafraîchit
        _ = LoadDataAsync();
    }

    private string GetFilterLabel(string f) => f switch
    {
        "valid" => L["Hsc_Filter_Valid"].Value,
        "invalid" => L["Hsc_Filter_Invalid"].Value,
        "anomalie" => L["Hsc_Filter_Anomaly"].Value,
        _ => f
    };

    private async Task LoadBarrieres()
    {
        try { barrieres = (await BarriereService.GetAllAsync()).ToList(); } catch { }
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            stats = await ScanService.GetStatistiquesAsync(
                filter.DateDebut ?? DateTime.Today,
                filter.DateFin ?? DateTime.Today.AddDays(1).AddSeconds(-1));
        }
        catch { }
    }

    private async Task LoadDataGrid(Radzen.LoadDataArgs args)
    {
        isLoading = true;
        try
        {
            filter.Skip = args.Skip ?? 0;
            filter.Take = args.Top ?? 10;

            var result = await ScanService.GetScanHistoryAsync(filter);
            var data = result.Items.AsEnumerable();
            if (activeFilter == "anomalie")
                data = data.Where(s => s.AnomalieSignalee);
            items = data.ToList();
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, L["Msg_LoadFailed"].Value + " : " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        if (grid != null) await grid.FirstPage(true);
        await LoadStatsAsync();
    }

    private async Task ResetFilter()
    {
        filter = new ScanHistoryFilter
        {
            DateDebut = DateTime.Today,
            DateFin = DateTime.Today.AddDays(1).AddSeconds(-1)
        };
        activeFilter = null;
        await LoadDataAsync();
    }

    private async Task ShowScanDetails(ScanEvenement scan)
    {
        await DialogService.OpenAsync<ScanDetailsDialog>("Détails du Scan",
            new Dictionary<string, object> { { "Scan", scan } },
            new DialogOptions { Width = "600px" });
    }

    private string GetStatutLabel(string statut) => statut switch
    {
        "Valid" => L["Scan_Statut_Valid"].Value,
        "Invalid" => L["Scan_Statut_Invalid"].Value,
        "Expired" => L["Scan_Statut_Expired"].Value,
        "AlreadyUsed" => L["Scan_Statut_AlreadyUsed"].Value,
        "NotFound" => L["Scan_Statut_NotFound"].Value,
        _ => statut
    };

    private BadgeStyle GetStatutStyle(string statut) => statut switch
    {
        "Valid" => BadgeStyle.Success,
        "Invalid" => BadgeStyle.Danger,
        "Expired" => BadgeStyle.Warning,
        "AlreadyUsed" => BadgeStyle.Info,
        "NotFound" => BadgeStyle.Light,
        _ => BadgeStyle.Secondary
    };
}
