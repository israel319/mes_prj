@inject IAnomalieService AnomalieService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<RadzenStack Gap="1.5rem" Style="padding: 0.5rem;">
    @if (Anomalie != null)
    {
        @* Résumé de l'anomalie *@
        <RadzenCard Variant="Variant.Flat" Style="background: #fef3c7; border: 1px solid #fbbf24; border-radius: 12px; padding: 1rem;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Start" Gap="0.75rem">
                <RadzenIcon Icon="warning" Style="color: #d97706; font-size: 1.5rem;" />
                <RadzenStack Gap="0.25rem">
                    <RadzenText FontWeight="FontWeight.Bold" Style="color: #92400e;">
                        @GetTypeLabel(Anomalie.TypeAnomalie)
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: #a16207;">
                        @Anomalie.Description
                    </RadzenText>
                    @if (!string.IsNullOrEmpty(Anomalie.NumeroReferenceBon))
                    {
                        <RadzenText TextStyle="TextStyle.Caption" Style="font-family: monospace; color: #92400e;">
                            @L["Tad_Document"] @Anomalie.NumeroReferenceBon
                        </RadzenText>
                    }
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* Formulaire de traitement SEC-036 *@
        <RadzenStack Gap="1rem">
            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Caption" FontWeight="FontWeight.Bold">
                    @L["Tad_ResolutionLabel"] <span style="color: #e31b23;">*</span>
                </RadzenText>
                <RadzenTextArea @bind-Value="@resolution" Rows="3" Placeholder="@L["Tad_ResolutionPlaceholder"].Value" 
                                Style="width: 100%; border-radius: 6px;" />
            </RadzenStack>

            <RadzenStack Gap="0.25rem">
                <RadzenText TextStyle="TextStyle.Caption" FontWeight="FontWeight.Bold">@L["Tad_CorrectiveLabel"]</RadzenText>
                <RadzenTextArea @bind-Value="@actionsCorrectives" Rows="2" 
                                Placeholder="@L["Tad_CorrectivePlaceholder"].Value" 
                                Style="width: 100%; border-radius: 6px;" />
            </RadzenStack>
        </RadzenStack>

        @* Actions *@
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="@L["Tad_Btn_Cancel"].Value" Icon="close" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
            <RadzenButton Text="@L["Tad_Btn_MarkResolved"].Value" Icon="check_circle" ButtonStyle="ButtonStyle.Success" 
                          Click="@Submit" Disabled="@(string.IsNullOrWhiteSpace(resolution))" />
        </RadzenStack>
    }
</RadzenStack>

@code {
    [Parameter] public Anomalie? Anomalie { get; set; }

    private string resolution = "";
    private string? actionsCorrectives;

    private async Task Submit()
    {
        if (Anomalie == null || string.IsNullOrWhiteSpace(resolution))
            return;

        try
        {
            var result = await AnomalieService.MarkAsTraiteeAsync(
                Anomalie.Id,
                resolution, 
                actionsCorrectives);

            if (result.Success)
            {
                DialogService.Close(true);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, result.Message);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, ex.Message);
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }

    private string GetTypeLabel(string type) => type switch
    {
        "BarriereNonAutorisee" => L["Ano_BarriereNonAutorisee"].Value,
        "DocumentExpire" => L["Ano_DocumentExpire"].Value,
        "DocumentInexistant" => L["Ano_DocumentInexistant"].Value,
        "ScanDuplique" => L["Ano_ScanDuplique"].Value,
        "QRCodeInvalide" => L["Ano_QRCodeInvalide"].Value,
        "ItineraireNonRespectee" => L["Ano_ItineraireNonRespectee"].Value,
        "SignalementManuel" => L["Ano_SignalementManuel"].Value,
        _ => type
    };
}
