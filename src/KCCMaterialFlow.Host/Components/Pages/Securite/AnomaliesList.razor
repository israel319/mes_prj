@page "/securite/anomalies"
@attribute [Authorize(Roles = "Admin,Security,OPJ,Identification,Superviseur")]
@inject IAnomalieService AnomalieService
@inject IBarriereService BarriereService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Anomalies - KCC Material Flow</PageTitle>

<div style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">

    @* === EN-TÊTE === *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="1rem" class="rz-mb-6">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-grey); margin: 0;">
                <RadzenIcon Icon="report_problem" Style="vertical-align: middle; margin-right: 0.5rem; color: #ed8936;" />
                @L["Anl_Title"]
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500); margin: 0;">
                @L["Anl_Subtitle"]
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="@L["Anl_Btn_Dashboard"].Value" Icon="dashboard" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Info"
                          Click="@(() => NavigationManager.NavigateTo("/securite/anomalies/dashboard"))" />
            <RadzenButton Text="@L["Anl_Btn_Export"].Value" Icon="download" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Light" Click="@ExportAsync" />
            <RadzenButton Icon="refresh" Text="@L["Btn_Refresh"].Value" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Dark" Click="@LoadDataAsync" />
        </RadzenStack>
    </RadzenStack>


    @* Filtre actif *@
    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            Filtre actif : <strong>@(activeFilter == "critique" ? L["Anl_GravCritique"].Value : L["Anl_GravElevee"].Value)</strong>
        </RadzenAlert>
    }

    @* === RECHERCHE === *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" class="rz-mb-4">
        <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
        <RadzenTextBox @bind-Value="filter.SearchTerm" Placeholder="@L["Anl_SearchPlaceholder"].Value"
                       Style="flex: 1; min-width: 220px;" />
        <RadzenDropDown @bind-Value="filter.TypeAnomalie" Data="@typeOptions"
                        Placeholder="@L["Anl_PlaceholderType"].Value" AllowClear="true" Style="min-width: 180px;" />
        <RadzenDropDown @bind-Value="selectedStatut" Data="@statutOptions" TextProperty="Label" ValueProperty="Value"
                        Placeholder="@L["Anl_PlaceholderStatut"].Value" AllowClear="true" Style="min-width: 140px;" Change="@OnStatutChanged" />
        <RadzenDatePicker @bind-Value="filter.DateDebut" DateFormat="dd/MM/yyyy" Placeholder="@L["Filter_DateFrom"].Value" Style="width: 140px;" />
        <RadzenDatePicker @bind-Value="filter.DateFin" DateFormat="dd/MM/yyyy" Placeholder="@L["Filter_DateTo"].Value" Style="width: 140px;" />
        <RadzenButton Text="@L["Btn_Filter"].Value" Icon="search" ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Small" Click="@LoadDataAsync" />
        <RadzenButton Icon="restart_alt" Variant="Variant.Outlined" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ResetFilter" />
    </RadzenStack>

    @* === GRID === *@
    <RadzenDataGrid @ref="grid" Data="@items" TItem="Anomalie" IsLoading="@isLoading"
                    AllowPaging="true" PageSize="10" PagerHorizontalAlign="HorizontalAlign.Center"
                    AllowSorting="true" AllowFiltering="false" Count="@totalCount"
                    Density="Density.Compact"
                    GridLines="DataGridGridLines.Horizontal"
                    ExpandMode="DataGridExpandMode.Single"
                    LoadData="@LoadDataGrid" RowRender="@OnRowRender">
        <Template Context="anomalie">
            <div style="padding: 0.75rem 1rem; background: var(--rz-base-200); border-radius: 8px; margin: 0.25rem 0;">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap" Style="margin-bottom: 0.5rem;">
                    <span><strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Anl_Lbl_Date"] :</strong> @anomalie.DateSignalement.ToString("dd/MM/yyyy HH:mm")</span>
                    <span><strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Anl_Lbl_Barrier"] :</strong> @(anomalie.Barriere?.NomBarriere ?? "N/A")</span>
                    <span><strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Anl_Lbl_Document"] :</strong> @(string.IsNullOrEmpty(anomalie.NumeroReferenceBon) ? "—" : anomalie.NumeroReferenceBon)</span>
                </RadzenStack>
                <div style="margin-bottom: 0.5rem;">
                    <strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Anl_Lbl_Description"] :</strong>
                    <span>@anomalie.Description</span>
                </div>
                <div style="text-align: right; margin-top: 0.5rem;">
                    <RadzenButton Text="@L["Anl_Btn_ViewDetail"].Value" Icon="visibility" Variant="Variant.Outlined"
                                  ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Small"
                                  Click="@(() => VoirDetail(anomalie))" />
                </div>
            </div>
        </Template>
        <Columns>
            <RadzenDataGridColumn TItem="Anomalie" Title="@L["Anl_Col_Severity"]" Width="110px" Property="NiveauGravite" Sortable="true">
                <Template Context="anomalie">
                    <RadzenBadge Text="@GetGraviteLabel(anomalie.NiveauGravite)" BadgeStyle="@GetGraviteStyle(anomalie.NiveauGravite)" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Anomalie" Property="DateSignalement" Title="@L["Anl_Col_Date"]" Width="160px" Sortable="true">
                <Template Context="anomalie">
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0;">@anomalie.DateSignalement.ToString("dd/MM/yyyy")</RadzenText>
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500); margin: 0;">@anomalie.DateSignalement.ToString("HH:mm")</RadzenText>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Anomalie" Title="@L["Anl_Col_Type"]" Width="200px" Property="TypeAnomalie" Sortable="true">
                <Template Context="anomalie">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                        <RadzenIcon Icon="@GetTypeIcon(anomalie.TypeAnomalie)" Style="font-size: 1rem; color: var(--gray-500);" />
                        <span>@GetTypeLabel(anomalie.TypeAnomalie)</span>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Anomalie" Property="NumeroReferenceBon" Title="@L["Anl_Col_Document"]" Width="150px" Sortable="true">
                <Template Context="anomalie">
                    @if (!string.IsNullOrEmpty(anomalie.NumeroReferenceBon))
                    {
                        <span style="font-weight: 600;">@anomalie.NumeroReferenceBon</span>
                    }
                    else
                    {
                        <span style="color: var(--gray-400);">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Anomalie" Property="Description" Title="@L["Anl_Col_Description"]" Sortable="false">
                <Template Context="anomalie">
                    <RadzenText TextStyle="TextStyle.Body2" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 300px; display: block;" title="@anomalie.Description">
                        @anomalie.Description
                    </RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Anomalie" Title="@L["Anl_Col_Statut"]" Width="120px" Property="EstTraitee" Sortable="true">
                <Template Context="anomalie">
                    @if (anomalie.EstTraitee)
                    {
                        <RadzenBadge Text="@L["Anl_Statut_Traitee"].Value" BadgeStyle="BadgeStyle.Success" />
                    }
                    else
                    {
                        <RadzenBadge Text="@L["Anl_Statut_EnAttente"].Value" BadgeStyle="BadgeStyle.Warning" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Anomalie" Title="@L["Col_Actions"]" Width="200px" TextAlign="TextAlign.Right" Sortable="false">
                <Template Context="anomalie">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                        <RadzenButton Icon="visibility" Text="@L["Btn_Detail"].Value" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Dark" Click="@(() => VoirDetail(anomalie))" />
                        @if (!anomalie.EstTraitee)
                        {
                            <RadzenButton Icon="check_circle" Text="@L["Anl_Btn_Process"].Value" Size="ButtonSize.Small"
                                          ButtonStyle="ButtonStyle.Success" Click="@(() => TraiterAnomalie(anomalie))" />
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</div>

@code {
    private RadzenDataGrid<Anomalie>? grid;
    private IEnumerable<Anomalie> items = Enumerable.Empty<Anomalie>();
    private int totalCount = 0;
    private bool isLoading = false;
    private AnomalieFilter filter = new();
    private QuickStats stats = new();
    private string? selectedStatut;
    private string? activeFilter;

    private readonly List<string> typeOptions = new()
    {
        TypeAnomalieValues.BarriereNonAutorisee,
        TypeAnomalieValues.DocumentExpire,
        TypeAnomalieValues.DocumentInexistant,
        TypeAnomalieValues.ScanDuplique,
        TypeAnomalieValues.QRCodeInvalide,
        TypeAnomalieValues.ItineraireNonRespectee,
        TypeAnomalieValues.SignalementManuel
    };

    private List<StatutOption> statutOptions => new()
    {
        new StatutOption { Label = L["Anl_Statut_EnAttente"].Value, Value = "false" },
        new StatutOption { Label = L["Anl_Statut_Traitee"].Value, Value = "true" }
    };

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUserService.HasAnyActivite("SEC_SIGNALER_ANOMALIE", "SEC_TRAITER_ANOMALIE", "SEC_REOUVRIR_ANOMALIE"))
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }

        filter.DateDebut = DateTime.Today.AddDays(-30);
        filter.DateFin = DateTime.Today.AddDays(1).AddSeconds(-1);
        filter.EstTraitee = false;
        selectedStatut = "false";

        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            var dashboard = await AnomalieService.GetDashboardAsync();
            stats = new QuickStats
            {
                NonTraitees = dashboard.TotalNonTraitees,
                Critiques = dashboard.CritiquesNonTraitees,
                Elevees = dashboard.EleveesNonTraitees,
                TauxResolution = dashboard.TauxResolution
            };
        }
        catch { }
    }

    private async Task LoadDataGrid(Radzen.LoadDataArgs args)
    {
        isLoading = true;
        try
        {
            filter.Skip = args.Skip ?? 0;
            filter.Take = args.Top ?? 10;

            var result = await AnomalieService.SearchAsync(filter);
            items = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, L["Msg_LoadFailed"].Value + " : " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        if (grid != null) await grid.FirstPage(true);
        await LoadStatsAsync();
    }

    private async Task ResetFilter()
    {
        filter = new AnomalieFilter
        {
            DateDebut = DateTime.Today.AddDays(-30),
            DateFin = DateTime.Today.AddDays(1).AddSeconds(-1),
            EstTraitee = false
        };
        selectedStatut = "false";
        activeFilter = null;
        await LoadDataAsync();
    }

    private void OnStatutChanged(object value)
    {
        if (value is string s)
            filter.EstTraitee = s == "true" ? true : s == "false" ? false : null;
        else
            filter.EstTraitee = null;
    }

    private void SetFilter(string? f)
    {
        activeFilter = f;
        filter.NiveauGravite = f switch
        {
            "critique" => NiveauGraviteValues.Critique,
            "eleve" => NiveauGraviteValues.Eleve,
            _ => null
        };
        _ = LoadDataAsync();
    }

    private void OnRowRender(RowRenderEventArgs<Anomalie> args)
    {
        if (args.Data != null && !args.Data.EstTraitee && args.Data.NiveauGravite == NiveauGraviteValues.Critique)
        {
            args.Attributes.Add("style", "background-color: #fff5f5;");
        }
    }

    private void VoirDetail(Anomalie anomalie)
    {
        NavigationManager.NavigateTo($"/securite/anomalies/{anomalie.Id}");
    }

    private async Task TraiterAnomalie(Anomalie anomalie)
    {
        var result = await DialogService.OpenAsync<TraiterAnomalieDialog>("Traiter l'Anomalie",
            new Dictionary<string, object> { { "Anomalie", anomalie } },
            new DialogOptions { Width = "500px" });

        if (result is bool success && success)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Msg_Success"].Value, L["Anl_Btn_Process"].Value + " : OK");
            await LoadDataAsync();
        }
    }

    private async Task ExportAsync()
    {
        NotificationService.Notify(NotificationSeverity.Info, L["Anl_NotifExport"].Value, L["Anl_NotifExportDev"].Value);
        await Task.CompletedTask;
    }

    private string GetGraviteLabel(string gravite) => gravite switch
    {
        "Critique" => L["Grav_Critique"].Value,
        "Eleve" => L["Grav_Eleve"].Value,
        "Moyen" => L["Grav_Moyen"].Value,
        "Faible" => L["Grav_Faible"].Value,
        _ => gravite
    };

    private BadgeStyle GetGraviteStyle(string gravite) => gravite switch
    {
        "Critique" => BadgeStyle.Danger,
        "Eleve" => BadgeStyle.Warning,
        "Moyen" => BadgeStyle.Info,
        "Faible" => BadgeStyle.Light,
        _ => BadgeStyle.Secondary
    };

    private string GetTypeIcon(string type) => type switch
    {
        "BarriereNonAutorisee" => "block",
        "DocumentExpire" => "schedule",
        "DocumentInexistant" => "help_outline",
        "ScanDuplique" => "content_copy",
        "QRCodeInvalide" => "qr_code",
        "ItineraireNonRespectee" => "alt_route",
        "SignalementManuel" => "edit_note",
        _ => "warning"
    };

    private string GetTypeLabel(string type) => type switch
    {
        "BarriereNonAutorisee" => L["Ano_BarriereNonAutorisee"].Value,
        "DocumentExpire" => L["Ano_DocumentExpire"].Value,
        "DocumentInexistant" => L["Ano_DocumentInexistant"].Value,
        "ScanDuplique" => L["Ano_ScanDuplique"].Value,
        "QRCodeInvalide" => L["Ano_QRCodeInvalide"].Value,
        "ItineraireNonRespectee" => L["Ano_ItineraireNonRespectee"].Value,
        "SignalementManuel" => L["Ano_SignalementManuel"].Value,
        _ => type
    };

    private class QuickStats
    {
        public int NonTraitees { get; set; }
        public int Critiques { get; set; }
        public int Elevees { get; set; }
        public double TauxResolution { get; set; }
    }

    private class StatutOption
    {
        public string Label { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
