@page "/liste-rejets"
@attribute [Authorize]
@using KCCMaterialFlow.Host.Components.Dialogs
@inject INotificationRejetService NotificationRejetService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Rejets_Title"] — KCC Material Flow</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Rejets_Title"]</h1>
                <p class="kcp-subtitle">@L["Rejets_Subtitle"]</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn" type="button" @onclick="MarkAllAsRead" disabled="@(!rejets.Any(r => !r.EstLue))">
                    <RadzenIcon Icon="done_all" Style="font-size:1rem;" />
                    @L["Rejets_MarkAllRead"]
                </button>
                <button class="kcp-btn" type="button" @onclick="LoadRejetsAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">


    @* Filtre actif *@
    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            @L["Lbl_ActiveFilter"] <strong>@(activeFilter == "non-lus" ? L["Rejets_Unread"] : L["Rejets_Read"])</strong>
        </RadzenAlert>
    }

    @* === CONTENU === *@
    @if (isLoading)
    {
        <RadzenCard>
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="padding: 4rem;">
                <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500);">@L["Rejets_Loading"]</RadzenText>
            </RadzenStack>
        </RadzenCard>
    }
    else if (!filteredRejets.Any())
    {
        <RadzenCard>
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem" Style="padding: 4rem;">
                <RadzenIcon Icon="check_circle" Style="font-size: 4rem; color: var(--kcc-green); opacity: 0.4;" />
                    <RadzenText TextStyle="TextStyle.H6" Style="color: var(--kcc-green); font-weight: 600;">@L["Rejets_None"]</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500);">@L["Rejets_NoneDesc"]</RadzenText>
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        @* === BARRE DE RECHERCHE === *@
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" class="rz-mb-4">
            <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
            <RadzenTextBox @bind-Value="searchTerm" Placeholder="@L["Rejets_SearchPlaceholder"]"
                           Style="flex: 1;" Change="@(_ => StateHasChanged())" />
            @if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              Click="@(() => { searchTerm = null; StateHasChanged(); })" />
            }
        </RadzenStack>

        <RadzenDataGrid Data="@filteredRejets" TItem="NotificationRejet"
                        AllowPaging="true" PageSize="10" PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowSorting="true" AllowFiltering="false"
                        Density="Density.Compact"
                        GridLines="DataGridGridLines.Horizontal"
                        ExpandMode="DataGridExpandMode.Single">
            <Template Context="rejet">
                <div style="padding: 0.75rem 1rem; background: var(--rz-base-200); border-radius: 8px; margin: 0.25rem 0;">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" Wrap="FlexWrap.Wrap" Style="margin-bottom: 0.5rem;">
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Lbl_Requester"] :</strong> @(rejet.DemandeurNom ?? "N/A")</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Rejets_Step"] :</strong> @(rejet.EtapeRejet ?? "N/A")</span>
                        <span><strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Lbl_Date"] :</strong> @rejet.DateRejet.ToString("dd/MM/yyyy HH:mm")</span>
                    </RadzenStack>
                    <div style="margin-bottom: 0.5rem;">
                        <strong style="color: var(--gray-500); font-size: 0.8rem;">@L["Rejets_FullReason"]</strong>
                        <span>@rejet.MotifRejet</span>
                    </div>
                    <div style="text-align: right; margin-top: 0.5rem;">
                        <RadzenButton Text="@L["Rejets_Detail"]" Icon="visibility" Variant="Variant.Outlined"
                                      ButtonStyle="ButtonStyle.Dark" Size="ButtonSize.Small"
                                      Click="@(() => ShowRejetDetail(rejet))" />
                    </div>
                </div>
            </Template>
            <Columns>
                <RadzenDataGridColumn TItem="NotificationRejet" Title="@L["Col_Type"]" Width="100px" Property="BonType" Sortable="true">
                    <Template Context="rejet">
                        <RadzenBadge Text="@rejet.BonType"
                                     BadgeStyle="@(rejet.BonType == "BEM" ? BadgeStyle.Info : BadgeStyle.Secondary)" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="NotificationRejet" Property="NumeroReference" Title="@L["Col_Reference"]" Width="200px" Sortable="true">
                    <Template Context="rejet">
                        <RadzenStack Gap="0.25rem">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600; margin: 0;">@rejet.NumeroReference</RadzenText>
                                  @if (!rejet.EstLue)
                                {
                                    <RadzenBadge Text="@L["Rejets_New"]" BadgeStyle="BadgeStyle.Danger" />
                                }
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500); margin: 0;">
                                @rejet.DateRejet.ToString("dd/MM/yyyy")
                            </RadzenText>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="NotificationRejet" Property="ApprobateurNom" Title="@L["Rejets_RejectedBy"]" Width="180px" Sortable="true" />
                <RadzenDataGridColumn TItem="NotificationRejet" Property="EtapeRejet" Title="@L["Rejets_Step"]" Width="140px" Sortable="true" />
                <RadzenDataGridColumn TItem="NotificationRejet" Property="MotifRejet" Title="@L["Rejets_Reason"]" Sortable="false">
                    <Template Context="rejet">
                        <RadzenText TextStyle="TextStyle.Body2" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 320px; display: block;" title="@rejet.MotifRejet">
                            @rejet.MotifRejet
                        </RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="NotificationRejet" Title="@L["Col_Status"]" Width="120px" Sortable="false">
                    <Template Context="rejet">
                        @if (rejet.EstLue)
                        {
                            <RadzenBadge Text="@L["Rejets_Read"]" BadgeStyle="BadgeStyle.Light" />
                        }
                        else
                        {
                            <RadzenBadge Text="@L["Rejets_Unread"]" BadgeStyle="BadgeStyle.Warning" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="NotificationRejet" Title="@L["Col_Actions"]" Width="140px" TextAlign="TextAlign.Right" Sortable="false">
                    <Template Context="rejet">
                        <RadzenButton Icon="visibility" Text="@L["Rejets_Detail"]" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Dark"
                                      Click="@(() => ShowRejetDetail(rejet))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
    </main>
</div>

@code {
    private List<NotificationRejet> rejets = new();
    private bool isLoading = true;
    private string? activeFilter;
    private string? searchTerm;

    private IEnumerable<NotificationRejet> filteredRejets
    {
        get
        {
            IEnumerable<NotificationRejet> q = rejets;
            if (activeFilter == "non-lus") q = q.Where(r => !r.EstLue);
            else if (activeFilter == "lus") q = q.Where(r => r.EstLue);

            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var s = searchTerm.Trim();
                q = q.Where(r =>
                    (r.NumeroReference ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (r.ApprobateurNom ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (r.MotifRejet ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (r.DemandeurNom ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q;
        }
    }

    private void SetFilter(string? f)
    {
        activeFilter = f;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRejetsAsync();
    }

    private async Task LoadRejetsAsync()
    {
        isLoading = true;
        try
        {
            var allRejets = await NotificationRejetService.GetNotificationsAsync();

            // Filtrer par rôle utilisateur
            var roles = CurrentUserService.GetUserRoles().ToList();
            var currentLogin = CurrentUserService.GetUserLogin();
            var currentName = CurrentUserService.GetUserDisplayName();
            var isAdmin = roles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));

            if (isAdmin)
            {
                rejets = allRejets.OrderByDescending(r => r.DateRejet).ToList();
            }
            else
            {
                rejets = allRejets
                    .Where(r =>
                        (r.DemandeurNom?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true) ||
                        (r.DemandeurNom?.Equals(currentName, StringComparison.OrdinalIgnoreCase) == true) ||
                        (r.ApprobateurLogin?.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) == true) ||
                        (r.ApprobateurNom?.Equals(currentName, StringComparison.OrdinalIgnoreCase) == true))
                    .OrderByDescending(r => r.DateRejet)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Impossible de charger les rejets: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowRejetDetail(NotificationRejet rejet)
    {
        await DialogService.OpenAsync<RejetDetailDialog>(
            "Détails du rejet",
            new Dictionary<string, object>
            {
                { "Notification", rejet },
                { "OnMarkedAsRead", EventCallback.Factory.Create(this, async () =>
                    {
                        await NotificationRejetService.MarquerCommeLueAsync(rejet.Id);
                        rejet.EstLue = true;
                        rejet.DateLecture = DateTime.Now;
                        DialogService.Close();
                        StateHasChanged();
                    })
                },
                { "OnClose", EventCallback.Factory.Create(this, () => DialogService.Close()) }
            },
            new DialogOptions
            {
                Width = "860px",
                Height = "460px",
                CloseDialogOnOverlayClick = true,
                ShowClose = false,
                CssClass = "kcc-dialog-clean"
            });

        if (!rejet.EstLue)
        {
            await NotificationRejetService.MarquerCommeLueAsync(rejet.Id);
            rejet.EstLue = true;
            rejet.DateLecture = DateTime.Now;
            StateHasChanged();
        }
    }

    private async Task MarkAllAsRead()
    {
        var nonLus = rejets.Where(r => !r.EstLue).Select(r => r.Id).ToList();
        if (nonLus.Any())
        {
            await NotificationRejetService.MarquerCommeLuesAsync(nonLus);
            foreach (var rejet in rejets.Where(r => !r.EstLue))
            {
                rejet.EstLue = true;
                rejet.DateLecture = DateTime.Now;
            }
            NotificationService.Notify(NotificationSeverity.Success, "Succès", $"{nonLus.Count} notification(s) marquée(s) comme lue(s)");
            StateHasChanged();
        }
    }
}


