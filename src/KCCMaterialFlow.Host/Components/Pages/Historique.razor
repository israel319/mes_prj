@page "/historique"
@attribute [Authorize]
@using KCCMaterialFlow.Module.BonEntree.Services
@using KCCMaterialFlow.Module.BonSortie.Services
@using KCCMaterialFlow.Module.BonEntree.Repositories
@using BEMEntities = KCCMaterialFlow.Module.BonEntree.Entities
@using BSMEntities = KCCMaterialFlow.Module.BonSortie.Entities
@using ClosedXML.Excel
@using KCCMaterialFlow.Module.Shared.Services
@using KCCMaterialFlow.Module.Shared.Entities

@inject ICurrentUserService CurrentUserService
@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject IStatutService StatutService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime

<PageTitle>Historique - KCC Material Flow</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    @* === EN-TÊTE === *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
                <RadzenIcon Icon="history" Style="vertical-align: middle; margin-right: 0.5rem;" />
                Historique des Bons
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-light); margin-top: 0.25rem;">
                Traçabilité complète des actions sur les bons de matériel • @CurrentUserService.GetUserDisplayName()
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            @if (CanExport)
            {
                <RadzenButton Text="Exporter Excel" Icon="download" ButtonStyle="ButtonStyle.Success"
                              Click="@ExportHistoriqueExcel" />
            }
            <RadzenButton Icon="refresh" Text="Actualiser" Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Light" Click="@LoadDataAsync" />
        </RadzenStack>
    </RadzenStack>

    @* === FILTRES === *@
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Style="padding: 0.5rem 0;">
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-light);">Rechercher</RadzenText>
                <RadzenTextBox @bind-Value="@searchTerm" Placeholder="Référence, demandeur..."
                               Style="min-width: 250px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-light);">Statut</RadzenText>
                <RadzenDropDown @bind-Value="@selectedStatut" Data="@statutOptions"
                                TextProperty="Text" ValueProperty="Value"
                                Placeholder="Tous" AllowClear="true"
                                Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-light);">Date début</RadzenText>
                <RadzenDatePicker @bind-Value="@dateDebut" DateFormat="dd/MM/yyyy" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-light);">Date fin</RadzenText>
                <RadzenDatePicker @bind-Value="@dateFin" DateFormat="dd/MM/yyyy" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenButton Icon="search" Text="Filtrer" Click="@ApplyFilter" ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton Icon="clear" Text="Effacer" Click="@ResetFilter" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" />
        </RadzenStack>
    </RadzenCard>

    @* === TABS BEM / BSM === *@
    <RadzenCard>
        <RadzenTabs @bind-SelectedIndex="@selectedTabIndex">
            <Tabs>
                @* === TAB BEM === *@
                <RadzenTabsItem Text="@($"Entrées ({filteredBEMSummary.Count})")">
                    <RadzenDataGrid Data="@filteredBEMSummary" TItem="BonSummary"
                                    AllowPaging="true" PageSize="15" PagerHorizontalAlign="HorizontalAlign.Center"
                                    AllowSorting="true" AllowColumnResize="true"
                                    Style="margin-top: 0.5rem;"
                                    EmptyText="Aucun bon d'entrée trouvé"
                                    Density="Density.Compact">
                        <Template Context="bon">
                            @* === DETAIL : Historique simplifié === *@
                            <div style="padding: 0.5rem 1rem; background: var(--rz-base-100, #f8f9fa);">
                                <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                    <thead>
                                        <tr style="border-bottom: 1px solid #dee2e6; color: #6c757d; font-size: 0.78rem;">
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 130px;">Date</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 110px;">Action</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Par</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Commentaire</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 150px;">Résultat</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (bon.Details.Any())
                                        {
                                            @foreach (var detail in bon.Details)
                                            {
                                                <tr style="border-bottom: 1px solid #f0f0f0;">
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; white-space: nowrap;">@detail.DateAction.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(detail.Action)"></span>
                                                        <span style="font-weight: 500;">@GetActionLabel(detail.Action)</span>
                                                    </td>
                                                    <td style="padding: 0.3rem 0.5rem;">@detail.ActionPar</td>
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; font-style: italic;">@(string.IsNullOrEmpty(detail.Commentaire) ? "—" : detail.Commentaire)</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="font-size: 0.8rem; color: @GetActionResultColor(detail.Action); font-weight: 500;">@GetActionResultText(detail.Action)</span>
                                                        @if (!string.IsNullOrEmpty(detail.StatutApres))
                                                        {
                                                            <span style="font-size: 0.75rem; color: #6c757d; margin-left: 0.25rem;">→ @GetStatutLabel(detail.StatutApres)</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="5" style="padding: 0.5rem; color: #999; font-style: italic;">Aucun historique enregistré.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </Template>
                        <Columns>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NumeroReference" Title="Référence" Width="160px">
                                <Template Context="bon">
                                    <a href="@($"/bon-entree/{bon.BonId}")" style="font-weight: 600; text-decoration: none; color: var(--kcc-primary);">
                                        @bon.NumeroReference
                                    </a>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NomDemandeur" Title="Demandeur" Width="160px" />
                            <RadzenDataGridColumn TItem="BonSummary" Property="StatutActuel" Title="Statut" Width="160px">
                                <Template Context="bon">
                                    <span style="font-weight: 500; color: @GetStatutColor(bon.StatutActuel);">@GetStatutLabel(bon.StatutActuel)</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DerniereAction" Title="Dernière action" Width="200px">
                                <Template Context="bon">
                                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(bon.DerniereAction)"></span>
                                    <span style="font-weight: 500;">@GetActionLabel(bon.DerniereAction)</span>
                                    <span style="margin-left: 0.25rem; font-size: 0.83rem; color: #6c757d;">par @bon.DernierActionPar</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DateDerniereAction" Title="Date" Width="145px"
                                                  SortOrder="SortOrder.Descending">
                                <Template Context="bon">
                                    @bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm")
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NbActions" Title="Actions" Width="80px" TextAlign="TextAlign.Center">
                                <Template Context="bon">
                                    <RadzenBadge Text="@bon.NbActions.ToString()" BadgeStyle="BadgeStyle.Light" IsPill="true" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* === TAB BSM === *@
                <RadzenTabsItem Text="@($"Sorties ({filteredBSMSummary.Count})")">
                    <RadzenDataGrid Data="@filteredBSMSummary" TItem="BonSummary"
                                    AllowPaging="true" PageSize="15" PagerHorizontalAlign="HorizontalAlign.Center"
                                    AllowSorting="true" AllowColumnResize="true"
                                    Style="margin-top: 0.5rem;"
                                    EmptyText="Aucun bon de sortie trouvé"
                                    Density="Density.Compact">
                        <Template Context="bon">
                            @* === DETAIL : Historique simplifié === *@
                            <div style="padding: 0.5rem 1rem; background: var(--rz-base-100, #f8f9fa);">
                                <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                    <thead>
                                        <tr style="border-bottom: 1px solid #dee2e6; color: #6c757d; font-size: 0.78rem;">
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 130px;">Date</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 110px;">Action</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Par</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600;">Commentaire</th>
                                            <th style="padding: 0.35rem 0.5rem; font-weight: 600; width: 150px;">Résultat</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (bon.Details.Any())
                                        {
                                            @foreach (var detail in bon.Details)
                                            {
                                                <tr style="border-bottom: 1px solid #f0f0f0;">
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; white-space: nowrap;">@detail.DateAction.ToString("dd/MM/yyyy HH:mm")</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(detail.Action)"></span>
                                                        <span style="font-weight: 500;">@GetActionLabel(detail.Action)</span>
                                                    </td>
                                                    <td style="padding: 0.3rem 0.5rem;">@detail.ActionPar</td>
                                                    <td style="padding: 0.3rem 0.5rem; color: #6c757d; font-style: italic;">@(string.IsNullOrEmpty(detail.Commentaire) ? "—" : detail.Commentaire)</td>
                                                    <td style="padding: 0.3rem 0.5rem;">
                                                        <span style="font-size: 0.8rem; color: @GetActionResultColor(detail.Action); font-weight: 500;">@GetActionResultText(detail.Action)</span>
                                                        @if (!string.IsNullOrEmpty(detail.StatutApres))
                                                        {
                                                            <span style="font-size: 0.75rem; color: #6c757d; margin-left: 0.25rem;">→ @GetStatutLabel(detail.StatutApres)</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="5" style="padding: 0.5rem; color: #999; font-style: italic;">Aucun historique enregistré.</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </Template>
                        <Columns>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NumeroReference" Title="Référence" Width="160px">
                                <Template Context="bon">
                                    <a href="@($"/bon-sortie/{bon.BonId}")" style="font-weight: 600; text-decoration: none; color: var(--kcc-primary);">
                                        @bon.NumeroReference
                                    </a>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="TypeBon" Title="Type" Width="100px">
                                <Template Context="bon">
                                    <RadzenBadge Text="@bon.TypeBon" BadgeStyle="BadgeStyle.Secondary" IsPill="true" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NomDemandeur" Title="Demandeur" Width="150px" />
                            <RadzenDataGridColumn TItem="BonSummary" Property="StatutActuel" Title="Statut" Width="160px">
                                <Template Context="bon">
                                    <span style="font-weight: 500; color: @GetStatutColor(bon.StatutActuel);">@GetStatutLabel(bon.StatutActuel)</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DerniereAction" Title="Dernière action" Width="200px">
                                <Template Context="bon">
                                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; @GetTimelineDotStyle(bon.DerniereAction)"></span>
                                    <span style="font-weight: 500;">@GetActionLabel(bon.DerniereAction)</span>
                                    <span style="margin-left: 0.25rem; font-size: 0.83rem; color: #6c757d;">par @bon.DernierActionPar</span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="DateDerniereAction" Title="Date" Width="145px"
                                                  SortOrder="SortOrder.Descending">
                                <Template Context="bon">
                                    @bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm")
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="BonSummary" Property="NbActions" Title="Actions" Width="80px" TextAlign="TextAlign.Center">
                                <Template Context="bon">
                                    <RadzenBadge Text="@bon.NbActions.ToString()" BadgeStyle="BadgeStyle.Light" IsPill="true" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    </RadzenCard>
</RadzenStack>

@code {
    private int selectedTabIndex;
    #pragma warning disable CS0414
    private bool isLoading = true;
    #pragma warning restore CS0414
    private string searchTerm = "";
    private string selectedStatut = "";
    private DateTime? dateDebut;
    private DateTime? dateFin;
    private bool isAdmin;
    private List<string> userRoles = new();

    private bool CanExport => userRoles.Any(r => r.Equals("Identification", StringComparison.OrdinalIgnoreCase));

    private List<BonSummary> bemSummaryItems = new();
    private List<BonSummary> bsmSummaryItems = new();

    private List<BonSummary> filteredBEMSummary => ApplyFilters(bemSummaryItems);
    private List<BonSummary> filteredBSMSummary => ApplyFilters(bsmSummaryItems);

    private List<StatutOption> statutOptions = new();
    private List<Statut> allDbStatuts = new();

    /// <summary>
    /// Mapping CodeStatut BD → préfixes StatutActuel dans les bons
    /// </summary>
    private static readonly Dictionary<string, string[]> CodeStatutToActuelMap = new(StringComparer.OrdinalIgnoreCase)
    {
        ["BROUILLON"] = new[] { "Draft" },
        ["EN_ATTENTE_APPROBATION"] = new[] { "Pending" },
        ["APPROUVE"] = new[] { "Approved" },
        ["REJETE"] = new[] { "Rejected" },
        ["EN_COURS"] = new[] { "InTransit" },
        ["TERMINE"] = new[] { "Completed" },
        ["EXPIRE"] = new[] { "Expired" },
        ["ANNULE"] = new[] { "Cancelled" },
        ["RETOURNE"] = new[] { "Returned" },
        ["ARCHIVE"] = new[] { "Archived" },
        ["INVESTIGATION"] = new[] { "Investigation" }
    };

    protected override async Task OnInitializedAsync()
    {
        userRoles = CurrentUserService.GetUserRoles().ToList();
        isAdmin = userRoles.Any(r => r.Equals("Admin", StringComparison.OrdinalIgnoreCase));

        // Charger les statuts depuis la table Statuts en BD
        allDbStatuts = (await StatutService.GetAllAsync()).ToList();
        statutOptions = allDbStatuts
            .Select(s => new StatutOption { Text = s.LibelleStatut, Value = s.CodeStatut })
            .ToList();

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            var currentLogin = CurrentUserService.GetUserLogin();
            var currentName = CurrentUserService.GetUserDisplayName();

            var approverRoles = new[] { "Superviseur", "GM", "OPJ", "IT", "Environnement", "Investigation", "Barriere" };
            var isApprover = userRoles.Any(r => approverRoles.Contains(r, StringComparer.OrdinalIgnoreCase));

            var bemResult = await BonEntreeService.GetListAsync(new BonEntreeFilter { Take = 5000 });
            var bsmResult = await BonSortieService.GetListAsync(new BonSortieFilter { Take = 5000 });

            IEnumerable<BEMEntities.BonEntree> visibleBEM;
            IEnumerable<BSMEntities.BonSortie> visibleBSM;

            // Vérifier si l'utilisateur est Identification (cas spécial : ne voit QUE ce qu'il a approuvé)
            var isIdentification = userRoles.Any(r => r.Equals("Identification", StringComparison.OrdinalIgnoreCase));

            if (isAdmin)
            {
                // Admin voit tout
                visibleBEM = bemResult.Items;
                visibleBSM = bsmResult.Items;
            }
            else if (isIdentification)
            {
                // Identification voit UNIQUEMENT les bons qu'il a approuvés (présent dans historiques)
                visibleBEM = bemResult.Items
                    .Where(b => b.Historiques.Any(h => h.ActionBy.Equals(currentLogin, StringComparison.OrdinalIgnoreCase)))
                    .ToList();

                visibleBSM = bsmResult.Items
                    .Where(b => b.Historiques.Any(h => h.UtilisateurLogin.Equals(currentLogin, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
            }
            else if (isApprover)
            {
                // Approbateur voit : ses propres bons + bons en attente à son niveau
                var myBEMIds = new HashSet<int>();
                var myBEM = bemResult.Items
                    .Where(b => b.NomDemandeur.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) ||
                                b.NomDemandeur.Equals(currentName, StringComparison.OrdinalIgnoreCase))
                    .ToList();
                foreach (var b in myBEM) myBEMIds.Add(b.IdBon);

                // Ajouter les bons en attente au niveau de l'utilisateur
                var pendingBEM = await BonEntreeService.GetPendingApprovalsAsync();
                foreach (var bon in pendingBEM)
                {
                    if (!myBEMIds.Contains(bon.IdBon))
                    {
                        myBEM.Add(bon);
                        myBEMIds.Add(bon.IdBon);
                    }
                }

                // Ajouter aussi les bons déjà traités par ce rôle (historique visible)
                var allBEM = bemResult.Items
                    .Where(b => !myBEMIds.Contains(b.IdBon) &&
                                b.Historiques.Any(h => h.ActionBy.Equals(currentLogin, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
                foreach (var b in allBEM) myBEM.Add(b);

                visibleBEM = myBEM;

                var myBSMIds = new HashSet<int>();
                var myBSM = bsmResult.Items
                    .Where(b => b.NomDemandeur.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) ||
                                b.NomDemandeur.Equals(currentName, StringComparison.OrdinalIgnoreCase) ||
                                b.CreatedByLogin.Equals(currentLogin, StringComparison.OrdinalIgnoreCase))
                    .ToList();
                foreach (var b in myBSM) myBSMIds.Add(b.IdBon);

                var pendingBSM = await BonSortieService.GetPendingApprovalsAsync();
                foreach (var bon in pendingBSM)
                {
                    if (!myBSMIds.Contains(bon.IdBon))
                    {
                        myBSM.Add(bon);
                        myBSMIds.Add(bon.IdBon);
                    }
                }

                // Ajouter les bons déjà traités par cet utilisateur
                var allBSM = bsmResult.Items
                    .Where(b => !myBSMIds.Contains(b.IdBon) &&
                                b.Historiques.Any(h => h.UtilisateurLogin.Equals(currentLogin, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
                foreach (var b in allBSM) myBSM.Add(b);

                visibleBSM = myBSM;
            }
            else
            {
                // Utilisateur normal : voit uniquement ses propres bons
                visibleBEM = bemResult.Items
                    .Where(b => b.NomDemandeur.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) ||
                                b.NomDemandeur.Equals(currentName, StringComparison.OrdinalIgnoreCase));

                visibleBSM = bsmResult.Items
                    .Where(b => b.NomDemandeur.Equals(currentLogin, StringComparison.OrdinalIgnoreCase) ||
                                b.NomDemandeur.Equals(currentName, StringComparison.OrdinalIgnoreCase) ||
                                b.CreatedByLogin.Equals(currentLogin, StringComparison.OrdinalIgnoreCase));
            }

            // === Construire les résumés BEM (1 ligne par bon) ===
            bemSummaryItems = visibleBEM.Select(bon =>
            {
                var details = bon.Historiques
                    .OrderByDescending(h => h.ActionDate)
                    .Select(h => new HistoriqueDetail
                    {
                        Action = h.ActionDescription,
                        ActionPar = h.ActionByNom ?? h.ActionBy,
                        DateAction = h.ActionDate,
                        Commentaire = h.Comment ?? "",
                        StatutAvant = h.StatutAvant,
                        StatutApres = h.StatutApres
                    })
                    .ToList();

                // Fallback : si aucun historique enregistré, créer une entrée synthétique
                if (!details.Any())
                {
                    details.Add(new HistoriqueDetail
                    {
                        Action = "Nouveau",
                        ActionPar = bon.NomDemandeur,
                        DateAction = bon.DateCreation,
                        Commentaire = $"Bon d'entrée {bon.NumeroReference}",
                        StatutAvant = null,
                        StatutApres = bon.StatutActuel
                    });
                }

                var derniere = details.First();
                return new BonSummary
                {
                    BonId = bon.IdBon,
                    NumeroReference = bon.NumeroReference,
                    TypeBon = "BEM",
                    NomDemandeur = bon.NomDemandeur,
                    StatutActuel = bon.StatutActuel,
                    DerniereAction = derniere.Action,
                    DernierActionPar = derniere.ActionPar,
                    DateDerniereAction = derniere.DateAction,
                    NbActions = details.Count,
                    Details = details
                };
            })
            .OrderByDescending(x => x.DateDerniereAction)
            .ToList();

            // === Construire les résumés BSM (1 ligne par bon) ===
            bsmSummaryItems = visibleBSM.Select(bon =>
            {
                var details = bon.Historiques
                    .OrderByDescending(h => h.DateAction)
                    .Select(h => new HistoriqueDetail
                    {
                        Action = h.TypeAction,
                        ActionPar = h.UtilisateurNom ?? h.UtilisateurLogin,
                        DateAction = h.DateAction,
                        Commentaire = h.Description ?? "",
                        StatutAvant = h.StatutAvant,
                        StatutApres = h.StatutApres
                    })
                    .ToList();

                // Fallback pour les bons sans historique
                if (!details.Any())
                {
                    details.Add(new HistoriqueDetail
                    {
                        Action = "Nouveau",
                        ActionPar = bon.NomDemandeur,
                        DateAction = bon.DateCreation,
                        Commentaire = $"Bon de sortie {bon.NumeroReference}",
                        StatutAvant = null,
                        StatutApres = bon.StatutActuel
                    });
                }

                var derniere = details.First();
                return new BonSummary
                {
                    BonId = bon.IdBon,
                    NumeroReference = bon.NumeroReference,
                    TypeBon = GetTypeBSM(bon),
                    NomDemandeur = bon.NomDemandeur,
                    StatutActuel = bon.StatutActuel,
                    DerniereAction = derniere.Action,
                    DernierActionPar = derniere.ActionPar,
                    DateDerniereAction = derniere.DateAction,
                    NbActions = details.Count,
                    Details = details
                };
            })
            .OrderByDescending(x => x.DateDerniereAction)
            .ToList();


        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }



    private List<BonSummary> ApplyFilters(List<BonSummary> items)
    {
        var result = items.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var search = searchTerm.ToLowerInvariant();
            result = result.Where(i =>
                i.NumeroReference.ToLowerInvariant().Contains(search) ||
                i.NomDemandeur.ToLowerInvariant().Contains(search) ||
                i.DerniereAction.ToLowerInvariant().Contains(search) ||
                i.DernierActionPar.ToLowerInvariant().Contains(search));
        }

        if (!string.IsNullOrWhiteSpace(selectedStatut))
        {
            // Mapper le CodeStatut BD vers les valeurs StatutActuel des bons
            if (CodeStatutToActuelMap.TryGetValue(selectedStatut, out var prefixes))
            {
                result = result.Where(i => i.StatutActuel != null &&
                    prefixes.Any(p => i.StatutActuel.StartsWith(p, StringComparison.OrdinalIgnoreCase)));
            }
            else
            {
                result = result.Where(i => i.StatutActuel != null &&
                    i.StatutActuel.Equals(selectedStatut, StringComparison.OrdinalIgnoreCase));
            }
        }

        if (dateDebut.HasValue)
            result = result.Where(i => i.DateDerniereAction >= dateDebut.Value.Date);

        if (dateFin.HasValue)
            result = result.Where(i => i.DateDerniereAction <= dateFin.Value.Date.AddDays(1));

        return result.OrderByDescending(i => i.DateDerniereAction).ToList();
    }

    private void ApplyFilter() { StateHasChanged(); }
    private void ResetFilter()
    {
        searchTerm = "";
        selectedStatut = "";
        dateDebut = null;
        dateFin = null;
    }

    private async Task ExportHistoriqueExcel()
    {
        try
        {
            using var workbook = new XLWorkbook();
            string fileName;

            if (selectedTabIndex == 0)
            {
                // === Export onglet Entrées (BEM) ===
                var data = filteredBEMSummary;
                var ws = workbook.Worksheets.Add("Historique Entrées");
                var headers = new[] { "Référence", "Demandeur", "Statut", "Dernière action", "Par", "Date", "Nb Actions" };
                WriteHeaders(ws, headers, "#1B6EC2");

                int row = 2;
                foreach (var bon in data)
                {
                    ws.Cell(row, 1).Value = bon.NumeroReference;
                    ws.Cell(row, 2).Value = bon.NomDemandeur;
                    ws.Cell(row, 3).Value = GetStatutLabel(bon.StatutActuel);
                    ws.Cell(row, 4).Value = GetActionLabel(bon.DerniereAction);
                    ws.Cell(row, 5).Value = bon.DernierActionPar;
                    ws.Cell(row, 6).Value = bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm");
                    ws.Cell(row, 7).Value = bon.NbActions;
                    if (row % 2 == 0)
                        ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#F0F4FF");
                    row++;
                }
                ws.Columns().AdjustToContents();
                ws.RangeUsed()?.SetAutoFilter();
                fileName = $"Historique_Entrees_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            }
            else
            {
                // === Export onglet Sorties (BSM) ===
                var data = filteredBSMSummary;
                var ws = workbook.Worksheets.Add("Historique Sorties");
                var headers = new[] { "Référence", "Type", "Demandeur", "Statut", "Dernière action", "Par", "Date", "Nb Actions" };
                WriteHeaders(ws, headers, "#16A34A");

                int row = 2;
                foreach (var bon in data)
                {
                    ws.Cell(row, 1).Value = bon.NumeroReference;
                    ws.Cell(row, 2).Value = bon.TypeBon;
                    ws.Cell(row, 3).Value = bon.NomDemandeur;
                    ws.Cell(row, 4).Value = GetStatutLabel(bon.StatutActuel);
                    ws.Cell(row, 5).Value = GetActionLabel(bon.DerniereAction);
                    ws.Cell(row, 6).Value = bon.DernierActionPar;
                    ws.Cell(row, 7).Value = bon.DateDerniereAction.ToString("dd/MM/yyyy HH:mm");
                    ws.Cell(row, 8).Value = bon.NbActions;
                    if (row % 2 == 0)
                        ws.Range(row, 1, row, headers.Length).Style.Fill.BackgroundColor = XLColor.FromHtml("#F0FFF4");
                    row++;
                }
                ws.Columns().AdjustToContents();
                ws.RangeUsed()?.SetAutoFilter();
                fileName = $"Historique_Sorties_{DateTime.Now:yyyyMMdd_HHmm}.xlsx";
            }

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            stream.Position = 0;

            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur export", ex.Message);
        }
    }

    private static void WriteHeaders(IXLWorksheet ws, string[] headers, string colorHex)
    {
        for (int i = 0; i < headers.Length; i++)
        {
            var cell = ws.Cell(1, i + 1);
            cell.Value = headers[i];
            cell.Style.Font.Bold = true;
            cell.Style.Fill.BackgroundColor = XLColor.FromHtml(colorHex);
            cell.Style.Font.FontColor = XLColor.White;
            cell.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;
        }
    }

    private static string GetTypeBSM(BSMEntities.BonSortie bon) => bon switch
    {
        BSMEntities.Pret => "Prêt",
        BSMEntities.BonSortieExterne => "Externe",
        BSMEntities.BonSortieInterne => "Interne",
        _ => "Sortie"
    };

    /// <summary>
    /// Label du statut : utilise les libellés de la table Statuts en BD.
    /// Admin voit le niveau exact pour les Pending, les autres voient le libellé générique.
    /// </summary>
    private string GetStatutLabel(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "-";
        var upper = s.ToUpperInvariant();

        // Chercher d'abord par correspondance dans le mapping BD
        foreach (var dbStatut in allDbStatuts)
        {
            if (CodeStatutToActuelMap.TryGetValue(dbStatut.CodeStatut, out var prefixes))
            {
                if (prefixes.Any(p => upper.StartsWith(p.ToUpperInvariant())))
                {
                    // Pour les Pending, l'admin voit le détail
                    if (isAdmin && upper.StartsWith("PENDING") && dbStatut.CodeStatut.Equals("EN_ATTENTE_APPROBATION", StringComparison.OrdinalIgnoreCase))
                    {
                        return upper switch
                        {
                            "PENDINGSUP" or "PENDINGSUPERVISEUR" => "Chez Superviseur",
                            "PENDINGGM" => "Chez GM",
                            "PENDINGOPJ" => "Chez OPJ",
                            "PENDINGIDENTIFICATION" => "Chez Identification",
                            "PENDINGIT" => "Chez IT",
                            "PENDINGENV" => "Chez Environnement",
                            _ => $"Chez {s.Replace("Pending", "")}"
                        };
                    }
                    return dbStatut.LibelleStatut;
                }
            }
        }

        return s;
    }

    private static BadgeStyle GetBadgeStyle(string? s)
    {
        if (string.IsNullOrEmpty(s)) return BadgeStyle.Light;
        var upper = s.ToUpperInvariant();
        return upper switch
        {
            "DRAFT" => BadgeStyle.Light,
            "APPROVED" => BadgeStyle.Success,
            "REJECTED" => BadgeStyle.Danger,
            "RETURNED" => BadgeStyle.Warning,
            "COMPLETED" => BadgeStyle.Success,
            "CANCELLED" => BadgeStyle.Danger,
            _ when upper.StartsWith("PENDING") => BadgeStyle.Warning,
            _ => BadgeStyle.Light
        };
    }

    /// <summary>
    /// Traduit les termes d'action DB en labels simples et lisibles
    /// </summary>
    private static string GetActionLabel(string action)
    {
        var lower = action.ToLowerInvariant();
        if (lower.Contains("créat") || lower.Contains("creat") || lower == "nouveau") return "Nouveau";
        if (lower.Contains("soumis") || lower.Contains("submit") || lower.Contains("envoyé")) return "Envoyé";
        if (lower.Contains("appro") || lower.Contains("validé")) return "Validé";
        if (lower.Contains("rejet") || lower.Contains("reject") || lower.Contains("refus")) return "Refusé";
        if (lower.Contains("retour") || lower.Contains("renvoyé")) return "Renvoyé";
        if (lower.Contains("modif")) return "Modifié";
        if (lower.Contains("annul")) return "Annulé";
        if (lower.Contains("qr")) return "QR Code";
        if (lower.Contains("scan")) return "Scanné";
        return action;
    }

    private static BadgeStyle GetActionBadgeStyle(string action)
    {
        var label = GetActionLabel(action);
        return label switch
        {
            "Validé" => BadgeStyle.Success,
            "Refusé" => BadgeStyle.Danger,
            "Envoyé" => BadgeStyle.Warning,
            "Nouveau" => BadgeStyle.Info,
            "Renvoyé" => BadgeStyle.Warning,
            "Modifié" => BadgeStyle.Secondary,
            "QR Code" or "Scanné" => BadgeStyle.Success,
            "Annulé" => BadgeStyle.Danger,
            _ => BadgeStyle.Light
        };
    }

    private static string GetTimelineDotStyle(string action)
    {
        var label = GetActionLabel(action);
        return label switch
        {
            "Validé" => "background: #28a745;",
            "Refusé" => "background: #dc3545;",
            "Envoyé" => "background: #fd7e14;",
            "Nouveau" => "background: #6c757d;",
            "Renvoyé" => "background: #fd7e14;",
            "QR Code" or "Scanné" => "background: #28a745;",
            "Annulé" => "background: #dc3545;",
            "Modifié" => "background: #6c757d;",
            _ => "background: #adb5bd;"
        };
    }

    /// <summary>
