@inject DialogService DialogService

<RadzenStack Gap="1rem" class="rz-p-4">
    <RadzenText TextStyle="TextStyle.Body1">
        @GetActionDescription()
    </RadzenText>

    <RadzenFormField Text="@GetLabelText()" Style="width: 100%;">
        <RadzenTextArea @bind-Value="@commentaire"
                        Rows="4"
                        Placeholder="@GetPlaceholder()"
                        Style="width: 100%;" />
    </RadzenFormField>

    @if (Action == "reject" && string.IsNullOrWhiteSpace(commentaire))
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Size="AlertSize.Small">
            Le motif du rejet est obligatoire.
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Annuler"
                      Icon="close"
                      ButtonStyle="ButtonStyle.Light"
                      Click="@Cancel" />
        <RadzenButton Text="@GetButtonText()"
                      Icon="@GetButtonIcon()"
                      ButtonStyle="@GetButtonStyle()"
                      Click="@Confirm"
                      Disabled="@(Action == "reject" && string.IsNullOrWhiteSpace(commentaire))" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter]
    public string Action { get; set; } = "approve";

    private string? commentaire;

    private string GetActionDescription() => Action switch
    {
        "approve" => "Vous êtes sur le point d'approuver ce bon d'entrée.",
        "return" => "Ce bon sera retourné au demandeur pour modification. Veuillez indiquer les corrections nécessaires.",
        "reject" => "Ce bon sera définitivement rejeté. Cette action est irréversible.",
        _ => ""
    };

    private string GetLabelText() => Action switch
    {
        "reject" => "Motif du rejet *",
        "return" => "Raison du retour",
        _ => "Commentaire (optionnel)"
    };

    private string GetPlaceholder() => Action switch
    {
        "reject" => "Expliquez le motif du rejet...",
        "return" => "Indiquez les corrections nécessaires...",
        _ => "Ajoutez un commentaire (optionnel)..."
    };

    private string GetButtonText() => Action switch
    {
        "approve" => "Approuver",
        "return" => "Retourner",
        "reject" => "Rejeter",
        _ => "Confirmer"
    };

    private string GetButtonIcon() => Action switch
    {
        "approve" => "check_circle",
        "return" => "replay",
        "reject" => "cancel",
        _ => "check"
    };

    private Radzen.ButtonStyle GetButtonStyle() => Action switch
    {
        "approve" => Radzen.ButtonStyle.Success,
        "return" => Radzen.ButtonStyle.Warning,
        "reject" => Radzen.ButtonStyle.Danger,
        _ => Radzen.ButtonStyle.Primary
    };

    private void Cancel()
    {
        DialogService.Close(null);
    }

    private void Confirm()
    {
        DialogService.Close(commentaire ?? string.Empty);
    }
}
