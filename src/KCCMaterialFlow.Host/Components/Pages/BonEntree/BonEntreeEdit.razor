@page "/bon-entree/{Id:int}/edit"
@page "/bon-entree/{Id:int}/modifier"
@attribute [Authorize]
@using KCCMaterialFlow.Application.Common.Interfaces
@using KCCMaterialFlow.Domain.Entities
@inject IBonEntreeService BonEntreeService
@inject IReferenceDataService ReferenceDataService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["BemF_PageTitleEdit"] - KCC Material Flow</PageTitle>

<div class="kcp-page">

    @if (isLoading)
    {
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Large" />
            <RadzenText TextStyle="TextStyle.Body1">@L["BemV_Loading"]</RadzenText>
        </div>
    }
    else if (bon == null)
    {
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <RadzenIcon Icon="error_outline" Style="font-size: 64px; color: var(--rz-danger);" />
            <RadzenText TextStyle="TextStyle.H6">@L["BemF_NotFound"]</RadzenText>
            <RadzenButton Text="@L["Btn_Back"].Value" Click="GoBack" />
        </div>
    }
    else if (bon.StatutActuel != "Draft")
    {
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <RadzenIcon Icon="lock" Style="font-size: 64px; color: var(--rz-warning);" />
            <RadzenText TextStyle="TextStyle.H6">@L["BemF_CannotEdit"]</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">@L["BemF_CannotEditMsg"]</RadzenText>
            <RadzenButton Text="@L["Btn_Back"].Value" Click="GoBack" />
        </div>
    }
    else
    {
        @* ── Hero ── *@
        <div class="kcp-hero">
            <div class="kcp-hero-inner">
                <div>
                    <RadzenBadge Text="@L["BemF_Draft"].Value" BadgeStyle="BadgeStyle.Warning" Shade="Shade.Lighter" Style="margin-bottom: 0.5rem; font-size: 0.7rem;" />
                    <h1 class="kcp-title">@L["BemF_PageTitleEdit"] @bon.NumeroReference</h1>
                    <p class="kcp-subtitle">@L["BemF_FormTitle"] &bull; @L["BemF_CreatedOn"] @bon.DateCreation.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="kcp-hero-actions">
                    <button type="button" @onclick="GoBack" class="kcp-btn">@L["Btn_Cancel"]</button>
                </div>
            </div>
        </div>

        @* ── Main ── *@
        <main class="kcp-main">
        <div style="max-width: 800px; margin: 0 auto;">
        <div class="bon-form-layout">
        <div class="bon-form">
            <EditForm Model="@request" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                @* ── Informations Compagnie ── *@
                <section class="bon-form__section">
                    <h2 class="bon-form__section-title">@L["BemF_CompanyInfo"]</h2>
                    <RadzenRow Gap="1.25rem">
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_CompanyName"] <span class="required-star">*</span></label>
                            <RadzenDropDown @bind-Value="@selectedCompagnieId" Data="@compagnies"
                                            TextProperty="Nom" ValueProperty="Id"
                                            Placeholder="@L["BemF_SelectCompany"].Value"
                                            AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Change="@OnCompagnieChanged" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_ContractNumber"]</label>
                            <RadzenDropDown @bind-Value="@selectedContratId" Data="@contratsFiltered"
                                            TextProperty="PoNumber" ValueProperty="Id"
                                            Placeholder="@L["BemF_SelectContract"].Value"
                                            AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Change="@OnContratChanged" Style="width: 100%;" Density="Density.Compact"
                                            Disabled="@(selectedCompagnieId == null)" />
                        </RadzenColumn>
                    </RadzenRow>
                    <RadzenRow Gap="1.25rem">
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_ContractorEmail"]</label>
                            <RadzenTextBox @bind-Value="request.EmailContractant" Placeholder="@L["BemF_ContractorEmail"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_SiteManager"] <span class="required-star">*</span></label>
                            <RadzenTextBox @bind-Value="request.SiteManager" Placeholder="@L["BemF_SiteManagerPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                    </RadzenRow>
                    <RadzenRow Gap="1.25rem">
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_HostDept"] <span class="required-star">*</span></label>
                            <RadzenTextBox @bind-Value="request.HostDepartment" Placeholder="@L["BemF_HostDeptPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                    </RadzenRow>
                    <div>
                        <label class="bon-form__label">@L["BemF_EntryReason"] <span class="required-star">*</span></label>
                        <RadzenTextArea @bind-Value="request.ReasonOnSite" Rows="2" Style="width: 100%;" />
                    </div>
                </section>

                @* ── Détail de l'Escorteur ── *@
                <section class="bon-form__section">
                    <h2 class="bon-form__section-title">@L["BemF_EscortDetails"]</h2>
                    <RadzenRow Gap="1.25rem">
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_EscortName"] <span class="required-star">*</span></label>
                            <RadzenTextBox @bind-Value="request.NomEscorteur" Placeholder="@L["BemF_EscortName"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_EscortFunction"]</label>
                            <RadzenTextBox @bind-Value="request.FonctionEscorteur" Placeholder="@L["BemF_EscortFunction"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                    </RadzenRow>
                    <div>
                        <label class="bon-form__label">Date Expiration <span class="required-star">*</span></label>
                        <RadzenDatePicker @bind-Value="request.DateExpiration" DateFormat="dd/MM/yyyy" Style="width: 100%;" Density="Density.Compact" />
                    </div>
                </section>

                @* ── Trajet ── *@
                <section class="bon-form__section">
                    <h2 class="bon-form__section-title">@L["BemF_Route"]</h2>
                    <RadzenRow Gap="1.25rem">
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_From"]</label>
                            <RadzenTextBox @bind-Value="request.Provenance" Placeholder="@L["BemF_From"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                        <RadzenColumn Size="6">
                            <label class="bon-form__label">@L["BemF_To"]</label>
                            <RadzenTextBox @bind-Value="request.Destination" Placeholder="@L["BemF_To"].Value" Style="width: 100%;" Density="Density.Compact" />
                        </RadzenColumn>
                    </RadzenRow>
                    <div>
                        <label class="bon-form__label">@L["BemF_AdditionalDesc"]</label>
                        <RadzenTextArea @bind-Value="request.Description" Rows="2" Placeholder="@L["BemF_AddInfoPlaceholder"].Value" Style="width: 100%;" />
                    </div>
                </section>

                @* ── Matériels ── *@
                <section class="bon-form__section">
                    <h2 class="bon-form__section-title">@L["BemF_Materials"] (@materiels.Count @(materiels.Count > 1 ? L["BemF_Articles"].Value : L["BemF_Article"].Value))</h2>
                    @if (materiels.Any())
                    {
                        <RadzenDataGrid TItem="MaterielEditModel" Data="@materiels" AllowSorting="false" Density="Density.Compact" Style="font-size: 0.85rem;">
                            <Columns>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="@L["BemF_Designation"]" Width="35%">
                                    <Template Context="mat">
                                        <RadzenTextBox @bind-Value="mat.Designation" Placeholder="@L["BemF_Designation"].Value" Style="width:100%;" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="@L["BemF_ProductCode"]" Width="30%">
                                    <Template Context="mat">
                                        <RadzenTextBox @bind-Value="mat.CodeProduitSerial" Placeholder="@L["BemF_ProductCode"].Value" Style="width:100%;" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="@L["BemF_Qty"]" Width="20%" TextAlign="TextAlign.Center">
                                    <Template Context="mat">
                                        <RadzenNumeric @bind-Value="mat.Quantite" Min="1" Step="1" Style="width:100%;" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="" Width="15%" TextAlign="TextAlign.Center" Sortable="false">
                                    <Template Context="mat">
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                                      Click="@(() => RemoveMateriel(mat))" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    }
                    else
                    {
                        <div style="padding: 2rem; text-align: center; color: var(--rz-text-secondary-color);">
                            <RadzenIcon Icon="inventory_2" Style="font-size: 32px; opacity: 0.5;" />
                            <RadzenText TextStyle="TextStyle.Body2">@L["BemF_NoMaterialAdded"]</RadzenText>
                        </div>
                    }
                    <div style="margin-top: 0.75rem; display: flex; align-items: center; justify-content: space-between;">
                        <span style="font-size: 0.78rem; color: #6b7f7f;">@L["BemF_Total"] <strong style="color: #1e2a2a;">@materiels.Sum(m => m.Quantite)</strong> @(materiels.Sum(m => m.Quantite) > 1 ? L["BemF_Articles"].Value : L["BemF_Article"].Value)</span>
                        <button type="button" @onclick="AddMateriel" style="background: none; border: none; cursor: pointer; font-size: 0.78rem; font-weight: 500; color: #005f60; display: flex; align-items: center; gap: 0.25rem;">
                            <RadzenIcon Icon="add" Style="font-size: 0.95rem;" /> @L["BemF_Add"]
                        </button>
                    </div>
                </section>

                @* ── Actions ── *@
                <div class="bon-form__actions">
                    <RadzenButton Text="@(isSaving ? L["BemF_Saving"].Value : L["BemF_SaveChanges"].Value)" Icon="save"
                                  ButtonType="ButtonType.Submit" Disabled="@isSaving" class="bon-form__btn-submit" />
                </div>
            </EditForm>
        </div>
        </div>
        </div>
        </main>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private BonEntree? bon;
    private UpdateBonEntreeRequest request = new();
    private List<MaterielEditModel> materiels = new();
    private bool isLoading = true;
    private bool isSaving;

    // Références pour dropdowns
    private IEnumerable<Compagnie> compagnies = [];
    private IEnumerable<Contrat> contrats = [];
    private int? selectedCompagnieId;
    private int? selectedContratId;

    // Contrats filtrés par compagnie sélectionnée
    private IEnumerable<Contrat> contratsFiltered =>
        selectedCompagnieId.HasValue
            ? contrats.Where(c => c.CompagnieId == selectedCompagnieId.Value)
            : Enumerable.Empty<Contrat>();

    // Navigation retour via historique
    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    protected override async Task OnInitializedAsync()
    {
        // Charger les données de référence
        compagnies = await ReferenceDataService.GetCompagniesAsync();
        contrats = await ReferenceDataService.GetContratsAsync();

        bon = await BonEntreeService.GetAsync(Id);
        if (bon != null)
        {
            request = new UpdateBonEntreeRequest
            {
                IdBon = bon.Id,
                ContratId = bon.ContratId,
                NumeroContrat = bon.NumeroContrat,
                NomCompagnie = bon.NomCompagnie,
                EmailContractant = bon.EmailContractant,
                SiteManager = bon.SiteManager,
                HostDepartment = bon.HostDepartment,
                ReasonOnSite = bon.ReasonOnSite,
                NomEscorteur = bon.NomEscorteur,
                FonctionEscorteur = bon.FonctionEscorteur,
                Provenance = bon.Provenance,
                Destination = bon.Destination,
                Description = bon.Description,
                DateExpiration = bon.DateExpiration
            };

            // Pré-sélectionner la compagnie
            var comp = compagnies.FirstOrDefault(c => c.Nom == bon.NomCompagnie);
            selectedCompagnieId = comp?.Id;

            // Pré-sélectionner le contrat
            selectedContratId = bon.ContratId;

            // Charger les matériels existants
            materiels = bon.Materiels?.Select(m => new MaterielEditModel
            {
                IdMateriel = m.Id,
                Designation = m.Designation ?? "",
                CodeProduitSerial = m.CodeProduitSerial ?? "",
                Quantite = m.Quantite
            }).ToList() ?? new();
        }
        isLoading = false;
    }

    private void OnCompagnieChanged(object value)
    {
        selectedContratId = null;
        request.ContratId = null;
        request.NumeroContrat = string.Empty;

        if (value is int compagnieId)
        {
            var compagnie = compagnies.FirstOrDefault(c => c.Id == compagnieId);
            if (compagnie != null)
            {
                request.NomCompagnie = compagnie.Nom;
            }
        }
        else
        {
            request.NomCompagnie = string.Empty;
        }
        // Email & SiteManager sont désormais sur le Contrat — réinitialisés ici, remplis dans OnContratChanged
        request.EmailContractant = string.Empty;
        request.SiteManager = string.Empty;
    }

    private void OnContratChanged(object value)
    {
        if (value is int contratId)
        {
            var contrat = contrats.FirstOrDefault(c => c.Id == contratId);
            if (contrat != null)
            {
                request.ContratId = contrat.Id;
                request.NumeroContrat = contrat.PoNumber;
                request.EmailContractant = contrat.Email ?? string.Empty;
                request.SiteManager = contrat.SiteManager ?? string.Empty;
            }
        }
        else
        {
            request.ContratId = null;
            request.NumeroContrat = string.Empty;
            request.EmailContractant = string.Empty;
            request.SiteManager = string.Empty;
        }
    }

    private void AddMateriel()
    {
        materiels.Add(new MaterielEditModel { Quantite = 1 });
        materiels = new List<MaterielEditModel>(materiels);
    }

    private void RemoveMateriel(MaterielEditModel mat)
    {
        materiels.Remove(mat);
        materiels = new List<MaterielEditModel>(materiels);
    }

    private async Task HandleSubmit()
    {
        if (!materiels.Any())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Attention", "Ajoutez au moins un matériel");
            return;
        }

        // Vérifier les doublons de Code/N° Série
        var duplicates = materiels
            .Where(m => !string.IsNullOrWhiteSpace(m.CodeProduitSerial))
            .GroupBy(m => m.CodeProduitSerial!.Trim(), StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() > 1)
            .Select(g => g.Key)
            .ToList();
        if (duplicates.Any())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Doublons détectés",
                $"Code/N° série en doublon : {string.Join(", ", duplicates)}");
            return;
        }

        isSaving = true;
        try
        {
            // Convertir les matériels pour la requête
            request.Materiels = materiels.Select(m => new MaterielUpdateRequest
            {
                IdMateriel = m.IdMateriel,
                CodeProduitSerial = m.CodeProduitSerial,
                Designation = m.Designation,
                Quantite = m.Quantite
            }).ToList();

            var result = await BonEntreeService.UpdateAsync(request);
            if (result.Success)
            {
                NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, result.Message ?? L["Notif_ChangesSaved"].Value);
                Navigation.NavigateTo($"/bon-entree/{Id}");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, string.Join(", ", result.Errors));
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private class MaterielEditModel
    {
        public int IdMateriel { get; set; }
        public string Designation { get; set; } = "";
        public string CodeProduitSerial { get; set; } = "";
        public decimal Quantite { get; set; } = 1;
    }
}
