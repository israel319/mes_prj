@* BEM View - Full Radzen *@
@page "/bon-entree/{Id:int}"
@attribute [Authorize]
@using KCCMaterialFlow.Domain.Entities
@using KCCMaterialFlow.Domain.Enums
@inject IBonEntreeService BonEntreeService
@inject ICurrentUserService CurrentUserService
@inject INotificationRejetService NotificationRejetService
@inject IWorkflowApprobateurSpecialService ApprobateurSpecialService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<PageTitle>@(bon?.NumeroReference ?? L["BemV_EntryPermit"].Value) - KCC</PageTitle>

<div class="kcp-page">

    @* ===== ÉTATS DE CHARGEMENT / ERREUR (hors hero) ===== *@
    @if (isLoading)
    {
        <div style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Medium" />
                <RadzenText TextStyle="TextStyle.Body1">@L["BemV_Loading"]</RadzenText>
            </RadzenStack>
        </div>
    }
    else if (accessDenied)
    {
        <div style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="lock" Style="font-size: 3rem; color: var(--rz-danger);" />
                <RadzenText TextStyle="TextStyle.H6">@L["BemV_AccessDenied"]</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@L["BemV_AccessDeniedMsg"]</RadzenText>
                <RadzenButton Text="@L["Btn_Back"].Value" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Click="@GoBack" />
            </RadzenStack>
        </div>
    }
    else if (bon == null)
    {
        <div style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="error_outline" Style="font-size: 3rem; color: var(--rz-danger);" />
                <RadzenText TextStyle="TextStyle.H6">@L["BemV_NotFound"]</RadzenText>
                <RadzenButton Text="@L["Btn_Back"].Value" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Click="@GoBack" />
            </RadzenStack>
        </div>
    }
    else
    {
        @* ===== HERO ===== *@
        <div class="kcp-hero">
            <div class="kcp-hero-inner">
                <div>
                    @* Badges de statut *@
                    <div style="display:flex; gap:0.45rem; align-items:center; flex-wrap:wrap; margin-bottom:0.7rem;">
                        <RadzenBadge Text="@GetStatutLabel(bon.StatutActuel)" BadgeStyle="@GetStatusBadgeStyle()" />
                        <RadzenBadge Text="@L["BemV_TypeEntry"].Value" BadgeStyle="BadgeStyle.Light" />
                    </div>
                    <h1 class="kcp-title">@bon.NomDemandeur</h1>
                    <p class="kcp-subtitle">
                        @bon.NumeroReference
                        &nbsp;•&nbsp;
                        @L["BemV_CreatedAt"] @bon.DateCreation.ToString("dd/MM/yyyy")
                        &nbsp;•&nbsp;
                        @L["BemF_Expires"] @bon.DateExpiration.ToString("dd/MM/yyyy")
                    </p>
                </div>
                @* Boutons d'action dans le hero *@
                <div class="kcp-hero-actions">
                    <a class="kcp-btn" @onclick="@GoBack" href="javascript:void(0)">
                        <RadzenIcon Icon="arrow_back" Style="font-size:1rem;" />
                        @L["Btn_Back"]
                    </a>
                    @if (bon.StatutActuel == "Draft" && CanEdit)
                    {
                        <a class="kcp-btn" href="/bon-entree/@Id/modifier">
                            <RadzenIcon Icon="edit" Style="font-size:1rem;" />
                            @L["BemV_Edit"]
                        </a>
                    }
                    @if (CanDelete)
                    {
                        <button type="button" class="kcp-btn kcp-btn-danger" @onclick="@ShowDeleteDialog">
                            <RadzenIcon Icon="delete" Style="font-size:1rem;" />
                            @L["BemV_Delete"]
                        </button>
                    }
                    @if (CanSubmit)
                    {
                        <button type="button" class="kcp-btn kcp-btn-primary" @onclick="@SubmitForApproval">
                            <RadzenIcon Icon="send" Style="font-size:1rem;" />
                            @L["BemV_Submit"]
                        </button>
                    }
                    @if (CanApprove)
                    {
                        <button type="button" class="kcp-btn kcp-btn-success" @onclick="@ShowApproveDialog">
                            <RadzenIcon Icon="check" Style="font-size:1rem;" />
                            @L["BemV_Approve"]
                        </button>
                    }
                    @if (CanReject)
                    {
                        <button type="button" class="kcp-btn kcp-btn-danger" @onclick="@ShowRejectDialog">
                            <RadzenIcon Icon="close" Style="font-size:1rem;" />
                            @L["BemV_Reject"]
                        </button>
                    }
                    @if (bon.StatutActuel == "Approved" && HasStock)
                    {
                        <a class="kcp-btn kcp-btn-primary" href="/bon-sortie/nouveau?bemId=@bon.Id">
                            <RadzenIcon Icon="exit_to_app" Style="font-size:1rem;" />
                            @L["BemV_CreateBSE"]
                        </a>
                    }
                    @if (bon.StatutActuel == "Approved" && !string.IsNullOrEmpty(bon.QRCodeBase64) && CanPrint)
                    {
                        <a class="kcp-btn" href="/bon-entree/@Id/print">
                            <RadzenIcon Icon="print" Style="font-size:1rem;" />
                            @L["BemV_Print"]
                        </a>
                    }
                    @if (CanDownloadPdf)
                    {
                        <button type="button" class="kcp-btn" @onclick="@DownloadPdf">
                            <RadzenIcon Icon="picture_as_pdf" Style="font-size:1rem;" />
                            @L["BemV_DownloadPDF"]
                        </button>
                    }
                </div>
            </div>
        </div>

        @* ===== CONTENU PRINCIPAL FLOTTANT ===== *@
        <main class="kcp-main">

            @* === ALERTE RETOUR === *@
            @if (!string.IsNullOrEmpty(dernierCommentaireRetour) && bon.StatutActuel == "Draft")
            {
                <div class="conf-banner" style="background:#fff5e0; border-color:#f0c674;">
                    <span class="conf-icon">
                        <RadzenIcon Icon="warning" />
                    </span>
                    <p><strong>@L["BemV_ReturnModif"] —</strong> @dernierCommentaireRetour</p>
                </div>
            }

            @* === GRILLE DEUX COLONNES : gauche = infos+matériels | droite = workflow === *@
            <div style="display: grid; grid-template-columns: 1fr 380px; gap: 1rem; align-items: start;">

                @* ── COLONNE GAUCHE ── *@
                <div style="display: flex; flex-direction: column; gap: 1rem;">

                    @* Informations visiteur *@
                    <div class="kcp-card">
                        <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 1rem;">
                            @L["BemV_VisitorInfo"]
                        </h2>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem 1.5rem;">
                            <div>
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BemF_CompanyName"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); @(string.IsNullOrWhiteSpace(bon.NomCompagnie) ? "color:#9ca3af;" : "")">@(bon.NomCompagnie ?? "—")</div>
                            </div>
                            <div>
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["Col_Name"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); font-weight:500;">@bon.NomDemandeur</div>
                            </div>
                            <div>
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BemF_HostDept"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); @(string.IsNullOrWhiteSpace(bon.HostDepartment) ? "color:#9ca3af;" : "")">@(bon.HostDepartment ?? "—")</div>
                            </div>
                            <div>
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BemF_SiteManager"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); @(string.IsNullOrWhiteSpace(bon.SiteManager) ? "color:#9ca3af;" : "")">@(bon.SiteManager ?? "—")</div>
                            </div>
                            <div style="grid-column: span 2;">
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BemF_EntryReason"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); @(string.IsNullOrWhiteSpace(bon.ReasonOnSite) ? "color:#9ca3af;" : "")">@(bon.ReasonOnSite ?? "—")</div>
                            </div>
                        </div>
                    </div>

                    @* Matériels *@
                    <div class="kcp-card">
                        <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 1rem;">
                            @L["BemV_Materiels"]
                        </h2>
                        <RadzenDataGrid TItem="Materiel" Data="@bon.Materiels" AllowSorting="true" Density="Density.Compact" AllowPaging="false">
                            <Columns>
                                <RadzenDataGridColumn TItem="Materiel" Property="Quantite" Title="@L["BemV_Qty"]" Width="70px" TextAlign="TextAlign.Center" FormatString="{0:0.##}" />
                                <RadzenDataGridColumn TItem="Materiel" Property="Designation" Title="@L["BemV_Desc"]" />
                                <RadzenDataGridColumn TItem="Materiel" Property="CodeProduitSerial" Title="@L["BemV_Serial"]" Width="130px">
                                    <Template Context="mat">
                                        <span style="font-family: monospace; font-size:0.82rem; color: var(--kcc-f-text-muted);">@(mat.CodeProduitSerial ?? "—")</span>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Materiel" Title="@L["BemV_QtySortie"]" Width="95px" TextAlign="TextAlign.Center">
                                    <Template Context="mat">
                                        @{ var qteSortie = mat.Quantite - mat.QuantiteDisponible; }
                                        @(qteSortie > 0 ? qteSortie.ToString("0.##") : "—")
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Materiel" Title="@L["BemV_Solde"]" Width="75px" TextAlign="TextAlign.Center">
                                    <Template Context="mat">
                                        <strong>@mat.QuantiteDisponible.ToString("0.##")</strong>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Materiel" Title="@L["Col_Status"]" Width="105px" TextAlign="TextAlign.Center">
                                    <Template Context="mat">
                                        @if (mat.QuantiteDisponible == 0)
                                        {
                                            <RadzenBadge Text="@L["BemV_Exhausted"].Value" BadgeStyle="BadgeStyle.Light" />
                                        }
                                        else if (mat.Quantite - mat.QuantiteDisponible > 0)
                                        {
                                            <RadzenBadge Text="@L["BemV_Partial"].Value" BadgeStyle="BadgeStyle.Warning" />
                                        }
                                        else
                                        {
                                            <RadzenBadge Text="@L["BemV_Available"].Value" BadgeStyle="BadgeStyle.Success" />
                                        }
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                        <div style="display:flex; gap:1.5rem; justify-content:flex-end; margin-top:0.65rem; padding-top:0.65rem; border-top:1px solid var(--kcc-border, rgba(0,0,0,.07)); font-size:0.85rem;">
                            <span><strong>@L["BemV_TotalEntry"] :</strong> @bon.Materiels.Sum(m => m.Quantite).ToString("0.##")</span>
                            <span><strong>@L["BemV_TotalExit"] :</strong> @bon.Materiels.Sum(m => m.Quantite - m.QuantiteDisponible).ToString("0.##")</span>
                            <span><strong>@L["BemV_Balance"] :</strong> @bon.Materiels.Sum(m => m.QuantiteDisponible).ToString("0.##")</span>
                        </div>
                    </div>

                    @* BSE associé *@
                    @if (bon.BonSortieAssocieId.HasValue)
                    {
                        <div class="kcp-card" style="cursor:pointer; border-color:var(--kcc-primary,#00B193);"
                             @onclick="@(() => Navigation.NavigateTo($"/bon-sortie/{bon.BonSortieAssocieId}"))">
                            <div style="display:flex; align-items:center; gap:0.55rem; font-size:0.9rem;">
                                <RadzenIcon Icon="link" Style="color: var(--kcc-primary,#00B193);" />
                                <span><strong>@L["BemV_AssocBSE"] :</strong> @(bon.BonSortieAssocieNumero ?? $"BSE-{bon.BonSortieAssocieId}")</span>
                                <RadzenIcon Icon="open_in_new" Style="font-size: 0.85rem; color: var(--kcc-primary,#00B193);" />
                            </div>
                        </div>
                    }

                </div>@* fin colonne gauche *@

                @* ── COLONNE DROITE : Workflow ── *@
                <div>
                    @if (bon.StatutActuel != "Draft")
                    {
                        <div class="kcp-card">
                            <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 1rem;">
                                @L["BemV_Workflow"]
                            </h2>
                            @{
                                var appros = bon.Approbations.OrderBy(a => a.OrdreEtape).ToList();
                                var bonRejete = bon.StatutActuel == "Rejected";
                                var firstPending = bonRejete ? null : appros.FirstOrDefault(a => a.Decision == "En attente");
                            }
                            @if (appros.Any())
                            {
                                <RadzenStack Gap="0.4rem">
                                    @foreach (var a in appros)
                                    {
                                        var isCurrent = firstPending != null && a.Id == firstPending.Id;
                                        var isApproved = a.Decision is "Approuvé" or "Approuve";
                                        var isRejected = a.Decision is "Rejeté" or "Rejete";
                                        var isReturned = a.Decision is "Retourné" or "Retourne";
                                        var bgColor = isApproved ? "#dcfce7" : (isRejected || isReturned) ? "#fee2e2" : isCurrent ? "#fef3c7" : "var(--rz-base-200)";
                                        var borderColor = isApproved ? "#86efac" : (isRejected || isReturned) ? "#fca5a5" : isCurrent ? "#fcd34d" : "var(--rz-base-300)";
                                        var iconColor = isApproved ? "#16a34a" : (isRejected || isReturned) ? "#dc2626" : isCurrent ? "#d97706" : "#9ca3af";
                                        var icon = isApproved ? "check_circle" : isRejected ? "cancel" : isReturned ? "replay" : isCurrent ? "pending" : "radio_button_unchecked";

                                        <RadzenCard Variant="Variant.Flat" Style="@($"background: {bgColor}; border: 1px solid {borderColor}; border-radius: 3px; padding: 0.5rem 0.75rem;")">
                                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                <RadzenIcon Icon="@icon" Style="@($"color: {iconColor};")" />
                                                <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0;">
                                                    <strong>@a.NomEtape</strong>
                                                    @if (isApproved || isRejected || isReturned)
                                                    {
                                                        <span style="color: var(--rz-text-secondary-color); margin-left: 0.5rem; font-size: 0.85em;">@(a.NomApprobateur ?? "—") • @a.DateAction?.ToString("dd/MM HH:mm")</span>
                                                    }
                                                    else if (isCurrent)
                                                    {
                                                        var pool = GetActiveApproversFor(a.CodeEtape, bon.SiteId).ToList();
                                                        @if (pool.Count > 0)
                                                        {
                                                            <span style="color: #d97706; margin-left: 0.5rem; font-size: 0.85em;">
                                                                @L["BemV_Pending"]
                                                                @if (pool.Count == 1)
                                                                {
                                                                    <span> — <strong>@pool[0]</strong></span>
                                                                }
                                                                else
                                                                {
                                                                    <span> — @string.Join(", ", pool)</span>
                                                                }
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span style="color: #d97706; margin-left: 0.5rem; font-size: 0.85em;">
                                                                @L["BemV_Pending"]
                                                                @if (!string.IsNullOrEmpty(a.NomApprobateur))
                                                                {
                                                                    <span> — <strong>@a.NomApprobateur</strong></span>
                                                                }
                                                            </span>
                                                        }
                                                    }
                                                </RadzenText>
                                            </RadzenStack>
                                        </RadzenCard>
                                    }
                                </RadzenStack>
                            }
                            else
                            {
                                var legacyApproved = bon.StatutActuel is "Approved";
                                var legacyRejected = bon.StatutActuel is "Rejected";
                                var legacyBg = legacyApproved ? "#dcfce7" : legacyRejected ? "#fee2e2" : "#fef3c7";
                                var legacyBorder = legacyApproved ? "#86efac" : legacyRejected ? "#fca5a5" : "#fcd34d";
                                var legacyIconColor = legacyApproved ? "#16a34a" : legacyRejected ? "#dc2626" : "#d97706";
                                var legacyIcon = legacyApproved ? "check_circle" : legacyRejected ? "cancel" : "pending";
                                var legacyLabel = legacyApproved ? L["Statut_Approved"].Value : legacyRejected ? L["Statut_Rejected"].Value : bon.StatutActuel;

                                <RadzenCard Variant="Variant.Flat" Style="@($"background: {legacyBg}; border: 1px solid {legacyBorder}; padding: 0.5rem 0.75rem;")">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <RadzenIcon Icon="@legacyIcon" Style="@($"color: {legacyIconColor};")" />
                                        <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0;">
                                            <strong>@legacyLabel</strong>
                                            <span style="color: var(--kcc-text-muted); margin-left: 0.5rem; font-size: 0.85em;">@L["BemV_PreMigration"]</span>
                                        </RadzenText>
                                    </RadzenStack>
                                </RadzenCard>
                            }
                            @if (bon.StatutActuel == "Rejected" && notificationRejet != null)
                            {
                                <div style="margin-top: 0.75rem;">
                                    <RadzenButton Text="@L["BemV_RejectDetails"].Value" Icon="visibility" ButtonStyle="ButtonStyle.Danger"
                                                  Size="ButtonSize.Small" Click="@ShowRejetDetailsDialog" />
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        @* Draft : le workflow n'est pas encore démarré *@
                        <div class="kcp-card" style="text-align:center; padding:2rem 1rem; color:var(--kcc-f-text-muted,#6b7280);">
                            <RadzenIcon Icon="pending_actions" Style="font-size:2.5rem; opacity:.35;" />
                            <div style="margin-top:0.5rem; font-size:0.85rem;">@L["BemV_Draft"]</div>
                        </div>
                    }
                </div>@* fin colonne droite *@

            </div>@* fin grille *@

        </main>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private BonEntree? bon;
    private bool isLoading = true;
    private bool accessDenied = false;
    private string? dernierCommentaireRetour;
    private NotificationRejet? notificationRejet;
    private IReadOnlyList<WorkflowApprobateurSpecial> _activeSpecials = Array.Empty<WorkflowApprobateurSpecial>();

    private static readonly string[] RolesPrivilegies = { "Admin", "Superviseur", "GM", "OPJ", "Identification", "Security", "IT", "Environnement" };

    private bool CanViewBon => bon != null && (
        CurrentUserService.IsInAnyRole(RolesPrivilegies) ||
        bon.NomDemandeur == CurrentUserService.GetUserDisplayName()
    );

    private bool CanEdit => bon?.StatutActuel == "Draft" &&
                           CurrentUserService.HasActivite("BEM_MODIFIER") &&
                           (CurrentUserService.IsInAnyRole("Admin", "Demandeur") ||
                            bon.NomDemandeur == CurrentUserService.GetUserDisplayName());

    private bool CanSubmit => bon?.StatutActuel == "Draft" &&
                             CurrentUserService.HasActivite("BEM_SOUMETTRE") &&
                             (CurrentUserService.IsInAnyRole("Admin", "Demandeur") ||
                              bon.NomDemandeur == CurrentUserService.GetUserDisplayName());

    private bool CanDelete => bon?.StatutActuel == "Draft" &&
                             CurrentUserService.HasActivite("BEM_SUPPRIMER") &&
                             (CurrentUserService.IsInAnyRole("Admin", "Demandeur") ||
                              bon.NomDemandeur == CurrentUserService.GetUserDisplayName());

    private bool CanApproveSuperviseur => CanApproveCurrentStep("REPORTSTO");
    private bool CanApproveGM => CanApproveCurrentStep("GM");
    private bool CanApproveOPJ => CanApproveCurrentStep("OPJ");
    private bool CanApproveIdentification => CanApproveCurrentStep("IDENTIFICATION");

    private bool CanApprove => CanApproveCurrentStep(null);

    /// <summary>True si l'utilisateur courant est l'approbateur de l'étape en attente.
    /// Si <paramref name="codeEtapeFilter"/> est fourni, l'étape doit aussi correspondre à ce code.</summary>
    private bool CanApproveCurrentStep(string? codeEtapeFilter)
    {
        if (bon == null) return false;
        if (!CurrentUserService.HasActivite("BEM_APPROUVER")) return false;
        var current = bon.Approbations?
            .Where(a => a.Decision == "En attente")
            .OrderBy(a => a.OrdreEtape)
            .FirstOrDefault();
        if (current == null) return false;
        if (codeEtapeFilter != null &&
            !string.Equals(current.CodeEtape, codeEtapeFilter, StringComparison.OrdinalIgnoreCase))
            return false;
        // Pas de bypass Admin/SuperAdmin : seul l'approbateur désigné de l'étape
        // en cours peut agir. La chaîne d'approbation doit être respectée.
        return CurrentUserService.EmployeeId.HasValue
            && current.ApprobateurId == CurrentUserService.EmployeeId.Value;
    }

    private bool CanReject => CanApprove && CurrentUserService.HasActivite("BEM_REJETER");

    private bool CanReturn => CanApprove && CurrentUserService.HasActivite("BEM_RETOURNER");

    private bool CanPrint => bon?.StatutActuel == "Approved" && IsLastApprover();

    private bool IsLastApprover()
    {
        if (bon == null) return false;
        var lastApproved = bon.Approbations
            .Where(a => a.Decision is "Approuv\u00e9" or "Approuve")
            .OrderByDescending(a => a.OrdreEtape)
            .FirstOrDefault();
        if (lastApproved == null) return false;
        if (CurrentUserService.IsAdmin) return true;
        if (lastApproved.ApprobateurId.HasValue && CurrentUserService.EmployeeId.HasValue
            && lastApproved.ApprobateurId == CurrentUserService.EmployeeId)
            return true;
        var login = CurrentUserService.GetUserLogin()?.Trim().ToLowerInvariant() ?? "";
        var bs = login.LastIndexOf('\\');
        if (bs >= 0) login = login[(bs + 1)..];
        var at = login.IndexOf('@');
        if (at >= 0) login = login[..at];
        var approvalLogin = lastApproved.ApprobateurLogin?.Trim().ToLowerInvariant() ?? "";
        var bsA = approvalLogin.LastIndexOf('\\');
        if (bsA >= 0) approvalLogin = approvalLogin[(bsA + 1)..];
        var atA = approvalLogin.IndexOf('@');
        if (atA >= 0) approvalLogin = approvalLogin[..atA];
        if (!string.IsNullOrEmpty(login) && !string.IsNullOrEmpty(approvalLogin) && login == approvalLogin)
            return true;
        var mat = lastApproved.ApprobateurMatricule?.Trim().ToUpperInvariant() ?? "";
        var curMat = CurrentUserService.Matricule?.Trim().ToUpperInvariant() ?? "";
        return !string.IsNullOrEmpty(mat) && !string.IsNullOrEmpty(curMat) && mat == curMat;
    }

    private bool CanDownloadPdf => CurrentUserService.IsInAnyRole("Identification");

    private bool HasStock => bon?.Materiels.Any(m => m.Quantite > 0) == true;

    protected override async Task OnInitializedAsync()
    {
        await LoadBonAsync();
    }

    private async Task LoadBonAsync()
    {
        isLoading = true;
        accessDenied = false;
        try
        {
            bon = await BonEntreeService.GetAsync(Id);
            _activeSpecials = await ApprobateurSpecialService.GetAllAsync();

            if (bon != null && bon.StatutActuel == "Draft")
            {
                var dernierRetour = bon.Historiques
                    .Where(h => h.Action == ActionBonEntree.RetourModification)
                    .OrderByDescending(h => h.ActionDate)
                    .FirstOrDefault();

                if (dernierRetour != null)
                {
                    dernierCommentaireRetour = dernierRetour.Comment;
                }
            }

            if (bon != null && !CanViewBon)
            {
                accessDenied = true;
                bon = null;
                NotificationService.Notify(NotificationSeverity.Warning, L["BemV_AccessDenied"].Value,
                    L["BemV_AccessDeniedMsg"].Value);
                return;
            }

            if (bon != null && bon.StatutActuel == "Rejected")
            {
                notificationRejet = await NotificationRejetService.GetByNumeroReferenceAsync(bon.NumeroReference);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<string> GetActiveApproversFor(string? codeEtape, int? siteId)
    {
        if (_activeSpecials.Count == 0) yield break;
        TypeApprobateurSpecial? type = codeEtape?.ToUpperInvariant() switch
        {
            "OPJ" => TypeApprobateurSpecial.OPJ,
            "IDENTIFICATION" => TypeApprobateurSpecial.Identification,
            _ => null
        };
        if (type == null) yield break;
        var candidates = _activeSpecials.Where(s => s.Type == type.Value && s.EstActif).ToList();
        if (type == TypeApprobateurSpecial.OPJ)
        {
            var siteSpecific = candidates.Where(x => x.SiteId == siteId).ToList();
            var pool = siteSpecific.Count > 0 ? siteSpecific : candidates.Where(x => x.SiteId == null).ToList();
            foreach (var p in pool.OrderBy(x => x.Ordre))
                yield return p.Employee?.NomComplet ?? $"#{p.EmployeeId}";
        }
        else
        {
            foreach (var p in candidates.OrderBy(x => x.Ordre))
                yield return p.Employee?.NomComplet ?? $"#{p.EmployeeId}";
        }
    }

    private string GetStatutLabel(string? s) => s?.ToUpperInvariant() switch
    {
        "DRAFT" => L["Statut_Draft"].Value,
        "APPROVED" => L["Statut_Approved"].Value,
        "REJECTED" => L["Statut_Rejected"].Value,
        "RETURNED" => L["Statut_Returned"].Value,
        "CANCELLED" => L["Statut_Cancelled"].Value,
        // Tout statut Pending* → libellé générique. Le nom réel de l'approbateur courant
        // est affiché dans le badge "Chez {nom}" à côté (voir GetCurrentApproverName).
        _ when (s ?? "").ToUpperInvariant().StartsWith("PENDING") => L["Lbl_Pending"].Value,
        _ => s ?? "-"
    };

    private BadgeStyle GetStatusBadgeStyle() => bon?.StatutActuel?.ToUpperInvariant() switch
    {
        "APPROVED" => BadgeStyle.Success,
        "REJECTED" => BadgeStyle.Danger,
        "DRAFT" => BadgeStyle.Light,
        _ when bon?.StatutActuel != null && bon.StatutActuel.ToUpperInvariant().StartsWith("PENDING") => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };

    /// <summary>Nom de l'approbateur en attente actuel (étape courante de la chaîne).</summary>
    private string? GetCurrentApproverName()
    {
        if (bon == null || bon.StatutActuel is "Draft" or "Approved" or "Rejected" or "Cancelled")
            return null;
        var current = bon.Approbations?
            .Where(a => a.Decision == "En attente")
            .OrderBy(a => a.OrdreEtape)
            .FirstOrDefault();
        return current?.NomApprobateur;
    }

    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    private async Task DownloadPdf()
    {
        await JSRuntime.InvokeVoidAsync("open", $"/bon-entree/{Id}/print", "_blank");
    }

    private async Task SubmitForApproval()
    {
        var result = await BonEntreeService.SubmitForApprovalAsync(Id);
        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Msg_Success"].Value, L["Msg_Submitted"].Value);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"].Value, result.Message ?? L["Msg_UnexpectedError"].Value);
        }
    }

    private async Task ShowApproveDialog()
    {
        var result = await DialogService.OpenAsync<ApprobationDialog>(
            "Approuver le bon",
            new Dictionary<string, object> { { "Action", "approve" } },
            new DialogOptions { Width = "450px" }
        );

        if (result is string commentaire)
        {
            await PerformApproval(commentaire);
        }
    }

    private async Task ShowRejectDialog()
    {
        var result = await DialogService.OpenAsync<ApprobationDialog>(
            "Rejeter le bon",
            new Dictionary<string, object> { { "Action", "reject" } },
            new DialogOptions { Width = "450px" }
        );

        if (result is string motif && !string.IsNullOrWhiteSpace(motif))
        {
            await PerformRejection(motif);
        }
    }

    private async Task ShowReturnToUserDialog()
    {
        var result = await DialogService.OpenAsync<ApprobationDialog>(
            "Retourner pour modification",
            new Dictionary<string, object> { { "Action", "return" } },
            new DialogOptions { Width = "450px" }
        );

        if (result is string raison && !string.IsNullOrWhiteSpace(raison))
        {
            await PerformReturn(raison);
        }
    }

    private async Task PerformApproval(string commentaire)
    {
        var result = await BonEntreeService.ApproveAsync(new ApprovalRequest
        {
            BonId = Id,
            ReservesEventuelles = commentaire
        });

        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Msg_Approved"].Value);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_ApprovalError"].Value);
        }
    }

    private async Task PerformRejection(string motif)
    {
        var result = await BonEntreeService.RejectAsync(new ApprovalRequest
        {
            BonId = Id,
            ReservesEventuelles = motif
        });

        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Warning, L["Msg_Rejected"].Value, L["Msg_BonRejected"].Value);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_RejectionError"].Value);
        }
    }

    private async Task PerformReturn(string raison)
    {
        var result = await BonEntreeService.ReturnForModificationAsync(new ApprovalRequest
        {
            BonId = Id,
            ReservesEventuelles = raison
        });

        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Info, L["Msg_Returned"].Value, L["Msg_BonReturned"].Value);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_ReturnError"].Value);
        }
    }

    private async Task ShowDeleteDialog()
    {
        var confirmed = await DialogService.Confirm(
            string.Format(L["Notif_DeleteDraftConfirm"].Value, bon?.NumeroReference),
            L["Btn_Delete"].Value,
            new ConfirmOptions
            {
                OkButtonText = "Supprimer",
                CancelButtonText = "Annuler"
            });

        if (confirmed == true)
        {
            await DeleteDraft();
        }
    }

    private async Task DeleteDraft()
    {
        var result = await BonEntreeService.DeleteDraftAsync(Id);

        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Notif_Deleted"].Value, result.Message ?? L["Notif_DeleteSuccess"].Value);
            Navigation.NavigateTo("/bon-entree");
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_DeleteError"].Value);
        }
    }

