@page "/bon-entree/nouveau"
@attribute [Authorize]
@using KCCMaterialFlow.Application.Features.BonEntree.DTOs
@using KCCMaterialFlow.Application.Common.Interfaces
@using KCCMaterialFlow.Domain.Entities
@inject IBonEntreeService BonEntreeService
@inject NavigationManager Navigation
@inject NotificationService NotificationService

<PageTitle>Nouveau BEM - KCC Material Flow</PageTitle>

<div class="bon-form-layout">

    @* ===== FORMULAIRE (gauche) ===== *@
    <div class="bon-form">
        <EditForm Model="@request" OnValidSubmit="@HandleSubmit">
            <DataAnnotationsValidator />

            @* ── Header ── *@
            <div class="bon-form__header">
                <div class="bon-form__header-logo">
                    <div class="bon-form__header-icon">KCC</div>
                    <span class="bon-form__header-brand">KCC Material Flow</span>
                </div>
                <div class="bon-form__header-title">
                    <h1>Bon d'Entrée de Matériel</h1>
                    <p>SEC-FM-141(B) — Company Information</p>
                </div>
                <div class="bon-form__header-meta">
                    <p style="margin: 0;">Expire : <strong>@request.DateExpiration.ToString("dd/MM/yyyy")</strong></p>
                    <RadzenDatePicker @bind-Value="@request.DateExpiration" DateFormat="dd/MM/yyyy"
                                      Min="@DateTime.Today" Style="width: 140px; margin-top: 0.25rem;" Density="Density.Compact" />
                </div>
            </div>
            <div class="bon-form__divider"></div>

            @* ── Informations Compagnie ── *@
            <section class="bon-form__section">
                <h2 class="bon-form__section-title">Informations Compagnie</h2>
                <div class="bon-form__section-line"></div>
                <RadzenRow Gap="1.25rem">
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Company Name</label>
                        <RadzenDropDown @bind-Value="@selectedCompagnieId" Data="@compagnies"
                                        TextProperty="Nom" ValueProperty="Id"
                                        Placeholder="Sélectionner une compagnie"
                                        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        Change="@OnCompagnieChanged" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Contract Number (PO)</label>
                        <RadzenDropDown @bind-Value="@selectedContratId" Data="@contratsFiltered"
                                        TextProperty="PoNumber" ValueProperty="Id"
                                        Placeholder="Sélectionner un contrat"
                                        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        Change="@OnContratChanged" Style="width: 100%;" Density="Density.Compact"
                                        Disabled="@(!selectedCompagnieId.HasValue)" />
                    </RadzenColumn>
                </RadzenRow>
                <RadzenRow Gap="1.25rem" Style="margin-top: 1rem;">
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Contractor Email Address</label>
                        <RadzenTextBox @bind-Value="@request.EmailContractant" Placeholder="email@exemple.com" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Site Manager (Contractor)</label>
                        <RadzenTextBox @bind-Value="@request.SiteManager" Placeholder="Nom du responsable site" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                </RadzenRow>
                <RadzenRow Gap="1.25rem" Style="margin-top: 1rem;">
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Host Department</label>
                        <RadzenDropDown @bind-Value="@selectedDepartementId" Data="@departements"
                                        TextProperty="NomDepartement" ValueProperty="Id"
                                        Placeholder="Sélectionner un département"
                                        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        Change="@OnDepartementChanged" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                </RadzenRow>
                <div style="margin-top: 1rem;">
                    <label class="bon-form__label">Motif d'entrée</label>
                    <RadzenDropDown @bind-Value="@selectedRaisonEntreeId" Data="@raisonsEntree"
                                    TextProperty="Nom" ValueProperty="Id"
                                    Placeholder="-- Sélectionnez le motif d'entrée --"
                                    AllowClear="true"
                                    Change="@OnRaisonEntreeChanged" Style="width: 100%;" Density="Density.Compact" />
                    @if (selectedRaisonEntreeCode == "AUTRE")
                    {
                        <RadzenTextBox @bind-Value="@autreMotifEntreeTexte" Placeholder="Précisez le motif..." Style="width: 100%; margin-top: 0.5rem;"
                                       Change="@OnAutreMotifChanged" />
                    }
                </div>
            </section>

            @* ── Détail Escorteur ── *@
            <section class="bon-form__section">
                <h2 class="bon-form__section-title">Détail de l'Escorteur</h2>
                <div class="bon-form__section-line"></div>
                <RadzenRow Gap="1.25rem">
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Nom / Name</label>
                        <RadzenTextBox @bind-Value="@request.NomEscorteur" Placeholder="Nom de l'escorteur" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">Fonction / Function</label>
                        <RadzenTextBox @bind-Value="@request.FonctionEscorteur" Placeholder="Fonction" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                </RadzenRow>
            </section>

            @* ── Trajet ── *@
            <section class="bon-form__section">
                <h2 class="bon-form__section-title">Trajet</h2>
                <div class="bon-form__section-line"></div>
                <RadzenRow Gap="1.25rem">
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">From (Provenance)</label>
                        <RadzenDropDown TValue="int?" @bind-Value="@selectedProvenanceId"
                                        Data="@sites" TextProperty="Nom" ValueProperty="Id"
                                        Placeholder="-- Sélectionner provenance --" AllowFiltering="true"
                                        Change="@OnProvenanceChanged" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <label class="bon-form__label">To (Destination)</label>
                        <RadzenDropDown TValue="int?" @bind-Value="@selectedDestinationId"
                                        Data="@availableDestinations" TextProperty="Nom" ValueProperty="Id"
                                        Placeholder="-- Sélectionner destination --" AllowFiltering="true"
                                        Change="@OnDestinationChanged" Style="width: 100%;" Density="Density.Compact" />
                    </RadzenColumn>
                </RadzenRow>
            </section>

            @* ── Matériels ── *@
            <section class="bon-form__section">
                <h2 class="bon-form__section-title">Matériels</h2>
                <div class="bon-form__section-line"></div>
                <RadzenDataGrid TItem="MaterielRequest" Data="@request.Materiels" Density="Density.Compact" Style="font-size: 0.8rem;">
                    <Columns>
                        <RadzenDataGridColumn TItem="MaterielRequest" Title="Code produit / N° Serial" Width="25%">
                            <Template Context="item">
                                <RadzenTextBox @bind-Value="item.CodeProduitSerial" Placeholder="Code/Serial" Style="width: 100%; border: none; box-shadow: none; padding: 0.15rem 0.25rem; font-size: 0.8rem;" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="MaterielRequest" Title="Désignation" Width="45%">
                            <Template Context="item">
                                <RadzenTextBox @bind-Value="item.Designation" Placeholder="Description du matériel" Style="width: 100%; border: none; box-shadow: none; padding: 0.15rem 0.25rem; font-size: 0.8rem;" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="MaterielRequest" Title="Quantité" Width="15%" TextAlign="TextAlign.Center">
                            <Template Context="item">
                                <RadzenNumeric @bind-Value="item.Quantite" Min="1" Style="width: 100%; border: none; box-shadow: none; font-size: 0.8rem; text-align: center;" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="MaterielRequest" Width="15%" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                            <Template Context="item">
                                <RadzenButton Icon="delete_outline" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                              Click="@(() => RemoveMateriel(item))" Disabled="@(request.Materiels.Count <= 1)" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                <div style="margin-top: 0.75rem; display: flex; align-items: center; justify-content: space-between;">
                    <span style="font-size: 0.75rem; color: #6b7280;">Total : <strong style="color: #1a1a1a;">@request.Materiels.Sum(m => m.Quantite)</strong> article@(request.Materiels.Sum(m => m.Quantite) > 1 ? "s" : "")</span>
                    <button type="button" @onclick="AddMateriel" style="background: none; border: none; cursor: pointer; font-size: 0.75rem; font-weight: 500; color: #6b7280; display: flex; align-items: center; gap: 0.25rem;">
                        <RadzenIcon Icon="add" Style="font-size: 0.85rem;" /> Ajouter
                    </button>
                </div>
            </section>

            @* ── Réserves ── *@
            <section class="bon-form__section">
                <h2 class="bon-form__section-title">Réserves Éventuelles</h2>
                <div class="bon-form__section-line"></div>
                <RadzenTextArea @bind-Value="@request.Description" Placeholder="Observations, réserves ou commentaires..." Rows="3" Style="width: 100%; font-size: 0.8rem;" />
            </section>

            @* ── Actions ── *@
            <div class="bon-form__actions">
                <RadzenButton Text="Brouillon" Icon="save" class="bon-form__btn-draft"
                              Click="@HandleSubmit" Disabled="@isSaving" />
                <RadzenButton Text="Soumettre" Icon="send" class="bon-form__btn-submit"
                              Click="@HandleSubmitAndSend" Disabled="@isSaving" />
            </div>
        </EditForm>
    </div>

    @* ===== REVIEW PANEL (droite) ===== *@
    <div class="bon-form__review">
        <div class="bon-form__review-header">
            <RadzenIcon Icon="fact_check" Style="font-size: 1rem;" />
            <span>Review</span>
        </div>

        <div class="bon-form__review-body">
            @* Compagnie *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="business" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Compagnie</div>
                @if (!string.IsNullOrWhiteSpace(request.NomCompagnie))
                {
                    <div style="background: rgba(59,130,246,0.06); padding: 0.5rem 0.6rem; border-left: 3px solid var(--rz-info);">
                        <div style="font-size: 0.78rem; font-weight: 600; color: #1a1a1a;">@request.NomCompagnie</div>
                        @if (!string.IsNullOrWhiteSpace(request.NumeroContrat))
                        {
                            <div style="font-size: 0.68rem; color: #6b7280; margin-top: 0.15rem;">PO: @request.NumeroContrat</div>
                        }
                    </div>
                }
                else
                {
                    <span class="bon-form__review-empty">Aucune compagnie sélectionnée</span>
                }
            </div>

            @* Département *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="domain" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Département Hôte</div>
                @if (!string.IsNullOrWhiteSpace(request.HostDepartment))
                {
                    <RadzenBadge Text="@request.HostDepartment" BadgeStyle="BadgeStyle.Primary" Style="font-size: 0.65rem;" />
                }
                else
                {
                    <span class="bon-form__review-empty">Non défini</span>
                }
            </div>

            @* Motif *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="label" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Motif d'entrée</div>
                @if (!string.IsNullOrWhiteSpace(request.ReasonOnSite))
                {
                    <RadzenBadge Text="@request.ReasonOnSite" BadgeStyle="BadgeStyle.Info" Style="font-size: 0.65rem;" />
                }
                else
                {
                    <span class="bon-form__review-empty">Aucun motif</span>
                }
            </div>

            @* Trajet *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="swap_horiz" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Trajet</div>
                <div style="display: flex; align-items: center; gap: 0.4rem;">
                    <div style="flex: 1; text-align: center; padding: 0.4rem; background: #f9fafb;">
                        <div style="font-size: 0.55rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">From</div>
                        <div style="font-size: 0.75rem; font-weight: 600; color: #1a1a1a; margin-top: 0.1rem;">@(string.IsNullOrWhiteSpace(request.Provenance) ? "—" : request.Provenance)</div>
                    </div>
                    <RadzenIcon Icon="arrow_forward" Style="color: #00B193; font-size: 1rem;" />
                    <div style="flex: 1; text-align: center; padding: 0.4rem; background: #f9fafb;">
                        <div style="font-size: 0.55rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">To</div>
                        <div style="font-size: 0.75rem; font-weight: 600; color: #1a1a1a; margin-top: 0.1rem;">@(string.IsNullOrWhiteSpace(request.Destination) ? "—" : request.Destination)</div>
                    </div>
                </div>
            </div>

            @* Matériels *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="category" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Matériels (@request.Materiels.Count(m => !string.IsNullOrWhiteSpace(m.Designation) || !string.IsNullOrWhiteSpace(m.CodeProduitSerial)))</div>
                @{
                    var filledMateriels = request.Materiels.Where(m => !string.IsNullOrWhiteSpace(m.Designation) || !string.IsNullOrWhiteSpace(m.CodeProduitSerial)).ToList();
                }
                @if (filledMateriels.Any())
                {
                    <div style="max-height: 140px; overflow-y: auto;">
                        @foreach (var mat in filledMateriels.Take(5))
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.35rem 0; border-bottom: 1px solid #f3f4f6;">
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-size: 0.72rem; font-weight: 500; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @(string.IsNullOrWhiteSpace(mat.Designation) ? "(Sans désignation)" : mat.Designation)
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(mat.CodeProduitSerial))
                                    {
                                        <div style="font-size: 0.6rem; color: #9ca3af;">@mat.CodeProduitSerial</div>
                                    }
                                </div>
                                <RadzenBadge Text="@mat.Quantite.ToString()" BadgeStyle="BadgeStyle.Primary" Style="font-size: 0.6rem; min-width: 22px;" />
                            </div>
                        }
                        @if (filledMateriels.Count > 5)
                        {
                            <div style="font-size: 0.65rem; color: #9ca3af; text-align: center; padding: 0.3rem 0; font-style: italic;">
                                + @(filledMateriels.Count - 5) autre(s)...
                            </div>
                        }
                    </div>
                    <div style="margin-top: 0.4rem; padding-top: 0.4rem; border-top: 1px solid #e5e7eb; font-size: 0.72rem; color: #1a1a1a;">
                        Total: <strong>@request.Materiels.Sum(m => m.Quantite)</strong> articles
                    </div>
                }
                else
                {
                    <span class="bon-form__review-empty">Aucun matériel saisi</span>
                }
            </div>

            @* Escorteur *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="person" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Escorteur</div>
                @if (!string.IsNullOrWhiteSpace(request.NomEscorteur))
                {
                    <div style="font-size: 0.75rem; font-weight: 500; color: #1a1a1a;">@request.NomEscorteur</div>
                    @if (!string.IsNullOrWhiteSpace(request.FonctionEscorteur))
                    {
                        <div style="font-size: 0.65rem; color: #9ca3af; margin-top: 0.1rem;">@request.FonctionEscorteur</div>
                    }
                }
                else
                {
                    <span class="bon-form__review-empty">Non renseigné</span>
                }
            </div>

            @* Validité *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="event" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Validité</div>
                <div style="font-size: 0.75rem; color: #1a1a1a;">Expire le: <strong>@request.DateExpiration.ToString("dd/MM/yyyy")</strong></div>
            </div>
        </div>

        @* Footer statut *@
        <div class="bon-form__review-footer">
            @if (CanSubmit())
            {
                <div style="display: flex; align-items: center; gap: 0.35rem; color: #16a34a;">
                    <RadzenIcon Icon="check_circle" Style="font-size: 1rem;" />
                    <span style="font-size: 0.75rem; font-weight: 500;">Prêt à soumettre</span>
                </div>
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 0.35rem; color: #9ca3af;">
                    <RadzenIcon Icon="info" Style="font-size: 1rem;" />
                    <span style="font-size: 0.75rem;">Complétez le formulaire</span>
                </div>
            }
        </div>
    </div>

</div>
