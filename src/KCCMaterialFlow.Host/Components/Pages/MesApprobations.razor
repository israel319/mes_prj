@page "/mes-approbations"
@attribute [Authorize]
@using KCCMaterialFlow.Host.Components.Dialogs
@inject ICurrentUserService CurrentUserService
@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject KCCMaterialFlow.Host.Services.UserRoleCacheService RoleCacheService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Appro_Title"] — KCC Material Flow</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Appro_Title"]</h1>
                <p class="kcp-subtitle">@L["Appro_Subtitle"] • @CurrentUserService.GetUserDisplayName()</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn" type="button" @onclick="LoadDataAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">

        @* ─── LÉGENDE ─── *@
        <RadzenCard class="rz-mb-4" Style="padding: 0.75rem 1rem;">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                         Wrap="FlexWrap.Wrap" Gap="1.5rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                    <RadzenBadge Text="@L["Appro_EntryType"].Value" BadgeStyle="BadgeStyle.Info" />
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500);">@L["Appro_EntryVouchers"]</RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                    <RadzenBadge Text="@L["Appro_ExitType"].Value" BadgeStyle="BadgeStyle.Secondary" />
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500);">@L["Appro_ExitVouchers"]</RadzenText>
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* ─── ONGLETS BSM / BEM ─── *@
        <RadzenTabs RenderMode="TabRenderMode.Client">
            <Tabs>
                <RadzenTabsItem Icon="output">
                    <Template>
                        <span>@L["Appro_ExitVouchers"]</span>
                        @if (pendingBonsSortie.Count > 0)
                        {
                            <RadzenBadge Text="@pendingBonsSortie.Count.ToString()" BadgeStyle="BadgeStyle.Warning"
                                         Style="margin-left: 0.4rem; font-size: 0.7rem;" />
                        }
                    </Template>
                    <ChildContent>
                        @if (isLoading)
                        {
                            <RadzenCard>
                                <RadzenStack AlignItems="AlignItems.Center" Style="padding: 3rem;">
                                    <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                                </RadzenStack>
                            </RadzenCard>
                        }
                        else if (!pendingBonsSortie.Any())
                        {
                            <RadzenCard>
                                <RadzenStack AlignItems="AlignItems.Center" Style="padding: 3rem;" Gap="0.75rem">
                                    <RadzenIcon Icon="check_circle" Style="font-size:3.5rem; color:var(--kcc-green); opacity:0.4;" />
                                    <RadzenText TextStyle="TextStyle.H6" Style="color:var(--kcc-green); font-weight:600;">@L["Appro_NoPending"]</RadzenText>
                                </RadzenStack>
                            </RadzenCard>
                        }
                        else
                        {
                            <RadzenDataGrid TItem="ApprobationDto" Data="@pendingBonsSortie.OrderBy(a => a.DateCreation)"
                                            AllowSorting="true" AllowFiltering="true" AllowPaging="true" PageSize="15"
                                            PagerHorizontalAlign="HorizontalAlign.Center"
                                            GridLines="DataGridGridLines.Horizontal">
                                <Columns>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Type"]" Width="90px" Property="TypeBon">
                                        <Template Context="bon">
                                            <RadzenBadge Text="@(bon.TypeBon == "BEM" ? L["Appro_EntryType"].Value : L["Appro_ExitType"].Value)"
                                                         BadgeStyle="@(bon.TypeBon == "BEM" ? BadgeStyle.Info : BadgeStyle.Secondary)" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Reference"]" Width="180px" Property="NumeroReference">
                                        <Template Context="bon">
                                            <a href="@bon.Url" style="font-weight:700; color:var(--kcc-primary); text-decoration:none;">@bon.NumeroReference</a>
                                            <div style="font-size:0.75rem; color:var(--gray-500);">@bon.DateCreation.ToString("dd/MM/yyyy")</div>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Requester"]" Width="160px" Property="Demandeur">
                                        <Template Context="bon"><span>@(bon.Demandeur ?? "—")</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Description"]" Property="Description">
                                        <Template Context="bon"><span style="color:var(--gray-500); font-size:0.82rem;">@(bon.Description ?? "—")</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Status"]" Width="160px" Property="StatutLibelle">
                                        <Template Context="bon">
                                            <RadzenBadge Text="@bon.StatutLibelle" BadgeStyle="BadgeStyle.Warning" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_LastStep"]" Width="220px" Property="EtapeEnCours" Sortable="false">
                                        <Template Context="bon">
                                            @if (!string.IsNullOrWhiteSpace(bon.EtapeEnCours))
                                            {
                                                <div style="display:flex;align-items:flex-start;gap:0.35rem;margin-bottom:0.25rem;">
                                                    <RadzenIcon Icon="schedule" Style="font-size:0.9rem;color:#f59e0b;flex-shrink:0;margin-top:0.05rem;" />
                                                    <div>
                                                        <div style="font-size:0.78rem;color:#b45309;font-weight:700;line-height:1.2;">@bon.EtapeEnCours</div>
                                                        @if (!string.IsNullOrWhiteSpace(bon.ApprobateurEnCours))
                                                        {
                                                            <div style="font-size:0.7rem;color:var(--gray-500);">@bon.ApprobateurEnCours</div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bon.DerniereEtapeApprouvee))
                                            {
                                                <div style="display:flex;align-items:flex-start;gap:0.35rem;">
                                                    <RadzenIcon Icon="check_circle" Style="font-size:0.9rem;color:#16a34a;flex-shrink:0;margin-top:0.05rem;" />
                                                    <div>
                                                        <div style="font-size:0.75rem;color:#16a34a;font-weight:600;line-height:1.2;">@bon.DerniereEtapeApprouvee</div>
                                                        @if (!string.IsNullOrWhiteSpace(bon.DernierApprobateur))
                                                        {
                                                            <div style="font-size:0.7rem;color:var(--gray-500);">@bon.DernierApprobateur</div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            @if (string.IsNullOrWhiteSpace(bon.EtapeEnCours) && string.IsNullOrWhiteSpace(bon.DerniereEtapeApprouvee))
                                            {
                                                <span style="color:var(--gray-400);">—</span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Actions"]" Width="90px" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                                        <Template Context="bon">
                                            <RadzenButton Icon="visibility" Text="@L["Btn_View"].Value" Size="ButtonSize.Small"
                                                          ButtonStyle="ButtonStyle.Success" Variant="Variant.Filled"
                                                          Click="@(() => OpenDetailDialog(bon, canAct))"
                                                          Style="font-size:0.78rem;" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    </ChildContent>
                </RadzenTabsItem>
                <RadzenTabsItem Icon="input">
                    <Template>
                        <span>@L["Appro_EntryVouchers"]</span>
                        @if (pendingBonsEntree.Count > 0)
                        {
                            <RadzenBadge Text="@pendingBonsEntree.Count.ToString()" BadgeStyle="BadgeStyle.Info"
                                         Style="margin-left: 0.4rem; font-size: 0.7rem;" />
                        }
                    </Template>
                    <ChildContent>
                        @if (isLoading)
                        {
                            <RadzenCard>
                                <RadzenStack AlignItems="AlignItems.Center" Style="padding: 3rem;">
                                    <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                                </RadzenStack>
                            </RadzenCard>
                        }
                        else if (!pendingBonsEntree.Any())
                        {
                            <RadzenCard>
                                <RadzenStack AlignItems="AlignItems.Center" Style="padding: 3rem;" Gap="0.75rem">
                                    <RadzenIcon Icon="check_circle" Style="font-size:3.5rem; color:var(--kcc-green); opacity:0.4;" />
                                    <RadzenText TextStyle="TextStyle.H6" Style="color:var(--kcc-green); font-weight:600;">@L["Appro_NoPending"]</RadzenText>
                                </RadzenStack>
                            </RadzenCard>
                        }
                        else
                        {
                            <RadzenDataGrid TItem="ApprobationDto" Data="@pendingBonsEntree.OrderBy(a => a.DateCreation)"
                                            AllowSorting="true" AllowFiltering="true" AllowPaging="true" PageSize="15"
                                            PagerHorizontalAlign="HorizontalAlign.Center"
                                            GridLines="DataGridGridLines.Horizontal">
                                <Columns>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Type"]" Width="90px" Property="TypeBon">
                                        <Template Context="bon">
                                            <RadzenBadge Text="@(bon.TypeBon == "BEM" ? L["Appro_EntryType"].Value : L["Appro_ExitType"].Value)"
                                                         BadgeStyle="@(bon.TypeBon == "BEM" ? BadgeStyle.Info : BadgeStyle.Secondary)" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Reference"]" Width="180px" Property="NumeroReference">
                                        <Template Context="bon">
                                            <a href="@bon.Url" style="font-weight:700; color:var(--kcc-primary); text-decoration:none;">@bon.NumeroReference</a>
                                            <div style="font-size:0.75rem; color:var(--gray-500);">@bon.DateCreation.ToString("dd/MM/yyyy")</div>
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Requester"]" Width="160px" Property="Demandeur">
                                        <Template Context="bon"><span>@(bon.Demandeur ?? "—")</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Description"]" Property="Description">
                                        <Template Context="bon"><span style="color:var(--gray-500); font-size:0.82rem;">@(bon.Description ?? "—")</span></Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Status"]" Width="160px" Property="StatutLibelle">
                                        <Template Context="bon">
                                            <RadzenBadge Text="@bon.StatutLibelle" BadgeStyle="BadgeStyle.Warning" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_LastStep"]" Width="220px" Property="EtapeEnCours" Sortable="false">
                                        <Template Context="bon">
                                            @if (!string.IsNullOrWhiteSpace(bon.EtapeEnCours))
                                            {
                                                <div style="display:flex;align-items:flex-start;gap:0.35rem;margin-bottom:0.25rem;">
                                                    <RadzenIcon Icon="schedule" Style="font-size:0.9rem;color:#f59e0b;flex-shrink:0;margin-top:0.05rem;" />
                                                    <div>
                                                        <div style="font-size:0.78rem;color:#b45309;font-weight:700;line-height:1.2;">@bon.EtapeEnCours</div>
                                                        @if (!string.IsNullOrWhiteSpace(bon.ApprobateurEnCours))
                                                        {
                                                            <div style="font-size:0.7rem;color:var(--gray-500);">@bon.ApprobateurEnCours</div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(bon.DerniereEtapeApprouvee))
                                            {
                                                <div style="display:flex;align-items:flex-start;gap:0.35rem;">
                                                    <RadzenIcon Icon="check_circle" Style="font-size:0.9rem;color:#16a34a;flex-shrink:0;margin-top:0.05rem;" />
                                                    <div>
                                                        <div style="font-size:0.75rem;color:#16a34a;font-weight:600;line-height:1.2;">@bon.DerniereEtapeApprouvee</div>
                                                        @if (!string.IsNullOrWhiteSpace(bon.DernierApprobateur))
                                                        {
                                                            <div style="font-size:0.7rem;color:var(--gray-500);">@bon.DernierApprobateur</div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            @if (string.IsNullOrWhiteSpace(bon.EtapeEnCours) && string.IsNullOrWhiteSpace(bon.DerniereEtapeApprouvee))
                                            {
                                                <span style="color:var(--gray-400);">—</span>
                                            }
                                        </Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="ApprobationDto" Title="@L["Col_Actions"]" Width="90px" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                                        <Template Context="bon">
                                            <RadzenButton Icon="visibility" Text="@L["Btn_View"].Value" Size="ButtonSize.Small"
                                                          ButtonStyle="ButtonStyle.Success" Variant="Variant.Filled"
                                                          Click="@(() => OpenDetailDialog(bon, canAct))"
                                                          Style="font-size:0.78rem;" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    </ChildContent>
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>

    </main>
</div>

@code {
    private bool isLoading = true;
    private bool canAct; // false pour Admin/SuperAdmin

    private List<ApprobationDto> pendingBonsEntree = new();
    private List<ApprobationDto> pendingBonsSortie = new();
    private List<ApprobationDto> approvedBonsEntree = new();
    private List<ApprobationDto> approvedBonsSortie = new();

    protected override async Task OnInitializedAsync()
    {
        var niveau = CurrentUserService.NiveauAdmin;
        var isAdmin = niveau is KCCMaterialFlow.Domain.Enums.NiveauAdmin.Admin
                                or KCCMaterialFlow.Domain.Enums.NiveauAdmin.SuperAdmin;
        var isApprover = isAdmin || RoleCacheService.IsApprover(CurrentUserService.GetUserLogin());
        if (!isApprover)
        {
            NavigationManager.NavigateTo("/", replace: true);
            return;
        }
        // Admin/SuperAdmin voient la liste mais ne peuvent pas approuver/rejeter
        canAct = !isAdmin;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var bonsEntreeTask = BonEntreeService.GetPendingApprovalsAsync();
            var bonsSortieTask = BonSortieService.GetPendingApprovalsAsync();
            await Task.WhenAll(bonsEntreeTask, bonsSortieTask);

            var bonsEntree = bonsEntreeTask.Result;
            var bonsSortie = bonsSortieTask.Result;

            var bemApprobationTasks = bonsEntree.Select(async be =>
            {
                var dto = new ApprobationDto
                {
                    Id = be.Id,
                    TypeBon = "BEM",
                    NumeroReference = be.NumeroReference,
                    Demandeur = be.NomDemandeur,
                    Description = $"{be.NomCompagnie} - {be.ReasonOnSite}",
                    Provenance = be.Provenance,
                    Destination = be.Destination,
                    DateCreation = be.DateCreation,
                    StatutCode = be.StatutActuel,
                    StatutLibelle = GetStatutLibelle(be.StatutActuel),
                    NombreMateriels = be.Materiels?.Count ?? 0,
                    Url = $"/bon-entree/{be.Id}"
                };

                try
                {
                    var approbations = await BonEntreeService.GetApprobationsAsync(be.Id);
                    var derniereApprobation = approbations
                        .Where(a => a.Decision == "Approuvé" && a.DateAction != null)
                        .OrderByDescending(a => a.DateAction)
                        .FirstOrDefault();

                    if (derniereApprobation != null)
                    {
                        dto.DerniereEtapeApprouvee = derniereApprobation.NomEtape;
                        dto.DernierApprobateur = derniereApprobation.NomApprobateur;
                        dto.DateDerniereApprobation = derniereApprobation.DateAction;
                        dto.CommentaireDernierApprobateur = derniereApprobation.ReservesEventuelles;
                    }

                    var etapeEnCours = approbations
                        .FirstOrDefault(a => a.Decision == "En attente");

                    if (etapeEnCours != null)
                    {
                        dto.EtapeEnCours = etapeEnCours.NomEtape;
                        dto.ApprobateurEnCours = etapeEnCours.NomApprobateur;
                    }
                }
                catch { }

                return dto;
            });

            var bsmApprobationTasks = bonsSortie.Select(async bs =>
            {
                var dto = new ApprobationDto
                {
                    Id = bs.Id,
                    TypeBon = bs is BonSortieExterne ? "BSM" : "BSI",
                    NumeroReference = bs.NumeroReference,
                    Demandeur = bs.NomDemandeur,
                    Description = bs.MotifSortie,
                    Provenance = bs.Provenance,
                    Destination = bs.Destination,
                    DateCreation = bs.DateCreation,
                    StatutCode = bs.StatutActuel,
                    StatutLibelle = GetStatutLibelle(bs.StatutActuel),
                    NombreMateriels = bs.Materiels?.Count ?? 0,
                    Url = $"/bon-sortie/{bs.Id}"
                };

                try
                {
                    var approbations = await BonSortieService.GetApprobationsAsync(bs.Id);
                    var derniereApprobation = approbations
                        .Where(a => a.Decision == "Approuvé" && a.DateAction != null)
                        .OrderByDescending(a => a.DateAction)
                        .FirstOrDefault();

                    if (derniereApprobation != null)
                    {
                        dto.DerniereEtapeApprouvee = derniereApprobation.NomEtape;
                        dto.DernierApprobateur = derniereApprobation.NomApprobateur;
                        dto.DateDerniereApprobation = derniereApprobation.DateAction;
                        dto.CommentaireDernierApprobateur = derniereApprobation.ReservesEventuelles;
                    }

                    var etapeEnCours = approbations
                        .FirstOrDefault(a => a.Decision == "En attente");

                    if (etapeEnCours != null)
                    {
                        dto.EtapeEnCours = etapeEnCours.NomEtape;
                        dto.ApprobateurEnCours = etapeEnCours.NomApprobateur;
                    }
                }
                catch { }

                return dto;
            });

            pendingBonsEntree = (await Task.WhenAll(bemApprobationTasks)).ToList();
            pendingBonsSortie = (await Task.WhenAll(bsmApprobationTasks)).ToList();

            try
            {
                var approvedBemTask = BonEntreeService.GetApprovedByMeAsync();
                var approvedBsmTask = BonSortieService.GetApprovedByMeAsync();
                await Task.WhenAll(approvedBemTask, approvedBsmTask);

                approvedBonsEntree = approvedBemTask.Result.Select(be => new ApprobationDto
                {
                    Id = be.Id,
                    TypeBon = "BEM",
                    NumeroReference = be.NumeroReference,
                    Demandeur = be.NomDemandeur,
                    Description = $"{be.NomCompagnie} - {be.ReasonOnSite}",
                    DateCreation = be.DateCreation,
                    StatutCode = "Approved",
                    StatutLibelle = L["Status_Approved"].Value,
                    NombreMateriels = be.Materiels?.Count ?? 0,
                    Url = $"/bon-entree/{be.Id}"
                }).ToList();

                approvedBonsSortie = approvedBsmTask.Result.Select(bs => new ApprobationDto
                {
                    Id = bs.Id,
                    TypeBon = bs is KCCMaterialFlow.Domain.Entities.BonSortieExterne ? "BSM" : "BSI",
                    NumeroReference = bs.NumeroReference,
                    Demandeur = bs.NomDemandeur,
                    Description = bs.MotifSortie,
                    DateCreation = bs.DateCreation,
                    StatutCode = "Approved",
                    StatutLibelle = L["Status_Approved"].Value,
                    NombreMateriels = bs.Materiels?.Count ?? 0,
                    Url = $"/bon-sortie/{bs.Id}"
                }).ToList();
            }
            catch { }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenDetailDialog(ApprobationDto approbation, bool showActions)
    {
        var parameters = new Dictionary<string, object>
        {
            { "BonId", approbation.Id },
            { "TypeBon", approbation.TypeBon },
            { "ShowActions", showActions && canAct }
        };

        var result = await DialogService.OpenAsync<BonDetailDialog>(
            approbation.NumeroReference,
            parameters,
            new DialogOptions
            {
                Width = "960px",
                CloseDialogOnOverlayClick = false,
                ShowClose = false,
                Resizable = true,
                Draggable = true,
                CssClass = "kcc-dialog-clean"
            }
        );

        if (result is BonDetailDialog.DialogResult dialogResult && dialogResult.Success)
        {
            if (dialogResult.Action == "approved_final")
            {
                NotificationService.Notify(NotificationSeverity.Success, L["Msg_Approved"].Value, approbation.NumeroReference);
                if (approbation.TypeBon == "BEM")
                    pendingBonsEntree.RemoveAll(b => b.Id == approbation.Id);
                else
                    pendingBonsSortie.RemoveAll(b => b.Id == approbation.Id);

                var approvedDto = new ApprobationDto
                {
                    Id = approbation.Id,
                    TypeBon = approbation.TypeBon,
                    NumeroReference = approbation.NumeroReference,
                    Demandeur = approbation.Demandeur,
                    Description = approbation.Description,
                    DateCreation = approbation.DateCreation,
                    StatutCode = "Approved",
                    StatutLibelle = L["Status_Approved"].Value,
                    NombreMateriels = approbation.NombreMateriels,
                    Url = approbation.Url
                };
                if (approbation.TypeBon == "BEM")
                    approvedBonsEntree.Insert(0, approvedDto);
                else
                    approvedBonsSortie.Insert(0, approvedDto);
                StateHasChanged();
                var printUrl = approbation.TypeBon == "BEM"
                    ? $"/bon-entree/{approbation.Id}/print"
                    : $"/bon-sortie/{approbation.Id}/print";
                NavigationManager.NavigateTo(printUrl);
                return;
            }
            else if (dialogResult.Action == "approved")
            {
                NotificationService.Notify(NotificationSeverity.Success, L["Msg_Approved"].Value, approbation.NumeroReference);
            }
            else if (dialogResult.Action == "rejected")
            {
                NotificationService.Notify(NotificationSeverity.Warning, L["Msg_Rejected"].Value, approbation.NumeroReference);
            }

            if (approbation.TypeBon == "BEM")
                pendingBonsEntree.RemoveAll(b => b.Id == approbation.Id);
            else
                pendingBonsSortie.RemoveAll(b => b.Id == approbation.Id);

            StateHasChanged();
        }
    }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
    }

    private async Task QuickApprove(ApprobationDto approbation)
    {
        var commentaire = await ShowCommentDialog("Approuver", approbation.NumeroReference, true);
        if (commentaire == null) return;

        try
        {
            if (approbation.TypeBon == "BEM")
            {
                var request = new ApprovalRequest
                {
                    BonId = approbation.Id,
                    ReservesEventuelles = commentaire
                };
                var result = await BonEntreeService.ApproveAsync(request);
                if (result.Success)
                {
                    NotificationService.Notify(NotificationSeverity.Success, L["Msg_Approved"].Value, approbation.NumeroReference);
                    pendingBonsEntree.RemoveAll(b => b.Id == approbation.Id);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_ApprovalError"].Value);
                }
            }
            else
            {
                var request = new BonSortieApprovalRequest
                {
                    IdBon = approbation.Id,
                    Commentaire = commentaire
                };
                var result = await BonSortieService.ApproveAsync(request);
                if (result.Success)
                {
                    NotificationService.Notify(NotificationSeverity.Success, L["Msg_Approved"].Value, approbation.NumeroReference);
                    pendingBonsSortie.RemoveAll(b => b.Id == approbation.Id);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_ApprovalError"].Value);
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, ex.Message);
        }

        StateHasChanged();
    }

    private async Task QuickReject(ApprobationDto approbation)
    {
        var motif = await ShowCommentDialog("Rejeter", approbation.NumeroReference, false);
        if (motif == null) return;

        try
        {
            if (approbation.TypeBon == "BEM")
            {
                var request = new ApprovalRequest
                {
                    BonId = approbation.Id,
                    ReservesEventuelles = motif
                };
                var result = await BonEntreeService.RejectAsync(request);
                if (result.Success)
                {
                    NotificationService.Notify(NotificationSeverity.Warning, L["Msg_Rejected"].Value, approbation.NumeroReference);
                    pendingBonsEntree.RemoveAll(b => b.Id == approbation.Id);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_RejectionError"].Value);
                }
            }
            else
            {
                var request = new RejectRequest
                {
                    IdBon = approbation.Id,
                    Motif = motif
                };
                var result = await BonSortieService.RejectAsync(request);
                if (result.Success)
                {
                    NotificationService.Notify(NotificationSeverity.Warning, L["Msg_Rejected"].Value, approbation.NumeroReference);
                    pendingBonsSortie.RemoveAll(b => b.Id == approbation.Id);
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_RejectionError"].Value);
                }
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, ex.Message);
        }

        StateHasChanged();
    }

    private async Task<string?> ShowCommentDialog(string action, string numeroReference, bool isApproval)
    {
        var parameters = new Dictionary<string, object>
        {
            { "Action", action },
            { "NumeroReference", numeroReference },
            { "IsApproval", isApproval }
        };

        var result = await DialogService.OpenAsync<ApprovalCommentDialog>(
            $"{action} - {numeroReference}",
            parameters,
            new DialogOptions 
            { 
                Width = "500px", 
                Height = "380px",
                CloseDialogOnOverlayClick = false,
                ShowClose = true
            }
        );
        
        return result as string;
    }

    private string GetStatutLibelle(string code) => code?.ToUpperInvariant() switch
    {
        "PENDINGSUP" or "PENDING_SUP" or "PENDINGGM" or "PENDING_GM"
        or "PENDINGIT" or "PENDING_IT" or "PENDINGENV" or "PENDING_ENV"
        or "PENDINGOPJ" or "PENDING_OPJ" or "PENDINGIDENTIFICATION" or "PENDING_ID"
        or "PENDINGSUPERVISEUR"                                            => L["Status_Pending"].Value,
        "APPROVED"                                                         => L["Status_Approved"].Value,
        "REJECTED"                                                         => L["Status_Rejected"].Value,
        "DRAFT"                                                            => L["Status_Draft"].Value,
        "COMPLETED"                                                        => L["Status_Completed"].Value,
        "CANCELLED"                                                        => L["Status_Cancelled"].Value,
        "RETURNED"                                                         => L["Status_Returned"].Value,
        _                                                                  => code ?? "-"
    };

