            NotificationService.Notify(NotificationSeverity.Success, L["Msg_Success"], result.Message ?? L["Msg_Deleted"]);
            Navigation.NavigateTo("/bon-sortie");
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"], result.Message ?? L["Msg_UnexpectedError"].Value);
        }
    }

