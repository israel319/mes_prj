    private async Task PerformApproval(string commentaire)
    {
        var result = await BonSortieService.ApproveAsync(new BonSortieApprovalRequest
        {
            IdBon = Id,
            Commentaire = commentaire
        });

        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Msg_Success"], L["Msg_Submitted"]);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"], result.Message ?? L["Msg_UnexpectedError"].Value);
        }
    }

    private async Task PerformRejection(string motif)
    {
        var result = await BonSortieService.RejectAsync(new RejectRequest
        {
            IdBon = Id,
            Motif = motif
        });
        
        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Warning, L["Msg_Rejected"], L["Msg_BonRejected"]);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"], result.Message ?? L["Msg_UnexpectedError"].Value);
        }
    }

    private async Task PerformReturn(string raison)
    {
        var result = await BonSortieService.ReturnForModificationAsync(new BonSortieApprovalRequest
        {
            IdBon = Id,
            Commentaire = raison
        });

        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Info, L["Msg_Returned"], L["Msg_BonReturned"]);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"], result.Message ?? L["Msg_UnexpectedError"].Value);
        }
    }

    private async Task ShowReturnDialog()
    {
        var result = await DialogService.OpenAsync<ReturnLoanDialog>(
            "Enregistrer le retour",
