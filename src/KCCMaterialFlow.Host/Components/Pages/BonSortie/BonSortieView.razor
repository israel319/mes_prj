@* BSM View - Radzen Components *@
@page "/bon-sortie/{Id:int}"
@using BonSortieEntity = KCCMaterialFlow.Domain.Entities.BonSortie
@attribute [Authorize]
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject INotificationRejetService NotificationRejetService
@inject IWorkflowApprobateurSpecialService ApprobateurSpecialService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<PageTitle>@(bon?.NumeroReference ?? L["BsmV_PageTitle"].Value) - KCC</PageTitle>

<div class="kcp-page">

    @* ===== ÉTATS DE CHARGEMENT / ERREUR (hors hero) ===== *@
    @if (isLoading)
    {
        <div style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Medium" />
                <RadzenText TextStyle="TextStyle.Body1">@L["BsmV_Loading"]</RadzenText>
            </RadzenStack>
        </div>
    }
    else if (accessDenied)
    {
        <div style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="lock" Style="font-size: 3rem; color: var(--rz-danger);" />
                <RadzenText TextStyle="TextStyle.H6">@L["BemV_AccessDenied"]</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2">@L["BemV_AccessDeniedMsg"]</RadzenText>
                <RadzenButton Text="@L["Btn_Back"].Value" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Click="@GoBack" />
            </RadzenStack>
        </div>
    }
    else if (bon == null)
    {
        <div style="display:flex; justify-content:center; align-items:center; min-height:60vh;">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.75rem">
                <RadzenIcon Icon="error_outline" Style="font-size: 3rem; color: var(--rz-danger);" />
                <RadzenText TextStyle="TextStyle.H6">@L["BsmV_NotFound"]</RadzenText>
                <RadzenButton Text="@L["Btn_Back"].Value" Icon="arrow_back" ButtonStyle="ButtonStyle.Primary" Click="@GoBack" />
            </RadzenStack>
        </div>
    }
    else
    {
        @* ===== HERO ===== *@
        <div class="kcp-hero">
            <div class="kcp-hero-inner">
                <div>
                    @* Badges de statut *@
                    <div style="display:flex; gap:0.45rem; align-items:center; flex-wrap:wrap; margin-bottom:0.7rem;">
                        <RadzenBadge Text="@GetStatutLabel(bon.StatutActuel)" BadgeStyle="@GetStatusBadgeStyle()" />
                        <RadzenBadge Text="@GetTypeLabel()" BadgeStyle="@GetTypeBadgeStyle()" />
                    </div>
                    <h1 class="kcp-title">@bon.NomDemandeur</h1>
                    <p class="kcp-subtitle">
                        @bon.NumeroReference
                        &nbsp;•&nbsp;
                        @L["BemV_CreatedAt"] @bon.DateCreation.ToString("dd/MM/yyyy")
                        &nbsp;•&nbsp;
                        @L["BemF_Expires"] @bon.DateExpiration.ToString("dd/MM/yyyy")
                    </p>
                </div>
                @* Boutons d'action dans le hero *@
                <div class="kcp-hero-actions">
                    <a class="kcp-btn" @onclick="@GoBack" href="javascript:void(0)">
                        <RadzenIcon Icon="arrow_back" Style="font-size:1rem;" />
                        @L["Btn_Back"]
                    </a>
                    @if (bon.StatutActuel == "Draft" && CanEdit)
                    {
                        <a class="kcp-btn" href="/bon-sortie/@Id/modifier">
                            <RadzenIcon Icon="edit" Style="font-size:1rem;" />
                            @L["BemV_Edit"]
                        </a>
                    }
                    @if (CanDelete)
                    {
                        <button type="button" class="kcp-btn kcp-btn-danger" @onclick="@ShowDeleteDialog">
                            <RadzenIcon Icon="delete" Style="font-size:1rem;" />
                            @L["BemV_Delete"]
                        </button>
                    }
                    @if (CanSubmit)
                    {
                        <button type="button" class="kcp-btn kcp-btn-primary" @onclick="@SubmitForApproval">
                            <RadzenIcon Icon="send" Style="font-size:1rem;" />
                            @L["BemV_Submit"]
                        </button>
                    }
                    @if (CanApprove)
                    {
                        <button type="button" class="kcp-btn kcp-btn-success" @onclick="@ShowApproveDialog">
                            <RadzenIcon Icon="check" Style="font-size:1rem;" />
                            @L["BemV_Approve"]
                        </button>
                    }
                    @if (CanReject)
                    {
                        <button type="button" class="kcp-btn kcp-btn-danger" @onclick="@ShowRejectDialog">
                            <RadzenIcon Icon="close" Style="font-size:1rem;" />
                            @L["BemV_Reject"]
                        </button>
                    }
                    @if (bon is Pret pret2 && !pret2.EstRetourne && bon.StatutActuel == "Approved")
                    {
                        <button type="button" class="kcp-btn kcp-btn-primary" @onclick="@ShowReturnDialog">
                            <RadzenIcon Icon="assignment_return" Style="font-size:1rem;" />
                            @L["BsmV_LoanReturn"]
                        </button>
                    }
                    @if (bon.StatutActuel == "Approved" && !string.IsNullOrEmpty(bon.QRCodeBase64) && CanPrint)
                    {
                        <a class="kcp-btn" href="/bon-sortie/@Id/print">
                            <RadzenIcon Icon="print" Style="font-size:1rem;" />
                            @L["BemV_Print"]
                        </a>
                    }
                    @if (CanDownloadPdf)
                    {
                        <button type="button" class="kcp-btn" @onclick="@DownloadPdf">
                            <RadzenIcon Icon="picture_as_pdf" Style="font-size:1rem;" />
                            @L["BemV_DownloadPDF"]
                        </button>
                    }
                </div>
            </div>
        </div>

        @* ===== CONTENU PRINCIPAL FLOTTANT ===== *@
        <main class="kcp-main">

            @* === ALERTE RETOUR === *@
            @if (!string.IsNullOrEmpty(dernierCommentaireRetour) && bon.StatutActuel == "Draft")
            {
                <div class="conf-banner" style="background:#fff5e0; border-color:#f0c674;">
                    <span class="conf-icon"><RadzenIcon Icon="warning" /></span>
                    <p><strong>@L["BemV_ReturnModif"] —</strong> @dernierCommentaireRetour</p>
                </div>
            }

            @* === ALERTE PRÊT === *@
            @if (bon is Pret pret)
            {
                <RadzenAlert AlertStyle="@(pret.EstRetourne ? AlertStyle.Success : pret.EstEnRetard ? AlertStyle.Danger : AlertStyle.Info)"
                             ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small" Icon="schedule">
                    <strong>@L["BsmV_PretTitle"]</strong> @pret.DateRetourPrevue.ToString("dd/MM/yyyy")
                    @if (pret.EstRetourne)
                    {
                        <span> &#10003; @L["BsmV_ReturnedOn"] @pret.DateRetourEffective?.ToString("dd/MM/yyyy")</span>
                    }
                    else if (pret.EstEnRetard)
                    {
                        <span> &#9888; @L["BsmV_Overdue"] @pret.JoursRetard @L["BsmV_Days"]</span>
                    }
                </RadzenAlert>
            }


            @* === GRILLE DEUX COLONNES : gauche = infos+matériels | droite = workflow === *@
            <div style="display: grid; grid-template-columns: 1fr 380px; gap: 1rem; align-items: start;">

                @* ── COLONNE GAUCHE ── *@
                <div style="display: flex; flex-direction: column; gap: 1rem;">

                    @* Informations du demandeur *@
                    <div class="kcp-card">
                        <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 1rem;">
                            @L["BsmV_RequesterInfo"]
                        </h2>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem 1.5rem;">
                            <div>
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BsmF_NameLabel"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); font-weight:500;">@bon.NomDemandeur</div>
                            </div>
                            <div>
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BsmF_FunctionLabel"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827);">@(bon.FonctionDemandeur ?? "—")</div>
                            </div>
                            <div style="grid-column: span 2;">
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BsmF_DeptLabel"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827);">@(bon.DepartementDemandeur ?? "—")</div>
                            </div>
                            <div style="grid-column: span 2;">
                                <div style="font-size:0.75rem; font-weight:600; color:var(--kcc-f-text-muted,#6b7280); text-transform:uppercase; letter-spacing:.05em; margin-bottom:0.25rem;">@L["BsmV_ExitReason"]</div>
                                <div style="font-size:0.9rem; color:var(--kcc-f-text,#111827); min-height:2.5rem;">@(bon.MotifSortie ?? "—")</div>
                            </div>
                        </div>
                    </div>

                    @* Matériels *@
                    <div class="kcp-card">
                        <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 1rem;">
                            @L["BsmV_Materials"]
                        </h2>
                        <RadzenDataGrid TItem="MaterielSortie" Data="@bon.Materiels" Density="Density.Compact" AllowPaging="false">
                            <Columns>
                                <RadzenDataGridColumn TItem="MaterielSortie" Title="@L["BsmV_ColSerial"]" Width="120px">
                                    <Template Context="mat">
                                        <code>@(mat.CodeProduitSerial ?? "—")</code>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielSortie" Property="Designation" Title="@L["BsmV_ColDesc"]" />
                                <RadzenDataGridColumn TItem="MaterielSortie" Title="@L["BsmV_ColQty"]" Width="80px" TextAlign="TextAlign.Center">
                                    <Template Context="mat">
                                        <strong>@mat.Quantite.ToString("0.00")</strong>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielSortie" Title="@L["BonVue_ColFrom"]" Width="150px">
                                    <Template Context="mat">@bon.Provenance</Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielSortie" Title="@L["BonVue_ColTo"]" Width="150px">
                                    <Template Context="mat">@bon.Destination</Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                        <div class="totaux-row" style="justify-content: flex-end;">
                            <span><strong>@L["BsmV_Total"] :</strong> @bon.Materiels.Sum(m => m.Quantite).ToString("0.00")</span>
                        </div>
                    </div>

                    @* BEM associé (BSE Externe uniquement) *@
                    @if (bon is BonSortieExterne ext && ext.BonEntreeAssocieId.HasValue)
                    {
                        <div class="kcp-card" style="border: 1px solid var(--kcc-primary, #00B193);">
                            <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 0.75rem;">
                                @L["BsmV_AssocBem"]
                            </h2>
                            <a @onclick="@(() => Navigation.NavigateTo($"/bon-entree/{ext.BonEntreeAssocieId}"))"
                               style="display: inline-flex; align-items: center; gap: 0.45rem; color: var(--kcc-f-teal); font-weight: 600; cursor: pointer; text-decoration: none;">
                                <RadzenIcon Icon="link" Style="font-size: 1rem;" />
                                BEM-@ext.BonEntreeAssocieId
                                <RadzenIcon Icon="open_in_new" Style="font-size: 0.85rem;" />
                            </a>
                        </div>
                    }

                </div>

                @* ── COLONNE DROITE : WORKFLOW ── *@
                <div>
                    @if (bon.StatutActuel != "Draft")
                    {
                        <div class="kcp-card">
                            <h2 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:var(--kcc-primary,#00B193); margin:0 0 1rem;">
                                @L["BemV_Workflow"]
                            </h2>
                            @{
                                var appros = bon.Approbations.OrderBy(a => a.OrdreEtape).ToList();
                                var bonRejete = bon.StatutActuel == "Rejected";
                                var firstPending = bonRejete ? null : appros.FirstOrDefault(a => a.Decision == "En attente");
                            }
                            @if (appros.Any())
                            {
                                <RadzenStack Gap="0.4rem">
                                    @foreach (var a in appros)
                                    {
                                        var isCurrent = firstPending != null && a.Id == firstPending.Id;
                                        var isApproved = a.Decision is "Approuvé" or "Approuve";
                                        var isRejected = a.Decision is "Rejeté" or "Rejete";
                                        var isReturned = a.Decision is "Retourné" or "Retourne";
                                        var bgColor = isApproved ? "#dcfce7" : (isRejected || isReturned) ? "#fee2e2" : isCurrent ? "#fef3c7" : "var(--kcc-bg-subtle)";
                                        var borderColor = isApproved ? "#86efac" : (isRejected || isReturned) ? "#fca5a5" : isCurrent ? "#fcd34d" : "var(--kcc-border)";
                                        var iconColor = isApproved ? "#16a34a" : (isRejected || isReturned) ? "#dc2626" : isCurrent ? "#d97706" : "#9ca3af";
                                        var icon = isApproved ? "check_circle" : isRejected ? "cancel" : isReturned ? "replay" : isCurrent ? "pending" : "radio_button_unchecked";

                                        <RadzenCard Variant="Variant.Flat" Style="@($"background: {bgColor}; border: 1px solid {borderColor}; border-radius: 3px; padding: 0.5rem 0.75rem;")">
                                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                <RadzenIcon Icon="@icon" Style="@($"color: {iconColor};")" />
                                                <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0;">
                                                    <strong>@a.NomEtape</strong>
                                                    @if (isApproved || isRejected || isReturned)
                                                    {
                                                        <span style="color: var(--kcc-text-muted); margin-left: 0.5rem; font-size: 0.85em;">@(a.NomApprobateur ?? "—") • @a.DateAction?.ToString("dd/MM HH:mm")</span>
                                                    }
                                                    else if (isCurrent)
                                                    {
                                                        var pool = GetActiveApproversFor(a.CodeEtape, bon.SiteId).ToList();
                                                        @if (pool.Count > 0)
                                                        {
                                                            <span style="color: #d97706; margin-left: 0.5rem; font-size: 0.85em;">
                                                                @L["BemV_Pending"]
                                                                @if (pool.Count == 1)
                                                                {
                                                                    <span> — <strong>@pool[0]</strong></span>
                                                                }
                                                                else
                                                                {
                                                                    <span> — @string.Join(", ", pool)</span>
                                                                }
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span style="color: #d97706; margin-left: 0.5rem; font-size: 0.85em;">
                                                                @L["BemV_Pending"]
                                                                @if (!string.IsNullOrEmpty(a.NomApprobateur))
                                                                {
                                                                    <span> — <strong>@a.NomApprobateur</strong></span>
                                                                }
                                                            </span>
                                                        }
                                                    }
                                                </RadzenText>
                                            </RadzenStack>
                                        </RadzenCard>
                                    }
                                </RadzenStack>
                            }
                            else
                            {
                                @* Bon pré-migration : approuvé/rejeté sans lignes d'approbation détaillées *@
                                var legacyApproved = bon.StatutActuel is "Approved" or "Completed" or "ExitDone" or "Closed";
                                var legacyRejected = bon.StatutActuel == "Rejected";
                                var legacyBg = legacyApproved ? "#dcfce7" : legacyRejected ? "#fee2e2" : "#fef3c7";
                                var legacyBorder = legacyApproved ? "#86efac" : legacyRejected ? "#fca5a5" : "#fcd34d";
                                var legacyIconColor = legacyApproved ? "#16a34a" : legacyRejected ? "#dc2626" : "#d97706";
                                var legacyIcon = legacyApproved ? "check_circle" : legacyRejected ? "cancel" : "pending";
                                var legacyLabel = legacyApproved ? "Approuvé" : legacyRejected ? "Rejeté" : bon.StatutActuel;

                                <RadzenCard Variant="Variant.Flat" Style="@($"background: {legacyBg}; border: 1px solid {legacyBorder}; padding: 0.5rem 0.75rem;")">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <RadzenIcon Icon="@legacyIcon" Style="@($"color: {legacyIconColor};")" />
                                        <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0;">
                                            <strong>@legacyLabel</strong>
                                            <span style="color: var(--kcc-text-muted); margin-left: 0.5rem; font-size: 0.85em;">@L["BemV_PreMigration"]</span>
                                        </RadzenText>
                                    </RadzenStack>
                                </RadzenCard>
                            }

                            @if (bon.StatutActuel == "Rejected" && notificationRejet != null)
                            {
                                <div style="margin-top: 0.75rem;">
                                    <RadzenButton Text="@L["BemV_RejectDetails"].Value" Icon="visibility" ButtonStyle="ButtonStyle.Danger"
                                                  Size="ButtonSize.Small" Click="@ShowRejetDetailsDialog" />
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="kcp-card" style="text-align:center; padding:2rem 1rem; color:var(--kcc-f-text-muted,#6b7280);">
                            <RadzenIcon Icon="pending_actions" Style="font-size:2.5rem; opacity:.35;" />
                            <div style="margin-top:0.5rem; font-size:0.85rem;">@L["BemV_Draft"]</div>
                        </div>
                    }
                </div>

            </div>
        </main>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private BonSortieEntity? bon;
    private bool isLoading = true;
    private bool accessDenied = false;
    private string? dernierCommentaireRetour;
    private KCCMaterialFlow.Domain.Entities.NotificationRejet? notificationRejet;
    private IReadOnlyList<WorkflowApprobateurSpecial> _activeSpecials = Array.Empty<WorkflowApprobateurSpecial>();

    private static readonly string[] RolesPrivilegies = { "Admin", "Superviseur", "GM", "OPJ", "Identification", "Security", "IT", "Environnement" };
    
    private bool CanViewBon => bon != null && (
        CurrentUserService.IsInAnyRole(RolesPrivilegies) ||
        bon.NomDemandeur == CurrentUserService.GetUserDisplayName()
    );

    private bool CanEdit => bon?.StatutActuel == "Draft" && 
                           CurrentUserService.HasActivite("BSM_MODIFIER") &&
                           (CurrentUserService.IsInAnyRole("Admin", "Demandeur") ||
                            bon.NomDemandeur == CurrentUserService.GetUserDisplayName());

    private bool CanSubmit => bon?.StatutActuel == "Draft" && 
                             CurrentUserService.HasActivite("BSM_SOUMETTRE") &&
                             (CurrentUserService.IsInAnyRole("Admin", "Demandeur") ||
                              bon.NomDemandeur == CurrentUserService.GetUserDisplayName());

    private bool CanDelete => bon?.StatutActuel == "Draft" && 
                             CurrentUserService.HasActivite("BSM_SUPPRIMER") &&
                             (CurrentUserService.IsInAnyRole("Admin", "Demandeur") ||
                              bon.NomDemandeur == CurrentUserService.GetUserDisplayName());

    private bool CanApproveIT => CanApproveCurrentStep("ITDEPARTMENT");
    private bool CanApproveENV => CanApproveCurrentStep("ENVIRONMENTDEPARTMENT");
    private bool CanApproveSuperviseur => CanApproveCurrentStep("REPORTSTO");
    private bool CanApproveGM => CanApproveCurrentStep("GM");
    private bool CanApproveOPJ => CanApproveCurrentStep("OPJ");
    private bool CanApproveIdentification => CanApproveCurrentStep("IDENTIFICATION");

    private bool CanApprove => CanApproveCurrentStep(null);

    /// <summary>True si l'utilisateur courant est l'approbateur de l'étape en attente.
    /// Si <paramref name="codeEtapeFilter"/> est fourni, l'étape doit aussi correspondre à ce code.</summary>
    private bool CanApproveCurrentStep(string? codeEtapeFilter)
    {
        if (bon == null) return false;
        if (!CurrentUserService.HasActivite("BSM_APPROUVER")) return false;
        var current = bon.Approbations?
            .Where(a => a.Decision == "En attente")
            .OrderBy(a => a.OrdreEtape)
            .FirstOrDefault();
        if (current == null) return false;
        if (codeEtapeFilter != null &&
            !string.Equals(current.CodeEtape, codeEtapeFilter, StringComparison.OrdinalIgnoreCase))
            return false;
        // Pas de bypass Admin/SuperAdmin : seul l'approbateur désigné de l'étape
        // en cours peut agir. La chaîne d'approbation doit être respectée.
        return CurrentUserService.EmployeeId.HasValue
            && current.ApprobateurId == CurrentUserService.EmployeeId.Value;
    }

    private bool CanReject => CanApprove && CurrentUserService.HasActivite("BSM_REJETER");

    private bool CanReturn => CanApprove && CurrentUserService.HasActivite("BSM_RETOURNER");

    private bool CanPrint => bon?.StatutActuel == "Approved" && IsLastApprover();

    private bool IsLastApprover()
    {
        if (bon == null) return false;
        var lastApproved = bon.Approbations
            .Where(a => a.Decision is "Approuv\u00e9" or "Approuve")
            .OrderByDescending(a => a.OrdreEtape)
            .FirstOrDefault();
        if (lastApproved == null) return false;
        if (CurrentUserService.IsAdmin) return true;
        if (lastApproved.ApprobateurId.HasValue && CurrentUserService.EmployeeId.HasValue
            && lastApproved.ApprobateurId == CurrentUserService.EmployeeId)
            return true;
        var login = CurrentUserService.GetUserLogin()?.Trim().ToLowerInvariant() ?? "";
        var bs = login.LastIndexOf('\\');
        if (bs >= 0) login = login[(bs + 1)..];
        var at = login.IndexOf('@');
        if (at >= 0) login = login[..at];
        var approvalLogin = lastApproved.ApprobateurLogin?.Trim().ToLowerInvariant() ?? "";
        var bsA = approvalLogin.LastIndexOf('\\');
        if (bsA >= 0) approvalLogin = approvalLogin[(bsA + 1)..];
        var atA = approvalLogin.IndexOf('@');
        if (atA >= 0) approvalLogin = approvalLogin[..atA];
        if (!string.IsNullOrEmpty(login) && !string.IsNullOrEmpty(approvalLogin) && login == approvalLogin)
            return true;
        var mat = lastApproved.ApprobateurMatricule?.Trim().ToUpperInvariant() ?? "";
        var curMat = CurrentUserService.Matricule?.Trim().ToUpperInvariant() ?? "";
        return !string.IsNullOrEmpty(mat) && !string.IsNullOrEmpty(curMat) && mat == curMat;
    }

    private bool CanDownloadPdf => CurrentUserService.IsInAnyRole("Identification");

    protected override async Task OnInitializedAsync()
    {
        await LoadBonAsync();
    }

    private async Task LoadBonAsync()
    {
        isLoading = true;
        accessDenied = false;
        try
        {
            bon = await BonSortieService.GetAsync(Id);
            _activeSpecials = await ApprobateurSpecialService.GetAllAsync();
            
            if (bon != null && bon.StatutActuel == "Draft")
            {
                var dernierRetour = bon.Historiques
                    .Where(h => h.ActionDescription == "Retour")
                    .OrderByDescending(h => h.ActionDate)
                    .FirstOrDefault();
                
                if (dernierRetour != null)
                {
                    dernierCommentaireRetour = dernierRetour.Comment?.Replace("Retourné pour modification: ", "");
                }
            }
            
            if (bon != null && !CanViewBon)
            {
                accessDenied = true;
                bon = null;
                NotificationService.Notify(NotificationSeverity.Warning, L["BemV_AccessDenied"], 
                    L["BemV_AccessDeniedMsg"]);
                return;
            }
            
            if (bon != null && bon.StatutActuel == "Rejected")
            {
                notificationRejet = await NotificationRejetService.GetByNumeroReferenceAsync(bon.NumeroReference);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"], ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

