    private async Task SubmitForApproval()
    {
        var result = await BonSortieService.SubmitForApprovalAsync(Id);
        if (result.Success)
        {
            NotificationService.Notify(NotificationSeverity.Success, L["Msg_Success"], L["Msg_Approved"]);
            await LoadBonAsync();
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Msg_Error"], result.Message ?? L["Msg_UnexpectedError"].Value);
        }
    }

    private async Task ShowApproveDialog()
    {
        var result = await DialogService.OpenAsync<ApprovalDialog>(
            L["Dlg_ApproveLabel"],
            new Dictionary<string, object> { { "IsReject", false } },
            new DialogOptions { Width = "450px" }
        );
        
        if (result is string commentaire)
        {
            await PerformApproval(commentaire);
        }
    }

    private async Task ShowRejectDialog()
    {
        var result = await DialogService.OpenAsync<ApprovalDialog>(
            L["Dlg_RejectLabel"],
            new Dictionary<string, object> { { "IsReject", true } },
            new DialogOptions { Width = "450px" }
        );
        
