    {
        Pret => "Prêt",
        BonSortieInterne => "Interne",
        BonSortieExterne => "Externe",
        _ => "Sortie"
    };

    private string GetTypeBadgeClass() => bon switch
    {
        BonSortieExterne => "badge-externe",
        _ => "badge-interne"
    };

    private string GetDescriptionMateriel() => bon switch
    {
        BonSortieExterne e => e.DescriptionMateriel ?? "(non spécifié)",
        BonSortieInterne i => i.DescriptionMateriel ?? "(non spécifié)",
        _ => "(non spécifié)"
    };

    private IEnumerable<string> GetActiveApproversFor(string? codeEtape, int? siteId)
    {
        if (_activeSpecials.Count == 0) yield break;
        TypeApprobateurSpecial? type = codeEtape?.ToUpperInvariant() switch
        {
            "OPJ" => TypeApprobateurSpecial.OPJ,
            "IDENTIFICATION" => TypeApprobateurSpecial.Identification,
            _ => null
        };
        if (type == null) yield break;
        var candidates = _activeSpecials.Where(s => s.Type == type.Value && s.EstActif).ToList();
        if (type == TypeApprobateurSpecial.OPJ)
        {
            var siteSpecific = candidates.Where(x => x.SiteId == siteId).ToList();
            var pool = siteSpecific.Count > 0 ? siteSpecific : candidates.Where(x => x.SiteId == null).ToList();
            foreach (var p in pool.OrderBy(x => x.Ordre))
                yield return p.Employee?.NomComplet ?? $"#{p.EmployeeId}";
        }
        else
        {
            foreach (var p in candidates.OrderBy(x => x.Ordre))
                yield return p.Employee?.NomComplet ?? $"#{p.EmployeeId}";
        }
    }

    private string GetStatutLabel(string? s) => s?.ToUpperInvariant() switch
    {
        "DRAFT" => L["Statut_Draft"].Value,
        "APPROVED" => L["Statut_Approved"].Value,
        "REJECTED" => L["Statut_Rejected"].Value,
        "RETURNED" => L["Statut_Returned"].Value,
        "CANCELLED" => L["Statut_Cancelled"].Value,
        // Tout statut Pending* → libellé générique. Le nom réel de l'approbateur courant
        // est affiché dans le badge "Chez {nom}" à côté (voir GetCurrentApproverName).
        _ when (s ?? "").ToUpperInvariant().StartsWith("PENDING") => L["Lbl_Pending"].Value,
        _ => s ?? "-"
    };

    private string GetStatusBadgeClass() => bon?.StatutActuel?.ToUpperInvariant() switch
    {
        "APPROVED" => "badge-approved",
        "REJECTED" => "badge-rejected",
        "DRAFT" => "badge-draft",
        _ when bon?.StatutActuel != null && bon.StatutActuel.ToUpperInvariant().StartsWith("PENDING") => "badge-pending",
        _ => "badge-draft"
    };

    private BadgeStyle GetStatusBadgeStyle() => bon?.StatutActuel?.ToUpperInvariant() switch
    {
        "APPROVED" => BadgeStyle.Success,
        "REJECTED" => BadgeStyle.Danger,
        "DRAFT" => BadgeStyle.Light,
        "RETURNED" => BadgeStyle.Warning,
        _ when bon?.StatutActuel != null && bon.StatutActuel.ToUpperInvariant().StartsWith("PENDING") => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };

    private BadgeStyle GetTypeBadgeStyle() => bon switch
    {
        BonSortieExterne => BadgeStyle.Info,
        _ => BadgeStyle.Secondary
    };

    /// <summary>Nom de l'approbateur en attente actuel (étape courante de la chaîne).</summary>
    private string? GetCurrentApproverName()
    {
        if (bon == null || bon.StatutActuel is "Draft" or "Approved" or "Rejected" or "Cancelled")
            return null;
        var current = bon.Approbations?
            .Where(a => a.Decision == "En attente")
            .OrderBy(a => a.OrdreEtape)
            .FirstOrDefault();
        return current?.NomApprobateur;
    }

