@* BSM-066: Dropdown TypeMateriel avec icônes/couleurs *@
@using KCCMaterialFlow.Domain.Enums

<div class="type-materiel-selector">
    <RadzenLabel Text="@Label" Style="font-size: 0.75rem; font-weight: 600; color: #888;" />
    <RadzenDropDown @bind-Value="@Value" Data="@options" TextProperty="Text" ValueProperty="Value"
        Style="width: 100%;" Placeholder="Sélectionner le type..." Disabled="@Disabled"
        Change="@OnValueChanged">
        <Template Context="option">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <div style="@GetIconStyle(((TypeOption)option).Value)">
                    <RadzenIcon Icon="@GetIcon(((TypeOption)option).Value)" Style="font-size: 1.2rem;" />
                </div>
                <span>@((TypeOption)option).Text</span>
            </RadzenStack>
        </Template>
        <ValueTemplate Context="option">
            @if (option != null)
            {
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <div style="@GetIconStyle(((TypeOption)option).Value)">
                        <RadzenIcon Icon="@GetIcon(((TypeOption)option).Value)" Style="font-size: 1.2rem;" />
                    </div>
                    <span>@((TypeOption)option).Text</span>
                </RadzenStack>
            }
        </ValueTemplate>
    </RadzenDropDown>
    
    @if (!string.IsNullOrEmpty(HelpText))
    {
        <RadzenText TextStyle="TextStyle.Caption" Style="color: #6c757d; margin-top: 0.25rem;">
            @HelpText
        </RadzenText>
    }
</div>

@code {
    [Parameter] public TypeMateriel Value { get; set; }
    [Parameter] public EventCallback<TypeMateriel> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Type de Matériel *";
    [Parameter] public string? HelpText { get; set; }
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool ShowAll { get; set; } = true;

    private List<TypeOption> options = new();

    protected override void OnInitialized()
    {
        options = new List<TypeOption>
        {
            new("Circulaire", TypeMateriel.Circulaire),
            new("Informatique", TypeMateriel.Informatique),
            new("Fin de Chantier", TypeMateriel.FinChantier),
            new("Résidu / Déchet", TypeMateriel.Residu),
            new("Radioprotection", TypeMateriel.Radioprotection),
            new("Modification", TypeMateriel.Modification),
            new("Prêt", TypeMateriel.Pret),
            new("Autre", TypeMateriel.Autre)
        };
    }

    private async Task OnValueChanged(object args)
    {
        if (args is TypeMateriel type)
        {
            await ValueChanged.InvokeAsync(type);
        }
    }

    private string GetIcon(TypeMateriel type)
    {
        if (type == TypeMateriel.Informatique) return "computer";
        if (type == TypeMateriel.Residu) return "eco";
        if (type == TypeMateriel.Radioprotection) return "eco";
        if (type == TypeMateriel.Circulaire) return "autorenew";
        if (type == TypeMateriel.Pret) return "assignment_return";
        if (type == TypeMateriel.FinChantier) return "construction";
        if (type == TypeMateriel.Modification) return "build";
        return "inventory_2";
    }

    private string GetIconStyle(TypeMateriel type)
    {
        string color;
        if (type == TypeMateriel.Informatique) color = "#0d6efd";
        else if (type == TypeMateriel.Residu || type == TypeMateriel.Radioprotection) color = "#198754";
        else if (type == TypeMateriel.Circulaire) color = "#fd7e14";
        else if (type == TypeMateriel.Pret) color = "#6f42c1";
        else color = "#6c757d";
        return $"width: 28px; height: 28px; border-radius: 6px; background-color: {color}20; color: {color}; display: flex; align-items: center; justify-content: center;";
    }

    private record TypeOption(string Text, TypeMateriel Value);
}
