@* BSM-067: Composant recherche bon d'entrée *@
@inject IBonSortieService BonSortieService
@inject NotificationService Notification

<div class="bon-entree-searcher">
    <RadzenLabel Text="@Label" Style="font-size: 0.75rem; font-weight: 600; color: #888;" />
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
        <RadzenTextBox @bind-Value="@searchText" Placeholder="ID du BEM..." Style="flex: 1;"
            @onkeydown="@HandleKeyDown" Disabled="@(IsLoading || Disabled)" />
        <RadzenButton Icon="search" ButtonStyle="ButtonStyle.Primary" Click="@SearchAsync" 
            IsBusy="@IsLoading" Disabled="@(string.IsNullOrWhiteSpace(searchText) || Disabled)" />
        @if (SelectedBonEntreeId.HasValue)
        {
            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Click="@Clear" Disabled="@Disabled" />
        }
    </RadzenStack>

    @if (IsLoading)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" 
            Style="height: 3px; margin-top: 0.25rem;" />
    }

    @if (errorMessage != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" 
            Size="AlertSize.Small" Style="margin-top: 0.5rem;">
            @errorMessage
        </RadzenAlert>
    }

    @if (SelectedBonEntreeId.HasValue && selectedResult != null)
    {
        <RadzenCard Variant="Variant.Flat" Style="margin-top: 0.75rem; border: 1px solid #28a745; border-radius: 8px; background-color: #d4edda;">
            <RadzenStack Gap="0.5rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="check_circle" Style="color: #28a745; font-size: 1.5rem;" />
                    <RadzenText TextStyle="TextStyle.Subtitle1" FontWeight="FontWeight.Bold" Style="color: #155724;">
                        @selectedResult.NumeroReference
                    </RadzenText>
                </RadzenStack>
                @if (!string.IsNullOrEmpty(selectedResult.NomCompagnie))
                {
                    <RadzenText TextStyle="TextStyle.Body2">@selectedResult.NomCompagnie</RadzenText>
                }
            </RadzenStack>
        </RadzenCard>
    }
</div>

@code {
    [Parameter] public int? SelectedBonEntreeId { get; set; }
    [Parameter] public EventCallback<int?> SelectedBonEntreeIdChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Bon d'Entrée Associé (BEM) *";
    [Parameter] public bool Disabled { get; set; } = false;
    [Parameter] public bool Required { get; set; } = true;

    private string searchText = "";
    private string? errorMessage;
    private bool IsLoading = false;
    private BonEntreeAvailabilityResult? selectedResult;

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(searchText)) return;

        IsLoading = true;
        errorMessage = null;

        try
        {
            if (!int.TryParse(searchText.Trim(), out var bonId))
            {
                errorMessage = "Veuillez entrer un ID numérique valide";
                return;
            }

            var result = await BonSortieService.CheckBonEntreeAvailabilityAsync(bonId);

            if (result.IsAvailable)
            {
                selectedResult = result;
                SelectedBonEntreeId = bonId;
                await SelectedBonEntreeIdChanged.InvokeAsync(bonId);
                searchText = "";
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "BEM non trouvé ou non disponible";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task Clear()
    {
        SelectedBonEntreeId = null;
        selectedResult = null;
        searchText = "";
        errorMessage = null;
        await SelectedBonEntreeIdChanged.InvokeAsync(null);
    }
}
