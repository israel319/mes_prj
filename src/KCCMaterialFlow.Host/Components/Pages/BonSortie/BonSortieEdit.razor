@* BSM-051: Formulaire de modification - Style moderne *@
@page "/bon-sortie/{Id:int}/modifier"
@using BonSortieEntity = KCCMaterialFlow.Domain.Entities.BonSortie
@attribute [Authorize]
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject IReferenceDataService ReferenceDataService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime

<PageTitle>Modifier BSM - KCC Material Flow</PageTitle>

<div class="edit-container">
    @if (isLoading)
    {
        <div style="text-align: center; padding: 4rem;">
            <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Large" />
            <p style="margin-top: 1rem; color: #64748b;">Chargement...</p>
        </div>
    }
    else if (bon == null)
    {
        <div style="text-align: center; padding: 4rem;">
            <RadzenIcon Icon="error_outline" Style="font-size: 64px; color: #dc2626;" />
            <h3 style="margin-top: 1rem;">Bon de sortie non trouvé</h3>
            <RadzenButton Text="Retour" Click="GoBack" Style="margin-top: 1rem;" />
        </div>
    }
    else if (!CanEdit)
    {
        <div style="text-align: center; padding: 4rem;">
            <RadzenIcon Icon="lock" Style="font-size: 64px; color: #f59e0b;" />
            <h3 style="margin-top: 1rem;">Ce bon ne peut plus être modifié</h3>
            <p style="color: #64748b;">Statut actuel : @GetStatutLabel(bon.StatutActuel)</p>
            <RadzenButton Text="Retour" Click="GoBack" Style="margin-top: 1rem;" />
        </div>
    }
    else
    {
        @* Header *@
        <div class="edit-header">
            <div class="header-left">
                <RadzenButton Icon="arrow_back" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Click="@GoBack" />
                <h1 class="page-title">Modifier @bon.NumeroReference</h1>
            </div>
            <RadzenBadge Text="@GetStatutLabel(bon.StatutActuel)" BadgeStyle="@GetStatusBadgeStyle(bon.StatutActuel)" />
        </div>

        @* Info Banner *@
        <div class="info-banner">
            <span>
                <strong>Type:</strong> @GetTypeLabel(bon) &nbsp;|&nbsp;
                <strong>Créé le:</strong> @bon.DateCreation.ToString("dd/MM/yyyy à HH:mm")
            </span>
        </div>

        <EditForm Model="@model" OnValidSubmit="@HandleSubmit">
            <DataAnnotationsValidator />

            @* === SECTION: Informations Demandeur === *@
            <div class="section-card">
                <div class="section-header">
                    <RadzenIcon Icon="person" /> Informations Demandeur
                </div>
                <div class="section-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <RadzenLabel Text="Demandeur" />
                            <RadzenTextBox Value="@bon.NomDemandeur" ReadOnly="true" Style="width: 100%;" />
                        </div>
                        <div class="form-group">
                            <RadzenLabel Text="Fonction" />
                            <RadzenTextBox @bind-Value="model.FonctionDemandeur" Style="width: 100%;" />
                        </div>
                        <div class="form-group">
                            <RadzenLabel Text="Département" />
                            <RadzenTextBox @bind-Value="model.DepartementDemandeur" Style="width: 100%;" />
                        </div>
                    </div>
                </div>
            </div>

            @* === SECTION: Raison de Sortie === *@
            <div class="section-card">
                <div class="section-header">
                    <RadzenIcon Icon="category" /> Raison de Sortie
                </div>
                <div class="section-body">
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Type de Matériel <small style="color: #94a3b8;">(dérivé du motif)</small></label>
                            <RadzenDropDown @bind-Value="model.TypeMateriel" Data="@typeMaterielOptions"
                                            TextProperty="Text" ValueProperty="Value"
                                            Style="width: 100%;" Disabled="true" />
                        </div>
                        <div class="form-group" style="display: flex; align-items: flex-end;">
                            <RadzenBadge Text="@GetRaisonLabel(model.TypeMateriel)" BadgeStyle="@GetRaisonBadgeStyle(model.TypeMateriel)" />
                        </div>
                    </div>
                </div>
            </div>

            @* === SECTION: Trajet & Destination === *@
            <div class="section-card">
                <div class="section-header">
                    <RadzenIcon Icon="local_shipping" /> Trajet & Destination
                </div>
                <div class="section-body">
                    <div class="trajet-visual" style="margin-bottom: 1.25rem;">
                        <div class="trajet-point">
                            <div class="trajet-label">Provenance (FROM)</div>
                            <RadzenDropDown @bind-Value="model.Provenance" Data="@sitesOptions"
                                            TextProperty="Text" ValueProperty="Value"
                                            Placeholder="Sélectionner..." AllowClear="true"
                                            Style="min-width: 150px; background: white;" />
                        </div>
                        <span class="trajet-arrow">→</span>
                        <div class="trajet-point">
                            <div class="trajet-label">Destination (TO)</div>
                            <RadzenDropDown @bind-Value="model.Destination" Data="@sitesOptions"
                                            TextProperty="Text" ValueProperty="Value"
                                            Placeholder="Sélectionner..." AllowClear="true"
                                            Style="min-width: 150px; background: white;" />
                        </div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <RadzenLabel Text="Description" />
                            <RadzenTextBox @bind-Value="model.Description" Placeholder="Description optionnelle..." Style="width: 100%;" />
                        </div>
                        @if (IsExterne || IsPret)
                        {
                            <div class="form-group">
                                <RadzenLabel Text="Nom Destinataire" />
                                <RadzenTextBox @bind-Value="model.NomDestinataire" Style="width: 100%;" />
                            </div>
                            <div class="form-group">
                                <RadzenLabel Text="Adresse Destination" />
                                <RadzenTextBox @bind-Value="model.AdresseDestination" Style="width: 100%;" />
                            </div>
                        }

                    </div>
                </div>
            </div>

            @* === SECTION: Véhicule (pour Externe/Prêt) === *@
            @if (IsExterne || IsPret)
            {
                <div class="section-card">
                    <div class="section-header">
                        <RadzenIcon Icon="directions_car" /> Véhicule & Chauffeur
                    </div>
                    <div class="section-body">
                        <div class="form-grid">
                            <div class="form-group">
                                <RadzenLabel Text="Numéro Véhicule" />
                                <RadzenTextBox @bind-Value="model.NumeroVehicule" Placeholder="Ex: ABC-123" Style="width: 100%;" />
                            </div>
                            <div class="form-group">
                                <RadzenLabel Text="Nom Chauffeur" />
                                <RadzenTextBox @bind-Value="model.NomChauffeur" Style="width: 100%;" />
                            </div>
                            <div class="form-group">
                                <RadzenLabel Text="Téléphone Chauffeur" />
                                <RadzenTextBox @bind-Value="model.TelephoneChauffeur" Placeholder="+243..." Style="width: 100%;" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* === SECTION: Date Retour (pour Prêt) === *@
            @if (IsPret)
            {
                <div class="section-card">
                    <div class="section-header">
                        <RadzenIcon Icon="event" /> Date de Retour Prévue
                    </div>
                    <div class="section-body">
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Date de Retour</label>
                                <RadzenDatePicker @bind-Value="model.DateRetourPrevue" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Date d'Expiration</label>
                                <RadzenDatePicker @bind-Value="model.DateExpiration" DateFormat="dd/MM/yyyy" Style="width: 100%;" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* === SECTION: Motif de Sortie === *@
            <div class="section-card">
                <div class="section-header">
                    <RadzenIcon Icon="description" /> Motif de Sortie
                </div>
                <div class="section-body">
                    <div class="form-group">
                        <RadzenLabel Text="Motif *" />
                        <RadzenTextArea @bind-Value="model.MotifSortie" Placeholder="Décrivez le motif de cette sortie..." Rows="3" Style="width: 100%;" />
                    </div>
                </div>
            </div>

            @* === SECTION: Matériels === *@
            <div class="section-card">
                <div class="section-header">
                    <RadzenIcon Icon="inventory_2" /> Matériels (@model.Materiels.Count articles)
                </div>
                <div class="section-body" style="padding: 0;">
                    @if (model.Materiels.Any())
                    {
                        <table class="materiels-table">
                            <thead>
                                <tr>
                                    <th style="width: 40%;">Désignation</th>
                                    <th style="width: 30%;">N° Série / Code</th>
                                    <th style="width: 15%;">Quantité</th>
                                    <th style="width: 15%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mat in model.Materiels)
                                {
                                    <tr>
                                        <td class="input-cell">
                                            <RadzenTextBox @bind-Value="mat.Designation" Placeholder="Désignation..." Style="width: 100%;" />
                                        </td>
                                        <td class="input-cell">
                                            <RadzenTextBox @bind-Value="mat.CodeProduitSerial" Placeholder="N° série..." Style="width: 100%;" />
                                        </td>
                                        <td class="input-cell">
                                            <RadzenNumeric @bind-Value="mat.Quantite" Min="1" Style="width: 100%;" />
                                        </td>
                                        <td style="text-align: center;">
                                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                                          Click="@(() => RemoveMateriel(mat))" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-materiels">
                            <RadzenIcon Icon="inventory_2" Style="font-size: 32px; opacity: 0.5;" />
                            <p>Aucun matériel ajouté</p>
                        </div>
                    }
                    <div style="padding: 0 1rem 1rem 1rem;">
                        <RadzenButton Text="Ajouter un matériel" Icon="add" ButtonStyle="ButtonStyle.Success" Variant="Variant.Outlined"
                                      Click="@AddMateriel" ButtonType="ButtonType.Button" />
                    </div>
                </div>
            </div>

            @* === Actions Footer === *@
            <div class="actions-footer">
                <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" ButtonType="ButtonType.Button"
                              Click="@GoBack" />
                <RadzenButton Text="@(isSubmitting ? "Enregistrement..." : "Enregistrer les modifications")" 
                              ButtonStyle="ButtonStyle.Primary" Icon="save" ButtonType="ButtonType.Submit"
                              Disabled="@isSubmitting" IsBusy="@isSubmitting" />
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private BonSortieEntity? bon;
    private EditModel model = new();
    private bool isLoading = true;
    private bool isSubmitting = false;

    private bool CanEdit => bon?.StatutActuel == "Draft" || bon?.StatutActuel == "Returned";
    private bool IsExterne => bon is BonSortieExterne && bon is not Pret;
    private bool IsInterne => bon is BonSortieInterne;
    private bool IsPret => bon is Pret;

    // Navigation retour via historique
    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    private List<object> typeMaterielOptions = new()
    {
        new { Text = "Circulaire", Value = TypeMateriel.Circulaire },
        new { Text = "Informatique", Value = TypeMateriel.Informatique },
        new { Text = "Fin de Chantier", Value = TypeMateriel.FinChantier },
        new { Text = "Résidu", Value = TypeMateriel.Residu },
        new { Text = "Radioprotection", Value = TypeMateriel.Radioprotection },
        new { Text = "Modification", Value = TypeMateriel.Modification },
        new { Text = "Prêt", Value = TypeMateriel.Pret },
        new { Text = "Autre", Value = TypeMateriel.Autre }
    };

    private List<object> sitesOptions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSitesAsync();
        await LoadBonAsync();
    }

    private async Task LoadSitesAsync()
    {
        var sitesList = (await ReferenceDataService.GetSitesAsync())
            .OrderBy(s => s.OrdreAffichage)
            .ThenBy(s => s.Code)
            .Select(s => new { Text = s.Code ?? s.Nom, Value = s.Code ?? s.Nom });
        
        sitesOptions = sitesList.Cast<object>().ToList();
    }

    private async Task LoadBonAsync()
    {
        isLoading = true;
        try
        {
            bon = await BonSortieService.GetAsync(Id);
            if (bon != null)
            {
                model = new EditModel
                {
                    FonctionDemandeur = bon.FonctionDemandeur ?? "",
                    DepartementDemandeur = bon.DepartementDemandeur ?? "",
                    TypeMateriel = GetTypeMateriel(bon),
                    Provenance = bon.Provenance ?? "",
                    Destination = bon.Destination ?? "",
                    Description = bon.Description ?? "",
                    MotifSortie = bon.MotifSortie ?? "",
                    DateExpiration = bon.DateExpiration,
                    Materiels = bon.Materiels?.Select(m => new MaterielEditModel
                    {
                        IdMateriel = m.Id,
                        Designation = m.Designation ?? "",
                        CodeProduitSerial = m.CodeProduitSerial ?? "",
                        Quantite = m.Quantite
                    }).ToList() ?? new()
                };

                // Charger les champs spécifiques selon le type
                if (bon is BonSortieExterne ext)
                {
                    model.NomDestinataire = ext.NomDestinataire ?? "";
                    model.AdresseDestination = ext.AdresseDestination ?? "";
                    model.NumeroVehicule = ext.NumeroVehicule ?? "";
                    model.NomChauffeur = ext.NomChauffeur ?? "";
                    model.TelephoneChauffeur = ext.TelephoneChauffeur ?? "";
                }

                if (bon is Pret pret)
                {
                    model.DateRetourPrevue = pret.DateRetourPrevue;
                }

                // BonSortieInterne: aucun champ spécifique supplémentaire
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddMateriel()
    {
        model.Materiels.Add(new MaterielEditModel { Quantite = 1 });
    }

    private void RemoveMateriel(MaterielEditModel mat)
    {
        model.Materiels.Remove(mat);
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(model.MotifSortie))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Attention", "Le motif de sortie est obligatoire");
            return;
        }

        if (!model.Materiels.Any())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Attention", "Ajoutez au moins un matériel");
            return;
        }

        isSubmitting = true;
        try
        {
            var request = new UpdateBonSortieRequest
            {
                IdBon = Id,
                MotifSortie = model.MotifSortie,
                Description = model.Description,
                Provenance = model.Provenance,
                Destination = model.Destination,
                FonctionDemandeur = model.FonctionDemandeur,
                DepartementDemandeur = model.DepartementDemandeur,
                DateExpiration = model.DateExpiration,
                DateRetourPrevue = IsPret ? model.DateRetourPrevue : null,
                NomDestinataire = model.NomDestinataire,
                AdresseDestination = model.AdresseDestination,
                NumeroVehicule = model.NumeroVehicule,
                NomChauffeur = model.NomChauffeur,
                TelephoneChauffeur = model.TelephoneChauffeur,
                Materiels = model.Materiels.Select(m => new MaterielDto
                {
                    CodeProduitSerial = m.CodeProduitSerial,
                    Designation = m.Designation,
                    Quantite = m.Quantite
                }).ToList()
            };

            var result = await BonSortieService.UpdateAsync(request);
            if (result.Success)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Succès", "Modifications enregistrées avec succès");
                Navigation.NavigateTo($"/bon-sortie/{Id}");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", result.Message ?? "Erreur lors de l'enregistrement");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private TypeMateriel GetTypeMateriel(BonSortieEntity b) => b switch
    {
        BonSortieExterne e => e.TypeMateriel,
        BonSortieInterne i => i.TypeMateriel,
        _ => TypeMateriel.Autre
    };

    private string GetTypeLabel(BonSortieEntity b) => b switch
    {
        Pret => "Prêt",
        BonSortieInterne => "Interne",
        BonSortieExterne => "Externe",
        _ => "Sortie"
    };

    private string GetStatutLabel(string? statut) => statut switch
    {
        "Draft" => "Brouillon",
        "Approved" => "Approuvé",
        "Rejected" => "Rejeté",
        "Returned" => "Retourné",
        _ => statut ?? "-"
    };

    private string GetStatusClass(string? statut) => statut switch
    {
        "Draft" => "status-draft",
        "Approved" => "status-approved",
        "Rejected" => "status-rejected",
        "Returned" => "status-returned",
        _ => "status-draft"
    };

    private BadgeStyle GetStatusBadgeStyle(string? statut) => statut switch
    {
        "Draft" => BadgeStyle.Light,
        "Approved" => BadgeStyle.Success,
        "Rejected" => BadgeStyle.Danger,
        "Returned" => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };

    private string GetRaisonLabel(TypeMateriel type) => type switch
    {
        TypeMateriel.Circulaire => "Circulaire",
        TypeMateriel.Informatique => "Informatique",
        TypeMateriel.FinChantier => "Fin de Chantier",
        TypeMateriel.Residu => "Résidu",
        TypeMateriel.Radioprotection => "Radioprotection",
        TypeMateriel.Modification => "Modification",
        TypeMateriel.Pret => "Prêt",
        _ => "Autre"
    };

    private string GetRaisonClass(TypeMateriel type) => type switch
    {
        TypeMateriel.Circulaire => "raison-circulaire",
        TypeMateriel.Informatique => "raison-informatique",
        TypeMateriel.FinChantier => "raison-finchantier",
        TypeMateriel.Residu => "raison-residu",
        TypeMateriel.Radioprotection => "raison-radioprotection",
        TypeMateriel.Modification => "raison-modification",
        TypeMateriel.Pret => "raison-pret",
        _ => "raison-autre"
    };

    private BadgeStyle GetRaisonBadgeStyle(TypeMateriel type) => type switch
    {
        TypeMateriel.Circulaire => BadgeStyle.Info,
        TypeMateriel.Informatique => BadgeStyle.Primary,
        TypeMateriel.FinChantier => BadgeStyle.Warning,
        TypeMateriel.Residu => BadgeStyle.Danger,
        TypeMateriel.Radioprotection => BadgeStyle.Danger,
        TypeMateriel.Modification => BadgeStyle.Secondary,
        TypeMateriel.Pret => BadgeStyle.Success,
        _ => BadgeStyle.Light
    };

    private class EditModel
    {
        public string FonctionDemandeur { get; set; } = "";
        public string DepartementDemandeur { get; set; } = "";
        public TypeMateriel TypeMateriel { get; set; }
        public string Provenance { get; set; } = "";
        public string Destination { get; set; } = "";
        public string Description { get; set; } = "";
        public string MotifSortie { get; set; } = "";
        public DateTime DateExpiration { get; set; } = DateTime.Now.AddMonths(3);
        public DateTime DateRetourPrevue { get; set; } = DateTime.Now.AddMonths(1);
        
        // Externe/Prêt
        public string NomDestinataire { get; set; } = "";
        public string AdresseDestination { get; set; } = "";
        public string NumeroVehicule { get; set; } = "";
        public string NomChauffeur { get; set; } = "";
        public string TelephoneChauffeur { get; set; } = "";
        

        
        public List<MaterielEditModel> Materiels { get; set; } = new();
    }

    private class MaterielEditModel
    {
        public int IdMateriel { get; set; }
        public string Designation { get; set; } = "";
        public string CodeProduitSerial { get; set; } = "";
        public decimal Quantite { get; set; } = 1;
    }
}
