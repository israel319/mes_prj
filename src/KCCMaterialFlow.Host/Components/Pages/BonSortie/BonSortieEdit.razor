@* BSM-051: Formulaire de modification - Style moderne *@
@page "/bon-sortie/{Id:int}/modifier"
@using BonSortieEntity = KCCMaterialFlow.Domain.Entities.BonSortie
@attribute [Authorize]
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject IReferenceDataService ReferenceDataService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["BsmF_PageTitleEdit"]</PageTitle>

<div class="kcp-page">

    @if (isLoading)
    {
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <RadzenProgressBarCircular ShowValue="false" Size="ProgressBarCircularSize.Large" />
            <p>@L["BsmV_Loading"]</p>
        </div>
    }
    else if (bon == null)
    {
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <RadzenIcon Icon="error_outline" Style="font-size: 64px; color: #dc2626;" />
            <h3>@L["BsmF_NotFound"]</h3>
            <RadzenButton Text="@L["Btn_Back"].Value" Click="GoBack" />
        </div>
    }
    else if (!CanEdit)
    {
        <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <RadzenIcon Icon="lock" Style="font-size: 64px; color: #f59e0b;" />
            <h3>@L["BsmF_CannotEdit"]</h3>
            <p>@L["BsmF_CurrentStatus"] @GetStatutLabel(bon.StatutActuel)</p>
            <RadzenButton Text="@L["Btn_Back"].Value" Click="GoBack" />
        </div>
    }
    else
    {
        @* ── Hero ── *@
        <div class="kcp-hero">
            <div class="kcp-hero-inner">
                <div>
                    <RadzenBadge Text="@GetStatutLabel(bon.StatutActuel)" BadgeStyle="BadgeStyle.Warning" Shade="Shade.Lighter" Style="margin-bottom: 0.5rem; font-size: 0.7rem;" />
                    <h1 class="kcp-title">@L["BemV_Edit"] @bon.NumeroReference</h1>
                    <p class="kcp-subtitle">@L["BsmF_FormTitle"] &bull; @GetTypeLabel(bon) &bull; @L["BsmF_CreatedOn"] @bon.DateCreation.ToString("dd/MM/yyyy")</p>
                </div>
                <div class="kcp-hero-actions">
                    <button type="button" @onclick="GoBack" class="kcp-btn">@L["Btn_Cancel"]</button>
                </div>
            </div>
        </div>

        @* ── Main ── *@
        <main class="kcp-main">
        <div style="max-width: 800px; margin: 0 auto;">
        <div class="kcc-form-scope">
        <div class="form-card">
            <EditForm Model="@model" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                @* ── Section 1 : Informations Demandeur ── *@
                <div class="form-section-header">
                    <div class="section-number">1</div>
                    <h2>@L["BsmF_RequesterInfo"]</h2>
                </div>
                <div class="form-section-body">
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">@L["BsmF_Requester"]</label>
                            <RadzenTextBox Value="@bon.NomDemandeur" ReadOnly="true" Style="width: 100%;" Density="Density.Compact" />
                        </div>
                        <div class="field-group">
                            <label class="field-label">@L["BsmF_FunctionLabel"]</label>
                            <RadzenTextBox @bind-Value="model.FonctionDemandeur" Style="width: 100%;" Density="Density.Compact" />
                        </div>
                    </div>
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">@L["BsmF_DeptLabel"]</label>
                            <RadzenTextBox @bind-Value="model.DepartementDemandeur" Style="width: 100%;" Density="Density.Compact" />
                        </div>
                    </div>
                </div>
                <hr class="form-divider" />

                @* ── Section 2 : Raison de Sortie ── *@
                <div class="form-section-header">
                    <div class="section-number">2</div>
                    <h2>@L["BsmF_ExitReasonSection"]</h2>
                </div>
                <div class="form-section-body">
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">@L["BsmF_MaterialDesc"]</label>
                            <RadzenTextBox @bind-Value="model.DescriptionMateriel" Placeholder="@L["BsmF_MaterialDescPlaceholder"].Value"
                                           Style="width: 100%;" Density="Density.Compact" />
                        </div>
                    </div>
                </div>
                <hr class="form-divider" />

                @* ── Section 3 : Trajet & Destination ── *@
                <div class="form-section-header">
                    <div class="section-number">3</div>
                    <h2>@L["BsmF_RouteSection"]</h2>
                </div>
                <div class="form-section-body">
                    <div class="field-row">
                        <div class="field-group">
                            <label class="field-label">@L["BemF_From"]</label>
                            <RadzenDropDown @bind-Value="model.Provenance" Data="@sitesOptions"
                                            TextProperty="Text" ValueProperty="Value"
                                            Placeholder="@L["BsmF_SelectOrigin"].Value" AllowClear="true"
                                            Style="width: 100%;" Density="Density.Compact" />
                        </div>
                        <div class="field-group">
                            <label class="field-label">@L["BemF_To"]</label>
                            <RadzenDropDown @bind-Value="model.Destination" Data="@sitesOptions"
                                            TextProperty="Text" ValueProperty="Value"
                                            Placeholder="@L["BsmF_SelectDest"].Value" AllowClear="true"
                                            Style="width: 100%;" Density="Density.Compact" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">@L["BsmF_Description"]</label>
                        <RadzenTextBox @bind-Value="model.Description" Placeholder="@L["BsmF_DescPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                    </div>
                    @if (IsExterne || IsPret)
                    {
                        <div class="field-row" style="margin-top: 0.75rem;">
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_RecipientName"]</label>
                                <RadzenTextBox @bind-Value="model.NomDestinataire" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_RecipientAddress"]</label>
                                <RadzenTextBox @bind-Value="model.AdresseDestination" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                        </div>
                    }
                </div>
                <hr class="form-divider" />

                @* ── Section 4 : Véhicule (Externe/Prêt) ── *@
                @if (IsExterne || IsPret)
                {
                    <div class="form-section-header">
                        <div class="section-number">4</div>
                        <h2>@L["BsmF_VehicleSection"]</h2>
                    </div>
                    <div class="form-section-body">
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_VehicleNumber"]</label>
                                <RadzenTextBox @bind-Value="model.NumeroVehicule" Placeholder="@L["BsmF_VehiclePlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_DriverName"]</label>
                                <RadzenTextBox @bind-Value="model.NomChauffeur" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                        </div>
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_DriverPhone"]</label>
                                <RadzenTextBox @bind-Value="model.TelephoneChauffeur" Placeholder="@L["BsmF_PhonePlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                        </div>
                    </div>
                    <hr class="form-divider" />
                }

                @* ── Section 5 : Date Retour (Prêt) ── *@
                @if (IsPret)
                {
                    <div class="form-section-header">
                        <div class="section-number">5</div>
                        <h2>@L["BsmF_ReturnDateSection"]</h2>
                    </div>
                    <div class="form-section-body">
                        <div class="field-row">
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_ReturnDateLabel"]</label>
                                <RadzenDatePicker @bind-Value="model.DateRetourPrevue" DateFormat="dd/MM/yyyy" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                            <div class="field-group">
                                <label class="field-label">@L["BsmF_ExpiryDateLabel"]</label>
                                <RadzenDatePicker @bind-Value="model.DateExpiration" DateFormat="dd/MM/yyyy" Style="width: 100%;" Density="Density.Compact" />
                            </div>
                        </div>
                    </div>
                    <hr class="form-divider" />
                }

                @* ── Section 6 : Motif de Sortie ── *@
                <div class="form-section-header">
                    <div class="section-number">6</div>
                    <h2>@L["BsmV_ExitReason"]</h2>
                </div>
                <div class="form-section-body">
                    <div class="field-group">
                        <label class="field-label">@L["BsmF_Reason"] <span class="req">*</span></label>
                        <RadzenTextArea @bind-Value="model.MotifSortie" Placeholder="@L["BsmF_ExitReasonPlaceholder"].Value" Rows="3" Style="width: 100%; font-size: 0.8rem;" />
                    </div>
                </div>
                <hr class="form-divider" />

                @* ── Section 7 : Matériels ── *@
                <div class="form-section-header">
                    <div class="section-number">7</div>
                    <h2>@L["BemF_Materials"] (@model.Materiels.Count @(model.Materiels.Count > 1 ? L["BemF_Articles"].Value : L["BemF_Article"].Value))</h2>
                </div>
                <div class="form-section-body">
                    @if (model.Materiels.Any())
                    {
                        <RadzenDataGrid TItem="MaterielEditModel" Data="@model.Materiels" AllowSorting="false" Density="Density.Compact" Style="font-size: 0.85rem;">
                            <Columns>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="@L["BsmF_DesignationLabel"]" Width="40%">
                                    <Template Context="mat">
                                        <RadzenTextBox @bind-Value="mat.Designation" Placeholder="@L["BsmF_DesignationPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="@L["BsmF_SerialLabel"]" Width="30%">
                                    <Template Context="mat">
                                        <RadzenTextBox @bind-Value="mat.CodeProduitSerial" Placeholder="@L["BsmF_SerialPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="@L["BemF_Qty"]" Width="15%" TextAlign="TextAlign.Center">
                                    <Template Context="mat">
                                        <RadzenNumeric @bind-Value="mat.Quantite" Min="1" Style="width: 100%;" Density="Density.Compact" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="MaterielEditModel" Title="" Width="15%" TextAlign="TextAlign.Center" Sortable="false">
                                    <Template Context="mat">
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                                      Click="@(() => RemoveMateriel(mat))" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    }
                    else
                    {
                        <div style="padding: 2rem; text-align: center; color: var(--rz-text-secondary-color);">
                            <RadzenIcon Icon="inventory_2" Style="font-size: 32px; opacity: 0.5;" />
                            <p style="margin: 0.5rem 0 0 0;">@L["BemF_NoMaterialAdded"]</p>
                        </div>
                    }
                    <div class="totaux-row">
                        <span>@L["BemF_Total"] <strong>@model.Materiels.Sum(m => m.Quantite)</strong> @(model.Materiels.Sum(m => m.Quantite) > 1 ? L["BemF_Articles"].Value : L["BemF_Article"].Value)</span>
                        <button type="button" @onclick="AddMateriel" style="background: none; border: none; cursor: pointer; font-size: .75rem; font-weight: 600; color: var(--kcc-f-teal); display: flex; align-items: center; gap: .25rem;">
                            <RadzenIcon Icon="add" Style="font-size: .85rem;" /> @L["BsmF_AddMaterial"]
                        </button>
                    </div>
                </div>

                @* ── Actions ── *@
                <div style="display: flex; justify-content: flex-end; padding: 1.25rem 1.5rem 0.5rem; gap: 0.75rem;">
                    <RadzenButton Text="@(isSubmitting ? L["BemF_Saving"].Value : L["BemF_SaveChanges"].Value)"
                                  Icon="save" ButtonType="ButtonType.Submit"
                                  Disabled="@isSubmitting" IsBusy="@isSubmitting"
                                  ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Medium" />
                </div>
            </EditForm>
        </div>
        </div>
        </div>
        </main>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private BonSortieEntity? bon;
    private EditModel model = new();
    private bool isLoading = true;
    private bool isSubmitting = false;

    private bool CanEdit => bon?.StatutActuel == "Draft" || bon?.StatutActuel == "Returned";
    private bool IsExterne => bon is BonSortieExterne && bon is not Pret;
    private bool IsInterne => bon is BonSortieInterne;
    private bool IsPret => bon is Pret;

    // Navigation retour via historique
    private async Task GoBack() => await JSRuntime.InvokeVoidAsync("history.back");

    // TypeMateriel enum supprimé — voir DescriptionMateriel à la place
    private List<object> sitesOptions = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSitesAsync();
        await LoadBonAsync();
    }

    private async Task LoadSitesAsync()
    {
        var sitesList = (await ReferenceDataService.GetSitesAsync())
            .OrderBy(s => s.OrdreAffichage)
            .ThenBy(s => s.Code)
            .Select(s => new { Text = s.Code ?? s.Nom, Value = s.Code ?? s.Nom });
        
        sitesOptions = sitesList.Cast<object>().ToList();
    }

    private async Task LoadBonAsync()
    {
        isLoading = true;
        try
        {
            bon = await BonSortieService.GetAsync(Id);
            if (bon != null)
            {
                model = new EditModel
                {
                    FonctionDemandeur = bon.FonctionDemandeur ?? "",
                    DepartementDemandeur = bon.DepartementDemandeur ?? "",
                    DescriptionMateriel = GetDescriptionMateriel(bon),
                    Provenance = bon.Provenance ?? "",
                    Destination = bon.Destination ?? "",
                    Description = bon.Description ?? "",
                    MotifSortie = bon.MotifSortie ?? "",
                    DateExpiration = bon.DateExpiration,
                    Materiels = bon.Materiels?.Select(m => new MaterielEditModel
                    {
                        IdMateriel = m.Id,
                        Designation = m.Designation ?? "",
                        CodeProduitSerial = m.CodeProduitSerial ?? "",
                        Quantite = m.Quantite
                    }).ToList() ?? new()
                };

                // Charger les champs spécifiques selon le type
                if (bon is BonSortieExterne ext)
                {
                    model.NomDestinataire = ext.NomDestinataire ?? "";
                    model.AdresseDestination = ext.AdresseDestination ?? "";
                    model.NumeroVehicule = ext.NumeroVehicule ?? "";
                    model.NomChauffeur = ext.NomChauffeur ?? "";
                    model.TelephoneChauffeur = ext.TelephoneChauffeur ?? "";
                }

                if (bon is Pret pret)
                {
                    model.DateRetourPrevue = pret.DateRetourPrevue;
                }

                // BonSortieInterne: aucun champ spécifique supplémentaire
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddMateriel()
    {
        model.Materiels.Add(new MaterielEditModel { Quantite = 1 });
    }

    private void RemoveMateriel(MaterielEditModel mat)
    {
        model.Materiels.Remove(mat);
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(model.MotifSortie))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Attention", "Le motif de sortie est obligatoire");
            return;
        }

        if (!model.Materiels.Any())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Attention", "Ajoutez au moins un matériel");
            return;
        }

        isSubmitting = true;
        try
        {
            var request = new UpdateBonSortieRequest
            {
                IdBon = Id,
                MotifSortie = model.MotifSortie,
                Description = model.Description,
                Provenance = model.Provenance,
                Destination = model.Destination,
                FonctionDemandeur = model.FonctionDemandeur,
                DepartementDemandeur = model.DepartementDemandeur,
                DateExpiration = model.DateExpiration,
                DateRetourPrevue = IsPret ? model.DateRetourPrevue : null,
                NomDestinataire = model.NomDestinataire,
                AdresseDestination = model.AdresseDestination,
                NumeroVehicule = model.NumeroVehicule,
                NomChauffeur = model.NomChauffeur,
                TelephoneChauffeur = model.TelephoneChauffeur,
                Materiels = model.Materiels.Select(m => new MaterielDto
                {
                    CodeProduitSerial = m.CodeProduitSerial,
                    Designation = m.Designation,
                    Quantite = m.Quantite
                }).ToList()
            };

            var result = await BonSortieService.UpdateAsync(request);
            if (result.Success)
            {
                NotificationService.Notify(NotificationSeverity.Success, L["Lbl_Success"].Value, L["Notif_ChangesSaved"].Value);
                Navigation.NavigateTo($"/bon-sortie/{Id}");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, result.Message ?? L["Notif_SaveError"].Value);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"].Value, ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // TypeMateriel enum supprimé — utiliser DescriptionMateriel
    private string GetDescriptionMateriel(BonSortieEntity b) => b switch
    {
        BonSortieExterne e => e.DescriptionMateriel ?? "(non spécifié)",
        BonSortieInterne i => i.DescriptionMateriel ?? "(non spécifié)",
        _ => "(non spécifié)"
    };

    private string GetTypeLabel(BonSortieEntity b) => b switch
    {
        Pret => L["Bsl_TypePret"].Value,
        BonSortieInterne => L["Bsl_TypeInterne"].Value,
        BonSortieExterne => L["Bsl_TypeExterne"].Value,
        _ => L["Bsl_TypeSortie"].Value
    };

    private string GetStatutLabel(string? statut) => statut switch
    {
        "Draft" => L["Statut_Draft"].Value,
        "Approved" => L["Statut_Approved"].Value,
        "Rejected" => L["Statut_Rejected"].Value,
        "Returned" => L["Statut_Returned"].Value,
        _ => statut ?? "-"
    };

    private string GetStatusClass(string? statut) => statut switch
    {
        "Draft" => "status-draft",
        "Approved" => "status-approved",
        "Rejected" => "status-rejected",
        "Returned" => "status-returned",
        _ => "status-draft"
    };

    private BadgeStyle GetStatusBadgeStyle(string? statut) => statut switch
    {
        "Draft" => BadgeStyle.Light,
        "Approved" => BadgeStyle.Success,
        "Rejected" => BadgeStyle.Danger,
        "Returned" => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };

    // TypeMateriel supprimé — ces fonctions ne sont plus utilisées
    private string GetRaisonLabel(string? description) => description ?? "(non spécifié)";

    private BadgeStyle GetRaisonBadgeStyle(string? description) => BadgeStyle.Info;

    private class EditModel
    {
        public string FonctionDemandeur { get; set; } = "";
        public string DepartementDemandeur { get; set; } = "";
        public string? DescriptionMateriel { get; set; }
        public string Provenance { get; set; } = "";
        public string Destination { get; set; } = "";
        public string Description { get; set; } = "";
        public string MotifSortie { get; set; } = "";
        public DateTime DateExpiration { get; set; } = DateTime.Now.AddMonths(3);
        public DateTime DateRetourPrevue { get; set; } = DateTime.Now.AddMonths(1);
        
        // Externe/Prêt
        public string NomDestinataire { get; set; } = "";
        public string AdresseDestination { get; set; } = "";
        public string NumeroVehicule { get; set; } = "";
        public string NomChauffeur { get; set; } = "";
        public string TelephoneChauffeur { get; set; } = "";
        

        
        public List<MaterielEditModel> Materiels { get; set; } = new();
    }

    private class MaterielEditModel
    {
        public int IdMateriel { get; set; }
        public string Designation { get; set; } = "";
        public string CodeProduitSerial { get; set; } = "";
        public decimal Quantite { get; set; } = 1;
    }
}
