@page "/bon-sortie/creer"
@page "/bon-sortie/nouveau"
@attribute [Authorize]
@using KCCMaterialFlow.Domain.Entities
@using KCCMaterialFlow.Application.Common.Interfaces
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject IReferenceDataService ReferenceDataService
@inject ICategorieSortieService CategorieSortieService
@inject IRaisonEntreeService RaisonEntreeService
@inject IBonEntreeLockService BonEntreeLockService
@inject IAllEmployeeSearchService GlencoreSearchService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> L
@inject ITypeMaterielService TypeMaterielService

<PageTitle>@L["BsmF_PageTitleNew"]</PageTitle>

<div class="kcp-page">

@if (isLoading)
{
    <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center;">
        <RadzenProgressBar ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="width: 200px;" />
    </div>
}
else
{
    @* ── Hero ── *@
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <RadzenBadge Text="Nouveau BSM" BadgeStyle="BadgeStyle.Light" Shade="Shade.Lighter" Style="margin-bottom: 0.5rem; font-size: 0.7rem;" />
                <h1 class="kcp-title">@L["BsmF_FormTitle"]</h1>
                <p class="kcp-subtitle">@L["BsmF_FormSubtitle"] &bull; @L["Col_Reference"] : @(generatedNumero ?? "(auto)")</p>
            </div>
            <div class="kcp-hero-actions">
                <NavLink href="/bon-sortie" class="kcp-btn">@L["Btn_Back"]</NavLink>
                <button type="button" class="kcp-btn" @onclick="() => HandleSubmitAsync(false)" disabled="@isSubmitting">
                    <RadzenIcon Icon="save" Style="font-size:1rem;" />
                    @L["BemF_Draft"]
                </button>
                <button type="button" class="kcp-btn kcp-btn-primary" @onclick="() => HandleSubmitAsync(true)" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                                    Size="ProgressBarCircularSize.ExtraSmall"
                                                    Style="width:1rem; height:1rem; flex-shrink:0;" />
                    }
                    else
                    {
                        <RadzenIcon Icon="send" Style="font-size:1rem;" />
                    }
                    @(isSubmitting ? L["BsmF_InProgress"] : L["BemF_Submit"])
                </button>
            </div>
        </div>
    </div>

    @* ── Main : formulaire (gauche) + revue (droite) ── *@
    <main class="kcp-main">
    <div style="display: grid; grid-template-columns: 1fr 280px; gap: 1rem; align-items: start; max-width: 960px; margin: 0 auto;">

    @* ── Formulaire ── *@
    <div class="kcc-form-scope">

    @* ── Bannière info ── *@
    <div class="conf-banner">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p><strong>@L["BsmF_FormTitle"] —</strong> @L["BsmF_FormSubtitle"]</p>
    </div>

    <div class="form-card">

    @* ── Section 1 : Informations du demandeur ── *@
    <div class="form-section-header">
        <div class="section-number">1</div>
        <h2>@L["BsmF_RequesterInfo"]</h2>
    </div>
    <div class="form-section-body">
        <div class="field-row">
            <div class="field-group">
                <label class="field-label">@L["BsmF_NameLabel"]</label>
                <RadzenTextBox @bind-Value="model.NomDemandeur" Placeholder="@L["BsmF_NamePlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
            <div class="field-group">
                <label class="field-label">@L["BsmF_FunctionLabel"]</label>
                <RadzenTextBox @bind-Value="model.FonctionDemandeur" Placeholder="@L["BsmF_FunctionPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
            <div class="field-group">
                <label class="field-label">@L["BsmF_DeptLabel"]</label>
                <RadzenTextBox @bind-Value="model.DepartementDemandeur" Placeholder="@L["BsmF_DeptPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
        </div>
    </div>
    <hr class="form-divider" />

    @* ── Section 2 : Site KCC + Demande pour ── *@
    <div class="form-section-header">
        <div class="section-number">2</div>
        <h2>@L["BsmF_SiteSection"]</h2>
    </div>
    <div class="form-section-body">
        <div class="field-row">
            <div class="field-group">
                <label class="field-label">@L["BemF_KccSite"]</label>
                <RadzenDropDown TValue="int?" @bind-Value="siteKccId"
                                Data="@sites" TextProperty="Nom" ValueProperty="Id"
                                Placeholder="@L["BemF_PlSelectKccSite"].Value" AllowFiltering="true" AllowClear="true"
                                Style="width: 100%;" Density="Density.Compact" />
            </div>
            <div class="field-group">
                <label class="field-label">@L["BsmF_RequestFor"]</label>
                <RadzenDropDown TValue="string" @bind-Value="requestedForCode"
                                Data="@requestedForCandidates"
                                TextProperty="DisplayLabel" ValueProperty="EmployeeCode"
                                AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                AllowClear="true" LoadData="@OnRequestedForFilter"
                                Placeholder="@L["BsmF_SearchEmployee"].Value"
                                Change="@OnRequestedForChanged"
                                Style="width: 100%;" Density="Density.Compact" />
                @if (!string.IsNullOrWhiteSpace(requestedForDisplay))
                {
                    <div style="margin-top: 0.35rem; font-size: 0.72rem; color: #6b7280;">
                        @requestedForDisplay
                        @if (!string.IsNullOrWhiteSpace(requestedForDepartement))
                        {
                            <span> — @L["BsmF_DeptAbbr"] <strong>@requestedForDepartement</strong></span>
                        }
                        @if (!string.IsNullOrWhiteSpace(siteManagerAuto))
                        {
                            <span> — @L["BemF_SiteManager"] : <strong>@siteManagerAuto</strong></span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <hr class="form-divider" />

    @* ── Section 3 : Type sortie INTERNE / EXTERNE ── *@
    <div class="form-section-header">
        <div class="section-number">3</div>
        <h2>@L["BsmF_ExitType"]</h2>
    </div>
    <div class="form-section-body">
        <div style="display: flex; gap: 0.75rem;">
            <button type="button" @onclick="@(async () => await SetMode(false))"
                    class="mode-toggle-btn @(selectedMode == false ? "is-interne-active" : "")">
                INTERNE
            </button>
            <button type="button" @onclick="@(async () => await SetMode(true))"
                    class="mode-toggle-btn @(selectedMode == true ? "is-externe-active" : "")">
                EXTERNE
            </button>
        </div>
        @if (!selectedMode.HasValue)
        {
            <p style="font-size: 0.72rem; color: #9ca3af; margin: 0.5rem 0 0; font-style: italic;">
                @L["BsmF_SelectTypeContinue"]
            </p>
        }
    </div>
    <hr class="form-divider" />

    @* ── Section 4 : Type de matériel (workflow d'approbation) ── *@
    <div class="form-section-header">
        <div class="section-number">4</div>
        <h2>Type de matériel</h2>
    </div>
    <div class="form-section-body">
        <div class="field-group">
            <label class="field-label">Type de matériel <span class="req">*</span></label>
            <RadzenDropDown TValue="int?" @bind-Value="selectedTypeMaterielId"
                            Data="@TypesSortieFiltered"
                            TextProperty="NomType" ValueProperty="Id"
                            Placeholder="Sélectionner un type de matériel..."
                            Style="width: 100%;" Density="Density.Compact"
                            Change="@OnTypeMaterielChanged" />
        </div>
    </div>
    <hr class="form-divider" />

    @* ── Section 5 : BEM Source (EXTERNE, non encore lié) ── *@
    @if (selectedMode == true && selectedBemDetails == null && !IsPretType())
    {
    <div class="form-section-header">
        <div class="section-number">5</div>
        <h2>
            <span style="display: inline-flex; align-items: center; gap: 0.5rem;">
                <span style="padding: 0.2rem 0.65rem; font-size: 0.68rem; font-weight: 700; background: #3b82f6; color: #fff;">EXTERNE</span>
                @L["BsmF_BemSource"]
            </span>
        </h2>
    </div>
    <div class="form-section-body">
        <div class="field-group">
            <label class="field-label">@L["BsmF_SearchApprovedBem"] <span class="req">*</span></label>
            <RadzenDropDown TValue="int" @bind-Value="selectedBemIdPicker" Data="@bemsDisponiblesAll"
                            TextProperty="DisplayText" ValueProperty="IdBon"
                            AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Placeholder="@L["BsmF_SearchBemPlaceholder"].Value"
                            Change="@OnBemSelectedRadzen"
                            Style="width: 100%;" Density="Density.Compact" />
            @if (!bemsDisponiblesAll.Any())
            {
                <div style="margin-top: 0.5rem; font-size: 0.72rem; color: #f59e0b;">
                    <RadzenIcon Icon="warning" Style="font-size: 0.75rem; vertical-align: middle;" />
                    @L["BsmF_NoBemAvailable"]
                </div>
            }
        </div>
    </div>
    <hr class="form-divider" />
    }
    @if (selectedMode == true && selectedBemDetails != null && !IsPretType())
    {
    <div class="form-section-body" style="padding-top: 0;">
        <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.6rem 0.75rem; background: rgba(59,130,246,0.06); border-left: 3px solid var(--rz-info);">
            <RadzenIcon Icon="link" Style="color: var(--rz-info);" />
            <span style="flex: 1; font-size: 0.8rem;">
                <strong>@selectedBemDetails.NumeroReference</strong> — @selectedBemDetails.NomCompagnie (@selectedBemDetails.HostDepartment)
            </span>
            <RadzenBadge Text="@L["BsmF_Linked"].Value" BadgeStyle="BadgeStyle.Info" />
            <RadzenButton Icon="close" Size="ButtonSize.ExtraSmall" Variant="Variant.Text"
                          ButtonStyle="ButtonStyle.Light" Click="@OnDeselectBem" />
        </div>
    </div>
    <hr class="form-divider" />
    }
    @if (selectedMode == false)
    {
    @* ── Section 5 (INTERNE) : Motif ── *@
    <div class="form-section-header">
        <div class="section-number">5</div>
        <h2>
            <span style="display: inline-flex; align-items: center; gap: 0.5rem;">
                <span style="padding: 0.2rem 0.65rem; font-size: 0.68rem; font-weight: 700; background: #00B193; color: #fff;">INTERNE</span>
                @L["BsmF_Reason"]
            </span>
        </h2>
    </div>
    <div class="form-section-body">
        @if (!IsPretType())
        {
            <div class="field-group">
                <RadzenTextBox @bind-Value="selectedRaisonCode" Placeholder="@L["BsmF_ReasonPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
        }
        @if (IsPretType())
        {
            <div style="font-size:0.78rem; color:#b45309; background:rgba(245,158,11,0.08); border-left:3px solid #f59e0b; padding:0.5rem 0.75rem; margin-bottom:0.5rem;">
                <RadzenIcon Icon="swap_horiz" Style="font-size:0.85rem; vertical-align:middle; margin-right:0.25rem;" />
                @L["BsmF_LoanModeInfo"]
            </div>
            <div class="field-group" style="margin-top: 0.5rem;">
                <label class="field-label">@L["BsmF_ReturnDate"] <span class="req">*</span></label>
                <RadzenDatePicker @bind-Value="@pretDateRetourPrevue" DateFormat="dd/MM/yyyy" Min="@DateTime.Today.AddDays(1)"
                                  Placeholder="@L["BsmF_SelectReturnDate"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
        }
        else if (selectedRaisonCode == "PRET")
        {
            <div class="field-group" style="margin-top: 0.75rem;">
                <label class="field-label">@L["BsmF_ReturnDate"] <span class="req">*</span></label>
                <RadzenDatePicker @bind-Value="@pretDateRetourPrevue" DateFormat="dd/MM/yyyy" Min="@DateTime.Today.AddDays(1)"
                                  Placeholder="@L["BsmF_SelectReturnDate"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(selectedRaisonCode) && !IsPretType())
        {
            <div class="field-group" style="margin-top: 0.5rem;">
                <RadzenTextBox @bind-Value="commentaireMotif" Placeholder="@L["BsmF_PlCommentOptional"].Value" Style="width: 100%; font-size: 0.78rem;" Density="Density.Compact" />
            </div>
        }
    </div>
    <hr class="form-divider" />
    }

    @* ── Section 6 : Provenance / Destination ── *@
    <div class="form-section-header">
        <div class="section-number">6</div>
        <h2>@L["BsmF_OriginDest"]</h2>
    </div>
    <div class="form-section-body">
        <div class="field-row">
            <div class="field-group">
                <label class="field-label">@L["BemF_From"]</label>
                <RadzenDropDown TValue="int?" @bind-Value="siteFromId" Data="@sites" TextProperty="Nom" ValueProperty="Id"
                                Placeholder="@L["BsmF_SelectOrigin"].Value" Style="width: 100%;" Density="Density.Compact"
                                Disabled="@destinationFromBem" Change="@OnSiteFromChanged" />
            </div>
            <div class="field-group">
                <label class="field-label">@L["BemF_To"]</label>
                <RadzenDropDown TValue="int?" @bind-Value="siteToId" Data="@SitesExcludingFrom" TextProperty="Nom" ValueProperty="Id"
                                Placeholder="@L["BsmF_SelectDest"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
        </div>
        @if (destinationFromBem)
        {
            <p style="font-size: 0.7rem; color: #6b7280; margin: 0.5rem 0 0; font-style: italic;">
                <RadzenIcon Icon="info" Style="font-size: 0.75rem; vertical-align: middle;" /> @L["BsmF_SourceFromBem"]
            </p>
        }
    </div>
    <hr class="form-divider" />

    @* ── Section 7 : Matériels ── *@
    <div class="form-section-header">
        <div class="section-number">7</div>
        <h2>
            <span style="display: inline-flex; align-items: center; gap: 0.75rem;">
                @L["BemF_Materials"]
                @if (selectedMode == true && selectedBemDetails != null)
                {
                    <RadzenButton Text="@(L["BemV_Edit"].Value + " (" + selectedMateriels.Count + ")")" Icon="edit" ButtonStyle="ButtonStyle.Primary"
                                  Variant="Variant.Flat" Size="ButtonSize.ExtraSmall" Click="@OpenMaterielModal"
                                  Style="font-size: 0.68rem; gap: 0.2rem;" />
                }
            </span>
        </h2>
    </div>
    <div class="form-section-body">
        @if (selectedMode == true && selectedBemDetails != null)
        {
            @* Mode EXTERNE (depuis BEM) *@
            <RadzenDataGrid TItem="MaterielSelectable" Data="@selectedMateriels" Density="Density.Compact" Style="font-size: 0.8rem;">
                <Columns>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Title="@L["BsmV_ColQty"]" Width="15%" TextAlign="TextAlign.Center">
                        <Template Context="mat">
                            <RadzenNumeric @bind-Value="mat.QuantiteASortir" Min="1" Max="mat.QuantiteDisponible" Style="width: 55px; font-size: 0.8rem; text-align: center; margin: 0 auto;" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Title="@L["BsmV_ColSerial"]" Width="25%">
                        <Template Context="mat">
                            <code style="font-size: 0.75rem;">@mat.CodeProduitSerial</code>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Title="@L["BsmV_ColDesc"]" Width="60%">
                        <Template Context="mat">
                            <span style="font-size: 0.8rem; font-weight: 500;">@mat.Designation</span>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
                <EmptyTemplate>
                    <p style="text-align: center; padding: 1.5rem; color: #6b7280;">@L["BsmF_SelectBemMaterials"]</p>
                </EmptyTemplate>
            </RadzenDataGrid>
        }
        else
        {
            @* Mode INTERNE - Grille éditable *@
            <RadzenDataGrid TItem="MaterielSelectable" Data="@selectedMateriels" Density="Density.Compact" Style="font-size: 0.8rem;">
                <Columns>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Title="@L["BsmF_SerialColTitle"]" Width="25%">
                        <Template Context="mat">
                            <RadzenTextBox @bind-Value="mat.CodeProduitSerial" Placeholder="@L["BsmF_SerialColTitle"].Value" Style="width: 100%; border: none; box-shadow: none; padding: 0.15rem 0.25rem; font-size: 0.8rem;" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Title="@L["BsmF_DesignationLabel"]" Width="45%">
                        <Template Context="mat">
                            <RadzenTextBox @bind-Value="mat.Designation" Placeholder="@L["BsmF_MaterialDescPlaceholder"].Value" Style="width: 100%; border: none; box-shadow: none; padding: 0.15rem 0.25rem; font-size: 0.8rem;" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Title="@L["BemF_Qty"]" Width="15%" TextAlign="TextAlign.Center">
                        <Template Context="mat">
                            <RadzenNumeric @bind-Value="mat.QuantiteASortir" Min="1" Style="width: 100%; border: none; box-shadow: none; font-size: 0.8rem; text-align: center;" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="MaterielSelectable" Width="15%" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                        <Template Context="mat">
                            <RadzenButton Icon="delete_outline" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.ExtraSmall"
                                          Click="@(() => RemoveMateriel(mat))" Disabled="@(selectedMateriels.Count <= 1)" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
                <EmptyTemplate>
                    <p style="text-align: center; padding: 1rem; color: #6b7280;">@L["BsmF_AddMaterialsBelow"]</p>
                </EmptyTemplate>
            </RadzenDataGrid>
            <div class="totaux-row">
                <span>@L["BemF_Total"] <strong>@selectedMateriels.Sum(m => m.QuantiteASortir)</strong> @(selectedMateriels.Sum(m => m.QuantiteASortir) > 1 ? L["BemF_Articles"].Value : L["BemF_Article"].Value)</span>
                <button type="button" @onclick="AddEmptyMateriel" style="background: none; border: none; cursor: pointer; font-size: .75rem; font-weight: 600; color: var(--kcc-f-teal); display: flex; align-items: center; gap: .25rem;">
                    <RadzenIcon Icon="add" Style="font-size: .85rem;" /> @L["BemF_Add"]
                </button>
            </div>
        }
    </div>

    @* ── Section 8 : Motif EXTERNE ── *@
    @if (selectedMode == true && (selectedBemDetails != null || IsPretType()))
    {
    <hr class="form-divider" />
    <div class="form-section-header">
        <div class="section-number">8</div>
        <h2>@L["BsmF_ExternalReason"]</h2>
    </div>
    <div class="form-section-body">
        @if (IsPretType())
        {
            <div style="font-size:0.78rem; color:#b45309; background:rgba(245,158,11,0.08); border-left:3px solid #f59e0b; padding:0.5rem 0.75rem; margin-bottom:0.5rem;">
                <RadzenIcon Icon="swap_horiz" Style="font-size:0.85rem; vertical-align:middle; margin-right:0.25rem;" />
                @L["BsmF_LoanModeInfo"]
            </div>
            <div class="field-group" style="margin-top: 0.5rem;">
                <label class="field-label">@L["BsmF_ReturnDate"] <span class="req">*</span></label>
                <RadzenDatePicker @bind-Value="@pretDateRetourPrevue" DateFormat="dd/MM/yyyy" Min="@DateTime.Today.AddDays(1)"
                                  Placeholder="@L["BsmF_SelectReturnDate"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
        }
        else
        {
            <div class="field-group">
                <RadzenTextBox @bind-Value="selectedRaisonCode" Placeholder="@L["BsmF_ReasonPlaceholder"].Value" Style="width: 100%;" Density="Density.Compact" />
            </div>
            @if (selectedRaisonCode == "PRET")
            {
                <div class="field-group" style="margin-top: 0.75rem;">
                    <label class="field-label">@L["BsmF_ReturnDate"] <span class="req">*</span></label>
                    <RadzenDatePicker @bind-Value="@pretDateRetourPrevue" DateFormat="dd/MM/yyyy" Min="@DateTime.Today.AddDays(1)"
                                      Placeholder="@L["BsmF_SelectReturnDate"].Value" Style="width: 100%;" Density="Density.Compact" />
                </div>
            }
        }
    </div>
    }

    @* ── Section 9 : Checkpoints ── *@
    @if (!string.IsNullOrWhiteSpace(selectedRaisonCode))
    {
    <hr class="form-divider" />
    <div class="form-section-header">
        <div class="section-number">9</div>
        <h2>@L["BsmF_Checkpoints"]</h2>
    </div>
    <div class="form-section-body">
        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
            @foreach (var chk in checkpoints)
            {
                <div style="display: flex; align-items: center; gap: 0.35rem; cursor: pointer; font-size: 0.75rem;">
                    <RadzenCheckBox TValue="bool" Value="@chk.EstSelectionne" Change="@(val => ToggleCheckpoint(chk, val))" />
                    <span style="color: #1a1a1a;">@chk.Checkpoint.Nom</span>
                    @if (chk.EstSelectionne)
                    {
                        <span style="background: #00B193; color: #fff; font-size: 0.55rem; font-weight: 700; width: 16px; height: 16px; display: inline-flex; align-items: center; justify-content: center;">
                            @chk.OrdrePrevu
                        </span>
                    }
                </div>
            }
        </div>
    </div>
    }

    @* ── Erreur ── *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Size="AlertSize.Small" ShowIcon="false" Style="margin-top: 1.5rem; font-size: 0.78rem;">
            @errorMessage
        </RadzenAlert>
    }

    </div>
    </div>

    @* ── Panneau de revue ── *@
    <div class="bon-form__review">
        <div class="bon-form__review-header">
            <RadzenIcon Icon="fact_check" Style="font-size: 1rem;" />
            <span>@L["BemF_Review"]</span>
        </div>

        <div class="bon-form__review-body">
            @* Demandeur *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="person" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />@L["BsmF_ReviewDemandeur"]</div>
                @if (!string.IsNullOrWhiteSpace(model.NomDemandeur))
                {
                    <div style="font-size: 0.78rem; font-weight: 600; color: #1a1a1a;">@model.NomDemandeur</div>
                    @if (!string.IsNullOrWhiteSpace(model.FonctionDemandeur))
                    {
                        <div style="font-size: 0.65rem; color: #9ca3af; margin-top: 0.1rem;">@model.FonctionDemandeur</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(model.DepartementDemandeur))
                    {
                        <div style="font-size: 0.65rem; color: #9ca3af;">@model.DepartementDemandeur</div>
                    }
                }
                else
                {
                    <span class="bon-form__review-empty">@L["BsmF_ReviewNotFilled"]</span>
                }
            </div>

            @* Type INTERNE/EXTERNE *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="category" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />@L["BsmF_ReviewType"]</div>
                @if (selectedMode == true)
                {
                    <div style="display: flex; align-items: center; gap: 0.3rem;">
                        <RadzenBadge Text="@L["Bsm_BadgeExterne"].Value" BadgeStyle="BadgeStyle.Info" Style="font-size: 0.6rem;" />
                        @if (selectedBemDetails != null)
                        {
                            <span style="font-size: 0.68rem; color: #6b7280;">via @selectedBemDetails.NumeroReference</span>
                        }
                    </div>
                }
                else if (selectedMode == false)
                {
                    <RadzenBadge Text="@L["Bsm_BadgeInterne"].Value" BadgeStyle="BadgeStyle.Primary" Style="font-size: 0.6rem;" />
                }
                else
                {
                    <span class="bon-form__review-empty">@L["BsmF_ReviewNotSelected"]</span>
                }
            </div>

            @* Type de matériel *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="inventory" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />Type de matériel</div>
                @{
                    var selectedTypeMat = typesSortie.FirstOrDefault(t => t.Id == selectedTypeMaterielId);
                }
                @if (selectedTypeMat != null)
                {
                    <RadzenBadge Text="@selectedTypeMat.NomType" BadgeStyle="BadgeStyle.Success" Style="font-size: 0.65rem;" />
                }
                else
                {
                    <span class="bon-form__review-empty">@L["BsmF_ReviewNotSelected"]</span>
                }
            </div>

            @* Motif *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="label" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />@L["BsmF_Reason"]</div>
                @if (!string.IsNullOrWhiteSpace(selectedRaisonCode))
                {
                    <RadzenBadge Text="@selectedRaisonCode" BadgeStyle="BadgeStyle.Warning" Style="font-size: 0.65rem;" />
                    @if (!string.IsNullOrWhiteSpace(commentaireMotif))
                    {
                        <div style="font-size: 0.65rem; color: #9ca3af; margin-top: 0.15rem; font-style: italic;">@commentaireMotif</div>
                    }
                    @if (selectedRaisonCode == "PRET" && pretDateRetourPrevue.HasValue)
                    {
                        <div style="font-size: 0.65rem; color: #6b7280; margin-top: 0.15rem;">
                            <RadzenIcon Icon="event" Style="font-size: 0.7rem; vertical-align: middle;" /> @L["BsmF_ReviewReturn"] @pretDateRetourPrevue.Value.ToString("dd/MM/yyyy")
                        </div>
                    }
                }
                else
                {
                    <span class="bon-form__review-empty">@L["BsmF_ReviewNoReason"]</span>
                }
            </div>

            @* Trajet *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="swap_horiz" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />@L["BemF_Route"]</div>
                <div style="display: flex; align-items: center; gap: 0.4rem;">
                    <div style="flex: 1; text-align: center; padding: 0.4rem; background: #f9fafb;">
                        <div style="font-size: 0.55rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">From</div>
                        <div style="font-size: 0.75rem; font-weight: 600; color: #1a1a1a; margin-top: 0.1rem;">@(siteFromId.HasValue ? sites.FirstOrDefault(s => s.Id == siteFromId)?.Nom ?? "—" : "—")</div>
                    </div>
                    <RadzenIcon Icon="arrow_forward" Style="color: #00B193; font-size: 1rem;" />
                    <div style="flex: 1; text-align: center; padding: 0.4rem; background: #f9fafb;">
                        <div style="font-size: 0.55rem; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">To</div>
                        <div style="font-size: 0.75rem; font-weight: 600; color: #1a1a1a; margin-top: 0.1rem;">@(siteToId.HasValue ? sites.FirstOrDefault(s => s.Id == siteToId)?.Nom ?? "—" : "—")</div>
                    </div>
                </div>
            </div>

            @* Matériels *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="inventory_2" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />@L["BemF_Materials"] (@GetValidMaterielsCount())</div>
                @{
                    var reviewMateriels = selectedMateriels.Where(m => !string.IsNullOrWhiteSpace(m.Designation) || !string.IsNullOrWhiteSpace(m.CodeProduitSerial)).ToList();
                }
                @if (reviewMateriels.Any())
                {
                    <div style="max-height: 140px; overflow-y: auto;">
                        @foreach (var mat in reviewMateriels.Take(5))
                        {
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.35rem 0; border-bottom: 1px solid #f3f4f6;">
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-size: 0.72rem; font-weight: 500; color: #1a1a1a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                        @(string.IsNullOrWhiteSpace(mat.Designation) ? L["BsmF_ReviewNoDesig"].Value : mat.Designation)
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(mat.CodeProduitSerial))
                                    {
                                        <div style="font-size: 0.6rem; color: #9ca3af;">@mat.CodeProduitSerial</div>
                                    }
                                </div>
                                <RadzenBadge Text="@mat.QuantiteASortir.ToString()" BadgeStyle="BadgeStyle.Primary" Style="font-size: 0.6rem; min-width: 22px;" />
                            </div>
                        }
                        @if (reviewMateriels.Count > 5)
                        {
                            <div style="font-size: 0.65rem; color: #9ca3af; text-align: center; padding: 0.3rem 0; font-style: italic;">
                                + @(reviewMateriels.Count - 5) @L["BsmF_ReviewMore"]
                            </div>
                        }
                    </div>
                    <div style="margin-top: 0.4rem; padding-top: 0.4rem; border-top: 1px solid #e5e7eb; font-size: 0.72rem; color: #1a1a1a;">
                        @L["BemF_Total"]: <strong>@selectedMateriels.Sum(m => m.QuantiteASortir)</strong> @L["BemF_Articles"]
                    </div>
                }
                else
                {
                    <span class="bon-form__review-empty">@L["BemF_NoMaterialAdded"]</span>
                }
            </div>

            @* Checkpoints *@
            <div class="bon-form__review-section">
                <div class="bon-form__review-label"><RadzenIcon Icon="route" Style="font-size: 0.75rem; vertical-align: middle; margin-right: 0.2rem;" />@L["BsmF_Checkpoints"]</div>
                @{
                    var selectedCheckpoints = checkpoints.Where(c => c.EstSelectionne).OrderBy(c => c.OrdrePrevu).ToList();
                }
                @if (selectedCheckpoints.Any())
                {
                    <div style="display: flex; flex-wrap: wrap; gap: 0.25rem;">
                        @foreach (var chk in selectedCheckpoints)
                        {
                            <div style="display: inline-flex; align-items: center; gap: 0.2rem; padding: 0.15rem 0.4rem; background: rgba(0,177,147,0.08); font-size: 0.65rem; color: #00B193; font-weight: 500;">
                                <span style="font-size: 0.55rem; font-weight: 700;">@chk.OrdrePrevu</span>
                                @chk.Checkpoint.Nom
                            </div>
                        }
                    </div>
                }
                else
                {
                    <span class="bon-form__review-empty">@L["BsmF_ReviewNoCheckpoint"]</span>
                }
            </div>
        </div>

        @* Footer statut *@
        <div class="bon-form__review-footer">
            @if (CanSubmit())
            {
                <div style="display: flex; align-items: center; gap: 0.35rem; color: #16a34a;">
                    <RadzenIcon Icon="check_circle" Style="font-size: 1rem;" />
                    <span style="font-size: 0.75rem; font-weight: 500;">@L["BsmF_ReadyToSubmit"]</span>
                </div>
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 0.35rem; color: #9ca3af;">
                    <RadzenIcon Icon="info" Style="font-size: 1rem;" />
                    <span style="font-size: 0.75rem;">@L["BsmF_FillForm"]</span>
                </div>
            }
        </div>
    </div>

    </div>
    </main>
}

</div>

@* ── Modal sélection matériels (BEM EXTERNE uniquement) ── *@
@if (showMaterielModal && selectedMode == true && selectedBemDetails != null)
{
    <div style="position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; background: rgba(37,60,69,0.35);"
         @onclick="CloseMaterielModal">
        <div style="background: white; border: 1px solid #e5e7eb; box-shadow: 0 4px 20px rgba(0,0,0,0.15); width: 90%; max-width: 600px; display: flex; flex-direction: column; max-height: 80vh;" @onclick:stopPropagation="true">
            @* Header *@
            <div style="padding: 1rem 1.25rem; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; background: #f9fafb;">
                <div>
                    <div style="font-size: 0.85rem; font-weight: 600; color: #1a1a1a;">@L["BsmF_ModalTitle"]</div>
                    <div style="font-size: 0.72rem; color: #6b7280; margin-top: 0.15rem;">@selectedBemDetails.NumeroReference</div>
                </div>
                <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@CloseMaterielModal" />
            </div>

            @* Body *@
            <div style="padding: 1rem 1.25rem; overflow-y: auto; flex: 1;">
                @if (materielsBemSelectables.Any())
                {
                    @foreach (var mat in materielsBemSelectables)
                    {
                        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem; border: 1px solid @(mat.EstSelectionne ? "#00B193" : "rgba(0,0,0,0.08)"); margin-bottom: 0.5rem; background: @(mat.EstSelectionne ? "rgba(0,177,147,0.04)" : "white"); transition: background 0.15s, border-color 0.15s;">
                                <RadzenCheckBox TValue="bool" Value="@mat.EstSelectionne" Change="@(val => OnMaterielToggle(mat, val))" />
                                <div style="flex: 1; min-width: 0;">
                                    <div style="font-size: 0.78rem; font-weight: 600; color: #1a1a1a;">@mat.Designation</div>
                                    <div style="font-size: 0.68rem; color: #6b7280; margin-top: 0.1rem;">
                                        @mat.CodeProduitSerial
                                        <span style="margin-left: 0.5rem; font-size: 0.65rem; padding: 0.1rem 0.35rem; background: rgba(59,130,246,0.1); color: #2563eb;">Dispo: @mat.QuantiteDisponible</span>
                                    </div>
                                </div>
                                @if (mat.EstSelectionne)
                                {
                                    <RadzenNumeric TValue="decimal" @bind-Value="mat.QuantiteASortir" Min="1" Max="mat.QuantiteDisponible"
                                                   Style="width: 80px; font-size: 0.75rem;" Density="Density.Compact" />
                                }
                        </div>
                    }
                }
                else
                {
                    <div style="text-align: center; color: #999; padding: 2rem; font-size: 0.8rem;">
                        @L["BsmF_NoMaterialAvail"]
                    </div>
                }
            </div>

            @* Footer *@
            <div style="padding: 1rem 1.25rem; border-top: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; background: #f9fafb;">
                <span style="font-size: 0.72rem; color: #6b7280;">@materielsBemSelectables.Count(m => m.EstSelectionne) @L["BsmF_NbSelected"]</span>
                <div style="display: flex; gap: 0.75rem;">
                    <RadzenButton Text="@L["Btn_Cancel"].Value" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Medium"
                                  Click="@CloseMaterielModal" Style="font-size: 0.75rem;" />
                    <RadzenButton Text="@L["Dlg_Confirm"].Value"
                                  Icon="check" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Medium"
                                  Disabled="@(!materielsBemSelectables.Any(m => m.EstSelectionne))"
                                  Click="@ConfirmMaterielSelection" Style="font-size: 0.75rem;" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    // === PARAMÈTRE URL ===
    [SupplyParameterFromQuery(Name = "bemId")]
    public int? PreselectedBemId { get; set; }

    // === STATE ===
    private bool isSubmitting = false;
    private bool isLoading = true;
    private bool showMaterielModal = false;
    private string? errorMessage;
    private string? generatedNumero = "(auto)";
    private bool? selectedMode = null;   // null = non choisi, true = EXTERNE, false = INTERNE
    private int selectedBemIdPicker = 0;

    // === DONNÉES DE RÉFÉRENCE ===
    private List<KCCMaterialFlow.Domain.Entities.Site> sites = new();
    private List<CheckpointSelection> checkpoints = new();
    private List<BonEntreeForDropdown> bemsDisponibles = new();
    private List<BonEntreeForDropdown> bemsDisponiblesAll = new();
    private List<KCCMaterialFlow.Domain.Entities.TypeMaterielEntity> typesSortie = new();
    private int? selectedTypeMaterielId;

    // === MOTIF (libre, pas de DB-driven) ===
    private string? selectedRaisonCode;  // Motif libre (textbox) - replaces dropdown
    private string commentaireMotif = "";
    private DateTime? pretDateRetourPrevue = DateTime.Today.AddMonths(1);

    // === BEM ===
    private BonEntreeDetailsForSortie? selectedBemDetails;
    private List<MaterielSelectable> materielsBemSelectables = new();
    private List<MaterielSelectable> selectedMateriels = new();

    // === AJOUT MANUEL MATÉRIELS (BONS INTERNES) ===
    private string newMaterielCode = string.Empty;
    private string newMaterielDesignation = string.Empty;
    private decimal newMaterielQte = 1;

    // === FROM / TO (niveau bon, pas par matériel) ===
    private int? siteFromId;
    private int? siteToId;
    private bool destinationFromBem = false;

    // === Site KCC + RequestedFor (Glencore) ===
    private int? siteKccId;
    private string? requestedForCode;
    private string? requestedForDisplay;
    private string? requestedForDepartement;
    private string? siteManagerAuto;
    private List<RequestedForOption> requestedForCandidates = new();

    public sealed class RequestedForOption
    {
        public string EmployeeCode { get; set; } = string.Empty;
        public string DisplayLabel { get; set; } = string.Empty;
        public string? Display { get; set; }
        public string? Departement { get; set; }
        public string? ManagerHodCode { get; set; }
        public string? ManagerHodDisplay { get; set; }
    }

    // === Catalogue matériel (filtré par département du RequestedFor) ===
    // (supprimé — INTERNE n'utilise plus de catalogue)

    private async Task OnRequestedForFilter(Radzen.LoadDataArgs args)
    {
        var matches = await GlencoreSearchService.SearchAsync(args.Filter, maxResults: 25);
        requestedForCandidates = matches.Select(g => new RequestedForOption
        {
            EmployeeCode = g.EmployeeCode,
            Display = $"{g.FirstName} {g.LastName}".Trim(),
            Departement = g.Departement,
            ManagerHodCode = g.ManagerHodEmployeeCode,
            ManagerHodDisplay = g.ManagerHodEmployeeDisplay,
            DisplayLabel = $"{g.EmployeeCode} — {g.FirstName} {g.LastName}".Trim()
                           + (string.IsNullOrWhiteSpace(g.Departement) ? "" : $" ({g.Departement})")
        }).ToList();
    }

    private async Task OnRequestedForChanged(object value)
    {
        if (value is string code && !string.IsNullOrWhiteSpace(code))
        {
            var picked = requestedForCandidates.FirstOrDefault(c => c.EmployeeCode == code);
            if (picked != null)
            {
                requestedForCode = picked.EmployeeCode;
                requestedForDisplay = picked.Display;
                requestedForDepartement = picked.Departement;
                // Auto-déduire le Site Manager depuis ManagerHodEmployeeDisplay
                siteManagerAuto = !string.IsNullOrWhiteSpace(picked.ManagerHodDisplay)
                    ? picked.ManagerHodDisplay
                    : await GlencoreSearchService.GetSiteManagerForAsync(picked.EmployeeCode);
            }
        }
        else
        {
            requestedForCode = null;
            requestedForDisplay = null;
            requestedForDepartement = null;
            siteManagerAuto = null;
        }
        // (catalogue supprimé — mode INTERNE n'utilise plus de recherche)
    }

    private IEnumerable<KCCMaterialFlow.Domain.Entities.Site> SitesExcludingFrom =>
        siteFromId.HasValue
            ? sites.Where(s => s.Id != siteFromId.Value)
            : sites;

    // === MODÈLE ===
    private BsmModel model = new();

    // === CLASSES ===
    private class BsmModel
    {
        public string NomDemandeur { get; set; } = string.Empty;
        public string FonctionDemandeur { get; set; } = string.Empty;
        public string DepartementDemandeur { get; set; } = string.Empty;
    }

    private class MaterielSelectable
    {
        public int MaterielEntreeId { get; set; }
        public int BonEntreeId { get; set; }
        public string CodeProduitSerial { get; set; } = string.Empty;
        public string Designation { get; set; } = string.Empty;
        public decimal QuantiteInitiale { get; set; }
        public decimal QuantiteDisponible { get; set; }
        public decimal QuantiteASortir { get; set; } = 1;
        public bool EstSelectionne { get; set; }
    }

    private class CheckpointSelection
    {
        public KCCMaterialFlow.Domain.Entities.Checkpoint Checkpoint { get; set; } = null!;
        public bool EstSelectionne { get; set; }
        public int OrdrePrevu { get; set; }
    }

    // === LIFECYCLE ===
    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUserService.HasActivite("BSM_CREER"))
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        await LoadReferenceDataAsync();
        InitializeUserData();

        if (PreselectedBemId.HasValue && PreselectedBemId.Value > 0)
        {
            await HandlePreselectedBemAsync(PreselectedBemId.Value);
        }
        else
        {
            AddEmptyMateriel();
        }

        isLoading = false;
    }

    private async Task HandlePreselectedBemAsync(int bemId)
    {
        selectedMode = true;

        selectedBemDetails = await BonEntreeLockService.GetDetailsForSortieAsync(bemId);

        if (selectedBemDetails == null)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "BEM non trouvé",
                $"Le bon d'entrée #{bemId} n'est pas disponible pour sortie.");
            selectedMode = null;
            return;
        }

        materielsBemSelectables = selectedBemDetails.Materiels
            .Where(m => m.QuantiteDisponible > 0)
            .Select(m => new MaterielSelectable
            {
                MaterielEntreeId = m.IdMateriel,
                BonEntreeId = selectedBemDetails.IdBon,
                CodeProduitSerial = m.CodeProduitSerial,
                Designation = m.Designation,
                QuantiteInitiale = m.QuantiteInitiale,
                QuantiteDisponible = m.QuantiteDisponible,
                QuantiteASortir = m.QuantiteDisponible,
                EstSelectionne = true
            }).ToList();

        selectedMateriels = materielsBemSelectables.ToList();

        var matchedSite = sites.FirstOrDefault(s => s.Nom.Equals(selectedBemDetails.Destination, StringComparison.OrdinalIgnoreCase));
        if (matchedSite != null)
        {
            siteFromId = matchedSite.Id;
            destinationFromBem = true;
            if (siteToId.HasValue && siteToId.Value == siteFromId.Value)
            {
                siteToId = null;
            }
        }

        await AutoSelectMotifFromBemAsync();

        NotificationService.Notify(NotificationSeverity.Info, "BEM lié",
            $"Bon d'entrée {selectedBemDetails.NumeroReference} pré-chargé avec {selectedMateriels.Count} matériel(s).");
    }

    private async Task AutoSelectMotifFromBemAsync()
    {
        // Motif est maintenant un champ libre - pas de sélection auto requise
        selectedRaisonCode = null;
        await Task.CompletedTask;
    }

    private async Task LoadReferenceDataAsync()
    {
        sites = (await ReferenceDataService.GetSitesAsync()).OrderBy(s => s.OrdreAffichage).ToList();

        var chkList = (await ReferenceDataService.GetCheckpointsAsync()).OrderBy(c => c.OrdreDefaut).ToList();
        checkpoints = chkList.Select(c => new CheckpointSelection { Checkpoint = c }).ToList();

        bemsDisponiblesAll = (await BonEntreeLockService.GetAllAvailableForSortieAsync()).ToList();
        bemsDisponibles = bemsDisponiblesAll.ToList();

        typesSortie = (await TypeMaterielService.GetByCategorieAsync("Workflow Sortie")).OrderBy(t => t.Ordre).ToList();

        // Motif est libre - pas de chargement de raisons requises
    }

    private void InitializeUserData()
    {
        var currentUser = CurrentUserService.GetCurrentUser();
        if (currentUser != null)
        {
            model.NomDemandeur = currentUser.DisplayName ?? currentUser.Login;
            model.FonctionDemandeur = currentUser.Function ?? string.Empty;
            model.DepartementDemandeur = currentUser.Department ?? string.Empty;
        }
    }

    // === MODE (Interne / Externe) ===
    private bool IsExterne() => selectedMode == true;

    private static readonly string[] _interneTypes = { "BSM_CIRCULANT", "BSM_PRET_MATERIEL", "BSM_EQUIPEMENT_IT" };
    private static readonly string[] _externeExclus = { "BSM_CIRCULANT", "BSM_PRET_MATERIEL" };

    private IEnumerable<TypeMaterielEntity> TypesSortieFiltered
    {
        get
        {
            if (!selectedMode.HasValue) return typesSortie;
            return selectedMode == false
                ? typesSortie.Where(t => _interneTypes.Contains(t.CodeType))
                : typesSortie.Where(t => !_externeExclus.Contains(t.CodeType));
        }
    }

    private bool IsPretType() =>
        selectedTypeMaterielId.HasValue &&
        typesSortie.Any(t => t.Id == selectedTypeMaterielId.Value && t.CodeType == "BSM_PRET_MATERIEL");

    private void OnTypeMaterielChanged(object value)
    {
        if (IsPretType())
        {
            selectedRaisonCode = "PRET";
            // Un prêt ne nécessite pas de BEM source
            selectedBemDetails = null;
            selectedBemIdPicker = 0;
            materielsBemSelectables.Clear();
            if (!selectedMateriels.Any())
                AddEmptyMateriel();
            destinationFromBem = false;
        }
        else if (selectedRaisonCode == "PRET")
        {
            // Si on change de type depuis prêt, effacer le motif auto
            selectedRaisonCode = null;
        }
    }

    private async Task SetMode(bool isExterne)
    {
        selectedMode = isExterne;

        // Réinitialiser le type de matériel s'il n'est pas compatible avec le nouveau mode
        if (selectedTypeMaterielId.HasValue)
        {
            var compatible = isExterne
                ? !_externeExclus.Contains(typesSortie.FirstOrDefault(t => t.Id == selectedTypeMaterielId.Value)?.CodeType)
                : _interneTypes.Contains(typesSortie.FirstOrDefault(t => t.Id == selectedTypeMaterielId.Value)?.CodeType);
            if (!compatible)
            {
                selectedTypeMaterielId = null;
                selectedRaisonCode = null;
            }
        }

        if (!isExterne)
        {
            selectedBemIdPicker = 0;
            selectedBemDetails = null;
            materielsBemSelectables.Clear();
            selectedMateriels.Clear();
            AddEmptyMateriel();
            siteFromId = null;
            destinationFromBem = false;
            if (selectedRaisonCode != null && selectedRaisonCode != "PRET") selectedRaisonCode = null;
        }
    }

    private void OnDeselectBem()
    {
        selectedBemIdPicker = 0;
        selectedBemDetails = null;
        materielsBemSelectables.Clear();
        selectedMateriels.Clear();
        siteFromId = null;
        destinationFromBem = false;
        selectedRaisonCode = null;
    }

    // === BEM ===
    private async Task OnBemSelectedRadzen(object args)
    {
        if (args is int bemId && bemId > 0)
        {
            selectedBemDetails = await BonEntreeLockService.GetDetailsForSortieAsync(bemId);

            if (selectedBemDetails != null)
            {
                materielsBemSelectables = selectedBemDetails.Materiels
                    .Where(m => m.QuantiteDisponible > 0)
                    .Select(m => new MaterielSelectable
                    {
                        MaterielEntreeId = m.IdMateriel,
                        BonEntreeId = selectedBemDetails.IdBon,
                        CodeProduitSerial = m.CodeProduitSerial,
                        Designation = m.Designation,
                        QuantiteInitiale = m.QuantiteInitiale,
                        QuantiteDisponible = m.QuantiteDisponible,
                        QuantiteASortir = Math.Min(1, m.QuantiteDisponible)
                    }).ToList();

                var matchedSite = sites.FirstOrDefault(s => s.Nom.Equals(selectedBemDetails.Destination, StringComparison.OrdinalIgnoreCase));
                if (matchedSite != null)
                {
                    siteFromId = matchedSite.Id;
                    destinationFromBem = true;
                    if (siteToId.HasValue && siteToId.Value == siteFromId.Value)
                    {
                        siteToId = null;
                    }
                }

                selectedMateriels.Clear();

                await AutoSelectMotifFromBemAsync();
            }
        }
        else
        {
            selectedBemDetails = null;
            materielsBemSelectables.Clear();
            selectedMateriels.Clear();
            siteFromId = null;
            destinationFromBem = false;
            selectedRaisonCode = null;
        }
    }

    private void OnSiteFromChanged(object args)
    {
        if (siteToId.HasValue && siteFromId.HasValue && siteToId.Value == siteFromId.Value)
        {
            siteToId = null;
        }
    }

    // === MODAL ===
    private async Task OpenMaterielModal()
    {
        showMaterielModal = true;
        await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow='hidden'");
    }

    private async Task CloseMaterielModal()
    {
        showMaterielModal = false;
        await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow=''");
    }

    private void OnMaterielToggle(MaterielSelectable mat, bool isChecked)
    {
        mat.EstSelectionne = isChecked;
        if (isChecked && mat.QuantiteASortir < 1) mat.QuantiteASortir = 1;
    }

    private async Task ConfirmMaterielSelection()
    {
        if (selectedBemDetails != null)
        {
            selectedMateriels = materielsBemSelectables.Where(m => m.EstSelectionne).ToList();
        }
        showMaterielModal = false;
        await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow=''");
    }

    private void AddMaterielManuel()
    {
        if (string.IsNullOrWhiteSpace(newMaterielDesignation))
            return;

        // Vérifier l'unicité du Code/N° Série
        if (!string.IsNullOrWhiteSpace(newMaterielCode) &&
            selectedMateriels.Any(m => m.CodeProduitSerial?.Equals(newMaterielCode.Trim(), StringComparison.OrdinalIgnoreCase) == true))
        {
            errorMessage = $"Le code/N° série \"{newMaterielCode.Trim()}\" existe déjà dans la liste.";
            return;
        }

        var newMat = new MaterielSelectable
        {
            CodeProduitSerial = newMaterielCode,
            Designation = newMaterielDesignation.Trim(),
            QuantiteASortir = Math.Max(1, newMaterielQte),
            QuantiteDisponible = Math.Max(1, newMaterielQte),
            EstSelectionne = true
        };

        selectedMateriels.Add(newMat);
        errorMessage = null;

        newMaterielCode = string.Empty;
        newMaterielDesignation = string.Empty;
        newMaterielQte = 1;
    }

    private void AddEmptyMateriel()
    {
        var newMat = new MaterielSelectable
        {
            CodeProduitSerial = string.Empty,
            Designation = string.Empty,
            QuantiteASortir = 1,
            QuantiteDisponible = 9999,
            EstSelectionne = true
        };
        selectedMateriels.Add(newMat);
        selectedMateriels = new List<MaterielSelectable>(selectedMateriels);
    }

    private void RemoveMateriel(MaterielSelectable mat)
    {
        selectedMateriels.Remove(mat);
        selectedMateriels = new List<MaterielSelectable>(selectedMateriels);
    }

    private int GetMaterielCount()
    {
        if (selectedBemDetails != null)
        {
            return materielsBemSelectables.Count(m => m.EstSelectionne);
        }
        else
        {
            return selectedMateriels.Count;
        }
    }

    private int GetValidMaterielsCount()
    {
        return selectedMateriels.Count(m => !string.IsNullOrWhiteSpace(m.Designation));
    }

    // === CHECKPOINTS ===
    private void ToggleCheckpoint(CheckpointSelection chk, bool isChecked)
    {
        chk.EstSelectionne = isChecked;
        if (isChecked)
        {
            chk.OrdrePrevu = checkpoints.Count(c => c.EstSelectionne);
        }
        else
        {
            chk.OrdrePrevu = 0;
            ReorderCheckpoints();
        }
    }

    private void ReorderCheckpoints()
    {
        var ordre = 1;
        foreach (var chk in checkpoints.Where(c => c.EstSelectionne).OrderBy(c => c.OrdrePrevu))
        {
            chk.OrdrePrevu = ordre++;
        }
    }

    // === VALIDATION ===
    private bool CanSubmit()
    {
        if (!selectedMode.HasValue) return false;
        if (string.IsNullOrWhiteSpace(model.NomDemandeur)) return false;
        if (!siteFromId.HasValue || !siteToId.HasValue) return false;
        if (!IsPretType() && string.IsNullOrWhiteSpace(selectedRaisonCode)) return false;

        if (IsPretType() && (!pretDateRetourPrevue.HasValue || pretDateRetourPrevue.Value <= DateTime.Today)) return false;
        else if (selectedRaisonCode == "PRET" && (!pretDateRetourPrevue.HasValue || pretDateRetourPrevue.Value <= DateTime.Today)) return false;

        if (selectedMode != true)
        {
            return selectedMateriels.Count > 0
                && selectedMateriels.All(m => !string.IsNullOrWhiteSpace(m.Designation) && !string.IsNullOrWhiteSpace(m.CodeProduitSerial));
        }

        return selectedMateriels.Any();
    }

    // === SOUMISSION ===
    private async Task HandleSubmitAsync(bool submit)
    {
        if (isSubmitting) return;

        // Validation avec messages d'erreur
        var validationErrors = new List<string>();
        if (string.IsNullOrWhiteSpace(model.NomDemandeur)) validationErrors.Add("Nom du demandeur");
        if (!siteFromId.HasValue) validationErrors.Add("Provenance");
        if (!siteToId.HasValue) validationErrors.Add("Destination");
        if (!IsPretType() && string.IsNullOrWhiteSpace(selectedRaisonCode)) validationErrors.Add("Motif");
        if ((IsPretType() || selectedRaisonCode == "PRET") && (!pretDateRetourPrevue.HasValue || pretDateRetourPrevue.Value <= DateTime.Today)) validationErrors.Add("Date de retour prévue");
        if (!selectedMode.HasValue) validationErrors.Add("Type de bon (INTERNE ou EXTERNE)");
        if (!selectedMateriels.Any()) validationErrors.Add("Au moins un matériel");
        if (selectedMode != true && selectedMateriels.Any(m => string.IsNullOrWhiteSpace(m.Designation) || string.IsNullOrWhiteSpace(m.CodeProduitSerial)))
            validationErrors.Add("Désignation et code série de chaque matériel");

        // Vérifier les doublons de Code/N° Série
        if (selectedMode != true)
        {
            var duplicates = selectedMateriels
                .Where(m => !string.IsNullOrWhiteSpace(m.CodeProduitSerial))
                .GroupBy(m => m.CodeProduitSerial!.Trim(), StringComparer.OrdinalIgnoreCase)
                .Where(g => g.Count() > 1)
                .Select(g => g.Key)
                .ToList();
            if (duplicates.Any())
                validationErrors.Add($"Code/N° série en doublon : {string.Join(", ", duplicates)}");
        }

        if (validationErrors.Any())
        {
            errorMessage = $"Champs obligatoires manquants : {string.Join(", ", validationErrors)}";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var siteFrom = sites.FirstOrDefault(s => s.Id == siteFromId);
            var siteTo = sites.FirstOrDefault(s => s.Id == siteToId);

            var materiels = selectedMateriels.Select(m => new MaterielDto
            {
                CodeProduitSerial = m.CodeProduitSerial,
                Designation = m.Designation,
                Quantite = m.QuantiteASortir,
                MaterielEntreeId = m.MaterielEntreeId,
                BonEntreeId = m.BonEntreeId,
                BonEntreeNumero = selectedBemDetails?.NumeroReference,
                QuantiteInitialeBem = m.QuantiteInitiale,
                QuantiteDisponible = m.QuantiteDisponible
            }).ToList();

            var checkpointsList = checkpoints
                .Where(c => c.EstSelectionne)
                .OrderBy(c => c.OrdrePrevu)
                .Select(c => new CheckpointItineraireDto
                {
                    CheckpointId = c.Checkpoint.Id,
                    OrdrePrevu = c.OrdrePrevu
                }).ToList();

            BonSortieResult result;

            var isPret = IsPretType() || selectedRaisonCode == "PRET";

            if (selectedMode != true && !isPret)
            {
                var request = new CreateBonSortieInterneRequest
                {
                    NomDemandeur = model.NomDemandeur,
                    FonctionDemandeur = model.FonctionDemandeur,
                    DepartementDemandeur = model.DepartementDemandeur,
                    Provenance = siteFrom?.Nom ?? string.Empty,
                    Destination = siteTo?.Nom ?? string.Empty,
                    MotifSortie = selectedRaisonCode ?? string.Empty,
                    RaisonSortieCode = selectedRaisonCode,
                    BonEntreeAssocieId = selectedBemDetails?.IdBon,
                    Materiels = materiels,
                    CheckpointsItineraire = checkpointsList,
                    DateExpiration = DateTime.Now.AddMonths(6),
                    SiteId = siteKccId,
                    RequestedForEmployeeCode = requestedForCode,
                    RequestedForDisplay = requestedForDisplay,
                    RequestedForDepartement = requestedForDepartement,
                    SiteManager = siteManagerAuto,
                    TypeMaterielSortieId = selectedTypeMaterielId
                };

                result = await BonSortieService.CreateInterneAsync(request);
            }
            else if (selectedMode != true && isPret)
            {
                var pretRequest = new CreatePretRequest
                {
                    NomDemandeur = model.NomDemandeur,
                    FonctionDemandeur = model.FonctionDemandeur,
                    DepartementDemandeur = model.DepartementDemandeur,
                    Provenance = siteFrom?.Nom ?? string.Empty,
                    Destination = siteTo?.Nom ?? string.Empty,
                    MotifSortie = selectedRaisonCode ?? string.Empty,
                    RaisonSortieCode = selectedRaisonCode,
                    BonEntreeAssocieId = selectedBemDetails?.IdBon,
                    NomDestinataire = siteTo?.Nom ?? string.Empty,
                    Materiels = materiels,
                    CheckpointsItineraire = checkpointsList,
                    DateRetourPrevue = pretDateRetourPrevue ?? DateTime.Now.AddMonths(1),
                    DateExpiration = DateTime.Now.AddMonths(6),
                    SiteId = siteKccId,
                    RequestedForEmployeeCode = requestedForCode,
                    RequestedForDisplay = requestedForDisplay,
                    RequestedForDepartement = requestedForDepartement,
                    SiteManager = siteManagerAuto,
                    TypeMaterielSortieId = selectedTypeMaterielId
                };
                result = await BonSortieService.CreatePretAsync(pretRequest);
            }
            else
            {
                var request = new CreateBonSortieExterneRequest
                {
                    NomDemandeur = model.NomDemandeur,
                    FonctionDemandeur = model.FonctionDemandeur,
                    DepartementDemandeur = model.DepartementDemandeur,
                    Provenance = siteFrom?.Nom ?? string.Empty,
                    Destination = siteTo?.Nom ?? string.Empty,
                    MotifSortie = selectedRaisonCode ?? string.Empty,
                    RaisonSortieCode = selectedRaisonCode,
                    BonEntreeAssocieId = selectedBemDetails?.IdBon,
                    NomDestinataire = selectedBemDetails?.NomCompagnie ?? siteTo?.Nom ?? string.Empty,
                    Materiels = materiels,
                    CheckpointsItineraire = checkpointsList,
                    DateExpiration = DateTime.Now.AddMonths(6),
                    SiteId = siteKccId,
                    RequestedForEmployeeCode = requestedForCode,
                    RequestedForDisplay = requestedForDisplay,
                    RequestedForDepartement = requestedForDepartement,
                    SiteManager = siteManagerAuto,
                    TypeMaterielSortieId = selectedTypeMaterielId
                };
                result = await BonSortieService.CreateExterneAsync(request);
            }

            if (result.Success && result.Bon != null)
            {
                if (submit)
                {
                    await BonSortieService.SubmitForApprovalAsync(result.Bon.Id);
                }

                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = L["Lbl_Success"].Value,
                    Detail = submit
                        ? string.Format(L["Bsm_NotifBonSubmitted"].Value, result.Bon.NumeroReference)
                        : string.Format(L["Bsm_NotifBonDraft"].Value, result.Bon.NumeroReference),
                    Duration = 4000
                });

                Navigation.NavigateTo($"/bon-sortie/{result.Bon.Id}");
            }
            else
            {
                errorMessage = result.Errors.FirstOrDefault() ?? result.Message ?? L["Bsm_ErrorOccurred"].Value;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
