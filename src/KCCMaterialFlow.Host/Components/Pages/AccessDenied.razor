@page "/access-denied"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout EmptyLayout
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Ad_PageTitle"]</PageTitle>

<div class="ad-page">

    @* ── Décorations d'arrière-plan ── *@
    <div class="ad-bg-grid" aria-hidden="true"></div>
    <div class="ad-orb ad-orb--1" aria-hidden="true"></div>
    <div class="ad-orb ad-orb--2" aria-hidden="true"></div>
    <div class="ad-orb ad-orb--3" aria-hidden="true"></div>

    @* ── Header brand ── *@
    <header class="ad-header">
        <div class="ad-brand">
            <div class="ad-brand__logo">KCC</div>
            <div class="ad-brand__text">
                <span class="ad-brand__name">KCC Material Flow</span>
                <span class="ad-brand__tag">Kamoto Copper Company</span>
            </div>
        </div>
    </header>

    @* ── Carte centrale ── *@
    <main class="ad-main">
        <div class="ad-card">

            @* Pulsations autour du bouclier *@
            <div class="ad-shield">
                <span class="ad-shield__pulse ad-shield__pulse--1"></span>
                <span class="ad-shield__pulse ad-shield__pulse--2"></span>
                <div class="ad-shield__icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                </div>
            </div>

            <div class="ad-code">@L["Ad_ErrorCode"]</div>
            <h1 class="ad-title">@L["Ad_Title"]</h1>
            <p class="ad-subtitle">
                @L["Ad_Subtitle"]
            </p>

            <div class="ad-divider" aria-hidden="true">
                <span></span><span></span><span></span>
            </div>

            @* ── Étapes (3 colonnes horizontales) ── *@
            <ol class="ad-steps">
                <li>
                    <div class="ad-steps__num">1</div>
                    <div class="ad-steps__title">@L["Ad_Step1Title"]</div>
                    <div class="ad-steps__desc">@L["Ad_Step1Desc"]</div>
                </li>
                <li>
                    <div class="ad-steps__num">2</div>
                    <div class="ad-steps__title">@L["Ad_Step2Title"]</div>
                    <div class="ad-steps__desc">App. <em>KCC Material Flow</em>.</div>
                </li>
                <li>
                    <div class="ad-steps__num">3</div>
                    <div class="ad-steps__title">@L["Ad_Step3Title"]</div>
                    <div class="ad-steps__desc">@L["Ad_Step3Desc"]</div>
                </li>
            </ol>

            @* ── Actions ── *@
            <div class="ad-actions">
                <a href="https://glencorecopper.service-now.com" target="_blank" rel="noopener noreferrer"
                   class="ad-btn ad-btn--primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/>
                        <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                    @L["Ad_RequestAccess"]
                </a>
            </div>

            <div class="ad-help">
                @L["Ad_Help"] <a href="mailto:it-support@kcc.com">it-support@kcc.com</a>
            </div>
        </div>
    </main>

    @* ── Footer ── *@
    <footer class="ad-footer">
        © @DateTime.Now.Year Kamoto Copper Company — Material Flow Management System
    </footer>
</div>

<style>
    /* ════════════════════════════════════════════════════════════════
       ACCESS DENIED — Premium UI
       ════════════════════════════════════════════════════════════════ */

    :root {
        --ad-teal-900: #003a3b;
        --ad-teal-800: #005f60;
        --ad-teal-600: #00857d;
        --ad-teal-500: #00b193;
        --ad-ink: #0e2528;
        --ad-white: #ffffff;
        --ad-danger: #ff5b5b;
    }

    .ad-page {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background:
            radial-gradient(ellipse at 20% 10%, rgba(0, 177, 147, 0.18) 0%, transparent 55%),
            radial-gradient(ellipse at 80% 90%, rgba(0, 95, 96, 0.35) 0%, transparent 55%),
            linear-gradient(135deg, #062a2c 0%, #0e2528 50%, #062a2c 100%);
        color: var(--ad-white);
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        overflow: hidden;
    }

    /* ── Grille décorative ── */
    .ad-bg-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
        pointer-events: none;
    }

    /* ── Orbes flottants ── */
    .ad-orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.45;
        pointer-events: none;
    }
    .ad-orb--1 {
        top: -120px;
        left: -120px;
        width: 360px; height: 360px;
        background: radial-gradient(circle, #00b193 0%, transparent 70%);
        animation: ad-float 14s ease-in-out infinite;
    }
    .ad-orb--2 {
        bottom: -160px;
        right: -100px;
        width: 420px; height: 420px;
        background: radial-gradient(circle, #006d6e 0%, transparent 70%);
        animation: ad-float 18s ease-in-out infinite reverse;
    }
    .ad-orb--3 {
        top: 40%;
        right: 15%;
        width: 240px; height: 240px;
        background: radial-gradient(circle, #009a85 0%, transparent 70%);
        animation: ad-float 12s ease-in-out infinite;
        opacity: 0.30;
    }

    @@keyframes ad-float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%      { transform: translate(40px, -30px) scale(1.05); }
        66%      { transform: translate(-30px, 40px) scale(0.95); }
    }

    /* ── Header ── */
    .ad-header {
        position: relative;
        z-index: 2;
        padding: 1.75rem 2.5rem;
    }
    .ad-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .ad-brand__logo {
        width: 42px; height: 42px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--ad-teal-500), var(--ad-teal-800));
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 0.85rem;
        letter-spacing: 0.5px;
        color: white;
        box-shadow: 0 8px 24px -8px rgba(0, 177, 147, 0.6);
    }
    .ad-brand__text {
        display: flex; flex-direction: column; line-height: 1.2;
    }
    .ad-brand__name {
        font-weight: 700; font-size: 0.95rem; color: white;
        letter-spacing: -0.01em;
    }
    .ad-brand__tag {
        font-size: 0.72rem;
        color: rgba(255,255,255,0.55);
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    /* ── Main centré ── */
    .ad-main {
        position: relative;
        z-index: 2;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.5rem;
    }

    /* ── Carte glassmorphism ── */
    .ad-card {
        position: relative;
        width: 100%;
        max-width: 760px;
        padding: 2.5rem 2.75rem 2rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 20px;
        box-shadow:
            0 30px 80px -20px rgba(0, 0, 0, 0.55),
            0 0 0 1px rgba(0, 177, 147, 0.08) inset;
        text-align: center;
        animation: ad-card-in 0.7s cubic-bezier(.22,.9,.3,1.2);
    }
    @@keyframes ad-card-in {
        from { opacity: 0; transform: translateY(20px) scale(0.96); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Bouclier avec pulsations ── */
    .ad-shield {
        position: relative;
        width: 96px; height: 96px;
        margin: 0 auto 1.25rem;
        display: flex; align-items: center; justify-content: center;
    }
    .ad-shield__pulse {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1.5px solid rgba(255, 91, 91, 0.4);
        animation: ad-pulse 2.4s ease-out infinite;
    }
    .ad-shield__pulse--2 { animation-delay: 1.2s; }
    @@keyframes ad-pulse {
        0%   { transform: scale(0.9); opacity: 0.8; }
        100% { transform: scale(1.6); opacity: 0; }
    }
    .ad-shield__icon {
        position: relative;
        z-index: 2;
        width: 80px; height: 80px;
        border-radius: 50%;
        background: linear-gradient(145deg, rgba(255, 91, 91, 0.18), rgba(255, 91, 91, 0.05));
        border: 1.5px solid rgba(255, 91, 91, 0.45);
        color: #ff7676;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 32px -4px rgba(255, 91, 91, 0.45);
    }

    /* ── Texte principal ── */
    .ad-code {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.22em;
        color: var(--ad-teal-500);
        margin-bottom: 0.5rem;
    }
    .ad-title {
        margin: 0 0 0.85rem;
        font-size: 2.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: white;
        background: linear-gradient(180deg, #ffffff 0%, #c8e6e7 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .ad-subtitle {
        margin: 0 auto 1.75rem;
        max-width: 420px;
        font-size: 0.92rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.72);
    }
    .ad-subtitle strong {
        color: white;
        font-weight: 600;
    }

    /* ── Diviseur décoratif ── */
    .ad-divider {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.45rem;
        margin: 0 auto 1.75rem;
    }
    .ad-divider span {
        display: block;
        height: 4px; width: 4px;
        border-radius: 50%;
        background: var(--ad-teal-500);
        opacity: 0.6;
    }
    .ad-divider span:nth-child(2) {
        width: 32px;
        border-radius: 2px;
        opacity: 1;
    }

    /* ── Étapes (grille 3 colonnes) ── */
    .ad-steps {
        list-style: none;
        margin: 0 0 1.75rem;
        padding: 0;
        text-align: left;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        position: relative;
    }
    .ad-steps li {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        padding: 0.95rem 0.9rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        transition: background 0.2s, border-color 0.2s, transform 0.18s;
        position: relative;
    }
    .ad-steps li:hover {
        background: rgba(0, 177, 147, 0.10);
        border-color: rgba(0, 177, 147, 0.35);
        transform: translateY(-2px);
    }
    /* Flèches discrètes entre les étapes */
    .ad-steps li:not(:last-child)::after {
        content: "\203A";
        position: absolute;
        right: -0.55rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        color: rgba(0, 177, 147, 0.55);
        z-index: 2;
        line-height: 1;
    }
    .ad-steps__num {
        flex-shrink: 0;
        width: 26px; height: 26px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--ad-teal-500), var(--ad-teal-800));
        color: white;
        font-size: 0.78rem;
        font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 12px -2px rgba(0, 177, 147, 0.5);
    }
    .ad-steps__title {
        font-size: 0.84rem;
        font-weight: 600;
        color: white;
        line-height: 1.25;
    }
    .ad-steps__desc {
        font-size: 0.74rem;
        color: rgba(255, 255, 255, 0.55);
        line-height: 1.35;
    }
    .ad-steps em { color: var(--ad-teal-500); font-style: normal; font-weight: 600; }

    /* ── Boutons ── */
    .ad-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }
    .ad-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.78rem 1.5rem;
        border-radius: 10px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.18s, box-shadow 0.18s, background 0.2s;
        cursor: pointer;
        border: none;
    }
    .ad-btn--primary {
        background: linear-gradient(135deg, var(--ad-teal-500) 0%, var(--ad-teal-600) 100%);
        color: white;
        box-shadow: 0 12px 28px -10px rgba(0, 177, 147, 0.7);
    }
    .ad-btn--primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 18px 36px -10px rgba(0, 177, 147, 0.9);
    }
    .ad-btn--ghost {
        background: rgba(255, 255, 255, 0.05);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }
    .ad-btn--ghost:hover {
        background: rgba(255, 255, 255, 0.10);
        border-color: rgba(255, 255, 255, 0.25);
    }

    /* ── Aide ── */
    .ad-help {
        font-size: 0.78rem;
        color: rgba(255, 255, 255, 0.5);
        padding-top: 1.25rem;
        border-top: 1px dashed rgba(255, 255, 255, 0.08);
    }
    .ad-help a {
        color: var(--ad-teal-500);
        text-decoration: none;
        font-weight: 600;
    }
    .ad-help a:hover { text-decoration: underline; }

    /* ── Footer ── */
    .ad-footer {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 1.25rem;
        font-size: 0.74rem;
        color: rgba(255, 255, 255, 0.35);
        letter-spacing: 0.02em;
    }

    /* ── Responsive ── */
    @@media (max-width: 720px) {
        .ad-header { padding: 1.25rem 1.25rem; }
        .ad-card { padding: 2rem 1.5rem 1.75rem; border-radius: 16px; }
        .ad-title { font-size: 1.75rem; }
        .ad-subtitle { font-size: 0.86rem; }
        .ad-steps { grid-template-columns: 1fr; }
        .ad-steps li:not(:last-child)::after { display: none; }
        .ad-actions { flex-direction: column; }
        .ad-btn { width: 100%; justify-content: center; }
    }
</style>
