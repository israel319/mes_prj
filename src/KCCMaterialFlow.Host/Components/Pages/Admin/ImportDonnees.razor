@page "/admin/import-donnees"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using KCCMaterialFlow.Application.Common.Interfaces
@inject IDataImportService ImportService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Import Données - Admin - KCC Material Flow</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Imd_Title"]</h1>
                <p class="kcp-subtitle">@L["Imd_Subtitle"]</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn" type="button" @onclick="LoadBatchesAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">

    @* === ÉTAPE 1 : Upload === *@
    <RadzenCard class="rz-mb-4" Style="padding: 1.25rem;">
        <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 0.5rem;">
            <RadzenIcon Icon="cloud_upload" Style="vertical-align: middle; margin-right: 0.25rem;" />
            @L["Imd_Step1Title"]
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500); margin-bottom: 1rem;">
            @L["Imd_Step1Hint"]
        </RadzenText>

        <InputFile OnChange="OnFileSelected" accept=".xlsx" disabled="@isImporting" />

        @if (isImporting)
        {
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" Style="margin-top: 0.75rem;" />
            <RadzenText TextStyle="TextStyle.Body2" Style="display: inline-block; margin-left: 0.5rem;">@L["Imd_Reading"]</RadzenText>
        }

        @if (lastImport != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false" Style="margin-top: 1rem;">
                <strong>@L["Imd_ImportSuccess"]</strong> — Lot <code>@lastImport.BatchId.ToString("yyyy-MM-dd HH:mm:ss")</code> :
                @lastImport.CompaniesLoaded compagnies, @lastImport.ContractsLoaded contrats chargés en staging.
                <br />
                <strong>Employés</strong> : @lastImport.EmployeesUpserted upsertés directement, @lastImport.ReportToResolved liens ReportTo résolus, @lastImport.ReportToOrphans orphelin(s).
                @if (lastImport.Warnings.Count > 0)
                {
                    <ul style="margin: 0.5rem 0 0 1rem;">
                        @foreach (var w in lastImport.Warnings) { <li>@w</li> }
                    </ul>
                }
            </RadzenAlert>
        }
    </RadzenCard>

    @* === ÉTAPE 2 : Liste des lots + Merge === *@
    <RadzenCard Style="padding: 1.25rem;">
        <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 1rem;">
            <RadzenIcon Icon="merge" Style="vertical-align: middle; margin-right: 0.25rem;" />
            @L["Imd_Step2Title"]
        </RadzenText>

        @if (batches == null)
        {
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
        }
        else if (batches.Count == 0)
        {
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500);">@L["Imd_NoBatch"]</RadzenText>
        }
        else
        {
            <RadzenDataGrid Data="@batches" TItem="DataImportBatchSummary" AllowPaging="false" AllowSorting="false" Density="Density.Compact">
                <Columns>
                    <RadzenDataGridColumn TItem="DataImportBatchSummary" Property="BatchId" Title="@L["Imd_ColBatch"].Value" Width="180px">
                        <Template Context="b">
                            <code>@b.BatchId.ToString("yyyy-MM-dd HH:mm:ss")</code>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DataImportBatchSummary" Title="@L["Imd_ColCompanies"].Value" Width="140px">
                        <Template Context="b">
                            <RadzenBadge Text="@($"{b.CompaniesPending} / {b.CompaniesMerged}")"
                                         BadgeStyle="@(b.CompaniesPending > 0 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DataImportBatchSummary" Title="@L["Imd_ColContracts"].Value" Width="140px">
                        <Template Context="b">
                            <RadzenBadge Text="@($"{b.ContractsPending} / {b.ContractsMerged}")"
                                         BadgeStyle="@(b.ContractsPending > 0 ? BadgeStyle.Warning : BadgeStyle.Success)" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="DataImportBatchSummary" Title="@L["Col_Actions"].Value" Width="280px" TextAlign="TextAlign.Right">
                        <Template Context="b">
                            <RadzenButton Icon="merge" Text="@L["Imd_BtnMerge"].Value" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                          Disabled="@(isMerging || (b.CompaniesPending == 0 && b.ContractsPending == 0))"
                                          Click="@(() => MergeAsync(b.BatchId))" />
                            <RadzenButton Icon="delete" Text="@L["Imd_BtnPurge"].Value" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                          Disabled="@isMerging" Click="@(() => PurgeAsync(b.BatchId))" Style="margin-left: 0.25rem;" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }

        @if (lastMerge != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false" Style="margin-top: 1rem;">
                <strong>@L["Imd_MergeSuccess"]</strong> :
                @lastMerge.CompaniesUpserted compagnies, @lastMerge.ContractsUpserted contrats.
                @if (lastMerge.Warnings.Count > 0)
                {
                    <details style="margin-top: 0.5rem;">
                        <summary>@lastMerge.Warnings.Count @L["Imd_Warnings"]</summary>
                        <ul style="margin: 0.5rem 0 0 1rem; max-height: 200px; overflow: auto;">
                            @foreach (var w in lastMerge.Warnings.Take(50)) { <li>@w</li> }
                        </ul>
                    </details>
                }
            </RadzenAlert>
        }
    </RadzenCard>
    </main>
</div>

@code {
    private bool isImporting;
    private bool isMerging;
    private DataImportBatchResult? lastImport;
    private DataImportMergeResult? lastMerge;
    private List<DataImportBatchSummary>? batches;

    protected override async Task OnInitializedAsync() => await LoadBatchesAsync();

    private async Task LoadBatchesAsync()
    {
        var list = await ImportService.GetBatchesAsync();
        batches = list.ToList();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        if (!file.Name.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Format invalide", "Seuls les fichiers .xlsx sont acceptés.");
            return;
        }

        isImporting = true;
        lastImport = null;
        try
        {
            // 100 Mo max
            await using var src = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            using var ms = new MemoryStream();
            await src.CopyToAsync(ms);
            ms.Position = 0;

            lastImport = await ImportService.ImportToStagingAsync(ms);
            NotificationService.Notify(NotificationSeverity.Success, "Import réussi",
                $"{lastImport.CompaniesLoaded} compagnies, {lastImport.ContractsLoaded} contrats staging ; {lastImport.EmployeesUpserted} employés upsertés ({lastImport.ReportToResolved} ReportTo résolus).");
            await LoadBatchesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur d'import", ex.Message);
        }
        finally
        {
            isImporting = false;
        }
    }

    private async Task MergeAsync(DateTime batchId)
    {
        var confirm = await DialogService.Confirm(
            $"Merger le lot {batchId:yyyy-MM-dd HH:mm:ss} vers les tables réelles ?",
            "Confirmation",
            new ConfirmOptions { OkButtonText = "Merger", CancelButtonText = "Annuler" });
        if (confirm != true) return;

        isMerging = true;
        lastMerge = null;
        try
        {
            lastMerge = await ImportService.MergeStagingAsync(batchId);
            NotificationService.Notify(NotificationSeverity.Success, "Merge terminé",
                $"{lastMerge.CompaniesUpserted} compagnies, {lastMerge.ContractsUpserted} contrats mergés.");
            await LoadBatchesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur de merge", ex.Message);
        }
        finally
        {
            isMerging = false;
        }
    }

    private async Task PurgeAsync(DateTime batchId)
    {
        var confirm = await DialogService.Confirm(
            $"Supprimer définitivement le lot {batchId:yyyy-MM-dd HH:mm:ss} des tables tampons ? (les données déjà mergées ne sont pas affectées)",
            "Confirmation",
            new ConfirmOptions { OkButtonText = "Supprimer", CancelButtonText = "Annuler" });
        if (confirm != true) return;

        try
        {
            await ImportService.PurgeBatchAsync(batchId);
            NotificationService.Notify(NotificationSeverity.Success, "Lot supprimé", $"Lot {batchId:yyyy-MM-dd HH:mm:ss} purgé.");
            await LoadBatchesAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
    }
}
