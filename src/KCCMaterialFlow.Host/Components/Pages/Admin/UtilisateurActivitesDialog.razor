        max-height: 380px;
        overflow-y: auto;
        padding: 0.5rem 0;
    }

    /* ─── MODULE HEADER ─── */
    .kcc-modal__module-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.5rem;
