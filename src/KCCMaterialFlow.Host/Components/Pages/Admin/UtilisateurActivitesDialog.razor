@inject IActiviteService ActiviteService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache MemoryCache

<div class="kcc-modal">
    @* ─── BANDEAU SUPÉRIEUR ─── *@
    <div class="kcc-modal__topbar">
        <div class="kcc-modal__topbar-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
        </div>
        <div class="kcc-modal__topbar-text">
            <h2 class="kcc-modal__title">Gérer les activités</h2>
            <p class="kcc-modal__desc">Sélectionnez les activités autorisées pour cet utilisateur</p>
        </div>
        <button type="button" class="kcc-modal__close" @onclick="@Close" title="Fermer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
        </button>
    </div>

    @* ─── FICHE UTILISATEUR ─── *@
    <div class="kcc-modal__user-card">
        <div class="kcc-modal__user-avatar">
            @GetInitials(Utilisateur?.NomComplet)
        </div>
        <div class="kcc-modal__user-info">
            <span class="kcc-modal__user-name">@Utilisateur?.NomComplet</span>
            <span class="kcc-modal__user-login">@Utilisateur?.Login</span>
        </div>
        <div class="kcc-modal__user-stat">
            <span class="kcc-modal__user-stat-num">@assignedActiviteIds.Count</span>
            <span class="kcc-modal__user-stat-label">activité(s)</span>
        </div>
    </div>

    @* ─── ACTIONS RAPIDES ─── *@
    <div class="kcc-modal__toolbar">
        <button type="button" class="kcc-modal__toolbar-btn" @onclick="@SelectAll">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <polyline points="9 11 12 14 22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
            Tout sélectionner
        </button>
        <button type="button" class="kcc-modal__toolbar-btn" @onclick="@DeselectAll">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            </svg>
            Tout désélectionner
        </button>
        <span class="kcc-modal__toolbar-count">@assignedActiviteIds.Count / @allActivites.Count</span>
    </div>

    @* ─── INSTRUCTION ─── *@
    <p class="kcc-modal__hint">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
        </svg>
        Cliquez sur une activité pour l'activer ou la désactiver. Les modules sont regroupés par section.
    </p>

    @* ─── LISTE PAR MODULE ─── *@
    @if (isLoading)
    {
        <div class="kcc-modal__empty">Chargement des activités...</div>
    }
    else if (!activitesGrouped.Any())
    {
        <div class="kcc-modal__empty">Aucune activité disponible dans le système.</div>
    }
    else
    {
        <div class="kcc-modal__list">
            @foreach (var group in activitesGrouped)
            {
                var moduleLabel = GetModuleLabel(group.Key);
                var moduleIcon = GetModuleIcon(group.Key);
                var allInModule = group.Value.Select(a => a.Id).ToList();
                var allSelected = allInModule.All(id => assignedActiviteIds.Contains(id));
                var isCollapsed = collapsedModules.Contains(group.Key);
                var selectedCount = allInModule.Count(id => assignedActiviteIds.Contains(id));

                @* En-tête module *@
                <button type="button" class="kcc-modal__module-header" @onclick="@(() => ToggleModule(group.Key))">
                    <div class="kcc-modal__module-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <path d="@GetModuleIconPath(group.Key)"/>
                        </svg>
                    </div>
                    <span class="kcc-modal__module-name">@moduleLabel</span>
                    <span class="kcc-modal__module-count">@selectedCount/@allInModule.Count</span>
                    <button type="button" class="kcc-modal__module-toggle-all @(allSelected ? "kcc-modal__module-toggle-all--on" : "")"
                            @onclick="@(() => ToggleAllInModule(group.Key, !allSelected))" @onclick:stopPropagation="true"
                            title="@(allSelected ? "Désélectionner le module" : "Sélectionner le module")">
                        @if (allSelected)
                        {
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        }
                    </button>
                    <svg class="kcc-modal__module-chevron @(isCollapsed ? "" : "kcc-modal__module-chevron--open")" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </button>

                @* Activités du module *@
                @if (!isCollapsed)
                {
                    @foreach (var activite in group.Value)
                    {
                        var isAssigned = assignedActiviteIds.Contains(activite.Id);
                        <button type="button"
                                class="kcc-modal__item @(isAssigned ? "kcc-modal__item--on" : "")"
                                @onclick="@(() => ToggleActivite(activite.Id, !isAssigned))">

                            <div class="kcc-modal__item-indicator @(isAssigned ? "kcc-modal__item-indicator--on" : "")"></div>

                            <div class="kcc-modal__item-body">
                                <div class="kcc-modal__item-top">
                                    <span class="kcc-modal__item-name">@activite.NomActivite</span>
                                    @if (!string.IsNullOrEmpty(activite.CodeActivite))
                                    {
                                        <span class="kcc-modal__item-badge">@activite.CodeActivite</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(activite.Description))
                                {
                                    <span class="kcc-modal__item-desc">@activite.Description</span>
                                }
                            </div>

                            <div class="kcc-modal__item-toggle @(isAssigned ? "kcc-modal__item-toggle--on" : "")">
                                <div class="kcc-modal__item-toggle-dot"></div>
                            </div>
                        </button>
                    }
                }
            }
        </div>
    }

    @* ─── BARRE DE CHANGEMENTS ─── *@
    @if (HasChanges)
    {
        <div class="kcc-modal__changes">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
            </svg>
            <span>Modifications non enregistrées</span>
            @if (addedActivites.Any())
            {
                <span class="kcc-modal__changes-add">+@addedActivites.Count</span>
            }
            @if (removedActivites.Any())
            {
                <span class="kcc-modal__changes-rm">-@removedActivites.Count</span>
            }
        </div>
    }

    @* ─── ACTIONS ─── *@
    <div class="kcc-modal__footer">
        <button type="button" class="kcc-modal__btn kcc-modal__btn--ghost" @onclick="@Close">
            Annuler
        </button>
        <button type="button" class="kcc-modal__btn kcc-modal__btn--primary" @onclick="@Save" disabled="@(!HasChanges || isSaving)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
                <polyline points="17 21 17 13 7 13 7 21"/>
                <polyline points="7 3 7 8 15 8"/>
            </svg>
            Enregistrer les activités
        </button>
    </div>
</div>

<style>
