@page "/admin/types-materiels"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject ITypeMaterielService TypeMaterielService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Administration - Types de Matériel</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Tma_Title"]</h1>
                <p class="kcp-subtitle">@filteredTypes.Count @L["Tma_Count"] @types.Count</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn kcp-btn-primary" type="button" @onclick="ShowCreateDialog">
                    <RadzenIcon Icon="add_circle" Style="font-size:1rem;" />
                    @L["Tma_BtnNew"]
                </button>
                <button class="kcp-btn" type="button" @onclick="LoadDataAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">


    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            @L["Lbl_ActiveFilter"] <strong>@(activeFilter == "active" ? L["Lbl_Active"].Value : L["Lbl_Inactive"].Value)</strong>
        </RadzenAlert>
    }

    @* === RECHERCHE === *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" class="rz-mb-4">
        <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
        <RadzenTextBox @bind-Value="searchTerm" Placeholder="@L["Tma_SearchPh"].Value"
                       Style="flex: 1; min-width: 220px;" Change="@(_ => StateHasChanged())" />
        <RadzenDropDown TValue="string" Data="@categories" @bind-Value="filterCategorie"
                        AllowClear="true" Placeholder="@L["Tma_FilterAllCategories"].Value" Style="min-width: 180px;"
                        Change="@(_ => StateHasChanged())" />
        @if (!string.IsNullOrWhiteSpace(searchTerm) || !string.IsNullOrEmpty(filterCategorie))
        {
            <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ResetFilters" />
        }
    </RadzenStack>

    @* === GRID === *@
    <RadzenDataGrid @ref="grid" Data="@filteredTypes" TItem="TypeMaterielEntity"
                    AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="10"
                    PagerHorizontalAlign="HorizontalAlign.Center"
                    Density="Density.Compact"
                    GridLines="DataGridGridLines.Horizontal"
                    EmptyText="@L["Tma_Empty"].Value">
        <Columns>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="Ordre" Title="@L["Tma_ColNum"].Value" Width="60px" TextAlign="TextAlign.Center" Sortable="true" />
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="CodeType" Title="@L["Tma_ColType"].Value" Width="240px" Sortable="true">
                <Template Context="type">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        @if (!string.IsNullOrEmpty(type.Icone))
                        {
                            <div style="width: 32px; height: 32px; background: @(type.Couleur ?? "#6c757d"); border-radius: 8px;
                                        display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                <RadzenIcon Icon="@type.Icone" Style="color: #fff; font-size: 16px;" />
                            </div>
                        }
                        <div>
                            <div style="font-weight: 600; font-size: 0.85rem;">@type.NomType</div>
                            <div style="font-size: 0.75rem; color: var(--gray-500); font-family: monospace;">@type.CodeType</div>
                        </div>
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="Categorie" Title="@L["Tma_ColCategory"].Value" Width="140px" Sortable="true">
                <Template Context="type">
                    @if (!string.IsNullOrEmpty(type.Categorie))
                    {
                        <RadzenBadge Text="@type.Categorie" BadgeStyle="BadgeStyle.Light" />
                    }
                    else
                    {
                        <span style="color: #999;">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="@L["Tma_ColApprovals"].Value" Width="160px" Sortable="false">
                <Template Context="type">
                    <RadzenStack Gap="0.25rem">
                        <span style="font-size: 0.85rem; font-weight: 600;">@type.NiveauxApprobation @L["Tma_Levels"]</span>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem">
                            @if (type.RequiertApprobationDepartement)
                            {
                                <RadzenBadge Text="@L["Tma_BadgeDept"].Value" BadgeStyle="BadgeStyle.Info" />
                            }
                            @if (type.RequiertApprobationDirection)
                            {
                                <RadzenBadge Text="@L["Tma_BadgeDir"].Value" BadgeStyle="BadgeStyle.Warning" />
                            }
                        </RadzenStack>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="@L["Tma_ColValidity"].Value" Width="130px" Sortable="false">
                <Template Context="type">
                    <span style="font-size: 0.85rem;">@type.DureeValiditeDefautJours @L["Tma_DaysMax"] @type.DureeMaximumJours @L["Tma_DaysUnit"]</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="@L["Tma_ColRequired"].Value" Width="140px" Sortable="false">
                <Template Context="type">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" Wrap="FlexWrap.Wrap">
                        @if (type.NumeroSerieObligatoire)
                        {
                                <RadzenBadge Text="@L["Tma_BadgeSerial"].Value" BadgeStyle="BadgeStyle.Light" />
                        }
                        @if (type.PhotoObligatoire)
                        {
                                <RadzenBadge Text="@L["Tma_BadgePhoto"].Value" BadgeStyle="BadgeStyle.Light" />
                        }
                        @if (!type.NumeroSerieObligatoire && !type.PhotoObligatoire)
                        {
                            <span style="color: #999;">—</span>
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="EstActif" Title="@L["Sta_ColStatut"].Value" Width="100px" TextAlign="TextAlign.Center" Sortable="true">
                <Template Context="type">
                    @if (type.EstActif)
                    {
                        <RadzenBadge Text="@L["Tma_BadgeActive"].Value" BadgeStyle="BadgeStyle.Success" />
                    }
                    else
                    {
                        <RadzenBadge Text="@L["Tma_BadgeInactive"].Value" BadgeStyle="BadgeStyle.Light" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="@L["Col_Actions"].Value" Width="140px" TextAlign="TextAlign.Right" Sortable="false">
                <Template Context="type">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.4rem" JustifyContent="JustifyContent.End">
                        <RadzenButton Icon="edit" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Dark" Click="@(() => ShowEditDialog(type))" title="@L["Tt_Edit"].Value" />
                        <RadzenButton Icon="@(type.EstActif ? "block" : "check_circle")" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                      ButtonStyle="@(type.EstActif ? ButtonStyle.Warning : ButtonStyle.Success)"
                                      Click="@(() => ToggleStatus(type))" title="@(type.EstActif ? L["Tt_Disable"].Value : L["Tt_Enable"].Value)" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
    </main>
</div>

@code {
    private RadzenDataGrid<TypeMaterielEntity>? grid;
    private List<TypeMaterielEntity> types = [];
    private List<string> categories = [];

    private string? searchTerm;
    private string? filterCategorie;
    private string? activeFilter;

    private List<TypeMaterielEntity> filteredTypes
    {
        get
        {
            IEnumerable<TypeMaterielEntity> q = types;
            if (activeFilter == "active") q = q.Where(t => t.EstActif);
            else if (activeFilter == "inactive") q = q.Where(t => !t.EstActif);
            if (!string.IsNullOrWhiteSpace(filterCategorie))
                q = q.Where(t => t.Categorie == filterCategorie);
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var s = searchTerm.Trim();
                q = q.Where(t =>
                    t.CodeType.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    t.NomType.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (t.Categorie ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q.OrderBy(t => t.Ordre).ToList();
        }
    }

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        try
        {
            types = (await TypeMaterielService.GetAllAsync()).ToList();
            categories = (await TypeMaterielService.GetCategoriesAsync()).ToList();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private void SetFilter(string? f) { activeFilter = f; StateHasChanged(); }
    private void ResetFilters() { searchTerm = null; filterCategorie = null; StateHasChanged(); }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<TypeMaterielEditDialog>("Nouveau type de matériel",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Type créé avec succès");
        }
    }

    private async Task ShowEditDialog(TypeMaterielEntity type)
    {
        var result = await DialogService.OpenAsync<TypeMaterielEditDialog>("Modifier le type",
            new Dictionary<string, object> { { "TypeMateriel", type } },
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Type modifié avec succès");
        }
    }

    private async Task ToggleStatus(TypeMaterielEntity type)
    {
        var action = type.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} le type {type.NomType} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });

        if (confirmed == true)
        {
            try
            {
                await TypeMaterielService.DeleteAsync(type.Id);
                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    type.EstActif ? "Deactivate" : "Activate",
                    "TypeMateriel",
                    $"Type {type.NomType} {(type.EstActif ? "désactivé" : "activé")}",
                    type.Id.ToString(),
                    "TypeMateriel");
                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès",
                    $"Type {(type.EstActif ? "désactivé" : "activé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }
}
