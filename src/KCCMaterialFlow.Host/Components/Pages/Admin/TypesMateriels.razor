@page "/admin/types-materiels"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject ITypeMaterielService TypeMaterielService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Administration - Types de Matériel</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <AdminNav />

    @* ─── En-tête ─── *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
                Gestion des Types de Matériel
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            <RadzenButton Icon="refresh" Text="Actualiser" Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Secondary" Click="@LoadDataAsync" />
            <RadzenButton Text="Nouveau type" Icon="add" ButtonStyle="ButtonStyle.Primary"
                          Click="@ShowCreateDialog" />
        </RadzenStack>
    </RadzenStack>

    @* ─── Filtres ─── *@
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Style="padding: 0.5rem 0;">
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Catégorie</RadzenText>
                <RadzenDropDown TValue="string" Data="@categories" @bind-Value="@filterCategorie"
                                AllowClear="true" Placeholder="Toutes" Style="min-width: 160px;"
                                Change="@(args => ApplyFilters())" />
            </RadzenStack>
            <RadzenButton Icon="clear" Text="Effacer" Click="@ResetFilters"
                          ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" class="kcc-btn-clear" />
        </RadzenStack>
    </RadzenCard>

    @* ─── Grille des types ─── *@
    <RadzenCard>
        <RadzenDataGrid @ref="grid" Data="@filteredTypes" TItem="TypeMaterielEntity"
                        AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="15"
                        PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowColumnResize="true"
                        Density="Density.Compact"
                        EmptyText="Aucun type trouvé">
                <Columns>
                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="Ordre" Title="#" Width="50px" TextAlign="TextAlign.Center" />

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="CodeType" Title="Code" Width="220px">
                        <Template Context="type">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                @if (!string.IsNullOrEmpty(type.Icone))
                                {
                                    <div style="width: 28px; height: 28px; background: @(type.Couleur ?? "#6c757d");
                                                display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                        <RadzenIcon Icon="@type.Icone" Style="color: #fff; font-size: 14px;" />
                                    </div>
                                }
                                <div>
                                    <div style="font-weight: 600; font-size: 0.8rem; color: #1a1a1a;">@type.CodeType</div>
                                    <div style="font-size: 0.72rem; color: #666;">@type.NomType</div>
                                </div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="Categorie" Title="Catégorie" Width="130px">
                        <Template Context="type">
                            @if (!string.IsNullOrEmpty(type.Categorie))
                            {
                                <span style="font-size: 0.78rem; color: #374151;">@type.Categorie</span>
                            }
                            else
                            {
                                <span style="color: #999;">—</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="Approbations" Width="140px">
                        <Template Context="type">
                            <div style="display: flex; align-items: center; gap: 0.35rem;">
                                <span style="font-size: 0.78rem; font-weight: 600; color: #374151;">@type.NiveauxApprobation</span>
                                <span style="font-size: 0.72rem; color: #666;">niveau(x)</span>
                            </div>
                            <div style="display: flex; gap: 0.25rem; margin-top: 0.15rem;">
                                @if (type.RequiertApprobationDepartement)
                                {
                                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: rgba(59,130,246,0.1); color: #2563eb;">Dept</span>
                                }
                                @if (type.RequiertApprobationDirection)
                                {
                                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: rgba(245,158,11,0.1); color: #d97706;">Dir</span>
                                }
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="Validité" Width="110px">
                        <Template Context="type">
                            <div style="font-size: 0.78rem; color: #374151;">@type.DureeValiditeDefautJours j <span style="color: #999;">/ max @type.DureeMaximumJours j</span></div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="Requis" Width="120px">
                        <Template Context="type">
                            <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                                @if (type.NumeroSerieObligatoire)
                                {
                                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: #f3f4f6; color: #374151;">N° série</span>
                                }
                                @if (type.PhotoObligatoire)
                                {
                                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: #f3f4f6; color: #374151;">Photo</span>
                                }
                                @if (!type.NumeroSerieObligatoire && !type.PhotoObligatoire)
                                {
                                    <span style="color: #999;">—</span>
                                }
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Property="EstActif" Title="Statut" Width="80px" TextAlign="TextAlign.Center">
                        <Template Context="type">
                            @if (type.EstActif)
                            {
                                <span style="font-size: 0.72rem; font-weight: 600; color: #059669;">Actif</span>
                            }
                            else
                            {
                                <span style="font-size: 0.72rem; font-weight: 600; color: #dc2626;">Inactif</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="TypeMaterielEntity" Title="Actions" Width="90px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="type">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                              Click="@(() => ShowEditDialog(type))" title="Modifier" />
                                @if (type.EstActif)
                                {
                                    <RadzenButton Icon="block" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                                  Click="@(() => ToggleStatus(type))" title="Désactiver" />
                                }
                                else
                                {
                                    <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text" Size="ButtonSize.Small"
                                                  Click="@(() => ToggleStatus(type))" title="Activer" />
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
</RadzenStack>

@code {
    private RadzenDataGrid<TypeMaterielEntity>? grid;
    private List<TypeMaterielEntity> types = [];
    private List<TypeMaterielEntity> filteredTypes = [];
    private List<string> categories = [];
    
    private string? filterCategorie;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            types = (await TypeMaterielService.GetAllAsync()).ToList();
            categories = (await TypeMaterielService.GetCategoriesAsync()).ToList();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private void ApplyFilters()
    {
        var query = types.AsEnumerable();
        
        if (!string.IsNullOrWhiteSpace(filterCategorie))
        {
            query = query.Where(t => t.Categorie == filterCategorie);
        }
        
        filteredTypes = query.OrderBy(t => t.Ordre).ToList();
    }

    private void ResetFilters()
    {
        filterCategorie = null;
        ApplyFilters();
    }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<TypeMaterielEditDialog>("Nouveau type de matériel",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Type créé avec succès");
        }
    }

    private async Task ShowEditDialog(TypeMaterielEntity type)
    {
        var result = await DialogService.OpenAsync<TypeMaterielEditDialog>("Modifier le type",
            new Dictionary<string, object> { { "TypeMateriel", type } },
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Type modifié avec succès");
        }
    }

    private async Task ToggleStatus(TypeMaterielEntity type)
    {
        var action = type.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} le type {type.NomType} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });
        
        if (confirmed == true)
        {
            try
            {
                await TypeMaterielService.DeleteAsync(type.Id);
                
                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    type.EstActif ? "Deactivate" : "Activate",
                    "TypeMateriel",
                    $"Type {type.NomType} {(type.EstActif ? "désactivé" : "activé")}",
                    type.Id.ToString(),
                    "TypeMateriel");
                
                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès", 
                    $"Type {(type.EstActif ? "désactivé" : "activé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }
}
