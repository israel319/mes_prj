@inject IStatutService StatutService
@inject DialogService DialogService

<RadzenStack Gap="1rem">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Code *" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.CodeStatut" Style="width: 100%;" 
                               Placeholder="EN_ATTENTE" MaxLength="50" Disabled="@isSysteme" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenFormField Text="Libellé *" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.LibelleStatut" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="Description" Style="width: 100%;">
                <RadzenTextArea @bind-Value="@model.Description" Style="width: 100%;" Rows="2" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenFormField Text="Type de bon *" Style="width: 100%;">
                <RadzenDropDown TValue="string" Data="@typesBon" @bind-Value="@model.TypeBon"
                                Style="width: 100%;" Disabled="@isSysteme" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenFormField Text="Ordre d'affichage" Style="width: 100%;">
                <RadzenNumeric @bind-Value="@model.Ordre" Style="width: 100%;" Min="0" Max="100" Disabled="@isSysteme" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Couleur de fond" Style="width: 100%;">
                <RadzenColorPicker @bind-Value="@model.CouleurFond" Style="width: 100%;" ShowHSV="true" ShowRGBA="false" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Couleur du texte" Style="width: 100%;">
                <RadzenColorPicker @bind-Value="@model.CouleurTexte" Style="width: 100%;" ShowHSV="true" ShowRGBA="false" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Icône" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.Icone" Style="width: 100%;" 
                               Placeholder="bi-check-circle" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <div style="background-color: @model.CouleurFond; color: @model.CouleurTexte; 
                        padding: 0.5rem 1rem; border-radius: 20px; display: inline-block;">
                @if (!string.IsNullOrEmpty(model.Icone))
                {
                    <i class="@model.Icone" style="margin-right: 0.25rem;"></i>
                }
                @(string.IsNullOrEmpty(model.LibelleStatut) ? "Aperçu" : model.LibelleStatut)
            </div>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.EstFinal" TValue="bool" Disabled="@isSysteme" />
                <RadzenLabel Text="Statut final" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.RequiertAction" TValue="bool" Disabled="@isSysteme" />
                <RadzenLabel Text="Requiert une action" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.EstActif" TValue="bool" />
                <RadzenLabel Text="Statut actif" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" class="rz-mt-4">
        <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
        <RadzenButton Text="@(isEditMode ? "Enregistrer" : "Créer")" ButtonStyle="ButtonStyle.Primary" 
                      Click="@Save" Disabled="@(!IsValid)" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter]
    public Statut? Statut { get; set; }
    
    private Statut model = new();
    private bool isEditMode;
    private bool isSysteme;
    
    private readonly List<string> typesBon = ["Tous", "BonEntree", "BonSortie"];
    
    private bool IsValid => !string.IsNullOrWhiteSpace(model.CodeStatut) && 
                           !string.IsNullOrWhiteSpace(model.LibelleStatut);

    protected override void OnInitialized()
    {
        if (Statut != null)
        {
            isEditMode = true;
            isSysteme = Statut.EstSysteme;
            model = new Statut
            {
                Id = Statut.Id,
                CodeStatut = Statut.CodeStatut,
                LibelleStatut = Statut.LibelleStatut,
                Description = Statut.Description,
                TypeBon = Statut.TypeBon,
                CouleurFond = Statut.CouleurFond,
                CouleurTexte = Statut.CouleurTexte,
                Icone = Statut.Icone,
                Ordre = Statut.Ordre,
                EstFinal = Statut.EstFinal,
                RequiertAction = Statut.RequiertAction,
                StatutsSuivants = Statut.StatutsSuivants,
                EstActif = Statut.EstActif,
                EstSysteme = Statut.EstSysteme,
                DateCreation = Statut.DateCreation
            };
        }
        else
        {
            model.TypeBon = "Tous";
            model.CouleurFond = "#6c757d";
            model.CouleurTexte = "#ffffff";
            model.EstActif = true;
        }
    }

    private async Task Save()
    {
        if (!IsValid) return;
        
        try
        {
            if (isEditMode)
            {
                await StatutService.UpdateAsync(model);
            }
            else
            {
                await StatutService.CreateAsync(model);
            }
            
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Erreur lors de l'enregistrement: {ex.Message}", "Erreur");
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
}
