@page "/admin/departement-motifs"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using KCCMaterialFlow.Domain.Entities
@inject ICategorieSortieService CategorieSortieService
@inject IDepartementService DepartementService
@inject NotificationService NotificationService

<PageTitle>Administration - Mapping Départements / Motifs</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <AdminNav />

    @* ─── En-tête ─── *@
    <RadzenStack Gap="0.25rem">
        <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
            Mapping Départements / Motifs de Sortie
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-light); margin-top: 0.25rem;">
            Configurez quels motifs de sortie sont autorisés pour chaque département hôte.
            Les motifs par défaut s'appliquent à tous les départements sans mapping spécifique.
        </RadzenText>
    </RadzenStack>

    <RadzenRow Gap="1rem">
            @* ── Colonne gauche : Départements ── *@
            <RadzenColumn Size="4">
                <RadzenCard Style="min-height: 500px;">
                    <RadzenText TextStyle="TextStyle.Subtitle1" FontWeight="FontWeight.SemiBold" class="rz-mb-3">
                        Départements
                    </RadzenText>

                    @* Défaut *@
                    <div class="dept-item @(selectedDeptId == null && isDefaultSelected ? "dept-item--selected" : "")"
                         @onclick="() => SelectDefault()">
                        <RadzenIcon Icon="public" Style="margin-right: 0.5rem;" />
                        <span><strong>Défaut</strong> (tous les autres)</span>
                    </div>

                    <hr style="margin: 0.5rem 0;" />

                    @if (departements != null)
                    {
                        @foreach (var dept in departements.Where(d => d.EstActif))
                        {
                            var isSelected = selectedDeptId == dept.Id;
                            var mappingCount = deptMappingCounts.GetValueOrDefault(dept.Id, 0);
                            <div class="dept-item @(isSelected ? "dept-item--selected" : "")"
                                 @onclick="() => SelectDepartement(dept)">
                                <RadzenIcon Icon="business" Style="margin-right: 0.5rem;" />
                                <span>@dept.NomDepartement</span>
                                @if (mappingCount > 0)
                                {
                                    <RadzenBadge Text="@mappingCount.ToString()" BadgeStyle="BadgeStyle.Info" Style="margin-left: auto;" />
                                }
                            </div>
                        }
                    }
                </RadzenCard>
            </RadzenColumn>

            @* ── Colonne droite : Raisons autorisées ── *@
            <RadzenColumn Size="8">
                <RadzenCard Style="min-height: 500px;">
                    @if (isDefaultSelected || selectedDeptId.HasValue)
                    {
                        <RadzenText TextStyle="TextStyle.Subtitle1" FontWeight="FontWeight.SemiBold" class="rz-mb-3">
                            Motifs autorisés pour :
                            <strong>@(isDefaultSelected ? "Défaut (tous les autres)" : selectedDeptName)</strong>
                        </RadzenText>

                        @if (allRaisons != null)
                        {
                            <RadzenStack Gap="0.75rem">
                                @foreach (var categorie in allRaisons.Where(c => c.Raisons.Any()))
                                {
                                    <RadzenText TextStyle="TextStyle.Subtitle2" FontWeight="FontWeight.SemiBold"
                                                Style="color: var(--kcc-primary); margin-top: 0.5rem;">
                                        @categorie.Nom
                                    </RadzenText>
                                    @foreach (var raison in categorie.Raisons.Where(r => r.EstActif))
                                    {
                                        <div style="display: flex; align-items: center; padding: 0.25rem 0.5rem;">
                                            <RadzenCheckBox @bind-Value="@(selectedRaisonIds[raison.Id])"
                                                            TValue="bool"
                                                            Name="@($"raison_{raison.Id}")" />
                                            <RadzenLabel Text="@($"{raison.Nom} ({raison.Code})")"
                                                         Component="@($"raison_{raison.Id}")"
                                                         Style="margin-left: 0.5rem;" />
                                            @if (!string.IsNullOrWhiteSpace(raison.Description))
                                            {
                                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted); margin-left: 0.5rem;">
                                                    — @raison.Description
                                                </RadzenText>
                                            }
                                        </div>
                                    }
                                }
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Style="margin-top: 1.5rem;">
                                <RadzenButton Text="Sauvegarder" Icon="save" ButtonStyle="ButtonStyle.Primary"
                                              Click="@SaveMappings" IsBusy="@isSaving" />
                                <RadzenButton Text="Réinitialiser" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                                              Variant="Variant.Outlined" Click="@ReloadMappings" />
                            </RadzenStack>
                        }
                    }
                    else
                    {
                        <div style="display: flex; align-items: center; justify-content: center; height: 400px; color: var(--kcc-text-muted);">
                            <RadzenText TextStyle="TextStyle.Body1">
                                Sélectionnez un département pour configurer ses motifs autorisés
                            </RadzenText>
                        </div>
                    }
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
</RadzenStack>

<style>
    .dept-item {
        display: flex;
        align-items: center;
        padding: 0.6rem 0.75rem;
        cursor: pointer;
        border-radius: 6px;
        transition: background-color 0.15s;
    }
    .dept-item:hover { background-color: var(--kcc-primary-light, #e6f7f4); }
    .dept-item--selected {
        background-color: var(--kcc-primary-light, #e6f7f4);
        border-left: 3px solid var(--kcc-primary, #00B193);
    }
</style>

@code {
    private List<Departement>? departements;
    private List<CategorieSortie>? allRaisons;
    private Dictionary<int, bool> selectedRaisonIds = new();
    private Dictionary<int, int> deptMappingCounts = new();

    private int? selectedDeptId;
    private string? selectedDeptName;
    private bool isDefaultSelected;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        departements = (await DepartementService.GetAllAsync()).ToList();
        allRaisons = (await CategorieSortieService.GetAllCategoriesWithRaisonsAsync()).ToList();

        // Compter les mappings par département
        await LoadMappingCounts();
    }

    private async Task LoadMappingCounts()
    {
        deptMappingCounts.Clear();
        if (departements == null) return;

        foreach (var dept in departements.Where(d => d.EstActif))
        {
            var mappings = await CategorieSortieService.GetDepartementRaisonMappingsAsync(dept.Id);
            if (mappings.Count > 0)
                deptMappingCounts[dept.Id] = mappings.Count;
        }
    }

    private async Task SelectDefault()
    {
        selectedDeptId = null;
        selectedDeptName = null;
        isDefaultSelected = true;
        await ReloadMappings();
    }

    private async Task SelectDepartement(Departement dept)
    {
        selectedDeptId = dept.Id;
        selectedDeptName = dept.NomDepartement;
        isDefaultSelected = false;
        await ReloadMappings();
    }

    private async Task ReloadMappings()
    {
        var currentDeptId = isDefaultSelected ? null : selectedDeptId;
        var mappings = await CategorieSortieService.GetDepartementRaisonMappingsAsync(currentDeptId);
        var mappedIds = new HashSet<int>(mappings.Select(m => m.RaisonSortieId));

        selectedRaisonIds.Clear();
        if (allRaisons != null)
        {
            foreach (var cat in allRaisons)
            {
                foreach (var raison in cat.Raisons.Where(r => r.EstActif))
                {
                    selectedRaisonIds[raison.Id] = mappedIds.Contains(raison.Id);
                }
            }
        }
    }

    private async Task SaveMappings()
    {
        isSaving = true;
        try
        {
            var currentDeptId = isDefaultSelected ? null : selectedDeptId;
            var raisonIds = selectedRaisonIds.Where(kv => kv.Value).Select(kv => kv.Key).ToList();

            await CategorieSortieService.SaveDepartementRaisonMappingsAsync(currentDeptId, raisonIds);
            await LoadMappingCounts();

            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Success,
                Summary = "Mappings sauvegardés",
                Detail = $"{raisonIds.Count} motif(s) autorisé(s) pour {(isDefaultSelected ? "Défaut" : selectedDeptName)}",
                Duration = 3000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new Radzen.NotificationMessage
            {
                Severity = Radzen.NotificationSeverity.Error,
                Summary = "Erreur",
                Detail = ex.Message,
                Duration = 5000
            });
        }
        finally
        {
            isSaving = false;
        }
    }
}
