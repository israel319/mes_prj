@using KCCMaterialFlow.Module.Shared.Entities
@using KCCMaterialFlow.Module.Shared.Services
@inject IDepartementService DepartementService
@inject IUtilisateurService UtilisateurService
@inject DialogService DialogService

<RadzenStack Gap="1rem">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Code *" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.CodeDepartement" Style="width: 100%;" 
                               Placeholder="IT, RH, FIN..." MaxLength="20" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenFormField Text="Nom du département *" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.NomDepartement" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="Description" Style="width: 100%;">
                <RadzenTextArea @bind-Value="@model.Description" Style="width: 100%;" Rows="2" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenFieldset Text="Responsable du département">
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12">
                <RadzenFormField Text="Sélectionner le responsable *" Style="width: 100%;">
                    <RadzenDropDown TValue="string" Data="@utilisateurs" @bind-Value="@model.ResponsableLogin"
                                    TextProperty="DisplayText" ValueProperty="Login"
                                    AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Placeholder="Rechercher un utilisateur..." Style="width: 100%;"
                                    Change="@OnResponsableChanged" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        
        <RadzenRow Gap="1rem" class="rz-mt-2">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Nom du responsable" Style="width: 100%;">
                    <RadzenTextBox @bind-Value="@model.ResponsableNom" Style="width: 100%;" ReadOnly="true" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Email du responsable" Style="width: 100%;">
                    <RadzenTextBox @bind-Value="@model.ResponsableEmail" Style="width: 100%;" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
    </RadzenFieldset>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.EstActif" TValue="bool" />
                <RadzenLabel Text="Département actif" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" class="rz-mt-4">
        <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
        <RadzenButton Text="@(isEditMode ? "Enregistrer" : "Créer")" ButtonStyle="ButtonStyle.Primary" 
                      Click="@Save" Disabled="@(!IsValid)" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter]
    public Departement? Departement { get; set; }
    
    private Departement model = new();
    private List<UtilisateurDropdownItem> utilisateurs = [];
    private bool isEditMode;
    
    private bool IsValid => !string.IsNullOrWhiteSpace(model.CodeDepartement) && 
                           !string.IsNullOrWhiteSpace(model.NomDepartement) &&
                           !string.IsNullOrWhiteSpace(model.ResponsableLogin);

    protected override async Task OnInitializedAsync()
    {
        var users = await UtilisateurService.GetAllActiveAsync();
        utilisateurs = users.Select(u => new UtilisateurDropdownItem
        {
            Login = u.Login,
            NomComplet = u.NomComplet,
            Email = u.Email,
            DisplayText = $"{u.NomComplet} ({u.Login})"
        }).OrderBy(u => u.NomComplet).ToList();
        
        if (Departement != null)
        {
            isEditMode = true;
            model = new Departement
            {
                IdDepartement = Departement.IdDepartement,
                CodeDepartement = Departement.CodeDepartement,
                NomDepartement = Departement.NomDepartement,
                Description = Departement.Description,
                ResponsableLogin = Departement.ResponsableLogin,
                ResponsableNom = Departement.ResponsableNom,
                ResponsableEmail = Departement.ResponsableEmail,
                EstActif = Departement.EstActif,
                DateCreation = Departement.DateCreation
            };
        }
        else
        {
            model.EstActif = true;
        }
    }

    private void OnResponsableChanged(object? value)
    {
        if (value is string login)
        {
            var user = utilisateurs.FirstOrDefault(u => u.Login == login);
            if (user != null)
            {
                model.ResponsableNom = user.NomComplet;
                model.ResponsableEmail = user.Email;
            }
        }
    }

    private async Task Save()
    {
        if (!IsValid) return;
        
        try
        {
            model.CodeDepartement = model.CodeDepartement.ToUpperInvariant();
            model.DateModification = DateTime.Now;
            
            if (isEditMode)
            {
                await DepartementService.UpdateAsync(model);
            }
            else
            {
                model.DateCreation = DateTime.Now;
                await DepartementService.CreateAsync(model);
            }
            
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Erreur lors de l'enregistrement: {ex.Message}", "Erreur");
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
    
    private class UtilisateurDropdownItem
    {
        public string Login { get; set; } = string.Empty;
        public string NomComplet { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string DisplayText { get; set; } = string.Empty;
    }
}
