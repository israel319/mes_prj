@code {
    // ── État de navigation ──────────────────────────────────────────────────
    private int _phase = 1;
    private string _bonType = "BSM";

    // ── Données phase 1 ─────────────────────────────────────────────────────
    private List<WorkflowContextSummary>? _summary;
    private List<RaisonSortie> _raisons = new();
    private bool _loading = true;

    // ── Données phase 2 ─────────────────────────────────────────────────────
    private WorkflowContextSummary? _selectedRaison;
    private List<WorkflowEtapeConfig> _etapes = new();
    private int _editingIdx = -1;
    private bool _saving;

    private IReadOnlyList<WorkflowRoleDisponible> _rolesDisponibles = WorkflowRoleDisponible.TousLesRoles;

    // ── Contexte cross-département ──────────────────────────────────────────
    /// <summary>null = workflow standard (tous agents), sinon code dept de l'agent demandeur.</summary>
    private string? _selectedDeptContext;
    private List<DepartementInfo> _deptOverrides = new();
    private List<DepartementInfo> _allDepts = new();
    private bool _showExcBranch  = true;
    private bool _showStdBranch  = true;

    // ── Vue divisée (split view) ─────────────────────────────────────────────
    private List<WorkflowEtapeConfig> _standardEtapes = new();
    private int _editingIdxStd = -1;
    private bool _savingStd;

    // ── Drag & drop reorder ─────────────────────────────────────────────────
    private string? _dragList;   // "exc" = _etapes  |  "std" = _standardEtapes
    private int _dragSrcIdx = -1;
    private int _dragOverIdx = -1;

    // ── Initialisation ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var summary = await WorkflowService.GetWorkflowSummaryAsync(_bonType);
            _summary = summary.ToList();

            if (_raisons.Count == 0)
                _raisons = (await WorkflowService.GetRaisonsSortieAsync()).ToList();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"], ex.Message);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task SetBonTypeAsync(string type)
    {
        _bonType = type;
        await LoadAsync();
    }

    // ── Navigation phase 1 → 2 ─────────────────────────────────────────────
    private async Task SelectRaisonAsync(WorkflowContextSummary raison)
    {
        _selectedRaison = raison;
        _editingIdx = -1;
        _editingIdxStd = -1;
        _selectedDeptContext = null;
        _loading = true;
        StateHasChanged();
        try
        {
            var stdRaw = await WorkflowService.GetWorkflowEtapesForAdminAsync(_bonType, raison.RaisonSortieCode);
            var stdList = stdRaw.Select(e => new WorkflowEtapeConfig
            {
                RoleCode   = e.RoleCode,
                NomEtape   = e.NomEtape,
                OrdreEtape = e.OrdreEtape,
                EstActif   = e.EstActif,
            }).ToList();

            // Charger les exceptions départements + la liste complète
            _deptOverrides = (await WorkflowService.GetDepartementOverridesForRaisonAsync(_bonType, raison.RaisonSortieCode)).ToList();
            if (_allDepts.Count == 0)
                _allDepts = (await WorkflowService.GetDepartementsAsync()).ToList();

            if (_deptOverrides.Count > 0)
            {
                // Split view : standard à gauche, première exception à droite
                _standardEtapes = stdList;
                _selectedDeptContext = _deptOverrides[0].Code;
                var excRaw = await WorkflowService.GetWorkflowEtapesCrossAsync(
                    _bonType, raison.RaisonSortieCode, _deptOverrides[0].Code);
                _etapes = excRaw.Count > 0
                    ? excRaw.Select(e => new WorkflowEtapeConfig
                      { RoleCode = e.RoleCode, NomEtape = e.NomEtape, OrdreEtape = e.OrdreEtape, EstActif = e.EstActif }).ToList()
                    : stdList.Select(e => new WorkflowEtapeConfig
                      { RoleCode = e.RoleCode, NomEtape = e.NomEtape, OrdreEtape = e.OrdreEtape, EstActif = e.EstActif }).ToList();
            }
            else
            {
                // Vue simple : pas d'exception
                _etapes = stdList;
                _standardEtapes = new();
            }

            _phase = 2;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"], ex.Message);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void BackToSelector()
    {
        _phase = 1;
        _selectedRaison = null;
        _etapes.Clear();
        _standardEtapes = new();
        _editingIdx = -1;
        _editingIdxStd = -1;
        _selectedDeptContext = null;
        _deptOverrides.Clear();
    }

    // ── Commutation du contexte département ─────────────────────────────────
    private async Task SwitchDeptContextAsync(string? deptCode)
    {
        if (_selectedDeptContext == deptCode) return;
        _selectedDeptContext = deptCode;
        _editingIdx = -1;
        _loading = true;
        StateHasChanged();
        try
        {
            // Toujours (re)charger le workflow standard
            var stdRaw = await WorkflowService.GetWorkflowEtapesForAdminAsync(_bonType, _selectedRaison?.RaisonSortieCode);
            _standardEtapes = stdRaw.Select(e => new WorkflowEtapeConfig
            {
                RoleCode   = e.RoleCode,
                NomEtape   = e.NomEtape,
                OrdreEtape = e.OrdreEtape,
                EstActif   = e.EstActif,
            }).ToList();

            IReadOnlyList<WorkflowEtapeConfig> etapes = deptCode == null
                ? stdRaw
                : await WorkflowService.GetWorkflowEtapesCrossAsync(_bonType, _selectedRaison?.RaisonSortieCode, deptCode);

            if (deptCode != null && etapes.Count == 0)
            {
                // Nouvelle exception : pré-remplir avec 1 étape du département demandeur
                // suivie des étapes du workflow standard de ce matériel
                var deptRoleCode = GuessRoleForDept(deptCode);
                var deptRole = _rolesDisponibles.FirstOrDefault(r => r.RoleCode == deptRoleCode)
                               ?? _rolesDisponibles[0];
                var standard = await WorkflowService.GetWorkflowEtapesForAdminAsync(
                    _bonType, _selectedRaison?.RaisonSortieCode);

                var pre = new List<WorkflowEtapeConfig>
                {
                    new WorkflowEtapeConfig
                    {
                        RoleCode   = deptRole.RoleCode,
                        NomEtape   = $"Approbation {deptRole.Nom}",
                        OrdreEtape = 1,
                        EstActif   = true,
                    }
                };
                int order = 2;
                foreach (var s in standard)
                    pre.Add(new WorkflowEtapeConfig
                    {
                        RoleCode   = s.RoleCode,
                        NomEtape   = s.NomEtape,
                        OrdreEtape = order++,
                        EstActif   = s.EstActif,
                    });
                _etapes = pre;
            }
            else
            {
                _etapes = etapes.Select(e => new WorkflowEtapeConfig
                {
                    RoleCode   = e.RoleCode,
                    NomEtape   = e.NomEtape,
                    OrdreEtape = e.OrdreEtape,
                    EstActif   = e.EstActif,
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"], ex.Message);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task AddUniversalBranchAsync()
    {
        var universal = new DepartementInfo { Code = "*", Nom = "Tous les départements", NombreEmployes = 0 };
        if (!_deptOverrides.Any(d => d.Code == "*"))
            _deptOverrides.Add(universal);
        await SwitchDeptContextAsync("*");
    }

    private async Task AddDeptExceptionAsync(DepartementInfo dept)
    {
        // On ajoute l'onglet localement avant même d'avoir des étapes
        if (!_deptOverrides.Any(d => d.Code == dept.Code))
            _deptOverrides.Add(dept);
        await SwitchDeptContextAsync(dept.Code);
    }

    // ── Édition inline ──────────────────────────────────────────────────────
    private void ToggleEdit(int idx) =>
        _editingIdx = (_editingIdx == idx) ? -1 : idx;

    private void AppendStep()
    {
        var role = _rolesDisponibles.FirstOrDefault(r => !_etapes.Any(e => e.RoleCode == r.RoleCode))
                   ?? _rolesDisponibles[0];
        _etapes.Add(new WorkflowEtapeConfig
        {
            RoleCode   = role.RoleCode,
            NomEtape   = role.Nom,
            OrdreEtape = _etapes.Count + 1,
            EstActif   = true,
        });
        _editingIdx = _etapes.Count - 1;
    }

    private void InsertStepAt(int beforeIdx)
    {
        var role = _rolesDisponibles.FirstOrDefault(r => !_etapes.Any(e => e.RoleCode == r.RoleCode))
                   ?? _rolesDisponibles[0];
        _etapes.Insert(beforeIdx, new WorkflowEtapeConfig
        {
            RoleCode   = role.RoleCode,
            NomEtape   = role.Nom,
            OrdreEtape = beforeIdx + 1,
            EstActif   = true,
        });
        _editingIdx = beforeIdx;
    }

    private void RemoveStep(int idx)
    {
        _etapes.RemoveAt(idx);
        _editingIdx = -1;
    }

    private void MoveLeft(int idx)
    {
        if (idx <= 0) return;
        (_etapes[idx], _etapes[idx - 1]) = (_etapes[idx - 1], _etapes[idx]);
        _editingIdx = idx - 1;
    }

    private void MoveRight(int idx)
    {
        if (idx >= _etapes.Count - 1) return;
        (_etapes[idx], _etapes[idx + 1]) = (_etapes[idx + 1], _etapes[idx]);
        _editingIdx = idx + 1;
    }

    private void OnRoleChanged(WorkflowEtapeConfig etape)
    {
        var roleInfo = _rolesDisponibles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
        if (roleInfo != null && string.IsNullOrWhiteSpace(etape.NomEtape))
            etape.NomEtape = roleInfo.Nom;
    }

    private string ActiveDeptName => _deptOverrides.FirstOrDefault(d => d.Code == _selectedDeptContext)?.Nom ?? _selectedDeptContext ?? "";

    private int ForkTrunkLength
    {
        get
        {
            var n = 0;
            while (n < _standardEtapes.Count && n < _etapes.Count
                   && _standardEtapes[n].RoleCode == _etapes[n].RoleCode)
                n++;
            return n;
        }
    }

    /// <summary>Devine le rôle d'approbation le plus probable pour un code département.</summary>
    private string GuessRoleForDept(string deptCode)
    {
        var u = deptCode.ToUpperInvariant();
        if (u.Contains("ENV"))                    return "ENVIRONMENT";
        if (u.Contains("IT") || u.Contains("INFO")) return "IT";
        if (u.Contains("OPJ"))                    return "OPJ";
        if (u.Contains("IDENT"))                  return "IDENTIFICATION";
        if (u.Contains("SUP"))                    return "SUPERINTENDENT";
        if (u.Contains("GM"))                     return "GM";
        return _rolesDisponibles.Any(r => r.RoleCode == u) ? u : _rolesDisponibles[0].RoleCode;
    }

    // ── Édition inline — chaîne STANDARD (volet gauche du split view) ────────
    private void ToggleEditStd(int idx) => _editingIdxStd = (_editingIdxStd == idx) ? -1 : idx;

    private void AppendStepStd()
    {
        var role = _rolesDisponibles.FirstOrDefault(r => !_standardEtapes.Any(e => e.RoleCode == r.RoleCode))
                   ?? _rolesDisponibles[0];
        _standardEtapes.Add(new WorkflowEtapeConfig
        {
            RoleCode   = role.RoleCode,
            NomEtape   = role.Nom,
            OrdreEtape = _standardEtapes.Count + 1,
            EstActif   = true,
        });
        _editingIdxStd = _standardEtapes.Count - 1;
    }

    private void InsertStepAtStd(int beforeIdx)
    {
        var role = _rolesDisponibles.FirstOrDefault(r => !_standardEtapes.Any(e => e.RoleCode == r.RoleCode))
                   ?? _rolesDisponibles[0];
        _standardEtapes.Insert(beforeIdx, new WorkflowEtapeConfig
        {
            RoleCode   = role.RoleCode,
            NomEtape   = role.Nom,
            OrdreEtape = beforeIdx + 1,
            EstActif   = true,
        });
        _editingIdxStd = beforeIdx;
    }

    private void RemoveStepStd(int idx) { _standardEtapes.RemoveAt(idx); _editingIdxStd = -1; }

    private void MoveLeftStd(int idx)
    {
        if (idx <= 0) return;
        (_standardEtapes[idx], _standardEtapes[idx - 1]) = (_standardEtapes[idx - 1], _standardEtapes[idx]);
        _editingIdxStd = idx - 1;
    }

    private void MoveRightStd(int idx)
    {
        if (idx >= _standardEtapes.Count - 1) return;
        (_standardEtapes[idx], _standardEtapes[idx + 1]) = (_standardEtapes[idx + 1], _standardEtapes[idx]);
        _editingIdxStd = idx + 1;
    }

    // ── Glisser-déposer ─────────────────────────────────────────────────────
    private void DragStartExc(int idx) { _dragList = "exc"; _dragSrcIdx = idx; }
    private void DragStartStd(int idx) { _dragList = "std"; _dragSrcIdx = idx; }
    private void DragOverExc(int idx) { if (_dragList == "exc") _dragOverIdx = idx; }
    private void DragOverStd(int idx) { if (_dragList == "std") _dragOverIdx = idx; }
    private void DragEnd() { _dragList = null; _dragSrcIdx = -1; _dragOverIdx = -1; }

    private void DropExc(int targetIdx)
    {
        if (_dragList == "exc" && _dragSrcIdx >= 0 && _dragSrcIdx != targetIdx)
        {
            var item = _etapes[_dragSrcIdx];
            _etapes.RemoveAt(_dragSrcIdx);
            _etapes.Insert(targetIdx > _dragSrcIdx ? targetIdx - 1 : targetIdx, item);
            _editingIdx = -1;
        }
        DragEnd();
    }

    private void DropStd(int targetIdx)
    {
        if (_dragList == "std" && _dragSrcIdx >= 0 && _dragSrcIdx != targetIdx)
        {
            var item = _standardEtapes[_dragSrcIdx];
            _standardEtapes.RemoveAt(_dragSrcIdx);
            _standardEtapes.Insert(targetIdx > _dragSrcIdx ? targetIdx - 1 : targetIdx, item);
            _editingIdxStd = -1;
        }
        DragEnd();
    }

    private void OnRoleChangedStd(WorkflowEtapeConfig etape)
    {
        var roleInfo = _rolesDisponibles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
        if (roleInfo != null && string.IsNullOrWhiteSpace(etape.NomEtape))
            etape.NomEtape = roleInfo.Nom;
    }

    private async Task SaveStandardAsync()
    {
        _savingStd = true;
        try
        {
            for (int i = 0; i < _standardEtapes.Count; i++)
                _standardEtapes[i].OrdreEtape = i + 1;
            var login = CurrentUserService.GetUserLogin();
            await WorkflowService.SaveWorkflowEtapesAsync(
                _bonType, _selectedRaison?.RaisonSortieCode, _standardEtapes, login);
            NotificationService.Notify(NotificationSeverity.Success,
                L["Wfl_NotifSavedTitle"], "Workflow standard sauvegardé.");
            _editingIdxStd = -1;
            var updated = await WorkflowService.GetWorkflowSummaryAsync(_bonType);
            _summary = updated.ToList();
            _selectedRaison = _summary.FirstOrDefault(s => s.RaisonSortieCode == _selectedRaison?.RaisonSortieCode);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"], ex.Message); }
        finally { _savingStd = false; StateHasChanged(); }
    }

    // ── Sauvegarde ──────────────────────────────────────────────────────────
    private async Task SaveAsync()
    {
        _saving = true;
        try
        {
            for (int i = 0; i < _etapes.Count; i++)
                _etapes[i].OrdreEtape = i + 1;

            var login = CurrentUserService.GetUserLogin();

            if (_selectedDeptContext == null)
            {
                await WorkflowService.SaveWorkflowEtapesAsync(
                    _bonType, _selectedRaison?.RaisonSortieCode, _etapes, login);
            }
            else
            {
                await WorkflowService.SaveWorkflowEtapesCrossAsync(
                    _bonType, _selectedRaison?.RaisonSortieCode, _selectedDeptContext, _etapes, login);
            }

            NotificationService.Notify(NotificationSeverity.Success,
                L["Wfl_NotifSavedTitle"], L["Wfl_NotifSavedMsg"]);

            _editingIdx = -1;

            // Rafraîchir résumé + overrides
            var updated = await WorkflowService.GetWorkflowSummaryAsync(_bonType);
            _summary = updated.ToList();
            _selectedRaison = _summary.FirstOrDefault(s => s.RaisonSortieCode == _selectedRaison?.RaisonSortieCode);
            _deptOverrides = (await WorkflowService.GetDepartementOverridesForRaisonAsync(_bonType, _selectedRaison?.RaisonSortieCode)).ToList();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"], ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Réinitialisation ────────────────────────────────────────────────────
    private async Task ResetAsync()
    {
        if (_selectedRaison is null) return;

        string nomAffiche;
        string message;
        if (_selectedDeptContext != null)
        {
            var deptName = _deptOverrides.FirstOrDefault(d => d.Code == _selectedDeptContext)?.Nom ?? _selectedDeptContext;
            nomAffiche = $"«\u00a0{_selectedRaison.RaisonSortieNom}\u00a0» / {deptName}";
            message = $"Supprimer l'exception workflow pour les agents du département {deptName} qui soumettent une demande «\u00a0{_selectedRaison.RaisonSortieNom}\u00a0» ?";
        }
        else
        {
            nomAffiche = $"«\u00a0{_selectedRaison.RaisonSortieNom}\u00a0»";
            message = $"Réinitialiser le workflow {nomAffiche} ? La configuration personnalisée sera supprimée.";
        }

        var confirm = await DialogService.Confirm(
            message,
            _selectedDeptContext != null ? "Supprimer l'exception" : "Réinitialiser le workflow",
            new ConfirmOptions { OkButtonText = L["Btn_Delete"], CancelButtonText = L["Btn_Cancel"] });

        if (confirm != true) return;

        try
        {
            var login = CurrentUserService.GetUserLogin();
            if (_selectedDeptContext != null)
            {
                await WorkflowService.DeleteWorkflowEtapesCrossAsync(
                    _bonType, _selectedRaison.RaisonSortieCode, _selectedDeptContext, login);
                NotificationService.Notify(NotificationSeverity.Info,
                    "Exception supprimée", $"Exception {nomAffiche} supprimée.");
                var deptToRemove = _selectedDeptContext;
                _deptOverrides.RemoveAll(d => d.Code == deptToRemove);

                if (_deptOverrides.Count > 0)
                {
                    // Encore des exceptions → sélectionner la première restante
                    _selectedDeptContext = null; // reset pour que SwitchDept ne court-circuite pas
                    await SwitchDeptContextAsync(_deptOverrides[0].Code);
                }
                else
                {
                    // Plus d’exception → revenir en vue simple
                    _selectedDeptContext = null;
                    _standardEtapes = new();
                    _editingIdxStd = -1;
                    var std = await WorkflowService.GetWorkflowEtapesForAdminAsync(
                        _bonType, _selectedRaison?.RaisonSortieCode);
                    _etapes = std.Select(e => new WorkflowEtapeConfig
                    {
                        RoleCode = e.RoleCode, NomEtape = e.NomEtape,
                        OrdreEtape = e.OrdreEtape, EstActif = e.EstActif,
                    }).ToList();
                    _editingIdx = -1;
                    StateHasChanged();
                }
            }
            else
            {
                await WorkflowService.DeleteWorkflowEtapesAsync(
                    _bonType, _selectedRaison.RaisonSortieCode, login);
                NotificationService.Notify(NotificationSeverity.Info,
                    L["Wfl_NotifResetTitle"],
                    $"Workflow {nomAffiche} réinitialisé.");
                BackToSelector();
                await LoadAsync();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, L["Lbl_Error"], ex.Message);
        }
    }

    // ── Propriétés calculées (bannière phase 2) ─────────────────────────────
    private RaisonSortie? _bannerRaison =>
        _raisons.FirstOrDefault(r => r.Code == _selectedRaison?.RaisonSortieCode);

    private string _bannerIcon =>
        _selectedRaison?.RaisonSortieCode == null ? "all_inclusive" : (_bannerRaison?.Icone ?? "category");

    // ── Helpers d'affichage ─────────────────────────────────────────────────
    private static (BadgeStyle style, string icon) SourceBadge(string source) => source switch
    {
        "Spécifique raison" => (BadgeStyle.Primary,   "star"),
        "Base de données"   => (BadgeStyle.Primary,   "storage"),
        "Hérité générique"  => (BadgeStyle.Info,      "arrow_downward"),
        "Défaut métier"     => (BadgeStyle.Secondary, "code"),
        _                   => (BadgeStyle.Light,     "help"),
    };

    private static string SourceShort(string source) => source switch
    {
        "Spécifique raison" => "Spécifique",
        "Base de données"   => "Configuré",
        "Hérité générique"  => "Hérité",
        "Défaut métier"     => "Défaut",
        _                   => source,
    };
}
