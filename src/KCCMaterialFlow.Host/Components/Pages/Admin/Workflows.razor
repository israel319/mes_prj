@page "/admin/workflows"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using KCCMaterialFlow.Application.Common.Interfaces
@using KCCMaterialFlow.Domain.Entities
@inject IWorkflowConfigService WorkflowService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Wfl_Title"] - @L["Nav_Admin"] - KCC Material Flow</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Wfl_Title"]</h1>
                <p class="kcp-subtitle">@L["Wfl_Subtitle"]</p>
            </div>
            <div class="kcp-hero-actions">
                @if (_phase == 1)
                {
                    <button class="kcp-btn" type="button" @onclick="LoadAsync" disabled="@_loading">
                        <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                        @L["Btn_Refresh"]
                    </button>
                }
                else
                {
                    <button class="kcp-btn" type="button" @onclick="BackToSelector">
                        <RadzenIcon Icon="arrow_back" Style="font-size:1rem;" />
                        Retour
                    </button>
                }
            </div>
        </div>
    </div>

    <main class="kcp-main">

    @if (_phase == 1)
    {
        @* ══════════════════════════════════════════════════════
           PHASE 1 — Sélecteur : type de bon + cartes par type de matériel
           ══════════════════════════════════════════════════════ *@

        @* Toggle BSM / BEM *@
        <div class="wfl-type-toggle">
            <button type="button" class="wfl-type-btn @(_bonType == "BSM" ? "wfl-type-btn--active" : "")"
                    @onclick="@(() => SetBonTypeAsync("BSM"))">
                <RadzenIcon Icon="output" />
                BSM — Bons de sortie
            </button>
            <button type="button" class="wfl-type-btn @(_bonType == "BEM" ? "wfl-type-btn--active" : "")"
                    @onclick="@(() => SetBonTypeAsync("BEM"))">
                <RadzenIcon Icon="input" />
                BEM — Bons d'entrée
            </button>
        </div>

        @* Légende *@
        <div class="wfl-legend">
            <span class="wfl-legend-item">
                <RadzenBadge Text="Spécifique" BadgeStyle="BadgeStyle.Primary" />
                <span>Workflow configuré spécifiquement pour ce type</span>
            </span>
            <span class="wfl-legend-item">
                <RadzenBadge Text="Hérité" BadgeStyle="BadgeStyle.Info" />
                <span>Hérite du workflow générique</span>
            </span>
            <span class="wfl-legend-item">
                <RadzenBadge Text="Défaut" BadgeStyle="BadgeStyle.Secondary" />
                <span>Workflow par défaut du système</span>
            </span>
        </div>

        @if (_loading)
        {
            <div style="text-align:center; padding:4rem;">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            </div>
        }
        else if (_summary is not null)
        {
            @* Grille de cartes par type de matériel (raison de sortie) *@
            <div class="wfl-dept-grid">
                @foreach (var ctx in _summary)
                {
                    var item = ctx;
                    var (srcStyle, _) = SourceBadge(item.Source);
                    var raison = _raisons.FirstOrDefault(r => r.Code == item.RaisonSortieCode);
                    var icone = item.RaisonSortieCode == null ? "all_inclusive" : (raison?.Icone ?? "category");
                    var couleur = raison?.Couleur;

                    <div class="wfl-dept-card @(item.EstPersonnalise ? "wfl-dept-card--specific" : "")"
                         @onclick="@(() => SelectRaisonAsync(item))">

                        @* Icône type de matériel *@
                        <div class="wfl-mat-icon" style="@(couleur != null ? $"background:{couleur}22; color:{couleur};" : "")">
                            <RadzenIcon Icon="@icone" />
                        </div>

                        @* En-tête *@
                        <div class="wfl-dept-card__header">
                            <div class="wfl-dept-card__name">
                                <span>@item.RaisonSortieNom</span>
                                @if (item.RaisonSortieCode != null)
                                {
                                    <span class="wfl-dept-card__code">@item.RaisonSortieCode</span>
                                }
                            </div>
                            <RadzenBadge Text="@SourceShort(item.Source)" BadgeStyle="@srcStyle" Style="font-size:0.65rem;" />
                        </div>

                        @* Nombre d'étapes *@
                        <div class="wfl-dept-card__meta">
                            <RadzenIcon Icon="account_tree" />
                            @item.NombreEtapesResolu étape(s) d'approbation
                        </div>

                        @* Indicateur de personnalisation *@
                        <div class="wfl-dept-card__chain">
                            @if (item.EstPersonnalise)
                            {
                                <span class="wfl-role-chip" style="background:#6366f1;">Personnalisé</span>
                            }
                            else if (item.RaisonSortieCode != null)
                            {
                                <span class="wfl-dept-card__no-steps">Hérite du workflow générique</span>
                            }
                            else
                            {
                                <span class="wfl-dept-card__no-steps">
                                    @(item.Source == "Défaut métier" ? "Workflow système par défaut" : "Workflow de base configuré")
                                </span>
                            }
                        </div>

                        @* CTA *@
                        <div class="wfl-dept-card__cta">
                            <RadzenIcon Icon="tune" Style="font-size:0.85rem;" />
                            Configurer le workflow
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        @* ══════════════════════════════════════════════════════
           PHASE 2 — Éditeur visuel du workflow
           ══════════════════════════════════════════════════════ *@

        @* Bandeau contexte *@
        <div class="wfl-context-banner">
            <div class="wfl-mat-icon wfl-mat-icon--lg"
                 style="@(_bannerRaison?.Couleur != null ? $"background:{_bannerRaison.Couleur}22; color:{_bannerRaison.Couleur};" : "background:var(--kcc-primary-light,#e6faf7); color:var(--kcc-primary,#00b193);")">
                <RadzenIcon Icon="@_bannerIcon" />
            </div>
            <div class="wfl-context-banner__info">
                <div class="wfl-context-banner__title">@_selectedRaison?.RaisonSortieNom</div>
                <div class="wfl-context-banner__sub">
                    @if (_selectedRaison?.RaisonSortieCode != null)
                    {
                        <span>Code : @_selectedRaison.RaisonSortieCode · </span>
                    }
                    Workflow @_bonType · @_etapes.Count étape(s)
                </div>
            </div>
            <div class="wfl-context-banner__badges">
                <RadzenBadge Text="@_bonType"
                             BadgeStyle="@(_bonType == "BSM" ? BadgeStyle.Warning : BadgeStyle.Info)" />
                <RadzenBadge Text="@SourceShort(_selectedRaison?.Source ?? "")" BadgeStyle="@(SourceBadge(_selectedRaison?.Source ?? "").style)" />
            </div>
        </div>

        @* ─── Vue simple (pas d'exception) ou Vue divisée (exceptions) ─── *@
        @if (_deptOverrides.Count == 0)
        {
        @* ══ Vue simple ══ *@
        <div class="wfl-ctx-bar">
            <span class="wfl-ctx-bar__label">Contexte agent :</span>
            <button type="button" class="wfl-ctx-tab wfl-ctx-tab--active">
                <RadzenIcon Icon="groups" />
                Tous les agents
            </button>
            <div class="wfl-ctx-add">
                <button type="button" class="wfl-ctx-add-btn"
                        @onclick="AddUniversalBranchAsync">
                    <RadzenIcon Icon="call_split" />
                    Branche spécifique
                </button>
            </div>
        </div>

        <div class="wfl-editor">
            <div class="wfl-editor__label"><span>Chaîne d'approbation — Tous les agents</span></div>
            <div class="wfl-chain-scroll">
                <div class="wfl-chain">
                    <div class="wfl-terminus">
                        <div class="wfl-terminus__circle wfl-terminus__circle--start"><RadzenIcon Icon="play_arrow" /></div>
                        <span class="wfl-terminus__label">DÉBUT</span>
                    </div>
                    @for (int i = 0; i < _etapes.Count; i++)
                    {
                        var idx = i;
                        var etape = _etapes[idx];
                        var roleInfo = WorkflowRoleDisponible.TousLesRoles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
                        var isEditing = _editingIdx == idx;
                        var nodeColor = roleInfo?.Couleur ?? "#6b7280";
                        <div class="wfl-connector">
                            <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                            <button type="button" class="wfl-insert-btn" @onclick="@(() => InsertStepAt(idx))" title="Insérer une étape ici">+</button>
                        </div>
                        <div class="wfl-node @(isEditing ? "wfl-node--editing" : "") @(_dragList=="exc" && _dragOverIdx==idx ? "wfl-node--drag-over" : "")"
                             draggable="true"
                             @ondragstart="@(() => DragStartExc(idx))"
                             @ondragover:preventDefault
                             @ondragenter="@(() => DragOverExc(idx))"
                             @ondrop="@(() => DropExc(idx))"
                             @ondragend="DragEnd">
                            <div class="wfl-node__box"
                                 style="border-color:@(isEditing ? nodeColor : "var(--gray-200,#e5e7eb)"); background:@(isEditing ? nodeColor : "#fff");"
                                 @onclick="@(() => ToggleEdit(idx))">
                                <span class="wfl-node__drag material-icons">drag_indicator</span>
                                <div class="wfl-node__num" style="background:@(isEditing ? "rgba(255,255,255,0.25)" : nodeColor);">@(idx + 1)</div>
                                <div class="wfl-node__name" style="color:@(isEditing ? "#fff" : "#1e2a2a");">
                                    @(string.IsNullOrWhiteSpace(etape.NomEtape) ? (roleInfo?.Nom ?? etape.RoleCode) : etape.NomEtape)
                                </div>
                                @if (roleInfo?.EstAutoResolu == true)
                                {
                                    <div class="wfl-node__auto" style="color:@(isEditing ? "rgba(255,255,255,0.75)" : "var(--gray-400)");">⚡ Auto</div>
                                }
                            </div>
                            <span class="wfl-node__role-label" style="color:@nodeColor;">@(roleInfo?.Nom ?? etape.RoleCode)</span>
                            @if (isEditing)
                            {
                                <div class="wfl-edit-panel" style="border-color:@nodeColor;" @onclick:stopPropagation>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Rôle</label>
                                        <RadzenDropDown TValue="string" Data="@_rolesDisponibles" TextProperty="Nom" ValueProperty="RoleCode"
                                                        @bind-Value="etape.RoleCode" Style="width:100%;" Change="@(() => OnRoleChanged(etape))" />
                                    </div>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Nom affiché</label>
                                        <RadzenTextBox @bind-Value="etape.NomEtape" Placeholder="Nom de l'étape…" Style="width:100%;" />
                                    </div>
                                    <div class="wfl-edit-panel__actions">
                                        <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => RemoveStep(idx))" title="Supprimer" />
                                        <RadzenButton Icon="check_circle" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                                      Click="@(() => _editingIdx = -1)" title="Fermer" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="wfl-connector">
                        <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                        <button type="button" class="wfl-insert-btn" @onclick="AppendStep" title="Ajouter une étape">+</button>
                    </div>
                    <div class="wfl-terminus">
                        <div class="wfl-terminus__circle wfl-terminus__circle--end"><RadzenIcon Icon="flag" /></div>
                        <span class="wfl-terminus__label">APPROUVÉ</span>
                    </div>
                </div>
            </div>
            @if (_etapes.Count == 0)
            {
                <div class="wfl-empty-hint"><RadzenIcon Icon="info" /> Aucune étape définie — cliquez sur <strong>+</strong> pour en ajouter une.</div>
            }
        </div>

        <div class="wfl-actions-bar">
            <RadzenButton Text="@L["Btn_Save"]" Icon="save" ButtonStyle="ButtonStyle.Primary" Click="@SaveAsync" IsBusy="@_saving" />
            <span class="wfl-actions-bar__count">@_etapes.Count étape(s) configurée(s)</span>
        </div>
        }
        else
        {
        @* ══ Vue bifurquée : Tronc commun → Branches verticales ══ *@
        <div class="wfl-fork-wrap">
            @{ var trunkN = ForkTrunkLength; }

            @* ─── Tronc commun ─── *@
            <div class="wfl-fork-trunk">
                <div class="wfl-terminus">
                    <div class="wfl-terminus__circle wfl-terminus__circle--start"><RadzenIcon Icon="play_arrow" /></div>
                    <span class="wfl-terminus__label">DÉBUT</span>
                </div>
                @for (int i = 0; i < trunkN; i++)
                {
                    var idx = i;
                    var etape = _standardEtapes[idx];
                    var roleInfo = WorkflowRoleDisponible.TousLesRoles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
                    var isEditing = _editingIdxStd == idx;
                    var nodeColor = roleInfo?.Couleur ?? "#6b7280";
                    <div class="wfl-connector">
                        <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                        <button type="button" class="wfl-insert-btn" @onclick="@(() => InsertStepAtStd(idx))" title="Insérer">+</button>
                    </div>
                    <div class="wfl-node @(isEditing ? "wfl-node--editing" : "") @(_dragList=="std" && _dragOverIdx==idx ? "wfl-node--drag-over" : "")"
                         draggable="true"
                         @ondragstart="@(() => DragStartStd(idx))"
                         @ondragover:preventDefault
                         @ondragenter="@(() => DragOverStd(idx))"
                         @ondrop="@(() => DropStd(idx))"
                         @ondragend="DragEnd">
                        <div class="wfl-node__box"
                             style="border-color:@(isEditing ? nodeColor : "var(--gray-200,#e5e7eb)"); background:@(isEditing ? nodeColor : "#fff");"
                             @onclick="@(() => ToggleEditStd(idx))">
                            <span class="wfl-node__drag material-icons">drag_indicator</span>
                            <div class="wfl-node__num" style="background:@(isEditing ? "rgba(255,255,255,0.25)" : nodeColor);">@(idx + 1)</div>
                            <div class="wfl-node__name" style="color:@(isEditing ? "#fff" : "#1e2a2a");">
                                @(string.IsNullOrWhiteSpace(etape.NomEtape) ? (roleInfo?.Nom ?? etape.RoleCode) : etape.NomEtape)
                            </div>
                            @if (roleInfo?.EstAutoResolu == true)
                            {
                                <div class="wfl-node__auto" style="color:@(isEditing ? "rgba(255,255,255,0.75)" : "var(--gray-400)");">⚡ Auto</div>
                            }
                        </div>
                        <span class="wfl-node__role-label" style="color:@nodeColor;">@(roleInfo?.Nom ?? etape.RoleCode)</span>
                        @if (isEditing)
                        {
                            <div class="wfl-edit-panel" style="border-color:@nodeColor;" @onclick:stopPropagation>
                                <div class="wfl-edit-panel__field">
                                    <label class="wfl-edit-panel__label">Rôle</label>
                                    <RadzenDropDown TValue="string" Data="@_rolesDisponibles" TextProperty="Nom" ValueProperty="RoleCode"
                                                    @bind-Value="etape.RoleCode" Style="width:100%;" Change="@(() => OnRoleChangedStd(etape))" />
                                </div>
                                <div class="wfl-edit-panel__field">
                                    <label class="wfl-edit-panel__label">Nom affiché</label>
                                    <RadzenTextBox @bind-Value="etape.NomEtape" Placeholder="Nom de l'étape…" Style="width:100%;" />
                                </div>
                                <div class="wfl-edit-panel__actions">
                                    <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                                  Click="@(() => RemoveStepStd(idx))" />
                                    <RadzenButton Icon="check_circle" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                                  Click="@(() => _editingIdxStd = -1)" />
                                </div>
                            </div>
                        }
                    </div>
                }
                <div class="wfl-connector">
                    <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                </div>
            </div>

            @* ─── Losange de décision ─── *@
            <div class="wfl-fork-gate">
                <div class="wfl-fork-diamond">
                    <span>Département<br/>spécifique ?</span>
                </div>
            </div>

            @* ─── Branches ─── *@
            <div class="wfl-fork-branches">

                @* Branche exception — haut *@
                <div class="wfl-fork-branch wfl-fork-branch--exc @(!_showExcBranch ? "wfl-fork-branch--collapsed" : "")">
                    <button type="button" class="wfl-fork-branch__toggle"
                            @onclick="@(() => _showExcBranch = !_showExcBranch)">
                        <div class="wfl-connector"><div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div></div>
                        <span class="wfl-fork-branch__badge wfl-fork-branch__badge--yes">Oui</span>
                        <span class="wfl-fork-branch__name">Spécifique</span>
                        <span class="material-icons wfl-fork-branch__chevron">@(_showExcBranch ? "keyboard_arrow_down" : "keyboard_arrow_right")</span>
                    </button>
                    @if (_showExcBranch)
                    {
                    <div class="wfl-terminus">
                        <div class="wfl-terminus__circle wfl-terminus__circle--start"><RadzenIcon Icon="play_arrow" /></div>
                        <span class="wfl-terminus__label">DÉBUT</span>
                    </div>
                    @for (int t = 0; t < trunkN; t++)
                    {
                        var idx = t;
                        var etape = _etapes[idx];
                        var roleInfo = WorkflowRoleDisponible.TousLesRoles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
                        var isEditing = _editingIdx == idx;
                        var nodeColor = roleInfo?.Couleur ?? "#6b7280";
                        <div class="wfl-connector">
                            <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                            <button type="button" class="wfl-insert-btn" @onclick="@(() => InsertStepAt(idx))" title="Insérer">+</button>
                        </div>
                        <div class="wfl-node @(isEditing ? "wfl-node--editing" : "") @(_dragList=="exc" && _dragOverIdx==idx ? "wfl-node--drag-over" : "")"
                             draggable="true"
                             @ondragstart="@(() => DragStartExc(idx))"
                             @ondragover:preventDefault
                             @ondragenter="@(() => DragOverExc(idx))"
                             @ondrop="@(() => DropExc(idx))"
                             @ondragend="DragEnd">
                            <div class="wfl-node__box"
                                 style="border-color:@(isEditing ? nodeColor : "#93c5fd"); background:@(isEditing ? nodeColor : "#eff6ff");"
                                 @onclick="@(() => ToggleEdit(idx))">
                                <span class="wfl-node__drag material-icons">drag_indicator</span>
                                <div class="wfl-node__num" style="background:@(isEditing ? "rgba(255,255,255,0.25)" : nodeColor);">@(idx + 1)</div>
                                <div class="wfl-node__name" style="color:@(isEditing ? "#fff" : "#1e40af");">
                                    @(string.IsNullOrWhiteSpace(etape.NomEtape) ? (roleInfo?.Nom ?? etape.RoleCode) : etape.NomEtape)
                                </div>
                                @if (roleInfo?.EstAutoResolu == true)
                                {
                                    <div class="wfl-node__auto" style="color:@(isEditing ? "rgba(255,255,255,0.75)" : "var(--gray-400)")">⚡ Auto</div>
                                }
                            </div>
                            <span class="wfl-node__role-label" style="color:@nodeColor;">@(roleInfo?.Nom ?? etape.RoleCode)</span>
                            @if (isEditing)
                            {
                                <div class="wfl-edit-panel" style="border-color:@nodeColor;" @onclick:stopPropagation>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Rôle</label>
                                        <RadzenDropDown TValue="string" Data="@_rolesDisponibles" TextProperty="Nom" ValueProperty="RoleCode"
                                                        @bind-Value="etape.RoleCode" Style="width:100%;" Change="@(() => OnRoleChanged(etape))" />
                                    </div>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Nom affiché</label>
                                        <RadzenTextBox @bind-Value="etape.NomEtape" Placeholder="Nom de l'étape…" Style="width:100%;" />
                                    </div>
                                    <div class="wfl-edit-panel__actions">
                                        <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => RemoveStep(idx))" />
                                        <RadzenButton Icon="check_circle" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                                      Click="@(() => _editingIdx = -1)" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="wfl-branch-sep">
                        <span class="material-icons">call_split</span>
                        <span>Étapes spécifiques au département</span>
                    </div>
                    @for (int i = trunkN; i < _etapes.Count; i++)
                    {
                        var idx = i;
                        var etape = _etapes[idx];
                        var roleInfo = WorkflowRoleDisponible.TousLesRoles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
                        var isEditing = _editingIdx == idx;
                        var nodeColor = roleInfo?.Couleur ?? "#6b7280";
                        <div class="wfl-connector">
                            <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                            <button type="button" class="wfl-insert-btn" @onclick="@(() => InsertStepAt(idx))" title="Insérer">+</button>
                        </div>
                        <div class="wfl-node @(isEditing ? "wfl-node--editing" : "") @(_dragList=="exc" && _dragOverIdx==idx ? "wfl-node--drag-over" : "")"
                             draggable="true"
                             @ondragstart="@(() => DragStartExc(idx))"
                             @ondragover:preventDefault
                             @ondragenter="@(() => DragOverExc(idx))"
                             @ondrop="@(() => DropExc(idx))"
                             @ondragend="DragEnd">
                            <div class="wfl-node__box"
                                 style="border-color:@(isEditing ? nodeColor : "#93c5fd"); background:@(isEditing ? nodeColor : "#eff6ff");"
                                 @onclick="@(() => ToggleEdit(idx))">
                                <span class="wfl-node__drag material-icons">drag_indicator</span>
                                <div class="wfl-node__num" style="background:@(isEditing ? "rgba(255,255,255,0.25)" : nodeColor);">@(idx + 1)</div>
                                <div class="wfl-node__name" style="color:@(isEditing ? "#fff" : "#1e40af");">
                                    @(string.IsNullOrWhiteSpace(etape.NomEtape) ? (roleInfo?.Nom ?? etape.RoleCode) : etape.NomEtape)
                                </div>
                                @if (roleInfo?.EstAutoResolu == true)
                                {
                                    <div class="wfl-node__auto" style="color:@(isEditing ? "rgba(255,255,255,0.75)" : "var(--gray-400)");">⚡ Auto</div>
                                }
                            </div>
                            <span class="wfl-node__role-label" style="color:@nodeColor;">@(roleInfo?.Nom ?? etape.RoleCode)</span>
                            @if (isEditing)
                            {
                                <div class="wfl-edit-panel" style="border-color:@nodeColor;" @onclick:stopPropagation>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Rôle</label>
                                        <RadzenDropDown TValue="string" Data="@_rolesDisponibles" TextProperty="Nom" ValueProperty="RoleCode"
                                                        @bind-Value="etape.RoleCode" Style="width:100%;" Change="@(() => OnRoleChanged(etape))" />
                                    </div>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Nom affiché</label>
                                        <RadzenTextBox @bind-Value="etape.NomEtape" Placeholder="Nom de l'étape…" Style="width:100%;" />
                                    </div>
                                    <div class="wfl-edit-panel__actions">
                                        <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => RemoveStep(idx))" />
                                        <RadzenButton Icon="check_circle" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                                      Click="@(() => _editingIdx = -1)" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="wfl-connector">
                        <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                        <button type="button" class="wfl-insert-btn" @onclick="AppendStep" title="Ajouter">+</button>
                    </div>
                    <div class="wfl-terminus">
                        <div class="wfl-terminus__circle wfl-terminus__circle--end"><RadzenIcon Icon="flag" /></div>
                        <span class="wfl-terminus__label">APPROUVÉ</span>
                    </div>
                    }
                </div>

                @* Branche standard — bas *@
                <div class="wfl-fork-branch wfl-fork-branch--std @(!_showStdBranch ? "wfl-fork-branch--collapsed" : "")">
                    <button type="button" class="wfl-fork-branch__toggle"
                            @onclick="@(() => _showStdBranch = !_showStdBranch)">
                        <div class="wfl-connector"><div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div></div>
                        <span class="wfl-fork-branch__badge wfl-fork-branch__badge--no">Non</span>
                        <span class="wfl-fork-branch__name">Standard</span>
                        <span class="material-icons wfl-fork-branch__chevron">@(_showStdBranch ? "keyboard_arrow_down" : "keyboard_arrow_right")</span>
                    </button>
                    @if (_showStdBranch)
                    {
                    <div class="wfl-terminus">
                        <div class="wfl-terminus__circle wfl-terminus__circle--start"><RadzenIcon Icon="play_arrow" /></div>
                        <span class="wfl-terminus__label">DÉBUT</span>
                    </div>
                    @for (int t = 0; t < trunkN; t++)
                    {
                        var idx = t;
                        var etape = _standardEtapes[idx];
                        var roleInfo = WorkflowRoleDisponible.TousLesRoles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
                        var isEditing = _editingIdxStd == idx;
                        var nodeColor = roleInfo?.Couleur ?? "#6b7280";
                        <div class="wfl-connector">
                            <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                            <button type="button" class="wfl-insert-btn" @onclick="@(() => InsertStepAtStd(idx))" title="Insérer">+</button>
                        </div>
                        <div class="wfl-node @(isEditing ? "wfl-node--editing" : "") @(_dragList=="std" && _dragOverIdx==idx ? "wfl-node--drag-over" : "")"
                             draggable="true"
                             @ondragstart="@(() => DragStartStd(idx))"
                             @ondragover:preventDefault
                             @ondragenter="@(() => DragOverStd(idx))"
                             @ondrop="@(() => DropStd(idx))"
                             @ondragend="DragEnd">
                            <div class="wfl-node__box"
                                 style="border-color:@(isEditing ? nodeColor : "var(--gray-200,#e5e7eb)"); background:@(isEditing ? nodeColor : "#fff");"
                                 @onclick="@(() => ToggleEditStd(idx))">
                                <span class="wfl-node__drag material-icons">drag_indicator</span>
                                <div class="wfl-node__num" style="background:@(isEditing ? "rgba(255,255,255,0.25)" : nodeColor);">@(idx + 1)</div>
                                <div class="wfl-node__name" style="color:@(isEditing ? "#fff" : "#1e2a2a");">
                                    @(string.IsNullOrWhiteSpace(etape.NomEtape) ? (roleInfo?.Nom ?? etape.RoleCode) : etape.NomEtape)
                                </div>
                                @if (roleInfo?.EstAutoResolu == true)
                                {
                                    <div class="wfl-node__auto" style="color:@(isEditing ? "rgba(255,255,255,0.75)" : "var(--gray-400)")">⚡ Auto</div>
                                }
                            </div>
                            <span class="wfl-node__role-label" style="color:@nodeColor;">@(roleInfo?.Nom ?? etape.RoleCode)</span>
                            @if (isEditing)
                            {
                                <div class="wfl-edit-panel" style="border-color:@nodeColor;" @onclick:stopPropagation>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Rôle</label>
                                        <RadzenDropDown TValue="string" Data="@_rolesDisponibles" TextProperty="Nom" ValueProperty="RoleCode"
                                                        @bind-Value="etape.RoleCode" Style="width:100%;" Change="@(() => OnRoleChangedStd(etape))" />
                                    </div>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Nom affiché</label>
                                        <RadzenTextBox @bind-Value="etape.NomEtape" Placeholder="Nom de l'étape…" Style="width:100%;" />
                                    </div>
                                    <div class="wfl-edit-panel__actions">
                                        <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => RemoveStepStd(idx))" />
                                        <RadzenButton Icon="check_circle" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                                      Click="@(() => _editingIdxStd = -1)" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="wfl-branch-sep">
                        <span class="material-icons">linear_scale</span>
                        <span>Étapes standard</span>
                    </div>
                    @for (int i = trunkN; i < _standardEtapes.Count; i++)
                    {
                        var idx = i;
                        var etape = _standardEtapes[idx];
                        var roleInfo = WorkflowRoleDisponible.TousLesRoles.FirstOrDefault(r => r.RoleCode == etape.RoleCode);
                        var isEditing = _editingIdxStd == idx;
                        var nodeColor = roleInfo?.Couleur ?? "#6b7280";
                        <div class="wfl-connector">
                            <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                            <button type="button" class="wfl-insert-btn" @onclick="@(() => InsertStepAtStd(idx))" title="Insérer">+</button>
                        </div>
                        <div class="wfl-node @(isEditing ? "wfl-node--editing" : "") @(_dragList=="std" && _dragOverIdx==idx ? "wfl-node--drag-over" : "")"
                             draggable="true"
                             @ondragstart="@(() => DragStartStd(idx))"
                             @ondragover:preventDefault
                             @ondragenter="@(() => DragOverStd(idx))"
                             @ondrop="@(() => DropStd(idx))"
                             @ondragend="DragEnd">
                            <div class="wfl-node__box"
                                 style="border-color:@(isEditing ? nodeColor : "var(--gray-200,#e5e7eb)"); background:@(isEditing ? nodeColor : "#fff");"
                                 @onclick="@(() => ToggleEditStd(idx))">
                                <span class="wfl-node__drag material-icons">drag_indicator</span>
                                <div class="wfl-node__num" style="background:@(isEditing ? "rgba(255,255,255,0.25)" : nodeColor);">@(idx + 1)</div>
                                <div class="wfl-node__name" style="color:@(isEditing ? "#fff" : "#1e2a2a");">
                                    @(string.IsNullOrWhiteSpace(etape.NomEtape) ? (roleInfo?.Nom ?? etape.RoleCode) : etape.NomEtape)
                                </div>
                                @if (roleInfo?.EstAutoResolu == true)
                                {
                                    <div class="wfl-node__auto" style="color:@(isEditing ? "rgba(255,255,255,0.75)" : "var(--gray-400)");">⚡ Auto</div>
                                }
                            </div>
                            <span class="wfl-node__role-label" style="color:@nodeColor;">@(roleInfo?.Nom ?? etape.RoleCode)</span>
                            @if (isEditing)
                            {
                                <div class="wfl-edit-panel" style="border-color:@nodeColor;" @onclick:stopPropagation>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Rôle</label>
                                        <RadzenDropDown TValue="string" Data="@_rolesDisponibles" TextProperty="Nom" ValueProperty="RoleCode"
                                                        @bind-Value="etape.RoleCode" Style="width:100%;" Change="@(() => OnRoleChangedStd(etape))" />
                                    </div>
                                    <div class="wfl-edit-panel__field">
                                        <label class="wfl-edit-panel__label">Nom affiché</label>
                                        <RadzenTextBox @bind-Value="etape.NomEtape" Placeholder="Nom de l'étape…" Style="width:100%;" />
                                    </div>
                                    <div class="wfl-edit-panel__actions">
                                        <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => RemoveStepStd(idx))" />
                                        <RadzenButton Icon="check_circle" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text"
                                                      Click="@(() => _editingIdxStd = -1)" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <div class="wfl-connector">
                        <div class="wfl-connector__line"><span class="wfl-connector__arrow">›</span></div>
                        <button type="button" class="wfl-insert-btn" @onclick="AppendStepStd" title="Ajouter">+</button>
                    </div>
                    <div class="wfl-terminus">
                        <div class="wfl-terminus__circle wfl-terminus__circle--end"><RadzenIcon Icon="flag" /></div>
                        <span class="wfl-terminus__label">APPROUVÉ</span>
                    </div>
                    }
                </div>

            </div>
        </div>

        @* ─── Barres d'actions ─── *@
        <div class="wfl-fork-actions">
            <div class="wfl-actions-bar">
                <RadzenButton Text="Sauvegarder standard" Icon="save"
                              ButtonStyle="ButtonStyle.Success" Variant="Variant.Outlined"
                              Click="@SaveStandardAsync" IsBusy="@_savingStd" />
                <span class="wfl-actions-bar__count">@_standardEtapes.Count étape(s) standard</span>
            </div>
            <div class="wfl-actions-bar">
                <RadzenButton Text="Sauvegarder exception" Icon="save"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@SaveAsync" IsBusy="@_saving" />
                <RadzenButton Text="Supprimer cette exception" Icon="restart_alt"
                              ButtonStyle="ButtonStyle.Warning" Variant="Variant.Outlined"
                              Click="@ResetAsync" />
                <span class="wfl-actions-bar__count">@_etapes.Count étape(s) exception</span>
            </div>
        </div>
        }
    }

    </main>
</div>

<style>
    /* ── Icône type de matériel ─────────────────────────────── */
    .wfl-mat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--kcc-primary-light, #e6faf7);
        color: var(--kcc-primary, #00b193);
        font-size: 1.25rem;
        flex-shrink: 0;
        margin-bottom: 0.6rem;
    }
    .wfl-mat-icon--lg {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        font-size: 1.5rem;
        margin-bottom: 0;
    }

    /* ── Toggle BSM/BEM ─────────────────────────────────────── */
    .wfl-type-toggle {
        display: flex;
        gap: 0;
        border: 1.5px solid var(--gray-200, #e5e7eb);
        border-radius: 7px;
        overflow: hidden;
        width: fit-content;
        margin-bottom: 1.25rem;
    }
    .wfl-type-btn {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1.4rem;
        font-size: 0.84rem;
        font-weight: 700;
        border: none;
        background: #fff;
        color: var(--gray-500, #6b7280);
        cursor: pointer;
        transition: background .15s, color .15s;
    }
    .wfl-type-btn + .wfl-type-btn {
        border-left: 1.5px solid var(--gray-200, #e5e7eb);
    }
    .wfl-type-btn--active {
        background: var(--kcc-primary, #00b193);
        color: #fff;
    }

    /* ── Légende ────────────────────────────────────────────── */
    .wfl-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        font-size: 0.78rem;
        color: var(--gray-500, #6b7280);
    }
    .wfl-legend-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    /* ── Grille département ─────────────────────────────────── */
    .wfl-dept-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
        gap: 1rem;
    }
    .wfl-dept-card {
        background: #fff;
        border: 1.5px solid var(--gray-200, #e5e7eb);
        border-radius: 8px;
        padding: 1rem 1.1rem 0.85rem;
        cursor: pointer;
        transition: box-shadow .15s, border-color .15s, transform .1s;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }
    .wfl-dept-card:hover {
        border-color: var(--kcc-primary, #00b193);
        box-shadow: 0 4px 16px rgba(0,177,147,.13);
        transform: translateY(-1px);
    }
    .wfl-dept-card--specific {
        border-color: color-mix(in srgb, var(--kcc-primary,#00b193) 40%, transparent);
    }
    .wfl-dept-card__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }
    .wfl-dept-card__name {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-weight: 700;
        font-size: 0.88rem;
    }
    .wfl-dept-card__code {
        font-size: 0.7rem;
        color: var(--gray-400, #9ca3af);
        font-weight: 400;
    }
    .wfl-dept-card__meta {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.72rem;
        color: var(--gray-400, #9ca3af);
        margin-bottom: 0.55rem;
    }
    .wfl-dept-card__chain {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.2rem;
        min-height: 1.8rem;
        margin-bottom: 0.65rem;
    }
    .wfl-dept-card__no-steps {
        font-size: 0.73rem;
        color: var(--gray-300, #d1d5db);
        font-style: italic;
    }
    .wfl-dept-card__arrow {
        color: var(--gray-300, #d1d5db);
        font-size: 0.8rem;
    }
    .wfl-dept-card__cta {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--kcc-primary, #00b193);
        justify-content: flex-end;
    }
    .wfl-role-chip {
        display: inline-flex;
        align-items: center;
        color: #fff;
        border-radius: 4px;
        padding: 0.12rem 0.4rem;
        font-size: 0.68rem;
        font-weight: 700;
    }

    /* ── Bandeau contexte (phase 2) ─────────────────────────── */
    .wfl-context-banner {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.4rem;
        background: linear-gradient(135deg,#fff 60%,#f0fdf9 100%);
        border: 1.5px solid #a7f3d0;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        box-shadow: 0 2px 12px rgba(0,177,147,.08);
    }
    .wfl-context-banner__info { flex: 1; min-width: 0; }
    .wfl-context-banner__title { font-weight: 800; font-size: 1.05rem; color: #1a202c; }
    .wfl-context-banner__sub { font-size: 0.75rem; color: var(--gray-400, #9ca3af); margin-top: 0.15rem; }
    .wfl-context-banner__badges { display: flex; gap: 0.4rem; align-items: center; margin-left: auto; }

    /* ── Éditeur visuel ─────────────────────────────────────── */
    .wfl-editor {
        background: #fff;
        border: 1.5px solid var(--gray-200, #e5e7eb);
        border-radius: 12px;
        padding: 2rem 2.5rem 2.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.05);
    }
    .wfl-editor__label {
        text-align: center;
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--gray-400, #9ca3af);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 2.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .wfl-editor__label::before,
    .wfl-editor__label::after {
        content: '';
        flex: 1;
        max-width: 60px;
        height: 1px;
        background: var(--gray-200, #e5e7eb);
    }

    /* ── Chaîne graphique ───────────────────────────────────── */
    .wfl-chain-scroll { overflow: visible; padding-bottom: 0; }
    .wfl-chain {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        flex-wrap: nowrap;
        min-width: unset;
        width: 100%;
        max-width: 360px;
        padding: 0.75rem 1rem 1.5rem;
        margin: 0 auto;
    }

    /* ── Nœuds terminaux (DÉBUT / FIN) ──────────────────────── */
    .wfl-terminus {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
    }
    .wfl-terminus__circle {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }
    .wfl-terminus__circle--start {
        background: linear-gradient(135deg,#d1fae5,#a7f3d0);
        border: 2px solid #6ee7b7;
        color: #065f46;
    }
    .wfl-terminus__circle--end {
        background: linear-gradient(135deg,#d1fae5,#a7f3d0);
        border: 2px solid #34d399;
        color: #065f46;
    }
    .wfl-terminus__label {
        font-size: 0.6rem;
        color: #9ca3af;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    /* ── Connecteur flèche + bouton insérer ─────────────────── */
    .wfl-connector {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding-top: 0;
        gap: 4px;
    }
    .wfl-connector__line {
        width: 2px;
        height: 24px;
        background: linear-gradient(to bottom, #d1fae5, #a7f3d0);
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: center;
    }
    .wfl-connector__arrow {
        color: #6ee7b7;
        font-size: 1.1rem;
        position: absolute;
        bottom: -10px;
        left: 50%;
        right: auto;
        top: auto;
        transform: translateX(-50%) rotate(90deg);
        line-height: 1;
    }
    .wfl-insert-btn {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 1.5px dashed var(--kcc-primary, #00b193);
        background: white;
        color: var(--kcc-primary, #00b193);
        font-size: 0.9rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        line-height: 1;
        padding: 0;
        transition: background .12s, color .12s;
    }
    .wfl-insert-btn:hover {
        background: var(--kcc-primary, #00b193);
        color: #fff;
    }

    /* ── Nœud étape ─────────────────────────────────────────── */
    .wfl-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        position: relative;
        width: 100%;
        max-width: 320px;
    }
    .wfl-node__box {
        min-width: 220px;
        max-width: 100%;
        width: 100%;
        border: 2px solid var(--gray-200, #e5e7eb);
        border-radius: 10px;
        background: #fff;
        padding: 0.65rem 0.85rem 0.65rem 2.1rem;
        cursor: pointer;
        text-align: center;
        position: relative;
        transition: border-color .15s, background .15s, box-shadow .15s, transform .1s;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
    }
    .wfl-node__box:hover {
        box-shadow: 0 5px 18px rgba(0,0,0,.12);
        transform: translateY(-1px);
    }
    .wfl-node__num {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        color: #fff;
        font-size: 0.7rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 0.35rem;
        transition: background .15s;
        box-shadow: 0 1px 4px rgba(0,0,0,.15);
    }
    .wfl-node__name {
        font-size: 0.78rem;
        font-weight: 700;
        line-height: 1.35;
        word-break: break-word;
        transition: color .15s;
    }
    .wfl-node__auto {
        font-size: 0.62rem;
        margin-top: 0.2rem;
        transition: color .15s;
    }
    .wfl-node__role-label {
        font-size: 0.6rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.85;
    }

    /* ── Panneau d'édition inline ───────────────────────────── */
    .wfl-edit-panel {
        position: relative;
        top: auto;
        left: auto;
        margin-top: 0.4rem;
        z-index: 10;
        background: #fff;
        border: 1.5px solid var(--gray-200,#e5e7eb);
        border-radius: 10px;
        padding: 0.85rem;
        box-shadow: 0 4px 16px rgba(0,0,0,.10);
        width: 100%;
        animation: slideDown 0.12s ease;
    }
    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .wfl-edit-panel__field {
        margin-bottom: 0.55rem;
    }
    .wfl-edit-panel__label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--gray-500, #6b7280);
        margin-bottom: 0.2rem;
    }
    .wfl-edit-panel__actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.25rem;
        margin-top: 0.25rem;
        border-top: 1px solid var(--gray-100, #f3f4f6);
        padding-top: 0.4rem;
    }
    /* ── Poignée de drag ─────────────────────────────────────── */
    .wfl-node__drag {
        position: absolute;
        left: 0.35rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        color: var(--gray-300, #d1d5db);
        cursor: grab;
        user-select: none;
        transition: color 0.12s;
        line-height: 1;
