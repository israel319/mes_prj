@page "/admin/audit"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IAuditLogService AuditLogService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<PageTitle>Journal d'Audit - Admin - KCC Material Flow</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Aul_Title"]</h1>
                <p class="kcp-subtitle">@L["Aul_Subtitle"]</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn" type="button" @onclick="LoadDataAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">


    @* === FILTRES === *@
    <RadzenCard class="rz-mb-4" Style="padding: 1rem;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="0.75rem">
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-600);">@L["Filter_DateFrom"]</RadzenText>
                <RadzenDatePicker @bind-Value="@filterDateDebut" Style="min-width: 150px;" ShowTime="false" DateFormat="dd/MM/yyyy" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-600);">@L["Filter_DateTo"]</RadzenText>
                <RadzenDatePicker @bind-Value="@filterDateFin" Style="min-width: 150px;" ShowTime="false" DateFormat="dd/MM/yyyy" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-600);">@L["Aul_FilterUser"]</RadzenText>
                <RadzenTextBox @bind-Value="@filterUtilisateur" Style="min-width: 150px;" Placeholder="@L["Aul_FilterUserPh"].Value" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-600);">@L["Aul_FilterActionType"]</RadzenText>
                <RadzenDropDown TValue="string" Data="@typesAction" @bind-Value="@filterTypeAction" AllowClear="true" Placeholder="@L["Aul_FilterAllActions"].Value" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-600);">@L["Aul_FilterCategory"]</RadzenText>
                <RadzenDropDown TValue="string" Data="@categories" @bind-Value="@filterCategorie" AllowClear="true" Placeholder="@L["Aul_FilterAllCategories"].Value" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenButton Text="@L["Aul_BtnSearch"].Value" Icon="search" ButtonStyle="ButtonStyle.Primary" Click="@SearchAsync" />
            <RadzenButton Icon="clear" Text="@L["Aul_BtnReset"].Value" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined" Click="@ResetFilters" />
        </RadzenStack>
    </RadzenCard>

    @* === GRILLE === *@
    <RadzenCard Style="padding: 0;">
        <RadzenDataGrid @ref="grid" Data="@logs" TItem="AuditLog"
                        AllowFiltering="false" AllowSorting="true" AllowPaging="true"
                        PageSize="10" Count="@totalCount"
                        LoadData="@LoadDataGrid"
                        PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowColumnResize="true"
                        Density="Density.Compact"
                        GridLines="DataGridGridLines.Horizontal"
                        ExpandMode="DataGridExpandMode.Single"
                        EmptyText="@L["Aul_Empty"].Value">
            <Template Context="log">
                <div style="padding: 1rem; background: var(--rz-base-200);">
                    <RadzenRow Gap="1rem">
                        <RadzenColumn Size="12" SizeMD="6">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; color: var(--kcc-grey);">@L["Aul_LblDescription"]</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">@log.Description</RadzenText>
                            @if (!string.IsNullOrEmpty(log.EntiteType))
                            {
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500);">
                                    @L["Aul_LblEntity"] @log.EntiteType #@log.EntiteId
                                </RadzenText>
                            }
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="6">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 600; color: var(--kcc-grey);">@L["Aul_LblContext"]</RadzenText>
                            @if (!string.IsNullOrEmpty(log.AdresseIP))
                            {
                                <RadzenText TextStyle="TextStyle.Body2"><strong>@L["Aul_LblIP"]</strong> @log.AdresseIP</RadzenText>
                            }
                            @if (!string.IsNullOrEmpty(log.UserAgent))
                            {
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500);">@log.UserAgent</RadzenText>
                            }
                        </RadzenColumn>
                    </RadzenRow>
                    @if (!string.IsNullOrEmpty(log.AncienneValeur) || !string.IsNullOrEmpty(log.NouvelleValeur))
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-2">
                            <RadzenButton Text="@L["Aul_BtnViewChanges"].Value" Icon="compare_arrows" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Click="@(() => ShowDiff(log))" />
                        </RadzenStack>
                    }
                </div>
            </Template>
            <Columns>
                <RadzenDataGridColumn TItem="AuditLog" Property="DateAction" Title="@L["Aul_ColDate"].Value" Width="160px">
                    <Template Context="log">
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600;">@log.DateAction.ToString("dd/MM/yyyy")</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500);">@log.DateAction.ToString("HH:mm:ss")</RadzenText>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="AuditLog" Title="@L["Aul_ColUser"].Value" Width="170px">
                    <Template Context="log">
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: 600;">@log.UtilisateurNom</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--gray-500);">@log.UtilisateurLogin</RadzenText>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="AuditLog" Property="TypeAction" Title="@L["Aul_ColAction"].Value" Width="120px">
                    <Template Context="log">
                        <RadzenBadge Text="@log.TypeAction" BadgeStyle="@GetActionBadgeStyle(log.TypeAction)" Style="font-size: 0.7rem;" />
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="AuditLog" Property="Categorie" Title="@L["Aul_ColCategory"].Value" Width="130px">
                    <Template Context="log">
                        <RadzenText TextStyle="TextStyle.Body2">@log.Categorie</RadzenText>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="AuditLog" Property="Description" Title="@L["Aul_ColDescription"].Value">
                    <Template Context="log">
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-grey);">@log.Description</RadzenText>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="AuditLog" Property="Niveau" Title="@L["Aul_ColLevel"].Value" Width="100px" TextAlign="TextAlign.Center">
                    <Template Context="log">
                        <RadzenBadge Text="@log.Niveau" BadgeStyle="@GetNiveauBadgeStyle(log.Niveau)" Style="font-size: 0.7rem;" />
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="AuditLog" Title="@L["Col_Actions"].Value" Width="80px" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                    <Template Context="log">
                        @if (!string.IsNullOrEmpty(log.AncienneValeur) || !string.IsNullOrEmpty(log.NouvelleValeur))
                        {
                            <RadzenButton Icon="compare_arrows" ButtonStyle="ButtonStyle.Info" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => ShowDiff(log))" title="@L["Aul_BtnViewChanges"].Value" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
    </main>
</div>

@code {
    private RadzenDataGrid<AuditLog>? grid;
    private List<AuditLog> logs = [];
    private int totalCount;
    private AuditStats? stats;

    private DateTime filterDateDebut = DateTime.Today.AddDays(-7);
    private DateTime filterDateFin = DateTime.Today;
    private string? filterUtilisateur;
    private string? filterTypeAction;
    private string? filterCategorie;
    private string? filterNiveau;

    private const string NiveauInfo = "Info";
    private const string NiveauWarning = "Warning";
    private const string NiveauError = "Error";

    private readonly List<string> typesAction = ["Create", "Update", "Delete", "Activate", "Deactivate", "Login", "Logout", "Access", "Approve", "Reject"];
    private readonly List<string> categories = ["BonEntree", "BonSortie", "Materiel", "Utilisateur", "Departement", "Role", "Statut", "TypeMateriel", "ParametreSysteme", "Authentification"];

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadDataAsync()
    {
        await LoadStatsAsync();
        if (grid != null)
        {
            await grid.Reload();
        }
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            stats = await AuditLogService.GetStatsAsync(filterDateDebut, filterDateFin);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement des stats: {ex.Message}");
        }
    }

    private async Task LoadDataGrid(Radzen.LoadDataArgs args)
    {
        try
        {
            var skip = args.Skip ?? 0;
            var take = args.Top ?? 10;
            var page = (skip / take) + 1;

            var result = await AuditLogService.GetPagedAsync(
                page,
                take,
                filterDateDebut,
                filterDateFin,
                filterUtilisateur,
                filterTypeAction,
                filterCategorie);

            var items = result.Items.AsEnumerable();
            if (!string.IsNullOrEmpty(filterNiveau))
            {
                items = items.Where(l => l.Niveau == filterNiveau);
            }
            logs = items.ToList();
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private async Task SearchAsync()
    {
        await LoadStatsAsync();
        if (grid != null)
        {
            await grid.FirstPage(true);
        }
    }

    private async Task ResetFilters()
    {
        filterDateDebut = DateTime.Today.AddDays(-7);
        filterDateFin = DateTime.Today;
        filterUtilisateur = null;
        filterTypeAction = null;
        filterCategorie = null;
        filterNiveau = null;
        await SearchAsync();
    }

    private async Task SetNiveauFilter(string? niveau)
    {
        filterNiveau = niveau;
        if (grid != null)
        {
            await grid.FirstPage(true);
        }
    }

    private string GetCardStyle(string? niveau, string bgColor)
    {
        var isActive = filterNiveau == niveau;
        var border = isActive ? "2px solid var(--kcc-primary)" : "1px solid transparent";
        return $"background: {bgColor}; border: {border};";
    }

    private static BadgeStyle GetActionBadgeStyle(string action) => action switch
    {
        "Create" or "Approve" => BadgeStyle.Success,
        "Update" or "Login" => BadgeStyle.Info,
        "Delete" => BadgeStyle.Danger,
        "Reject" => BadgeStyle.Warning,
        _ => BadgeStyle.Light
    };

    private static BadgeStyle GetNiveauBadgeStyle(string niveau) => niveau switch
    {
        "Info" => BadgeStyle.Info,
        "Warning" => BadgeStyle.Warning,
        "Error" or "Critical" => BadgeStyle.Danger,
        _ => BadgeStyle.Light
    };

    private async Task ShowDiff(AuditLog log)
    {
        await DialogService.OpenAsync<AuditLogDiffDialog>("Modifications",
            new Dictionary<string, object> { { "AuditLog", log } },
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
    }
}
