@page "/admin/audit"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IAuditLogService AuditLogService
@inject NotificationService NotificationService

<PageTitle>Administration - Journal d'Audit</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <AdminNav />

    @* ─── En-tête ─── *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
                Journal d'Audit
            </RadzenText>
        </RadzenStack>
        <RadzenButton Icon="refresh" Text="Actualiser" Variant="Variant.Outlined"
                      ButtonStyle="ButtonStyle.Secondary" Click="@LoadDataAsync" />
    </RadzenStack>

    @* ─── Statistiques ─── *@
    @if (stats != null)
    {
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="6" SizeMD="3">
                <RadzenCard Style="text-align: center; background-color: rgba(59,130,246,0.08);">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #2563eb;">@stats.TotalActions</div>
                    <div style="font-size: 0.72rem; color: #666;">Total actions</div>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="3">
                <RadzenCard Style="text-align: center; background-color: rgba(5,150,105,0.08);">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #059669;">@stats.TotalUsers</div>
                    <div style="font-size: 0.72rem; color: #666;">Utilisateurs</div>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="3">
                <RadzenCard Style="text-align: center; background-color: rgba(245,158,11,0.08);">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #d97706;">@stats.ActionsByType.Count</div>
                    <div style="font-size: 0.72rem; color: #666;">Types d'actions</div>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="3">
                <RadzenCard Style="text-align: center; background-color: rgba(220,38,38,0.08);">
                    <div style="font-size: 1.5rem; font-weight: 700; color: #dc2626;">@stats.TotalErrors</div>
                    <div style="font-size: 0.72rem; color: #666;">Erreurs</div>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    }

    @* ─── Filtres ─── *@
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Style="padding: 0.5rem 0;">
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Date début</RadzenText>
                <RadzenDatePicker @bind-Value="@filterDateDebut" Style="min-width: 150px;"
                                  ShowTime="false" DateFormat="dd/MM/yyyy" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Date fin</RadzenText>
                <RadzenDatePicker @bind-Value="@filterDateFin" Style="min-width: 150px;"
                                  ShowTime="false" DateFormat="dd/MM/yyyy" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Utilisateur</RadzenText>
                <RadzenTextBox @bind-Value="@filterUtilisateur" Style="min-width: 150px;"
                               Placeholder="Login..." />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Type d'action</RadzenText>
                <RadzenDropDown TValue="string" Data="@typesAction" @bind-Value="@filterTypeAction"
                                AllowClear="true" Placeholder="Tous" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Catégorie</RadzenText>
                <RadzenDropDown TValue="string" Data="@categories" @bind-Value="@filterCategorie"
                                AllowClear="true" Placeholder="Toutes" Style="min-width: 140px;" />
            </RadzenStack>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="Rechercher" Icon="search" ButtonStyle="ButtonStyle.Primary"
                              Click="@(() => SearchAsync())" />
                <RadzenButton Icon="clear" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                              Click="@ResetFilters" title="Réinitialiser" class="kcc-btn-clear" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    @* ─── Grille des logs ─── *@
    <RadzenCard>
        <RadzenDataGrid @ref="grid" Data="@logs" TItem="AuditLog"
                        AllowFiltering="false" AllowSorting="true" AllowPaging="true"
                        PageSize="20" Count="@totalCount"
                        LoadData="@LoadDataGrid"
                        PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowColumnResize="true"
                        Density="Density.Compact"
                        EmptyText="Aucun log trouvé">
                <Columns>
                    <RadzenDataGridColumn TItem="AuditLog" Property="DateAction" Title="Date" Width="150px">
                        <Template Context="log">
                            <div>
                                <div style="font-size: 0.78rem; font-weight: 600; color: #1a1a1a;">
                                    @log.DateAction.ToString("dd/MM/yyyy HH:mm")
                                </div>
                                <div style="font-size: 0.72rem; color: #666;">
                                    @log.DateAction.ToString("ss")s
                                </div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AuditLog" Title="Utilisateur" Width="150px">
                        <Template Context="log">
                            <div>
                                <div style="font-weight: 600; font-size: 0.78rem; color: #1a1a1a;">@log.UtilisateurNom</div>
                                <div style="font-size: 0.72rem; color: #666;">@log.UtilisateurLogin</div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AuditLog" Property="TypeAction" Title="Action" Width="120px">
                        <Template Context="log">
                            <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: @GetActionBackground(log.TypeAction); color: @GetActionColor(log.TypeAction);">
                                @log.TypeAction
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AuditLog" Property="Categorie" Title="Catégorie" Width="120px">
                        <Template Context="log">
                            <span style="font-size: 0.78rem; color: #374151;">@log.Categorie</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AuditLog" Property="Description" Title="Détails">
                        <Template Context="log">
                            <div>
                                <div style="font-size: 0.78rem; color: #374151;">@log.Description</div>
                                @if (!string.IsNullOrEmpty(log.EntiteId))
                                {
                                    <div style="font-size: 0.72rem; color: #666;">
                                        @log.EntiteType #@log.EntiteId
                                    </div>
                                }
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AuditLog" Property="Niveau" Title="Niveau" Width="90px" TextAlign="TextAlign.Center">
                        <Template Context="log">
                            <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: @GetNiveauBackground(log.Niveau); color: @GetNiveauColor(log.Niveau);">
                                @log.Niveau
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AuditLog" Title="" Width="50px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="log">
                            @if (!string.IsNullOrEmpty(log.AncienneValeur) || !string.IsNullOrEmpty(log.NouvelleValeur))
                            {
                                <RadzenButton Icon="compare_arrows" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ShowDiff(log))" title="Voir les modifications" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
</RadzenStack>

@inject DialogService DialogService

@code {
    private RadzenDataGrid<AuditLog>? grid;
    private List<AuditLog> logs = [];
    private int totalCount;
    private AuditStats? stats;
    
    private DateTime filterDateDebut = DateTime.Today.AddDays(-7);
    private DateTime filterDateFin = DateTime.Today;
    private string? filterUtilisateur;
    private string? filterTypeAction;
    private string? filterCategorie;
    
    private readonly List<string> typesAction = ["Create", "Update", "Delete", "Activate", "Deactivate", "Login", "Logout", "Access", "Approve", "Reject"];
    private readonly List<string> categories = ["BonEntree", "BonSortie", "Materiel", "Utilisateur", "Departement", "Role", "Statut", "TypeMateriel", "ParametreSysteme", "Authentification"];

    protected override async Task OnInitializedAsync()
    {
        await LoadStatsAsync();
    }

    private async Task LoadDataAsync()
    {
        await LoadStatsAsync();
        if (grid != null)
        {
            await grid.Reload();
        }
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            stats = await AuditLogService.GetStatsAsync(filterDateDebut, filterDateFin);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement des stats: {ex.Message}");
        }
    }

    private async Task LoadDataGrid(Radzen.LoadDataArgs args)
    {
        try
        {
            var skip = args.Skip ?? 0;
            var take = args.Top ?? 20;
            var page = (skip / take) + 1;
            
            var result = await AuditLogService.GetPagedAsync(
                page, 
                take,
                filterDateDebut,
                filterDateFin,
                filterUtilisateur,
                filterTypeAction,
                filterCategorie);
            
            logs = result.Items.ToList();
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private async Task SearchAsync()
    {
        await LoadStatsAsync();
        if (grid != null)
        {
            await grid.FirstPage(true);
        }
    }

    private async Task ResetFilters()
    {
        filterDateDebut = DateTime.Today.AddDays(-7);
        filterDateFin = DateTime.Today;
        filterUtilisateur = null;
        filterTypeAction = null;
        filterCategorie = null;
        await SearchAsync();
    }

    private static string GetActionBackground(string action) => action switch
    {
        "Create" => "rgba(5,150,105,0.1)",
        "Update" => "rgba(59,130,246,0.1)",
        "Delete" => "rgba(220,38,38,0.1)",
        "Approve" => "rgba(5,150,105,0.1)",
        "Reject" => "rgba(245,158,11,0.1)",
        "Login" => "rgba(37,99,235,0.1)",
        "Logout" => "#f3f4f6",
        _ => "#f3f4f6"
    };

    private static string GetActionColor(string action) => action switch
    {
        "Create" => "#059669",
        "Update" => "#2563eb",
        "Delete" => "#dc2626",
        "Approve" => "#059669",
        "Reject" => "#d97706",
        "Login" => "#2563eb",
        "Logout" => "#374151",
        _ => "#374151"
    };

    private static string GetNiveauBackground(string niveau) => niveau switch
    {
        "Info" => "rgba(59,130,246,0.1)",
        "Warning" => "rgba(245,158,11,0.1)",
        "Error" => "rgba(220,38,38,0.1)",
        "Critical" => "rgba(220,38,38,0.1)",
        _ => "#f3f4f6"
    };

    private static string GetNiveauColor(string niveau) => niveau switch
    {
        "Info" => "#2563eb",
        "Warning" => "#d97706",
        "Error" => "#dc2626",
        "Critical" => "#dc2626",
        _ => "#374151"
    };

    private async Task ShowDiff(AuditLog log)
    {
        await DialogService.OpenAsync<AuditLogDiffDialog>("Modifications",
            new Dictionary<string, object> { { "AuditLog", log } },
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
    }
}
