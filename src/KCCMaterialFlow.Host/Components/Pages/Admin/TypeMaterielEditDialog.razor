@using TypeMaterielEntity = KCCMaterialFlow.Module.Shared.Entities.TypeMateriel
@using KCCMaterialFlow.Module.Shared.Services
@inject ITypeMaterielService TypeMaterielService
@inject DialogService DialogService

<RadzenStack Gap="1rem">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Code *" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.CodeType" Style="width: 100%;" 
                               Placeholder="VEHICULE" MaxLength="50" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenFormField Text="Nom *" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.NomType" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="Description" Style="width: 100%;">
                <RadzenTextArea @bind-Value="@model.Description" Style="width: 100%;" Rows="2" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Catégorie" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.Categorie" Style="width: 100%;" 
                               Placeholder="Ex: Matériel roulant" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Icône" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.Icone" Style="width: 100%;" 
                               Placeholder="bi-truck" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Couleur" Style="width: 100%;">
                <RadzenColorPicker @bind-Value="@model.Couleur" Style="width: 100%;" ShowHSV="true" ShowRGBA="false" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenFieldset Text="Workflow d'approbation">
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenFormField Text="Niveaux d'approbation" Style="width: 100%;">
                    <RadzenNumeric @bind-Value="@model.NiveauxApprobation" Style="width: 100%;" Min="0" Max="5" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenStack Style="padding-top: 1.5rem;">
                    <RadzenCheckBox @bind-Value="@model.RequiertApprobationDepartement" TValue="bool" />
                    <RadzenLabel Text="Approbation département" Style="margin-left: 0.5rem;" />
                </RadzenStack>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenStack Style="padding-top: 1.5rem;">
                    <RadzenCheckBox @bind-Value="@model.RequiertApprobationDirection" TValue="bool" />
                    <RadzenLabel Text="Approbation direction" Style="margin-left: 0.5rem;" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </RadzenFieldset>
    
    <RadzenFieldset Text="Durées de validité">
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Durée par défaut (jours)" Style="width: 100%;">
                    <RadzenNumeric @bind-Value="@model.DureeValiditeDefautJours" Style="width: 100%;" Min="1" Max="365" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Durée maximum (jours)" Style="width: 100%;">
                    <RadzenNumeric @bind-Value="@model.DureeMaximumJours" Style="width: 100%;" Min="1" Max="365" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
    </RadzenFieldset>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.NumeroSerieObligatoire" TValue="bool" />
                <RadzenLabel Text="N° série obligatoire" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.PhotoObligatoire" TValue="bool" />
                <RadzenLabel Text="Photo obligatoire" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                <RadzenCheckBox @bind-Value="@model.EstActif" TValue="bool" />
                <RadzenLabel Text="Type actif" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="Ordre d'affichage" Style="width: 100%;">
                <RadzenNumeric @bind-Value="@model.Ordre" Style="width: 100%;" Min="0" Max="100" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" class="rz-mt-4">
        <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
        <RadzenButton Text="@(isEditMode ? "Enregistrer" : "Créer")" ButtonStyle="ButtonStyle.Primary" 
                      Click="@Save" Disabled="@(!IsValid)" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter]
    public TypeMaterielEntity? TypeMateriel { get; set; }
    
    private TypeMaterielEntity model = new();
    private bool isEditMode;
    
    private bool IsValid => !string.IsNullOrWhiteSpace(model.CodeType) && 
                           !string.IsNullOrWhiteSpace(model.NomType);

    protected override void OnInitialized()
    {
        if (TypeMateriel != null)
        {
            isEditMode = true;
            model = new TypeMaterielEntity
            {
                IdTypeMateriel = TypeMateriel.IdTypeMateriel,
                CodeType = TypeMateriel.CodeType,
                NomType = TypeMateriel.NomType,
                Description = TypeMateriel.Description,
                Categorie = TypeMateriel.Categorie,
                Icone = TypeMateriel.Icone,
                Couleur = TypeMateriel.Couleur,
                RequiertApprobationDepartement = TypeMateriel.RequiertApprobationDepartement,
                RequiertApprobationDirection = TypeMateriel.RequiertApprobationDirection,
                NiveauxApprobation = TypeMateriel.NiveauxApprobation,
                DureeValiditeDefautJours = TypeMateriel.DureeValiditeDefautJours,
                DureeMaximumJours = TypeMateriel.DureeMaximumJours,
                NumeroSerieObligatoire = TypeMateriel.NumeroSerieObligatoire,
                PhotoObligatoire = TypeMateriel.PhotoObligatoire,
                Ordre = TypeMateriel.Ordre,
                EstActif = TypeMateriel.EstActif,
                DateCreation = TypeMateriel.DateCreation
            };
        }
        else
        {
            model.Couleur = "#6c757d";
            model.EstActif = true;
            model.DureeValiditeDefautJours = 30;
            model.DureeMaximumJours = 365;
            model.NiveauxApprobation = 1;
            model.RequiertApprobationDepartement = true;
        }
    }

    private async Task Save()
    {
        if (!IsValid) return;
        
        try
        {
            if (isEditMode)
            {
                await TypeMaterielService.UpdateAsync(model);
            }
            else
            {
                await TypeMaterielService.CreateAsync(model);
            }
            
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Erreur lors de l'enregistrement: {ex.Message}", "Erreur");
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
}
