@page "/admin/utilisateurs"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IUtilisateurService UtilisateurService
@inject IRoleService RoleService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject KCCMaterialFlow.Host.Services.UserRoleCacheService RoleCacheService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Administration - Utilisateurs</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <AdminNav />

    @* ─── En-tête ─── *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
                Gestion des Utilisateurs
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--kcc-text-light); margin-top: 0.25rem;">
                @filteredUtilisateurs.Count utilisateur(s) sur @utilisateurs.Count
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            <RadzenButton Icon="refresh" Text="Actualiser" Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Secondary" Click="@LoadDataAsync" />
            <RadzenButton Text="Nouvel utilisateur" Icon="person_add" ButtonStyle="ButtonStyle.Primary"
                          Click="@ShowCreateDialog" />
        </RadzenStack>
    </RadzenStack>

    @* ─── Filtres ─── *@
    <RadzenCard>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Wrap="FlexWrap.Wrap" Gap="1rem" Style="padding: 0.5rem 0;">
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Rechercher</RadzenText>
                <RadzenTextBox @bind-Value="@searchTerm" Placeholder="Nom, login, email..."
                               Style="min-width: 250px;" @oninput="@OnSearchChanged" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Département</RadzenText>
                <RadzenDropDown TValue="string" Data="@departements" @bind-Value="@filterDepartement"
                                AllowClear="true" Placeholder="Tous" Style="min-width: 160px;"
                                Change="@(args => ApplyFilters())" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Rôle</RadzenText>
                <RadzenDropDown TValue="int?" Data="@roles" @bind-Value="@filterRoleId"
                                TextProperty="NomRole" ValueProperty="Id"
                                AllowClear="true" Placeholder="Tous" Style="min-width: 160px;"
                                Change="@(args => ApplyFilters())" />
            </RadzenStack>
            <RadzenStack Gap="0.15rem">
                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--kcc-text-muted);">Statut</RadzenText>
                <RadzenDropDown TValue="bool?" Data="@statutOptions" @bind-Value="@filterActif"
                                TextProperty="Text" ValueProperty="Value"
                                AllowClear="true" Placeholder="Tous" Style="min-width: 120px;"
                                Change="@(args => ApplyFilters())" />
            </RadzenStack>
            <RadzenButton Icon="clear" Text="Effacer" Click="@ResetFilters"
                          ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" class="kcc-btn-clear" />
        </RadzenStack>
    </RadzenCard>

    @* ─── Tableau ─── *@
    <RadzenCard>
        <RadzenDataGrid @ref="grid" Data="@filteredUtilisateurs" TItem="Utilisateur"
                        AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="15"
                        PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowColumnResize="true"
                        Density="Density.Compact"
                        EmptyText="Aucun utilisateur trouvé">
            <Columns>
                <RadzenDataGridColumn TItem="Utilisateur" Property="NomComplet" Title="Utilisateur" Width="250px">
                    <Template Context="user">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <div style="width: 28px; height: 28px; background: #253C45;
                                        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
                                        color: #fff; font-size: 11px; font-weight: 600;">
                                @GetUserInitials(user.NomComplet)
                            </div>
                            <div>
                                <div style="font-weight: 600; font-size: 0.8rem; color: #1a1a1a;">@user.NomComplet</div>
                                <div style="font-size: 0.72rem; color: #666;">@user.Login</div>
                            </div>
                        </div>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Utilisateur" Property="Email" Title="Email">
                    <Template Context="user">
                        @if (!string.IsNullOrEmpty(user.Email))
                        {
                            <span>@user.Email</span>
                        }
                        else
                        {
                            <span style="color: #999;">—</span>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Utilisateur" Property="Departement" Title="Département" Width="160px">
                    <Template Context="user">
                        @if (!string.IsNullOrEmpty(user.Departement))
                        {
                            <span>@user.Departement</span>
                        }
                        else
                        {
                            <span style="color: #999;">—</span>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Utilisateur" Property="IdRole" Title="Rôle" Width="200px">
                    <Template Context="user">
                        @{ var roleName = GetRoleName(user); }
                        <span style="font-size: 0.75rem; font-weight: 500; color: @(roleName == "—" ? "#999" : GetRoleColor(roleName));">
                            @roleName
                        </span>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Utilisateur" Property="EstActif" Title="Statut" Width="90px" TextAlign="TextAlign.Center">
                    <Template Context="user">
                        @if (user.EstActif)
                        {
                            <span style="font-size: 0.75rem; font-weight: 600; color: #059669;">Actif</span>
                        }
                        else
                        {
                            <span style="font-size: 0.75rem; font-weight: 600; color: #dc2626;">Inactif</span>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Utilisateur" Title="Actions" Width="160px" TextAlign="TextAlign.Center" Sortable="false">
                    <Template Context="user">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.15rem" JustifyContent="JustifyContent.Center">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                          Click="@(() => ShowEditDialog(user))" title="Modifier" />
                            <RadzenButton Icon="shield" ButtonStyle="ButtonStyle.Info" Variant="Variant.Text" Size="ButtonSize.Small"
                                          Click="@(() => ShowRolesDialog(user))" title="Gérer les rôles" />
                            @if (user.EstActif)
                            {
                                <RadzenButton Icon="block" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ToggleUserStatus(user))" title="Désactiver" />
                            }
                            else
                            {
                                <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ToggleUserStatus(user))" title="Activer" />
                            }
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                          Click="@(() => DeleteUser(user))" title="Supprimer" />
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>

@code {
    private RadzenDataGrid<Utilisateur>? grid;
    private List<Utilisateur> utilisateurs = [];
    private List<Utilisateur> filteredUtilisateurs = [];
    private List<Role> roles = [];
    private List<string> departements = [];

    private string searchTerm = string.Empty;
    private string? filterDepartement;
    private int? filterRoleId;
    private bool? filterActif;

    private readonly List<object> statutOptions =
    [
        new { Text = "Actif", Value = true },
        new { Text = "Inactif", Value = false }
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var allUsers = await UtilisateurService.GetAllAsync();
            utilisateurs = allUsers.ToList();

            roles = (await RoleService.GetAllAsync()).ToList();

            departements = utilisateurs
                .Where(u => !string.IsNullOrEmpty(u.Departement))
                .Select(u => u.Departement!)
                .Distinct()
                .OrderBy(d => d)
                .ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private void ApplyFilters()
    {
        var query = utilisateurs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.ToUpperInvariant();
            query = query.Where(u =>
                u.Login.ToUpperInvariant().Contains(term) ||
                u.NomComplet.ToUpperInvariant().Contains(term) ||
                (u.Email?.ToUpperInvariant().Contains(term) ?? false) ||
                (u.Fonction?.ToUpperInvariant().Contains(term) ?? false));
        }

        if (!string.IsNullOrWhiteSpace(filterDepartement))
            query = query.Where(u => u.Departement == filterDepartement);

        if (filterRoleId.HasValue)
            query = query.Where(u => u.IdRole == filterRoleId.Value);

        if (filterActif.HasValue)
            query = query.Where(u => u.EstActif == filterActif.Value);

        filteredUtilisateurs = query.ToList();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        searchTerm = args.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        filterDepartement = null;
        filterRoleId = null;
        filterActif = null;
        ApplyFilters();
    }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<UtilisateurEditDialog>("Nouvel utilisateur",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });

        if (result is Utilisateur newUser)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès",
                $"Utilisateur '{newUser.NomComplet}' créé. Les activités sont automatiquement liées aux rôles.");
        }
        else if (result == true)
        {
            await LoadDataAsync();
        }
    }

    private async Task ShowEditDialog(Utilisateur user)
    {
        var result = await DialogService.OpenAsync<UtilisateurEditDialog>("Modifier l'utilisateur",
            new Dictionary<string, object> { { "Utilisateur", user } },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });

        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Utilisateur modifié avec succès");
        }
    }

    private async Task ShowRolesDialog(Utilisateur user)
    {
        var result = await DialogService.OpenAsync<UtilisateurRolesDialog>("Gérer les rôles",
            new Dictionary<string, object> { { "Utilisateur", user } },
            new DialogOptions { Width = "540px", Height = "auto", Resizable = false, Draggable = true, ShowTitle = false, CssClass = "kcc-dialog-clean" });

        if (result is string modifiedLogin)
        {
            // Si on a changé ses propres rôles, forcer un rechargement HTTP complet
            // vers l'accueil (on n'a peut-être plus accès à la page admin)
            var currentLogin = CurrentUserService.GetUserLogin();
            if (modifiedLogin.Equals(currentLogin, StringComparison.OrdinalIgnoreCase)
                || (currentLogin.Contains('\\') && modifiedLogin.Equals(currentLogin.Split('\\').Last(), StringComparison.OrdinalIgnoreCase)))
            {
                // Forcer un VRAI rechargement HTTP (pas la navigation améliorée Blazor)
                await JSRuntime.InvokeVoidAsync("forceReload", "/");
                return;
            }

            // Forcer le rechargement depuis la BD (le cache a été invalidé dans le dialog)
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Rôle mis à jour avec succès");
        }
    }

    private async Task ToggleUserStatus(Utilisateur user)
    {
        var action = user.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} l'utilisateur {user.NomComplet} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });

        if (confirmed == true)
        {
            try
            {
                user.EstActif = !user.EstActif;
                user.DateModification = DateTime.Now;
                await UtilisateurService.UpsertAsync(user);

                // Invalider le cache centralisé pour effet immédiat
                RoleCacheService.InvalidateUser(user.Login);

                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    user.EstActif ? "Activate" : "Deactivate",
                    "Utilisateur",
                    $"Utilisateur {user.NomComplet} {(user.EstActif ? "activé" : "désactivé")}",
                    user.Id.ToString(),
                    "Utilisateur");

                // Si on vient de se désactiver soi-même, forcer un rechargement HTTP complet
                var currentLogin = CurrentUserService.GetUserLogin();
                if (user.Login.Equals(currentLogin, StringComparison.OrdinalIgnoreCase)
                    || (currentLogin.Contains('\\') && user.Login.Equals(currentLogin.Split('\\').Last(), StringComparison.OrdinalIgnoreCase)))
                {
                    await JSRuntime.InvokeVoidAsync("forceReload", "/");
                    return;
                }

                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès", $"Utilisateur {(user.EstActif ? "activé" : "désactivé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }

    private async Task DeleteUser(Utilisateur user)
    {
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment supprimer définitivement l'utilisateur {user.NomComplet} ?\n\nCette action est irréversible. Toutes les données associées (rôles, activités) seront supprimées.",
            "Supprimer l'utilisateur",
            new ConfirmOptions { OkButtonText = "Supprimer", CancelButtonText = "Annuler" });

        if (confirmed == true)
        {
            try
            {
                await UtilisateurService.DeleteAsync(user.Id);

                // Invalider le cache centralisé
                RoleCacheService.InvalidateUser(user.Login);

                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    "Delete",
                    "Utilisateur",
                    $"Utilisateur {user.NomComplet} ({user.Login}) supprimé définitivement",
                    user.Id.ToString(),
                    "Utilisateur");

                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès", $"Utilisateur '{user.NomComplet}' supprimé");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Impossible de supprimer: {ex.Message}");
            }
        }
    }

    private static string GetRoleName(Utilisateur user)
    {
        // Source de vérité unique : FK IdRole → RolePrincipal
        if (user.RolePrincipal != null && !string.IsNullOrEmpty(user.RolePrincipal.NomRole))
            return user.RolePrincipal.NomRole;

        return "—";
    }

    private static string GetRoleColor(string roleName) => roleName switch
    {
        "Administrateur" or "Admin" => "#dc2626",
        "General Manager" or "GM" => "#7c3aed",
        "Superviseur" => "#2563eb",
        "Departement IT" or "IT" => "#0891b2",
        "Departement Environnement" or "Environnement" => "#059669",
        "Officier de Police Judiciaire" or "OPJ" => "#d97706",
        "Equipe Identification" or "Identification" => "#0d9488",
        "Investigation" => "#9333ea",
        "Demandeur" => "#6b7280",
        _ => "#374151"
    };

    private static string GetUserInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}";
        return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
    }
}
