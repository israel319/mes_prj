@page "/admin/utilisateurs"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IUtilisateurService UtilisateurService
@inject IRoleService RoleService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Administration - Utilisateurs</PageTitle>

<div style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <AdminNav />
    <RadzenStack Gap="1.5rem">
        @* ─── En-tête ─── *@
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn>
                <RadzenText TextStyle="TextStyle.H5" FontWeight="FontWeight.Bold" class="rz-mt-2">
                    <RadzenIcon Icon="people" Style="margin-right: 0.5rem; vertical-align: middle;" />
                    Gestion des Utilisateurs
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" Style="color: #718096;">
                    @filteredUtilisateurs.Count utilisateur(s) sur @utilisateurs.Count
                </RadzenText>
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                    <RadzenButton Text="Actualiser" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                                  Click="@LoadDataAsync" />
                    <RadzenButton Text="Nouvel utilisateur" Icon="person_add" ButtonStyle="ButtonStyle.Primary"
                                  Click="@ShowCreateDialog" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @* ─── Filtres ─── *@
        <RadzenCard Variant="Variant.Flat" Style="padding: 1rem;">
            <RadzenRow Gap="1rem" AlignItems="AlignItems.End">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Rechercher" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="@searchTerm" Placeholder="Nom, login, email..."
                                       Style="width: 100%;" @oninput="@OnSearchChanged" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenFormField Text="Département" Style="width: 100%;">
                        <RadzenDropDown TValue="string" Data="@departements" @bind-Value="@filterDepartement"
                                        AllowClear="true" Placeholder="Tous" Style="width: 100%;"
                                        Change="@(args => ApplyFilters())" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenFormField Text="Rôle" Style="width: 100%;">
                        <RadzenDropDown TValue="int?" Data="@roles" @bind-Value="@filterRoleId"
                                        TextProperty="NomRole" ValueProperty="Id"
                                        AllowClear="true" Placeholder="Tous" Style="width: 100%;"
                                        Change="@(args => ApplyFilters())" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenFormField Text="Statut" Style="width: 100%;">
                        <RadzenDropDown TValue="bool?" Data="@statutOptions" @bind-Value="@filterActif"
                                        TextProperty="Text" ValueProperty="Value"
                                        AllowClear="true" Placeholder="Tous" Style="width: 100%;"
                                        Change="@(args => ApplyFilters())" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenButton Text="Réinitialiser" Icon="clear" ButtonStyle="ButtonStyle.Light"
                                  Click="@ResetFilters" Style="width: 100%;" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>

        @* ─── Tableau ─── *@
        <RadzenCard Variant="Variant.Flat">
            <RadzenDataGrid @ref="grid" Data="@filteredUtilisateurs" TItem="Utilisateur"
                            AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="15"
                            PagerHorizontalAlign="HorizontalAlign.Center"
                            Style="border: none;">
                <Columns>
                    <RadzenDataGridColumn TItem="Utilisateur" Property="NomComplet" Title="Utilisateur" Width="250px">
                        <Template Context="user">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <div style="width: 28px; height: 28px; background: #253C45;
                                            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
                                            color: #fff; font-size: 11px; font-weight: 600;">
                                    @GetUserInitials(user.NomComplet)
                                </div>
                                <div>
                                    <div style="font-weight: 600; font-size: 0.8rem; color: #1a1a1a;">@user.NomComplet</div>
                                    <div style="font-size: 0.72rem; color: #666;">@user.Login</div>
                                </div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Utilisateur" Property="Email" Title="Email" Width="200px">
                        <Template Context="user">
                            @if (!string.IsNullOrEmpty(user.Email))
                            {
                                <span style="font-size: 0.78rem; color: #374151;">@user.Email</span>
                            }
                            else
                            {
                                <span style="color: #999;">—</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Utilisateur" Property="Departement" Title="Département" Width="140px">
                        <Template Context="user">
                            @if (!string.IsNullOrEmpty(user.Departement))
                            {
                                <span style="font-size: 0.78rem; color: #374151;">@user.Departement</span>
                            }
                            else
                            {
                                <span style="color: #999;">—</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Utilisateur" Property="IdRole" Title="Rôle" Width="140px">
                        <Template Context="user">
                            <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: @GetRoleBackground(user.RolePrincipal?.CodeRole); color: @GetRoleColor(user.RolePrincipal?.CodeRole);">
                                @GetRoleDisplayName(user.IdRole)
                            </span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Utilisateur" Property="EstActif" Title="Statut" Width="80px" TextAlign="TextAlign.Center">
                        <Template Context="user">
                            @if (user.EstActif)
                            {
                                <span style="font-size: 0.72rem; font-weight: 600; color: #059669;">Actif</span>
                            }
                            else
                            {
                                <span style="font-size: 0.72rem; font-weight: 600; color: #dc2626;">Inactif</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Utilisateur" Title="Actions" Width="150px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="user">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ShowEditDialog(user))" title="Modifier" />
                                <RadzenButton Icon="shield" ButtonStyle="ButtonStyle.Info" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ShowRolesDialog(user))" title="Gérer les rôles" />
                                <RadzenButton Icon="checklist" ButtonStyle="ButtonStyle.Warning" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ShowActivitesDialog(user))" title="Gérer les activités" />
                                @if (user.EstActif)
                                {
                                    <RadzenButton Icon="block" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                                  Click="@(() => ToggleUserStatus(user))" title="Désactiver" />
                                }
                                else
                                {
                                    <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text" Size="ButtonSize.Small"
                                                  Click="@(() => ToggleUserStatus(user))" title="Activer" />
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenStack>
</div>

@code {
    private RadzenDataGrid<Utilisateur>? grid;
    private List<Utilisateur> utilisateurs = [];
    private List<Utilisateur> filteredUtilisateurs = [];
    private List<Role> roles = [];
    private List<string> departements = [];

    private string searchTerm = string.Empty;
    private string? filterDepartement;
    private int? filterRoleId;
    private bool? filterActif;

    private readonly List<object> statutOptions =
    [
        new { Text = "Actif", Value = true },
        new { Text = "Inactif", Value = false }
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var allUsers = await UtilisateurService.GetAllAsync();
            utilisateurs = allUsers.ToList();

            roles = (await RoleService.GetAllAsync()).ToList();

            departements = utilisateurs
                .Where(u => !string.IsNullOrEmpty(u.Departement))
                .Select(u => u.Departement!)
                .Distinct()
                .OrderBy(d => d)
                .ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private void ApplyFilters()
    {
        var query = utilisateurs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.ToUpperInvariant();
            query = query.Where(u =>
                u.Login.ToUpperInvariant().Contains(term) ||
                u.NomComplet.ToUpperInvariant().Contains(term) ||
                (u.Email?.ToUpperInvariant().Contains(term) ?? false) ||
                (u.Fonction?.ToUpperInvariant().Contains(term) ?? false));
        }

        if (!string.IsNullOrWhiteSpace(filterDepartement))
            query = query.Where(u => u.Departement == filterDepartement);

        if (filterRoleId.HasValue)
            query = query.Where(u => u.IdRole == filterRoleId.Value);

        if (filterActif.HasValue)
            query = query.Where(u => u.EstActif == filterActif.Value);

        filteredUtilisateurs = query.ToList();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        searchTerm = args.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        filterDepartement = null;
        filterRoleId = null;
        filterActif = null;
        ApplyFilters();
    }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<UtilisateurEditDialog>("Nouvel utilisateur",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });

        if (result is Utilisateur newUser)
        {
            await LoadDataAsync();

            var activiteResult = await DialogService.OpenAsync<UtilisateurActivitesDialog>("Assigner les activités",
                new Dictionary<string, object> { { "Utilisateur", newUser } },
                new DialogOptions { Width = "600px", Height = "auto", Resizable = false, Draggable = true, ShowTitle = false, CssClass = "kcc-dialog-clean" });

            if (activiteResult == true)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Succès",
                    $"Utilisateur '{newUser.NomComplet}' créé et activités assignées");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Info, "Info",
                    $"Utilisateur '{newUser.NomComplet}' créé. Pensez à lui assigner des activités.");
            }
        }
        else if (result == true)
        {
            await LoadDataAsync();
        }
    }

    private async Task ShowEditDialog(Utilisateur user)
    {
        var result = await DialogService.OpenAsync<UtilisateurEditDialog>("Modifier l'utilisateur",
            new Dictionary<string, object> { { "Utilisateur", user } },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });

        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Utilisateur modifié avec succès");
        }
    }

    private async Task ShowRolesDialog(Utilisateur user)
    {
        var result = await DialogService.OpenAsync<UtilisateurRolesDialog>("Gérer les rôles",
            new Dictionary<string, object> { { "Utilisateur", user } },
            new DialogOptions { Width = "540px", Height = "auto", Resizable = false, Draggable = true, ShowTitle = false, CssClass = "kcc-dialog-clean" });

        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Rôles mis à jour avec succès");
        }
    }

    private async Task ShowActivitesDialog(Utilisateur user)
    {
        var result = await DialogService.OpenAsync<UtilisateurActivitesDialog>("Gérer les activités",
            new Dictionary<string, object> { { "Utilisateur", user } },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = false, Draggable = true, ShowTitle = false, CssClass = "kcc-dialog-clean" });

        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Activités mises à jour avec succès");
        }
    }

    private async Task ToggleUserStatus(Utilisateur user)
    {
        var action = user.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} l'utilisateur {user.NomComplet} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });

        if (confirmed == true)
        {
            try
            {
                user.EstActif = !user.EstActif;
                user.DateModification = DateTime.Now;
                await UtilisateurService.UpsertAsync(user);

                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    user.EstActif ? "Activate" : "Deactivate",
                    "Utilisateur",
                    $"Utilisateur {user.NomComplet} {(user.EstActif ? "activé" : "désactivé")}",
                    user.Id.ToString(),
                    "Utilisateur");

                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès", $"Utilisateur {(user.EstActif ? "activé" : "désactivé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }

    private string GetRoleDisplayName(int idRole)
    {
        var role = roles.FirstOrDefault(r => r.Id == idRole);
        return role?.NomRole ?? "—";
    }

    private static string GetRoleBackground(string? roleCode) => roleCode switch
    {
        "ADMIN" => "rgba(220,38,38,0.1)",
        "APPROBATEUR" => "rgba(245,158,11,0.1)",
        "AGENT_SECURITE" => "rgba(59,130,246,0.1)",
        _ => "#f3f4f6"
    };

    private static string GetRoleColor(string? roleCode) => roleCode switch
    {
        "ADMIN" => "#dc2626",
        "APPROBATEUR" => "#d97706",
        "AGENT_SECURITE" => "#2563eb",
        _ => "#374151"
    };

    private static string GetUserInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}";
        return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
    }
}
