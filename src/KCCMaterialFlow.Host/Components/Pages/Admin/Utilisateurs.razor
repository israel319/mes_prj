@page "/admin/utilisateurs"
@attribute [Authorize(Policy = "AdminOrAbove")]
@implements IDisposable
@using KCCMaterialFlow.Domain.Entities
@using KCCMaterialFlow.Domain.Enums
@using KCCMaterialFlow.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<KCCMaterialFlowDbContext> DbFactory
@inject ICurrentUserService CurrentUser
@inject KCCMaterialFlow.Host.Services.UserRoleCacheService RoleCache
@inject KCCMaterialFlow.Host.Services.UserRoleChangeTracker RoleChangeTracker
@inject NotificationService Notif
@inject IJSRuntime JS
@inject IParametreSystemeService ParametreService
@inject DialogService DialogSvc
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Usr_Title"] — @L["Nav_Admin"]</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Usr_Title"] (@totalAvecCompte)</h1>
            </div>
            <div class="kcp-hero-actions">
                @if (IsRealAdmin)
                {
                    <button class="kcp-btn kcp-btn-primary" type="button" @onclick="OuvrirNouvelUtilisateurAsync">
                        <RadzenIcon Icon="person_add" Style="font-size:1rem;" />
                        @L["Usr_BtnNew"]
                    </button>
                }
                <button class="kcp-btn" type="button" @onclick="LoadAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">

    @* === BARRE DE FILTRE === *@
    <RadzenCard Style="padding: 0.75rem 1.25rem; margin-bottom: 1rem;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="0.75rem">
            <RadzenIcon Icon="filter_list" Style="color: var(--kcc-primary); font-size: 1.1rem; flex-shrink: 0;" />
            <RadzenTextBox Value="@searchText" @oninput="OnSearchInput" Placeholder="@L["Usr_SearchPh"].Value"
                           Style="flex: 1; min-width: 220px; border-radius: 0.5rem;" />
            <RadzenDropDown @bind-Value="filterDepartement" Data="@departementOptions" AllowFiltering="true" AllowClear="true"
                           Placeholder="@L["Usr_FilterAllDepts"].Value" Style="min-width: 190px;"
                           Change="@OnDeptFilterChanged" />
            <RadzenDropDown @bind-Value="filterNiveau" Data="@niveauOptions" TextProperty="Text" ValueProperty="Value"
                           Placeholder="@L["Usr_FilterPh"].Value" Style="min-width: 150px;"
                           Change="@OnNiveauFilterChanged" />
        </RadzenStack>
    </RadzenCard>

    <div style="overflow-x: auto;">
    <RadzenCard Style="padding: 0; overflow: hidden; border-radius: 0.75rem;">
    <RadzenDataGrid Data="@rows" TItem="EmployeeAdminRow" AllowPaging="true" PageSize="@pageSize" AllowSorting="true"
                    PageSizeOptions="@pageSizeOptions" ShowPagingSummary="true"
                    AllowFiltering="false" EmptyText="@(loading ? L["Usr_Loading"].Value : L["Usr_Empty"].Value)">
        <Columns>
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Property="EmployeeCode" Title="@L["Imp_ColMatricule"].Value" Width="110px" />
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Property="DisplayName" Title="@L["Imp_ColName"].Value" />
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Property="Departement" Title="@L["Imp_ColDept"].Value" Width="200px" />
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Property="ReportsToDisplay" Title="@L["Usr_ColManager"].Value" Width="220px">
                <Template Context="row">
                    @(row.ReportsToDisplay ?? row.ReportToText ?? "—")
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Property="UserName" Title="@L["Imp_ColLogin"].Value" Width="200px" />
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Title="@L["Col_Status"].Value" Width="100px" TextAlign="TextAlign.Center" Sortable="false">
                <Template Context="row">
                    @if (!string.IsNullOrEmpty(row.UserName))
                    {
                        <RadzenBadge Text="@L["Sta_BadgeActif"].Value" BadgeStyle="BadgeStyle.Success" />
                    }
                    else
                    {
                        <RadzenBadge Text="@L["Sta_BadgeInactif"].Value" BadgeStyle="BadgeStyle.Secondary" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Title="@L["Usr_ColAdminLevel"].Value" Width="190px" Sortable="false">
                <Template Context="row">
                    @if (CanEditNiveau(row))
                    {
                        <RadzenDropDown TValue="NiveauAdmin"
                                        Value="@(row.NiveauAdmin ?? NiveauAdmin.Aucun)"
                                        Data="@AllowedNiveauValues(row)"
                                        Change="@(args => OnNiveauChanged(row, (NiveauAdmin)args!))"
                                        Style="width: 100%;" />
                    }
                    else if (row.NiveauAdmin == NiveauAdmin.SuperAdmin)
                    {
                        <RadzenBadge Text="SuperAdmin" BadgeStyle="BadgeStyle.Danger" />
                    }
                    else if (row.NiveauAdmin == NiveauAdmin.Admin)
                    {
                        <RadzenBadge Text="Admin" BadgeStyle="BadgeStyle.Warning" />
                    }
                    else if (approverCodes.Contains(row.EmployeeCode))
                    {
                        <RadzenBadge Text="@L["Rol_BadgeApprover"].Value" Style="background-color: #00B193; color: #fff;" />
                    }
                    else
                    {
                        <RadzenBadge Text="@L["Rol_BadgeNone"].Value" BadgeStyle="BadgeStyle.Light" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="EmployeeAdminRow" Title="@L["Col_Actions"].Value" Width="180px" Sortable="false">
                <Template Context="row">
                    @if (IsRealAdmin && row.EmployeeId != null
                          && !string.Equals(row.EmployeeCode ?? row.Login, CurrentRealMatricule, StringComparison.OrdinalIgnoreCase))
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem">
                            @if (row.EstActif == true)
                            {
                                <RadzenButton Text="@L["Tt_Disable"].Value" Icon="block" Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined"
                                              Click="@(() => ToggleAccesAsync(row, false))"
                                              title="@L["Usr_TitleRevoke"].Value" />
                            }
                            else
                            {
                                <RadzenButton Text="@L["Tt_Enable"].Value" Icon="check_circle" Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Success" Variant="Variant.Outlined"
                                              Click="@(() => ToggleAccesAsync(row, true))"
                                              title="@L["Usr_TitleGrant"].Value" />
                            }
                            @if (row.IsStandalone && IsRealSuperAdmin)
                            {
                                <RadzenButton Icon="delete" Size="ButtonSize.Small"
                                              ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text"
                                              Click="@(() => SupprimerAsync(row))"
                                              title="@L["Usr_TitleDelete"].Value" />
                            }
                        </RadzenStack>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
    </RadzenCard>
    </div>
    </main>
</div>

@code {
    private List<EmployeeAdminRow> rows = new();
    private HashSet<string> approverCodes = new(StringComparer.OrdinalIgnoreCase);
    private string searchText = "";
    private string? filterNiveau = "AvecCompte";
    private string? filterDepartement;
    private List<string> departementOptions = new();
    private int totalAvecCompte;
    private bool loading = true;
    private System.Threading.CancellationTokenSource? _searchCts;
    private bool _disposed;
    private string? CurrentRealMatricule;
    private bool IsRealSuperAdmin;
    private bool IsRealAdmin;
    private int pageSize = 25;
    private IEnumerable<int> pageSizeOptions = new[] { 10, 25, 50, 100, 200 };

    private record FilterOption(string Text, string? Value);
    private readonly List<FilterOption> niveauOptions = new()
    {
        new("Avec compte Windows", "AvecCompte"),
        new("Tous", null),
        new("Aucun", "Aucun"),
        new("Admin", "Admin"),
        new("SuperAdmin", "SuperAdmin"),
        new("Approbateurs", "Approbateur"),
        new("Sans compte Windows", "SansCompte")
    };

    private NiveauAdmin[] AllowedNiveauValues(EmployeeAdminRow row)
    {
        if (IsRealSuperAdmin)
            return new[] { NiveauAdmin.Aucun, NiveauAdmin.Admin, NiveauAdmin.SuperAdmin };
        return new[] { NiveauAdmin.Aucun, NiveauAdmin.Admin };
    }

    private bool CanEditNiveau(EmployeeAdminRow row)
    {
        if (!IsRealAdmin) return false;
        if (!string.IsNullOrEmpty(row.EmployeeCode)
            && string.Equals(row.EmployeeCode, CurrentRealMatricule, StringComparison.OrdinalIgnoreCase))
            return false;
        if (!IsRealSuperAdmin && row.NiveauAdmin == NiveauAdmin.SuperAdmin)
            return false;
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        var info = CurrentUser.GetCurrentUser();
        CurrentRealMatricule = info?.Matricule;
        IsRealSuperAdmin = info?.NiveauAdmin == NiveauAdmin.SuperAdmin;
        IsRealAdmin = info?.NiveauAdmin is NiveauAdmin.Admin or NiveauAdmin.SuperAdmin;

        try
        {
            var v = await ParametreService.GetIntValueAsync("UI_ITEMS_PAR_PAGE", 25);
            if (v > 0) pageSize = v;
        }
        catch { /* fallback 25 */ }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            // ---- Glencore query (filtres DB) ----
            var glQuery = ctx.AllEmployees.AsNoTracking().AsQueryable();

            // Filtre département
            if (!string.IsNullOrWhiteSpace(filterDepartement))
                glQuery = glQuery.Where(g => g.Departement == filterDepartement);

            // Filtre niveau via le filtre "AvecCompte" / "SansCompte"
            if (filterNiveau == "AvecCompte")
                glQuery = glQuery.Where(g => g.UserName != null && g.UserName != "");
            else if (filterNiveau == "SansCompte")
                glQuery = glQuery.Where(g => g.UserName == null || g.UserName == "");

            // Filtre texte (matricule, nom, login)
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var s = searchText.Trim().ToLower();
                glQuery = glQuery.Where(g =>
                    (g.EmployeeCode != null && g.EmployeeCode.ToLower().Contains(s)) ||
                    (g.FirstName    != null && g.FirstName.ToLower().Contains(s))    ||
                    (g.LastName     != null && g.LastName.ToLower().Contains(s))     ||
                    (g.UserName     != null && g.UserName.ToLower().Contains(s))     ||
                    (g.Mail         != null && g.Mail.ToLower().Contains(s)));
            }

            glQuery = glQuery.OrderBy(g => g.LastName).ThenBy(g => g.FirstName);

            // Compteur "avec compte" (indépendant des filtres texte/dept)
            totalAvecCompte = await ctx.AllEmployees.CountAsync(g => g.UserName != null && g.UserName != "");

            var glencore = await glQuery.Take(200).ToListAsync();

            var codes = glencore.Select(g => g.EmployeeCode).Where(c => !string.IsNullOrEmpty(c)).Distinct().ToList();
            var employees = codes.Any()
                ? await ctx.Employees.AsNoTracking()
                    .Where(e => e.Matricule != null && codes.Contains(e.Matricule))
                    .ToDictionaryAsync(e => e.Matricule!, e => e, StringComparer.OrdinalIgnoreCase)
                : new Dictionary<string, Employee>(StringComparer.OrdinalIgnoreCase);

            // AppUsers indexés par EmployeeId pour rcup NiveauAdmin / EstActif / Login
            var empIds = employees.Values.Select(e => e.Id).ToList();
            var appUsers = empIds.Any()
                ? await ctx.AppUsers.AsNoTracking()
                    .Where(u => u.EmployeeId != null && empIds.Contains(u.EmployeeId!.Value))
                    .ToListAsync()
                : new List<AppUser>();
            var appUserByEmpId = appUsers
                .GroupBy(u => u.EmployeeId!.Value)
                .ToDictionary(g => g.Key, g => g.First());

            // Approbateurs = codes référencés comme ReportsTo
            approverCodes = new HashSet<string>(
                glencore.Where(g => !string.IsNullOrWhiteSpace(g.ReportsToEmployeeCode))
                        .Select(g => g.ReportsToEmployeeCode!)
                        .Distinct(),
                StringComparer.OrdinalIgnoreCase);

            rows = glencore.Select(g =>
            {
                employees.TryGetValue(g.EmployeeCode, out var emp);
                AppUser? appUser = null;
                if (emp != null) appUserByEmpId.TryGetValue(emp.Id, out appUser);
                var display = $"{g.FirstName} {g.LastName}".Trim();
                if (string.IsNullOrWhiteSpace(display)) display = g.EmployeeCode;
                return new EmployeeAdminRow
                {
                    EmployeeCode    = g.EmployeeCode,
                    DisplayName     = display,
                    Departement     = g.Departement,
                    ReportsToDisplay = g.ManagerHodEmployeeDisplay,
                    UserName        = g.UserName,
                    Email           = g.Mail,
                    FirstName       = g.FirstName,
                    LastName        = g.LastName,
                    EmployeeId      = emp?.Id,
                    Login           = appUser?.Login,
                    NiveauAdmin     = appUser?.NiveauAdmin,
                    EstActif        = appUser?.EstActif
                };
            }).ToList();

            // ---- Utilisateurs standalone (non liés au RH) ----
            // On les inclut uniquement si le filtre Niveau n'exclut pas les "AvecCompte"
            if (filterNiveau != "SansCompte")
            {
                var glCodes = new HashSet<string>(codes, StringComparer.OrdinalIgnoreCase);
                var saQuery = ctx.Employees.AsNoTracking()
                    .Where(e => e.Matricule == null || !glCodes.Contains(e.Matricule));

                if (!string.IsNullOrWhiteSpace(searchText))
                {
                    var s = searchText.Trim().ToLower();
                    // Logins matching searchText (T_Users)
                    var matchingEmpIds = await ctx.AppUsers.AsNoTracking()
                        .Where(u => u.EmployeeId != null && u.Login.ToLower().Contains(s))
                        .Select(u => u.EmployeeId!.Value)
                        .ToListAsync();
                    saQuery = saQuery.Where(e =>
                        (e.Matricule    != null && e.Matricule.ToLower().Contains(s))  ||
                        (e.NomComplet   != null && e.NomComplet.ToLower().Contains(s)) ||
                        (e.Email        != null && e.Email.ToLower().Contains(s))      ||
                        matchingEmpIds.Contains(e.Id));
                }
                if (!string.IsNullOrWhiteSpace(filterDepartement))
                    saQuery = saQuery.Where(e => e.DepartementNom == filterDepartement);

                var standalone = await saQuery.Take(100).ToListAsync();
                var standaloneIds = standalone.Select(e => e.Id).ToList();
                var standaloneAppUsers = standaloneIds.Any()
                    ? await ctx.AppUsers.AsNoTracking()
                        .Where(u => u.EmployeeId != null && standaloneIds.Contains(u.EmployeeId!.Value))
                        .ToListAsync()
                    : new List<AppUser>();
                var standaloneAuByEmp = standaloneAppUsers
                    .GroupBy(u => u.EmployeeId!.Value)
                    .ToDictionary(g => g.Key, g => g.First());

                foreach (var emp in standalone)
                {
                    standaloneAuByEmp.TryGetValue(emp.Id, out var au);
                    var display = emp.DisplayName ?? emp.NomComplet ?? au?.Login ?? "—";
                    rows.Add(new EmployeeAdminRow
                    {
                        EmployeeCode    = emp.Matricule ?? "",
                        DisplayName     = display,
                        Departement     = emp.DepartementNom,
                        ReportToText    = emp.ReportToText,
                        UserName        = au?.Login,
                        Email           = emp.Email,
                        FirstName       = emp.Prenom,
                        LastName        = emp.Nom,
                        Login           = au?.Login,
                        EmployeeId      = emp.Id,
                        NiveauAdmin     = au?.NiveauAdmin,
                        EstActif        = au?.EstActif,
                        IsStandalone    = true
                    });
                }
            }

            // Filtres niveau Admin/SuperAdmin/Approbateur (post-join car ces données sont côté Employee)
            if (filterNiveau == "Admin")
                rows = rows.Where(r => r.NiveauAdmin == NiveauAdmin.Admin).ToList();
            else if (filterNiveau == "SuperAdmin")
                rows = rows.Where(r => r.NiveauAdmin == NiveauAdmin.SuperAdmin).ToList();
            else if (filterNiveau == "Approbateur")
                rows = rows.Where(r => approverCodes.Contains(r.EmployeeCode)).ToList();

            // Mise à jour de la liste des départements (lazy : seulement si vide)
            if (!departementOptions.Any())
            {
                departementOptions = await ctx.AllEmployees.AsNoTracking()
                    .Where(g => g.Departement != null)
                    .Select(g => g.Departement!)
                    .Distinct()
                    .OrderBy(d => d)
                    .ToListAsync();
            }
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;
        try
        {
            await Task.Delay(350, token);
            if (!token.IsCancellationRequested && !_disposed)
                await LoadAsync();
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnDeptFilterChanged(object? value)
    {
        filterDepartement = value as string;
        await LoadAsync();
    }

    private async Task OnNiveauFilterChanged(object? value)
    {
        filterNiveau = value as string;
        await LoadAsync();
    }

    private async Task OnNiveauChanged(EmployeeAdminRow row, NiveauAdmin newValue)
    {
        if (!IsRealSuperAdmin && (newValue == NiveauAdmin.SuperAdmin || row.NiveauAdmin == NiveauAdmin.SuperAdmin))
        {
            Notif.Notify(NotificationSeverity.Warning, "Action refusée",
                "Seul un SuperAdmin peut gérer le niveau SuperAdmin.");
            return;
        }
        if (!string.IsNullOrEmpty(row.EmployeeCode)
            && string.Equals(row.EmployeeCode, CurrentRealMatricule, StringComparison.OrdinalIgnoreCase))
        {
            Notif.Notify(NotificationSeverity.Warning, "Action refusée",
                "Vous ne pouvez pas modifier votre propre niveau.");
            return;
        }

        var previous = row.NiveauAdmin;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            // 1) Charger / créer l'Employee local depuis le référentiel Glencore
            Employee? dbEmp = null;
            if (row.EmployeeId.HasValue)
            {
                dbEmp = await ctx.Employees.FirstOrDefaultAsync(e => e.Id == row.EmployeeId.Value);
            }
            if (dbEmp == null && !string.IsNullOrWhiteSpace(row.EmployeeCode))
            {
                dbEmp = await ctx.Employees.FirstOrDefaultAsync(e => e.Matricule == row.EmployeeCode);
            }

            if (dbEmp == null)
            {
                // Provisionner depuis Glencore
                var glencore = await ctx.AllEmployees.AsNoTracking()
                    .FirstOrDefaultAsync(g => g.EmployeeCode == row.EmployeeCode);
                if (glencore == null)
                {
                    Notif.Notify(NotificationSeverity.Error, "Erreur",
                        $"Employé introuvable pour le code {row.EmployeeCode}.");
                    return;
                }

                var displayName = $"{glencore.FirstName} {glencore.LastName}".Trim();
                if (string.IsNullOrWhiteSpace(displayName)) displayName = glencore.EmployeeCode;

                dbEmp = new Employee
                {
                    Matricule = glencore.EmployeeCode,
                    NomComplet = displayName,
                    DisplayName = displayName,
                    Prenom = glencore.FirstName,
                    Nom = glencore.LastName,
                    Email = glencore.Mail,
                    DepartementNom = glencore.Departement,
                    EstInterne = true,
                    DateCreation = DateTime.Now
                };
                ctx.Employees.Add(dbEmp);
                await ctx.SaveChangesAsync();
                row.EmployeeId = dbEmp.Id;
            }

            // 2) Mettre à jour le niveau admin via AppUser (upsert)
            var appUser = await ctx.AppUsers.FirstOrDefaultAsync(u => u.EmployeeId == dbEmp.Id);
            if (appUser == null)
            {
                var loginValue = !string.IsNullOrWhiteSpace(row.Login) ? row.Login
                                : !string.IsNullOrWhiteSpace(row.UserName) ? row.UserName
                                : dbEmp.Matricule ?? row.EmployeeCode;
                appUser = new AppUser
                {
                    Login = loginValue!,
                    EmployeeId = dbEmp.Id,
                    NiveauAdmin = newValue,
                    EstActif = true,
                    DateCreation = DateTime.Now
                };
                ctx.AppUsers.Add(appUser);
                row.EstActif = true;
            }
            else
            {
                appUser.NiveauAdmin = newValue;
            }
            await ctx.SaveChangesAsync();

            row.NiveauAdmin = newValue;
            if (!string.IsNullOrWhiteSpace(row.EmployeeCode))
            {
                RoleCache.InvalidateUser(row.EmployeeCode);
                RoleChangeTracker.MarkChanged(row.EmployeeCode);
            }
            if (!string.IsNullOrWhiteSpace(row.Login) && row.Login != row.EmployeeCode)
            {
                RoleCache.InvalidateUser(row.Login);
                RoleChangeTracker.MarkChanged(KCCMaterialFlow.Host.Services.UserRoleCacheService.ExtractMatricule(row.Login));
            }

            Notif.Notify(NotificationSeverity.Success, "Niveau admin mis à jour",
                $"{row.DisplayName} → {newValue}");
        }
        catch (Exception ex)
        {
            row.NiveauAdmin = previous;
            Notif.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
    }

    private async Task ToggleAccesAsync(EmployeeAdminRow row, bool activer)
    {
        var previous = row.EstActif;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            if (row.EmployeeId is null) return;
            var appUser = await ctx.AppUsers.FirstOrDefaultAsync(u => u.EmployeeId == row.EmployeeId.Value);
            if (appUser == null)
            {
                Notif.Notify(NotificationSeverity.Warning, "Action impossible",
                    "Aucun compte applicatif (AppUser) pour cet employ. Affectez-lui d'abord un niveau d'accs.");
                return;
            }

            appUser.EstActif = activer;
            await ctx.SaveChangesAsync();
            row.EstActif = activer;

            if (!string.IsNullOrWhiteSpace(row.EmployeeCode))
            {
                RoleCache.InvalidateUser(row.EmployeeCode);
                RoleChangeTracker.MarkChanged(row.EmployeeCode);
            }
            if (!string.IsNullOrWhiteSpace(row.Login) && row.Login != row.EmployeeCode)
            {
                RoleCache.InvalidateUser(row.Login);
                RoleChangeTracker.MarkChanged(KCCMaterialFlow.Host.Services.UserRoleCacheService.ExtractMatricule(row.Login));
            }

            Notif.Notify(NotificationSeverity.Success,
                activer ? "Accès activé" : "Accès désactivé",
                $"{row.DisplayName} — accès {(activer ? "accordé" : "retiré")}.");
        }
        catch (Exception ex)
        {
            row.EstActif = previous;
            Notif.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
    }

    private async Task SupprimerAsync(EmployeeAdminRow row)
    {
        if (row.EmployeeId is null) return;

        var confirm = await DialogSvc.Confirm(
            $"Supprimer définitivement l'utilisateur <strong>{row.DisplayName}</strong> ({row.Login}) ?",
            "Confirmer la suppression",
            new ConfirmOptions { OkButtonText = "Supprimer", CancelButtonText = "Annuler" });
        if (confirm != true) return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            // Vérifier dépendances bloquantes
            var isApprobateurSpecial = await ctx.WorkflowApprobateursSpeciaux
                .AnyAsync(x => x.EmployeeId == row.EmployeeId.Value);
            if (isApprobateurSpecial)
            {
                Notif.Notify(NotificationSeverity.Warning, "Suppression impossible",
                    $"{row.DisplayName} est configuré comme approbateur spécial. Retirez-le d'abord dans la page Workflow.");
                return;
            }

            var emp = await ctx.Employees.FirstOrDefaultAsync(e => e.Id == row.EmployeeId.Value);
            if (emp == null) return;

            // Nullifier les références self-FK avant suppression
            await ctx.Employees
                .Where(e => e.ReportToEmployeeId == row.EmployeeId.Value)
                .ExecuteUpdateAsync(s => s.SetProperty(e => e.ReportToEmployeeId, (int?)null));

            ctx.Employees.Remove(emp);
            await ctx.SaveChangesAsync();

            rows.Remove(row);
            RoleCache.InvalidateUser(row.Login ?? row.EmployeeCode);
            Notif.Notify(NotificationSeverity.Success, "Utilisateur supprimé", $"{row.DisplayName} a été supprimé.");
        }
        catch (Exception ex)
        {
            Notif.Notify(NotificationSeverity.Error, "Erreur lors de la suppression", ex.Message);
        }
    }

    private async Task OuvrirNouvelUtilisateurAsync()
    {
        var result = await DialogSvc.OpenAsync<KCCMaterialFlow.Host.Components.Dialogs.NouvelUtilisateurDialog>(
            "Nouvel utilisateur",
            new Dictionary<string, object>
            {
                { "IsSuperAdmin", IsRealSuperAdmin }
            },
            new DialogOptions { Width = "520px", CloseDialogOnOverlayClick = false });

        if (result is int)
        {
            Notif.Notify(NotificationSeverity.Success, "Utilisateur créé", "Le nouvel utilisateur a été créé.");
            await LoadAsync();
        }
    }

    public void Dispose()
    {
        _disposed = true;
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }

    private sealed class EmployeeAdminRow
    {
        public string EmployeeCode { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string? Departement { get; set; }
        public string? ReportsToDisplay { get; set; }
        public string? ReportToText { get; set; }
        public string? UserName { get; set; }
