@page "/admin/departements"
@attribute [Authorize(Roles = "Admin")]
@using KCCMaterialFlow.Module.Shared.Entities
@using KCCMaterialFlow.Module.Shared.Services
@using Microsoft.AspNetCore.Authorization
@inject IDepartementService DepartementService
@inject IUtilisateurService UtilisateurService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Administration - Départements</PageTitle>

<div style="padding: 1.5rem;">
    <RadzenStack Gap="1.5rem">
        @* En-tête *@
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn>
                <RadzenBreadCrumb>
                    <RadzenBreadCrumbItem Path="/" Text="Accueil" Icon="home" />
                    <RadzenBreadCrumbItem Text="Administration" Icon="settings" />
                    <RadzenBreadCrumbItem Text="Départements" Icon="business" />
                </RadzenBreadCrumb>
                <RadzenText TextStyle="TextStyle.H5" FontWeight="FontWeight.Bold" class="rz-mt-2">
                    <RadzenIcon Icon="business" Style="margin-right: 0.5rem; vertical-align: middle;" />
                    Gestion des Départements
                </RadzenText>
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                    <RadzenButton Text="Actualiser" Icon="refresh" ButtonStyle="ButtonStyle.Light" 
                                  Click="@LoadDataAsync" />
                    <RadzenButton Text="Nouveau département" Icon="add_business" ButtonStyle="ButtonStyle.Primary"
                                  Click="@ShowCreateDialog" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @* Filtres *@
        <RadzenCard Variant="Variant.Flat" Style="padding: 1rem;">
            <RadzenRow Gap="1rem" AlignItems="AlignItems.End">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Rechercher" Style="width: 100%;">
                        <RadzenTextBox @bind-Value="@searchTerm" Placeholder="Code, nom, responsable..." 
                                       Style="width: 100%;" @oninput="@OnSearchChanged" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenFormField Text="Statut" Style="width: 100%;">
                        <RadzenDropDown TValue="bool?" Data="@statutOptions" @bind-Value="@filterActif"
                                        TextProperty="Text" ValueProperty="Value"
                                        AllowClear="true" Placeholder="Tous" Style="width: 100%;"
                                        Change="@(args => ApplyFilters())" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenButton Text="Réinitialiser" Icon="clear" ButtonStyle="ButtonStyle.Light" 
                                  Click="@ResetFilters" Style="width: 100%;" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>

        @* Grille des départements *@
        <RadzenCard Variant="Variant.Flat">
            <RadzenDataGrid @ref="grid" Data="@filteredDepartements" TItem="Departement" 
                            AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="15"
                            PagerHorizontalAlign="HorizontalAlign.Center"
                            Style="border: none;">
                <Columns>
                    <RadzenDataGridColumn TItem="Departement" Property="CodeDepartement" Title="Code" Width="100px">
                        <Template Context="dept">
                            <RadzenBadge Text="@dept.CodeDepartement" BadgeStyle="BadgeStyle.Primary" IsPill="true" />
                        </Template>
                    </RadzenDataGridColumn>
                    
                    <RadzenDataGridColumn TItem="Departement" Property="NomDepartement" Title="Nom" Width="250px" />
                    
                    <RadzenDataGridColumn TItem="Departement" Property="Description" Title="Description">
                        <Template Context="dept">
                            @(dept.Description ?? "-")
                        </Template>
                    </RadzenDataGridColumn>
                    
                    <RadzenDataGridColumn TItem="Departement" Property="ResponsableNom" Title="Responsable" Width="200px">
                        <Template Context="dept">
                            <RadzenStack Gap="0">
                                <RadzenText TextStyle="TextStyle.Body2" FontWeight="FontWeight.SemiBold">
                                    @(dept.ResponsableNom ?? "-")
                                </RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: #666;">
                                    @dept.ResponsableLogin
                                </RadzenText>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                    
                    <RadzenDataGridColumn TItem="Departement" Property="ResponsableEmail" Title="Email responsable" Width="200px">
                        <Template Context="dept">
                            @if (!string.IsNullOrEmpty(dept.ResponsableEmail))
                            {
                                <a href="mailto:@dept.ResponsableEmail" style="color: #0066cc;">@dept.ResponsableEmail</a>
                            }
                            else
                            {
                                <span style="color: #999;">-</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    
                    <RadzenDataGridColumn TItem="Departement" Property="EstActif" Title="Statut" Width="100px" TextAlign="TextAlign.Center">
                        <Template Context="dept">
                            @if (dept.EstActif)
                            {
                                <RadzenBadge Text="Actif" BadgeStyle="BadgeStyle.Success" IsPill="true" />
                            }
                            else
                            {
                                <RadzenBadge Text="Inactif" BadgeStyle="BadgeStyle.Danger" IsPill="true" />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    
                    <RadzenDataGridColumn TItem="Departement" Title="Actions" Width="120px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="dept">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                              Click="@(() => ShowEditDialog(dept))" title="Modifier" />
                                @if (dept.EstActif)
                                {
                                    <RadzenButton Icon="block" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                                  Click="@(() => ToggleStatus(dept))" title="Désactiver" />
                                }
                                else
                                {
                                    <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                                  Click="@(() => ToggleStatus(dept))" title="Activer" />
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenStack>
</div>

@code {
    private RadzenDataGrid<Departement>? grid;
    private List<Departement> departements = [];
    private List<Departement> filteredDepartements = [];
    
    private string searchTerm = string.Empty;
    private bool? filterActif;
    
    private readonly List<object> statutOptions = 
    [
        new { Text = "Actif", Value = true },
        new { Text = "Inactif", Value = false }
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            departements = (await DepartementService.GetAllAsync()).ToList();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private void ApplyFilters()
    {
        var query = departements.AsEnumerable();
        
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.ToUpperInvariant();
            query = query.Where(d => 
                d.CodeDepartement.ToUpperInvariant().Contains(term) ||
                d.NomDepartement.ToUpperInvariant().Contains(term) ||
                (d.ResponsableNom?.ToUpperInvariant().Contains(term) ?? false) ||
                d.ResponsableLogin.ToUpperInvariant().Contains(term));
        }
        
        if (filterActif.HasValue)
        {
            query = query.Where(d => d.EstActif == filterActif.Value);
        }
        
        filteredDepartements = query.ToList();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        searchTerm = args.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    private void ResetFilters()
    {
        searchTerm = string.Empty;
        filterActif = null;
        ApplyFilters();
    }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<DepartementEditDialog>("Nouveau département",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Département créé avec succès");
        }
    }

    private async Task ShowEditDialog(Departement dept)
    {
        var result = await DialogService.OpenAsync<DepartementEditDialog>("Modifier le département",
            new Dictionary<string, object> { { "Departement", dept } },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Département modifié avec succès");
        }
    }

    private async Task ToggleStatus(Departement dept)
    {
        var action = dept.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} le département {dept.NomDepartement} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });
        
        if (confirmed == true)
        {
            try
            {
                dept.EstActif = !dept.EstActif;
                dept.DateModification = DateTime.Now;
                await DepartementService.UpdateAsync(dept);
                
                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    dept.EstActif ? "Activate" : "Deactivate",
                    "Departement",
                    $"Département {dept.NomDepartement} {(dept.EstActif ? "activé" : "désactivé")}",
                    dept.IdDepartement.ToString(),
                    "Departement");
                
                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès", 
                    $"Département {(dept.EstActif ? "activé" : "désactivé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }
}
