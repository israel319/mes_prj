@page "/admin/statuts"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IStatutService StatutService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

<PageTitle>Administration - Statuts</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Sta_Title"]</h1>
                <p class="kcp-subtitle">@filteredStatuts.Count @L["Sta_Count"] @statuts.Count</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn kcp-btn-primary" type="button" @onclick="ShowCreateDialog">
                    <RadzenIcon Icon="add_circle" Style="font-size:1rem;" />
                    @L["Sta_BtnNew"]
                </button>
                <button class="kcp-btn" type="button" @onclick="LoadDataAsync">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">


    @if (!string.IsNullOrEmpty(activeFilter))
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter"
                     AllowClose="true" Close="@(() => SetFilter(null))" class="rz-mb-4">
            @L["Lbl_ActiveFilter"] <strong>@(activeFilter switch { "active" => L["Sta_FilterActifs"].Value, "system" => L["Sta_FilterSystem"].Value, "final" => L["Sta_FilterFinal"].Value, _ => "" })</strong>
        </RadzenAlert>
    }

    @* === RECHERCHE === *@
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" class="rz-mb-4">
        <RadzenIcon Icon="search" Style="color: var(--gray-400);" />
        <RadzenTextBox @bind-Value="searchTerm" Placeholder="@L["Sta_SearchPh"].Value"
                       Style="flex: 1; min-width: 220px;" Change="@(_ => StateHasChanged())" />
        <RadzenDropDown TValue="string" Data="@typesBon" @bind-Value="filterTypeBon"
                        AllowClear="true" Placeholder="@L["Sta_FilterAllTypes"].Value" Style="min-width: 180px;"
                        Change="@(_ => StateHasChanged())" />
        @if (!string.IsNullOrWhiteSpace(searchTerm) || !string.IsNullOrEmpty(filterTypeBon))
        {
            <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ResetFilters" />
        }
    </RadzenStack>

    @* === GRID === *@
    <RadzenDataGrid @ref="grid" Data="@filteredStatuts" TItem="Statut"
                    AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="10"
                    PagerHorizontalAlign="HorizontalAlign.Center"
                    Density="Density.Compact"
                    GridLines="DataGridGridLines.Horizontal"
                    EmptyText="@L["Sta_Empty"].Value">
        <Columns>
            <RadzenDataGridColumn TItem="Statut" Property="Ordre" Title="@L["Sta_ColNum"].Value" Width="60px" TextAlign="TextAlign.Center" Sortable="true" />
            <RadzenDataGridColumn TItem="Statut" Property="CodeStatut" Title="@L["Sta_ColStatut"].Value" Width="220px" Sortable="true">
                <Template Context="statut">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <div style="width: 32px; height: 32px; background: @statut.CouleurFond; border-radius: 8px;
                                    display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            @if (!string.IsNullOrEmpty(statut.Icone))
                            {
                                <i class="@statut.Icone" style="color: @statut.CouleurTexte; font-size: 14px;"></i>
                            }
                        </div>
                        <div>
                            <div style="font-weight: 600; font-size: 0.85rem;">@statut.LibelleStatut</div>
                            <div style="font-size: 0.75rem; color: var(--gray-500); font-family: monospace;">@statut.CodeStatut</div>
                        </div>
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Statut" Property="TypeBon" Title="@L["Sta_ColTypeBon"].Value" Width="130px" Sortable="true">
                <Template Context="statut">
                    <RadzenBadge Text="@statut.TypeBon" BadgeStyle="BadgeStyle.Light" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Statut" Property="Description" Title="@L["Sta_ColDescription"].Value">
                <Template Context="statut">
                    <span style="font-size: 0.85rem; color: var(--gray-600);">@(statut.Description ?? "—")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Statut" Title="@L["Sta_ColProprietes"].Value" Width="200px" Sortable="false">
                <Template Context="statut">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" Wrap="FlexWrap.Wrap">
                        @if (statut.EstSysteme)
                        {
                            <RadzenBadge Text="@L["Sta_BadgeSystem"].Value" BadgeStyle="BadgeStyle.Info" />
                        }
                        @if (statut.EstFinal)
                        {
                            <RadzenBadge Text="@L["Sta_BadgeFinal"].Value" BadgeStyle="BadgeStyle.Light" />
                        }
                        @if (statut.RequiertAction)
                        {
                            <RadzenBadge Text="@L["Sta_BadgeActionReq"].Value" BadgeStyle="BadgeStyle.Warning" />
                        }
                        @if (!statut.EstSysteme && !statut.EstFinal && !statut.RequiertAction)
                        {
                            <span style="color: #999;">—</span>
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Statut" Property="EstActif" Title="@L["Col_Actions"].Value" Width="100px" TextAlign="TextAlign.Center" Sortable="true">
                <Template Context="statut">
                    @if (statut.EstActif)
                    {
                        <RadzenBadge Text="@L["Sta_BadgeActif"].Value" BadgeStyle="BadgeStyle.Success" />
                    }
                    else
                    {
                        <RadzenBadge Text="@L["Sta_BadgeInactif"].Value" BadgeStyle="BadgeStyle.Light" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Statut" Title="@L["Col_Actions"].Value" Width="140px" TextAlign="TextAlign.Right" Sortable="false">
                <Template Context="statut">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.4rem" JustifyContent="JustifyContent.End">
                        <RadzenButton Icon="edit" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Dark" Click="@(() => ShowEditDialog(statut))" title="@L["Tt_Edit"].Value" />
                        @if (!statut.EstSysteme)
                        {
                            <RadzenButton Icon="@(statut.EstActif ? "block" : "check_circle")" Variant="Variant.Outlined" Size="ButtonSize.Small"
                                          ButtonStyle="@(statut.EstActif ? ButtonStyle.Warning : ButtonStyle.Success)"
                                          Click="@(() => ToggleStatus(statut))" title="@(statut.EstActif ? L["Tt_Disable"].Value : L["Tt_Enable"].Value)" />
                        }
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
    </main>
</div>

@code {
    private RadzenDataGrid<Statut>? grid;
    private List<Statut> statuts = [];

    private string? searchTerm;
    private string? filterTypeBon;
    private string? activeFilter;

    private readonly List<string> typesBon = ["BonEntree", "BonSortie"];

    private List<Statut> filteredStatuts
    {
        get
        {
            IEnumerable<Statut> q = statuts;
            if (activeFilter == "active") q = q.Where(s => s.EstActif);
            else if (activeFilter == "system") q = q.Where(s => s.EstSysteme);
            else if (activeFilter == "final") q = q.Where(s => s.EstFinal);
            if (!string.IsNullOrWhiteSpace(filterTypeBon))
                q = q.Where(s => s.TypeBon == filterTypeBon);
            if (!string.IsNullOrWhiteSpace(searchTerm))
            {
                var s = searchTerm.Trim();
                q = q.Where(x =>
                    x.CodeStatut.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    x.LibelleStatut.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    (x.Description ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q.OrderBy(s => s.Ordre).ToList();
        }
    }

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        try
        {
            statuts = (await StatutService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private void SetFilter(string? f) { activeFilter = f; StateHasChanged(); }
    private void ResetFilters() { searchTerm = null; filterTypeBon = null; StateHasChanged(); }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<StatutEditDialog>("Nouveau statut",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Statut créé avec succès");
        }
    }

    private async Task ShowEditDialog(Statut statut)
    {
        var result = await DialogService.OpenAsync<StatutEditDialog>("Modifier le statut",
            new Dictionary<string, object> { { "Statut", statut } },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Statut modifié avec succès");
        }
    }

    private async Task ToggleStatus(Statut statut)
    {
        if (statut.EstSysteme)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Information", "Les statuts système ne peuvent pas être modifiés");
            return;
        }
        var action = statut.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} le statut {statut.LibelleStatut} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });

        if (confirmed == true)
        {
            try
            {
                await StatutService.DeleteAsync(statut.Id);
                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    statut.EstActif ? "Deactivate" : "Activate",
                    "Statut",
                    $"Statut {statut.LibelleStatut} {(statut.EstActif ? "désactivé" : "activé")}",
                    statut.Id.ToString(),
                    "Statut");
                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès",
                    $"Statut {(statut.EstActif ? "désactivé" : "activé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }
}
