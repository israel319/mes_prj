@page "/admin/parametres"
@attribute [Authorize(Roles = "Admin")]
@using KCCMaterialFlow.Module.Shared.Entities
@using KCCMaterialFlow.Module.Shared.Services
@using Microsoft.AspNetCore.Authorization
@inject IParametreSystemeService ParametreService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Administration - Paramètres Système</PageTitle>

<div style="padding: 1.5rem;">
    <RadzenStack Gap="1.5rem">
        @* En-tête *@
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn>
                <RadzenBreadCrumb>
                    <RadzenBreadCrumbItem Path="/" Text="Accueil" Icon="home" />
                    <RadzenBreadCrumbItem Text="Administration" Icon="settings" />
                    <RadzenBreadCrumbItem Text="Paramètres" Icon="tune" />
                </RadzenBreadCrumb>
                <RadzenText TextStyle="TextStyle.H5" FontWeight="FontWeight.Bold" class="rz-mt-2">
                    <RadzenIcon Icon="tune" Style="margin-right: 0.5rem; vertical-align: middle;" />
                    Paramètres Système
                </RadzenText>
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                    <RadzenButton Text="Actualiser" Icon="refresh" ButtonStyle="ButtonStyle.Light" 
                                  Click="@LoadDataAsync" />
                    <RadzenButton Text="Nouveau paramètre" Icon="add" ButtonStyle="ButtonStyle.Primary"
                                  Click="@ShowCreateDialog" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @* Paramètres par catégorie *@
        @foreach (var category in GetCategoriesWithParametres())
        {
            <RadzenCard Variant="Variant.Flat">
                <RadzenText TextStyle="TextStyle.H6" FontWeight="FontWeight.SemiBold" class="rz-mb-4">
                    <RadzenIcon Icon="@GetCategoryIcon(category.Key)" Style="margin-right: 0.5rem; vertical-align: middle;" />
                    @category.Key
                </RadzenText>
                
                <RadzenDataGrid Data="@category.Value" TItem="ParametreSysteme" 
                                AllowFiltering="false" AllowSorting="false" AllowPaging="false"
                                Style="border: none;">
                    <Columns>
                        <RadzenDataGridColumn TItem="ParametreSysteme" Property="Cle" Title="Clé" Width="250px">
                            <Template Context="param">
                                <RadzenStack Gap="0">
                                    <RadzenText TextStyle="TextStyle.Body1" FontWeight="FontWeight.SemiBold">
                                        @param.Cle
                                    </RadzenText>
                                    @if (param.EstSysteme)
                                    {
                                        <RadzenBadge Text="Système" BadgeStyle="BadgeStyle.Secondary" IsPill="true" Style="font-size: 0.6rem;" />
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="ParametreSysteme" Property="Description" Title="Description" />
                        
                        <RadzenDataGridColumn TItem="ParametreSysteme" Title="Valeur" Width="200px">
                            <Template Context="param">
                                @switch (param.TypeDonnee)
                                {
                                    case "Boolean":
                                        <RadzenSwitch TValue="bool" Value="@(param.Valeur?.ToLower() == "true")" 
                                                     Disabled="@(!param.EstModifiable)"
                                                     Change="@(value => UpdateBooleanValue(param, value))" />
                                        break;
                                    case "Integer":
                                        <RadzenNumeric TValue="int" Value="@(int.TryParse(param.Valeur, out var intVal) ? intVal : 0)"
                                                       Disabled="@(!param.EstModifiable)"
                                                       Min="@(param.ValeurMin ?? int.MinValue)"
                                                       Max="@(param.ValeurMax ?? int.MaxValue)"
                                                       Change="@(value => UpdateIntegerValue(param, value))"
                                                       Style="width: 100%;" />
                                        break;
                                    default:
                                        <RadzenTextBox Value="@param.Valeur" 
                                                       Disabled="@(!param.EstModifiable)"
                                                       Change="@(value => UpdateStringValue(param, value))"
                                                       Style="width: 100%;" />
                                        break;
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="ParametreSysteme" Property="TypeDonnee" Title="Type" Width="100px" TextAlign="TextAlign.Center">
                            <Template Context="param">
                                <RadzenBadge Text="@param.TypeDonnee" BadgeStyle="BadgeStyle.Light" IsPill="true" />
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="ParametreSysteme" Title="Contraintes" Width="120px">
                            <Template Context="param">
                                @if (param.ValeurMin.HasValue || param.ValeurMax.HasValue)
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: #666;">
                                        @if (param.ValeurMin.HasValue && param.ValeurMax.HasValue)
                                        {
                                            @($"{param.ValeurMin} - {param.ValeurMax}")
                                        }
                                        else if (param.ValeurMin.HasValue)
                                        {
                                            @($"Min: {param.ValeurMin}")
                                        }
                                        else
                                        {
                                            @($"Max: {param.ValeurMax}")
                                        }
                                    </RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        
                        <RadzenDataGridColumn TItem="ParametreSysteme" Title="Actions" Width="80px" TextAlign="TextAlign.Center" Sortable="false">
                            <Template Context="param">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                              Click="@(() => ShowEditDialog(param))" title="Modifier"
                                              Disabled="@param.EstSysteme" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }
    </RadzenStack>
</div>

@code {
    private List<ParametreSysteme> parametres = [];
    private Dictionary<string, bool> expandedCategories = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            parametres = (await ParametreService.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private IEnumerable<KeyValuePair<string, List<ParametreSysteme>>> GetCategoriesWithParametres()
    {
        return parametres
            .GroupBy(p => p.Categorie ?? "Autre")
            .OrderBy(g => GetCategoryOrder(g.Key))
            .Select(g => new KeyValuePair<string, List<ParametreSysteme>>(g.Key, g.OrderBy(p => p.Ordre).ToList()));
    }

    private int GetCategoryOrder(string category) => category switch
    {
        "General" => 1,
        "Workflow" => 2,
        "Email" => 3,
        "Securite" => 4,
        "Interface" => 5,
        _ => 99
    };

    private string GetCategoryIcon(string category) => category switch
    {
        "General" => "settings",
        "Workflow" => "account_tree",
        "Email" => "email",
        "Securite" => "security",
        "Interface" => "palette",
        _ => "tune"
    };

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<ParametreEditDialog>("Nouveau paramètre",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Paramètre créé avec succès");
        }
    }

    private async Task ShowEditDialog(ParametreSysteme parametre)
    {
        var result = await DialogService.OpenAsync<ParametreEditDialog>("Modifier le paramètre",
            new Dictionary<string, object> { { "Parametre", parametre } },
            new DialogOptions { Width = "600px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Paramètre modifié avec succès");
        }
    }

    private async Task UpdateBooleanValue(ParametreSysteme param, bool value)
    {
        await UpdateParameterValue(param, value.ToString().ToLower());
    }

    private async Task UpdateIntegerValue(ParametreSysteme param, int value)
    {
        await UpdateParameterValue(param, value.ToString());
    }

    private async Task UpdateStringValue(ParametreSysteme param, string value)
    {
        await UpdateParameterValue(param, value);
    }

    private async Task UpdateParameterValue(ParametreSysteme param, string newValue)
    {
        try
        {
            var ancienneValeur = param.Valeur;
            var userLogin = CurrentUserService.GetUserLogin();
            await ParametreService.UpdateValueAsync(param.Cle, newValue, userLogin);
            
            await AuditLogService.LogAsync(
                userLogin,
                CurrentUserService.GetUserDisplayName(),
                "Update",
                "ParametreSysteme",
                $"Paramètre {param.Cle} modifié",
                param.IdParametre.ToString(),
                "ParametreSysteme",
                ancienneValeur: ancienneValeur,
                nouvelleValeur: newValue);
            
            NotificationService.Notify(NotificationSeverity.Success, "Succès", $"Paramètre {param.Cle} mis à jour");
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
    }
}
