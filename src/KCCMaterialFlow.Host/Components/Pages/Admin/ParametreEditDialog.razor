@inject IParametreSystemeService ParametreService
@inject DialogService DialogService
@inject IStringLocalizer<SharedResource> L

<RadzenStack Gap="1rem">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenFormField Text="@L["Ped_LblCle"].Value" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.Cle" Style="width: 100%;" 
                               Disabled="@isEditMode" 
                               Placeholder="NOM_PARAMETRE" MaxLength="100" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenFormField Text="@L["Ped_LblCategorie"].Value" Style="width: 100%;">
                <RadzenDropDown TValue="string" @bind-Value="@model.Categorie" 
                                Data="@categories" Style="width: 100%;" 
                                AllowClear="true" Placeholder="@L["Ped_PlaceholderCategorie"].Value" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="@L["Ped_LblLibelle"].Value" Style="width: 100%;">
                <RadzenTextBox @bind-Value="@model.Libelle" Style="width: 100%;" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="@L["Ped_LblDescription"].Value" Style="width: 100%;">
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenFormField Text="@L["Ped_LblTypeDonnee"].Value" Style="width: 100%;">
                <RadzenDropDown TValue="string" @bind-Value="@model.TypeDonnee" 
                                Data="@typeDonnees" Style="width: 100%;" 
                                Change="@OnTypeChange" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenFormField Text="@L["Ped_LblValeur"].Value" Style="width: 100%;">
                @switch (model.TypeDonnee)
                {
                    case "Boolean":
                        <RadzenDropDown TValue="string" @bind-Value="@model.Valeur" 
                                        Data="@booleanOptions" Style="width: 100%;" />
                        break;
                    case "Integer":
                        <RadzenNumeric TValue="int" Value="@(int.TryParse(model.Valeur, out var intVal) ? intVal : 0)"
                                       Change="@(val => model.Valeur = val.ToString())"
                                       Style="width: 100%;" />
                        break;
                    default:
                        <RadzenTextBox @bind-Value="@model.Valeur" Style="width: 100%;" />
                        break;
                }
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>
    
    @if (model.TypeDonnee == "Integer")
    {
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="@L["Ped_LblValeurMin"].Value" Style="width: 100%;">
                    <RadzenNumeric TValue="int?" @bind-Value="@model.ValeurMin" Style="width: 100%;" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="@L["Ped_LblValeurMax"].Value" Style="width: 100%;">
                    <RadzenNumeric TValue="int?" @bind-Value="@model.ValeurMax" Style="width: 100%;" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
    }
    
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenFormField Text="@L["Ped_LblOrdre"].Value" Style="width: 100%;">
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Style="padding-top: 1.5rem;">
                <RadzenCheckBox @bind-Value="@model.EstModifiable" TValue="bool" />
                <RadzenLabel Text="@L["Ped_ChkModifiable"].Value" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenStack Style="padding-top: 1.5rem;">
                <RadzenCheckBox @bind-Value="@model.EstVisible" TValue="bool" />
                <RadzenLabel Text="@L["Ped_ChkVisible"].Value" Style="margin-left: 0.5rem;" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" class="rz-mt-4">
        <RadzenButton Text="@L["Btn_Cancel"].Value" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
        <RadzenButton Text="@(isEditMode ? L["Btn_Save"].Value : L["Btn_Create"].Value)" ButtonStyle="ButtonStyle.Primary" 
                      Click="@Save" Disabled="@(!IsValid)" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter]
    public ParametreSysteme? Parametre { get; set; }
    
    private ParametreSysteme model = new();
    private bool isEditMode;
    
    private readonly List<string> categories = ["General", "Workflow", "Email", "Securite", "Interface"];
    private readonly List<string> typeDonnees = ["String", "Integer", "Boolean"];
    private readonly List<string> booleanOptions = ["true", "false"];
    
    private bool IsValid => !string.IsNullOrWhiteSpace(model.Cle) && 
                           !string.IsNullOrWhiteSpace(model.Categorie) &&
                           !string.IsNullOrWhiteSpace(model.TypeDonnee) &&
                           !string.IsNullOrWhiteSpace(model.Valeur) &&
                           !string.IsNullOrWhiteSpace(model.Libelle);

    protected override void OnInitialized()
    {
        if (Parametre != null)
        {
            isEditMode = true;
            model = new ParametreSysteme
            {
                Id = Parametre.Id,
                Cle = Parametre.Cle,
                Valeur = Parametre.Valeur,
                Libelle = Parametre.Libelle,
                Description = Parametre.Description,
                TypeDonnee = Parametre.TypeDonnee,
                Categorie = Parametre.Categorie,
                ValeurMin = Parametre.ValeurMin,
                ValeurMax = Parametre.ValeurMax,
                Ordre = Parametre.Ordre,
                EstModifiable = Parametre.EstModifiable,
                EstSysteme = Parametre.EstSysteme,
                EstVisible = Parametre.EstVisible
            };
        }
        else
        {
            model.TypeDonnee = "String";
            model.EstModifiable = true;
            model.EstVisible = true;
            model.Categorie = "General";
            model.Libelle = "";
        }
    }

    private void OnTypeChange()
    {
        // Reset value when type changes
        model.Valeur = model.TypeDonnee switch
        {
            "Boolean" => "false",
            "Integer" => "0",
            _ => ""
        };
        model.ValeurMin = null;
        model.ValeurMax = null;
    }

    private async Task Save()
    {
        if (!IsValid) return;
        
        try
        {
            if (isEditMode)
            {
                await ParametreService.UpdateAsync(model);
            }
            else
            {
                await ParametreService.CreateAsync(model);
            }
            
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            await DialogService.Alert($"Erreur lors de l'enregistrement: {ex.Message}", "Erreur");
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
}
