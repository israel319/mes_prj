@page "/admin/roles"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@using KCCMaterialFlow.Application.Common.Interfaces
@using KCCMaterialFlow.Domain.Entities
@using KCCMaterialFlow.Domain.Enums
@using KCCMaterialFlow.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<KCCMaterialFlowDbContext> DbFactory
@inject ICurrentUserService CurrentUserService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>Rôles &amp; Accès - Admin - KCC Material Flow</PageTitle>

<div class="kcp-page">
    <div class="kcp-hero">
        <div class="kcp-hero-inner">
            <div>
                <h1 class="kcp-title">@L["Rol_Title"]</h1>
                <p class="kcp-subtitle">@L["Rol_Subtitle"]</p>
            </div>
            <div class="kcp-hero-actions">
                <button class="kcp-btn" type="button" @onclick="@(() => Navigation.NavigateTo("/admin/utilisateurs"))">
                    <RadzenIcon Icon="people" Style="font-size:1rem;" />
                    @L["Rol_BtnManageUsers"]
                </button>
                <button class="kcp-btn" type="button" @onclick="LoadAsync" disabled="@_loading">
                    <RadzenIcon Icon="refresh" Style="font-size:1rem;" />
                    @L["Btn_Refresh"]
                </button>
            </div>
        </div>
    </div>
    <main class="kcp-main">

    @if (_loading)
    {
        <div style="text-align: center; padding: 3rem;">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                       Size="ProgressBarCircularSize.Large" />
        </div>
    }
    else
    {
        @* ─── CARTES STATISTIQUES ─── *@
        <RadzenRow Gap="1rem" class="rz-mb-6">
            @foreach (var stat in _stats)
            {
                <RadzenColumn Size="12" SizeSM="6" SizeMD="4">
                    <RadzenCard Style=@($"padding: 1.25rem; border-top: 4px solid {stat.Couleur}; height: 100%;")>
                        <RadzenStack Gap="0.5rem">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center"
                                         JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenStack Gap="0.1rem">
                                    <RadzenText TextStyle="TextStyle.H4"
                                                Style="@($"font-weight: 800; color: {stat.Couleur}; margin: 0;")">
                                        @stat.Compte
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Subtitle1"
                                                Style="font-weight: 600; color: var(--kcc-grey); margin: 0;">
                                        @stat.Libelle
                                    </RadzenText>
                                </RadzenStack>
                                <div style="@($"background:{stat.Couleur}20; color:{stat.Couleur}; width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center;")">
                                    <RadzenIcon Icon="@stat.Icone" Style="font-size: 1.6rem;" />
                                </div>
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500); margin: 0;">
                                @stat.Description
                            </RadzenText>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            }
        </RadzenRow>

        @* ─── DÉFINITION DES RÔLES ─── *@
        <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; color: var(--kcc-grey); margin-bottom: 0.75rem;">
            @L["Rol_SecRoleDef"]
        </RadzenText>
        <RadzenRow Gap="1rem" class="rz-mb-6">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard Style="padding: 1rem; border-left: 4px solid #9ca3af; height: 100%;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenBadge Text="@L["Rol_BadgeNone"].Value" BadgeStyle="BadgeStyle.Secondary" />
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 700; color: var(--kcc-grey);">
                            @L["Rol_SubStandard"]
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500);">
                            @L["Rol_DescStandard"]
                        </RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard Style="padding: 1rem; border-left: 4px solid #f59e0b; height: 100%;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenBadge Text="Admin" BadgeStyle="BadgeStyle.Warning" />
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 700; color: var(--kcc-grey);">
                            @L["Rol_SubAdmin"]
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500);">
                            @L["Rol_DescAdmin"]
                        </RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard Style="padding: 1rem; border-left: 4px solid #ef4444; height: 100%;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenBadge Text="SuperAdmin" BadgeStyle="BadgeStyle.Danger" />
                        <RadzenText TextStyle="TextStyle.Subtitle2" Style="font-weight: 700; color: var(--kcc-grey);">
                            @L["Rol_SubSuperAdmin"]
                        </RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--gray-500);">
                            @L["Rol_DescSuperAdmin"]
                        </RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        @* ─── LISTE DES ADMINS ─── *@
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"
                     AlignItems="AlignItems.Center" class="rz-mb-3">
            <RadzenText TextStyle="TextStyle.H5" Style="font-weight: 700; color: var(--kcc-grey); margin: 0;">
                @L["Rol_AdminListTitle"]
            </RadzenText>
            <RadzenTextBox @bind-Value="@_search" Placeholder="@L["Rol_FilterPh"].Value"
                           Style="width: 280px;" />
        </RadzenStack>

        @if (_admins.Count == 0)
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Shade="Shade.Lighter"
                         AllowClose="false">
                Aucun compte avec droits administratifs trouvé. Assignez un niveau Admin depuis la page
                <RadzenLink Path="/admin/utilisateurs" Text="@L["AdmNav_Users"]" />.
            </RadzenAlert>
        }
        else
        {
            <RadzenCard Style="padding: 0;">
                <RadzenDataGrid Data="@FilteredAdmins" TItem="AdminRow"
                                AllowSorting="true" AllowPaging="true" PageSize="20"
                                Density="Density.Compact" GridLines="DataGridGridLines.Horizontal"
                                EmptyText="@L["Lbl_NoResults"]">
                    <Columns>
                        <RadzenDataGridColumn TItem="AdminRow" Title="@L["Rol_ColMatricule"]" Width="110px">
                            <Template Context="row">
                                <code style="font-size: 0.8rem;">@row.Matricule</code>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="AdminRow" Property="NomComplet" Title="@L["Rol_ColFullName"]" />
                        <RadzenDataGridColumn TItem="AdminRow" Property="Departement" Title="@L["Rol_ColDept"]" Width="200px">
                            <Template Context="row">
                                <span style="color: var(--gray-500); font-size: 0.85rem;">
                                    @(row.Departement ?? "—")
                                </span>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="AdminRow" Property="Login" Title="@L["Rol_ColWinLogin"]" Width="200px">
                            <Template Context="row">
                                <span style="font-size: 0.8rem; color: var(--gray-500); font-family: monospace;">
                                    @(row.Login ?? "—")
                                </span>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="AdminRow" Title="@L["Rol_ColLevel"]" Width="130px">
                            <Template Context="row">
                                @if (row.NiveauAdmin == NiveauAdmin.SuperAdmin)
                                {
                                    <RadzenBadge Text="SuperAdmin" BadgeStyle="BadgeStyle.Danger" />
                                }
                                else
                                {
                                    <RadzenBadge Text="Admin" BadgeStyle="BadgeStyle.Warning" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="AdminRow" Property="EstActif" Title="@L["Rol_ColActive"]" Width="80px">
                            <Template Context="row">
                                <RadzenBadge Text="@(row.EstActif ? L["Lbl_Yes"].Value : L["Lbl_No"].Value)"
                                             BadgeStyle="@(row.EstActif ? BadgeStyle.Success : BadgeStyle.Secondary)" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="AdminRow" Title="" Width="130px" TextAlign="TextAlign.Right">
                            <Template Context="row">
                                <RadzenButton Icon="manage_accounts" Text="@L["Btn_Manage"].Value" Size="ButtonSize.Small"
                                              Variant="Variant.Text" ButtonStyle="ButtonStyle.Primary"
                                              Click='@(() => Navigation.NavigateTo("/admin/utilisateurs"))' />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }
    }
    </main>
</div>

@code {
    private List<AdminRow> _admins = new();
    private List<RoleStat> _stats = new();
    private string _search = "";
    private bool _loading = true;

    private IEnumerable<AdminRow> FilteredAdmins =>
        string.IsNullOrWhiteSpace(_search)
            ? _admins
            : _admins.Where(r =>
                (r.NomComplet?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.Matricule?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.Login?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true) ||
                (r.Departement?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            // Source unique de NiveauAdmin/EstActif/Login = AppUser
            var appUsers = await ctx.AppUsers.AsNoTracking()
                .Where(u => u.EmployeeId != null)
                .ToListAsync();
            var appUserByEmpId = appUsers
                .GroupBy(u => u.EmployeeId!.Value)
                .ToDictionary(g => g.Key, g => g.First());

            var employees = await ctx.Employees.AsNoTracking()
                .OrderBy(e => e.NomComplet)
                .ToListAsync();

            // Niveaux issus de AppUser (Aucun pour ceux sans compte)
            NiveauAdmin NiveauOf(int empId, NiveauAdmin defVal = NiveauAdmin.Aucun)
                => appUserByEmpId.TryGetValue(empId, out var u) ? u.NiveauAdmin : defVal;
            bool ActifOf(int empId)
                => appUserByEmpId.TryGetValue(empId, out var u) && u.EstActif;
            string? LoginOf(int empId)
                => appUserByEmpId.TryGetValue(empId, out var u) ? u.Login : null;

            var nbAdmin       = appUsers.Count(u => u.NiveauAdmin == NiveauAdmin.Admin);
            var nbSuperAdmin  = appUsers.Count(u => u.NiveauAdmin == NiveauAdmin.SuperAdmin);
            var nbStandard    = employees.Count - nbAdmin - nbSuperAdmin;

            _stats = new List<RoleStat>
            {
                new(L["Rol_StatUsers"].Value, nbStandard, L["Rol_StatUsersDesc"].Value, "person", "#6b7280"),
                new(L["Rol_StatAdmins"].Value, nbAdmin, L["Rol_StatAdminsDesc"].Value, "manage_accounts", "#f59e0b"),
                new(L["Rol_StatSuperAdmins"].Value, nbSuperAdmin, L["Rol_StatSuperAdminsDesc"].Value, "security", "#ef4444"),
            };

            _admins = employees
                .Where(e => NiveauOf(e.Id) != NiveauAdmin.Aucun)
                .Select(e => new AdminRow
                {
                    Matricule  = e.Matricule,
                    NomComplet = string.IsNullOrWhiteSpace(e.DisplayName) ? e.NomComplet : e.DisplayName,
                    Departement = e.DepartementNom,
                    Login      = LoginOf(e.Id),
                    NiveauAdmin = NiveauOf(e.Id),
                    EstActif   = ActifOf(e.Id),
                })
                .OrderByDescending(r => r.NiveauAdmin)
                .ThenBy(r => r.NomComplet)
                .ToList();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private record RoleStat(string Libelle, int Compte, string Description, string Icone, string Couleur);

    private sealed class AdminRow
    {
        public string? Matricule  { get; init; }
        public string  NomComplet { get; init; } = "";
        public string? Departement { get; init; }
        public string? Login      { get; init; }
        public NiveauAdmin NiveauAdmin { get; init; }
        public bool EstActif      { get; init; }
    }
}
