@page "/admin/roles"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IRoleService RoleService
@inject IPermissionService PermissionService
@inject IAuditLogService AuditLogService
@inject ICurrentUserService CurrentUserService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Administration - Rôles</PageTitle>

<RadzenStack Gap="1rem" Style="max-width: 1400px; margin: 0 auto; padding: 1.5rem;">
    <AdminNav />

    @* ─── En-tête ─── *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" Gap="1rem">
        <RadzenStack Gap="0.25rem">
            <RadzenText TextStyle="TextStyle.H4" Style="font-weight: 700; color: var(--kcc-slate); margin: 0;">
                Gestion des Rôles et Permissions
            </RadzenText>
        </RadzenStack>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            <RadzenButton Icon="refresh" Text="Actualiser" Variant="Variant.Outlined"
                          ButtonStyle="ButtonStyle.Secondary" Click="@LoadDataAsync" />
            <RadzenButton Text="Nouveau rôle" Icon="add" ButtonStyle="ButtonStyle.Primary"
                          Click="@ShowCreateDialog" />
        </RadzenStack>
    </RadzenStack>

    @* ─── Grille des rôles ─── *@
    <RadzenCard>
        <RadzenDataGrid @ref="grid" Data="@roles" TItem="Role"
                        AllowFiltering="false" AllowSorting="true" AllowPaging="true" PageSize="15"
                        PagerHorizontalAlign="HorizontalAlign.Center"
                        AllowColumnResize="true"
                        Density="Density.Compact"
                        EmptyText="Aucun rôle trouvé">
                <Columns>
                    <RadzenDataGridColumn TItem="Role" Property="CodeRole" Title="Rôle" Width="250px">
                        <Template Context="role">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <div style="width: 28px; height: 28px; background: @GetRoleBackground(role);
                                            display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <span style="color: @GetRoleColor(role); font-size: 13px; font-weight: 700;">@role.CodeRole[..1]</span>
                                </div>
                                <div>
                                    <div style="font-weight: 600; font-size: 0.8rem; color: #1a1a1a;">@role.NomRole</div>
                                    <div style="font-size: 0.72rem; color: #666;">@role.CodeRole</div>
                                </div>
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Role" Property="Description" Title="Description">
                        <Template Context="role">
                            <span style="font-size: 0.78rem; color: #555;">@(role.Description ?? "—")</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Role" Property="NiveauPriorite" Title="Priorité" Width="90px" TextAlign="TextAlign.Center">
                        <Template Context="role">
                            <span style="font-size: 0.78rem; font-weight: 600; color: #374151;">@role.NiveauPriorite</span>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Role" Title="Propriétés" Width="160px">
                        <Template Context="role">
                            <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                                @if (role.EstSysteme)
                                {
                                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: rgba(59,130,246,0.1); color: #2563eb;">Système</span>
                                }
                                @{
                                    var perms = GetRolePermissions(role.Id);
                                }
                                @if (perms.Count > 0)
                                {
                                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: #f3f4f6; color: #374151;">@perms.Count perm.</span>
                                }
                                @if (!role.EstSysteme && perms.Count == 0)
                                {
                                    <span style="color: #999;">—</span>
                                }
                            </div>
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Role" Property="EstActif" Title="Statut" Width="80px" TextAlign="TextAlign.Center">
                        <Template Context="role">
                            @if (role.EstActif)
                            {
                                <span style="font-size: 0.72rem; font-weight: 600; color: #059669;">Actif</span>
                            }
                            else
                            {
                                <span style="font-size: 0.72rem; font-weight: 600; color: #dc2626;">Inactif</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Role" Title="Actions" Width="90px" TextAlign="TextAlign.Center" Sortable="false">
                        <Template Context="role">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" JustifyContent="JustifyContent.Center">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Small"
                                              Click="@(() => ShowEditDialog(role))" title="Modifier"
                                              Disabled="@role.EstSysteme" />
                                @if (!role.EstSysteme)
                                {
                                    @if (role.EstActif)
                                    {
                                        <RadzenButton Icon="block" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                                      Click="@(() => ToggleStatus(role))" title="Désactiver" />
                                    }
                                    else
                                    {
                                        <RadzenButton Icon="check_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Text" Size="ButtonSize.Small"
                                                      Click="@(() => ToggleStatus(role))" title="Activer" />
                                    }
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>

        @* ─── Légende des permissions ─── *@
        <RadzenCard Style="padding: 1rem;">
            <div style="font-size: 0.72rem; font-weight: 600; color: #374151; margin-bottom: 0.5rem;">
                Permissions disponibles
            </div>
            <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                @foreach (var perm in allPermissions)
                {
                    <span style="font-size: 0.65rem; padding: 0.1rem 0.4rem; background: #f3f4f6; color: #374151;" title="@perm.NomPermission">@perm.CodePermission</span>
                }
            </div>
        </RadzenCard>
</RadzenStack>

@code {
    private RadzenDataGrid<Role>? grid;
    private List<Role> roles = [];
    private List<Permission> allPermissions = [];
    private Dictionary<int, List<Permission>> rolePermissionsMap = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            roles = (await RoleService.GetAllAsync()).ToList();
            allPermissions = (await PermissionService.GetAllAsync()).ToList();
            
            // Charger les permissions de chaque rôle
            rolePermissionsMap.Clear();
            foreach (var role in roles)
            {
                var perms = await PermissionService.GetPermissionsForRoleAsync(role.Id);
                rolePermissionsMap[role.Id] = perms.ToList();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", $"Erreur lors du chargement: {ex.Message}");
        }
    }

    private List<Permission> GetRolePermissions(int roleId)
    {
        return rolePermissionsMap.TryGetValue(roleId, out var perms) ? perms : [];
    }

    private async Task ShowCreateDialog()
    {
        var result = await DialogService.OpenAsync<RoleEditDialog>("Nouveau rôle",
            new Dictionary<string, object>(),
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Rôle créé avec succès");
        }
    }

    private async Task ShowEditDialog(Role role)
    {
        if (role.EstSysteme)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Information", "Les rôles système ne peuvent pas être modifiés");
            return;
        }
        
        var result = await DialogService.OpenAsync<RoleEditDialog>("Modifier le rôle",
            new Dictionary<string, object> { { "Role", role } },
            new DialogOptions { Width = "700px", Height = "auto", Resizable = true, Draggable = true });
        
        if (result == true)
        {
            await LoadDataAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Rôle modifié avec succès");
        }
    }

    private async Task ToggleStatus(Role role)
    {
        if (role.EstSysteme)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Information", "Les rôles système ne peuvent pas être modifiés");
            return;
        }
        
        var action = role.EstActif ? "désactiver" : "activer";
        var confirmed = await DialogService.Confirm(
            $"Voulez-vous vraiment {action} le rôle {role.NomRole} ?",
            $"Confirmer {action}",
            new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });
        
        if (confirmed == true)
        {
            try
            {
                await RoleService.DeleteAsync(role.Id);
                
                await AuditLogService.LogAsync(
                    CurrentUserService.GetUserLogin(),
                    CurrentUserService.GetUserDisplayName(),
                    role.EstActif ? "Deactivate" : "Activate",
                    "Role",
                    $"Rôle {role.NomRole} {(role.EstActif ? "désactivé" : "activé")}",
                    role.Id.ToString(),
                    "Role");
                
                await LoadDataAsync();
                NotificationService.Notify(NotificationSeverity.Success, "Succès", 
                    $"Rôle {(role.EstActif ? "désactivé" : "activé")}");
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
            }
        }
    }

    private static string GetRoleBackground(Role role) => role.CodeRole switch
    {
        "ADMIN" => "rgba(220,38,38,0.1)",
        "APPROBATEUR" => "rgba(245,158,11,0.1)",
        "AGENT_SECURITE" => "rgba(59,130,246,0.1)",
        _ => "#f3f4f6"
    };

    private static string GetRoleColor(Role role) => role.CodeRole switch
    {
        "ADMIN" => "#dc2626",
        "APPROBATEUR" => "#d97706",
        "AGENT_SECURITE" => "#2563eb",
        _ => "#374151"
    };
}
