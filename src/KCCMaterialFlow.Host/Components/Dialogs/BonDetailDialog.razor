@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IStringLocalizer<SharedResource> L

@if (isLoading)
{
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height: 400px; padding: 2rem;" Gap="1rem">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
        <RadzenText Style="color: #6b7280;">Chargement des détails...</RadzenText>
    </RadzenStack>
}
else if (errorMessage != null)
{
    <RadzenStack Gap="1.5rem" Style="padding: 1rem;">
        <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter">@errorMessage</RadzenAlert>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton Text="@L["Btn_Close"].Value" Icon="close" ButtonStyle="ButtonStyle.Light" Click="@Close" />
        </RadzenStack>
    </RadzenStack>
}
else
{
    <div style="display: flex; flex-direction: column;">

        @* ─── Header ─── *@
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem"
                     Style="padding: 1rem 1.25rem; background: #253C45; color: white; flex-shrink: 0;">
            <div style="width: 36px; height: 36px; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; border-radius: 0.5rem;">
                <RadzenIcon Icon="@(TypeBon == "BEM" ? "login" : "logout")" Style="color: white;" />
            </div>
            <RadzenStack Gap="0" Style="flex: 1; min-width: 0;">
                <RadzenText Style="font-weight: 700; color: white; margin: 0; font-size: 1rem;">@numeroReference</RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" Style="color: rgba(255,255,255,0.65); margin: 0;">
                    @(TypeBon == "BEM" ? "Bon d'Entrée Matériel" : "Bon de Sortie Matériel") &bull; @dateCreation.ToString("dd/MM/yyyy à HH:mm")
                </RadzenText>
            </RadzenStack>
            <RadzenBadge Text="@statutLibelle" BadgeStyle="@GetBadgeStyle()" Shade="Shade.Default" />
            <RadzenButton Icon="close" Variant="Variant.Text" ButtonStyle="ButtonStyle.Light"
                          Click="@Close" Style="color: rgba(255,255,255,0.7); min-width: unset;" />
        </RadzenStack>

        @* ─── Corps ─── *@
        <div style="display: flex;">

            @* Colonne gauche *@
            <div style="flex: 7; border-right: 1px solid rgba(0,0,0,0.06); display: flex; flex-direction: column;">
                <RadzenStack Gap="0">

                    @* ── Infos clés ── *@
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border-bottom:1px solid rgba(0,0,0,0.07);">

                        @* Demandeur *@
                        <div style="padding:0.8rem 1.1rem;border-right:1px solid rgba(0,0,0,0.06);border-bottom:1px solid rgba(0,0,0,0.06);">
                            <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9ca3af;margin-bottom:0.3rem;">Demandeur</div>
                            <div style="display:flex;align-items:center;gap:0.5rem;">
                                <div style="width:30px;height:30px;background:#BB8748;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:0.7rem;flex-shrink:0;border-radius:4px;">
                                    @GetInitials(demandeur)
                                </div>
                                <div style="font-weight:700;font-size:0.88rem;color:#1f2937;line-height:1.3;">@(demandeur ?? "N/A")</div>
                            </div>
                        </div>

                        @* Entreprise (BEM) ou Trajet compact (BSM) *@
                        @if (!string.IsNullOrEmpty(entreprise))
                        {
                            <div style="padding:0.8rem 1.1rem;border-bottom:1px solid rgba(0,0,0,0.06);">
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9ca3af;margin-bottom:0.3rem;">Entreprise</div>
                                <div style="display:flex;align-items:center;gap:0.4rem;">
                                    <RadzenIcon Icon="business" Style="font-size:1rem;color:#3b82f6;flex-shrink:0;" />
                                    <div style="font-weight:700;font-size:0.88rem;color:#1f2937;">@entreprise</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div style="padding:0.8rem 1.1rem;border-bottom:1px solid rgba(0,0,0,0.06);">
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9ca3af;margin-bottom:0.3rem;">Trajet</div>
                                <div style="display:flex;align-items:center;gap:0.4rem;">
                                    <span style="font-weight:700;font-size:0.88rem;color:#3b82f6;">@(provenance ?? "—")</span>
                                    <RadzenIcon Icon="arrow_forward" Style="font-size:0.9rem;color:#BB8748;" />
                                    <span style="font-weight:700;font-size:0.88rem;color:#00B193;">@(destination ?? "—")</span>
                                </div>
                            </div>
                        }

                        @* Motif / Raison *@
                        <div style="padding:0.8rem 1.1rem;border-right:1px solid rgba(0,0,0,0.06);@(string.IsNullOrEmpty(entreprise) ? "" : "border-top:0;")">
                            <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9ca3af;margin-bottom:0.3rem;">Motif</div>
                            <div style="display:flex;align-items:flex-start;gap:0.35rem;">
                                <RadzenIcon Icon="notes" Style="font-size:1rem;color:#f59e0b;flex-shrink:0;margin-top:0.05rem;" />
                                <div style="font-weight:600;font-size:0.88rem;color:#1f2937;line-height:1.4;">@(raison ?? "—")</div>
                            </div>
                        </div>

                        @* Trajet (seulement si BEM, la case Trajet n'est pas encore affichée) *@
                        @if (!string.IsNullOrEmpty(entreprise))
                        {
                            <div style="padding:0.8rem 1.1rem;">
                                <div style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9ca3af;margin-bottom:0.3rem;">Trajet</div>
                                <div style="display:flex;align-items:center;gap:0.4rem;">
                                    <span style="font-weight:700;font-size:0.88rem;color:#3b82f6;">@(provenance ?? "—")</span>
                                    <RadzenIcon Icon="arrow_forward" Style="font-size:0.9rem;color:#BB8748;" />
                                    <span style="font-weight:700;font-size:0.88rem;color:#00B193;">@(destination ?? "—")</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div></div>
                        }

                    </div>

                    @* Materiels *@
                    <div style="padding:0.85rem 1.1rem;flex:1;">
                        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.6rem;">
                            <RadzenIcon Icon="inventory_2" Style="font-size:1rem;color:#253C45;" />
                            <span style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#253C45;">Matériels</span>
                            <span style="font-size:0.72rem;font-weight:700;background:#253C45;color:white;padding:0.1rem 0.45rem;border-radius:10px;">@materiels.Count</span>
                        </div>
                        @if (materiels.Any())
                        {
                            <div style="max-height:260px;overflow-y:auto;border:1px solid rgba(0,0,0,0.09);border-radius:6px;">
                                <table style="width:100%;border-collapse:collapse;font-size:0.87rem;">
                                    <thead>
                                        <tr style="background:#f1f5f9;">
                                            <th style="text-align:left;padding:0.5rem 0.75rem;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;border-bottom:2px solid #e2e8f0;position:sticky;top:0;background:#f1f5f9;">Code / N° Série</th>
                                            <th style="text-align:left;padding:0.5rem 0.75rem;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;border-bottom:2px solid #e2e8f0;position:sticky;top:0;background:#f1f5f9;">Désignation</th>
                                            <th style="width:60px;text-align:right;padding:0.5rem 0.75rem;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;border-bottom:2px solid #e2e8f0;position:sticky;top:0;background:#f1f5f9;">Qté</th>
                                            @if (TypeBon == "BEM")
                                            {
                                                <th style="width:70px;text-align:center;padding:0.5rem 0.75rem;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;border-bottom:2px solid #e2e8f0;position:sticky;top:0;background:#f1f5f9;">Dispo</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (mat, idx) in materiels.Select((m, i) => (m, i)))
                                        {
                                            <tr style="@(idx % 2 == 0 ? "background:white;" : "background:#fafbfc;")">
                                                <td style="padding:0.55rem 0.75rem;border-bottom:1px solid rgba(0,0,0,0.05);">
                                                    @if (!string.IsNullOrEmpty(mat.NumeroSerie))
                                                    {
                                                        <span style="font-family:monospace;font-size:0.82rem;font-weight:700;color:#3b82f6;background:rgba(59,130,246,0.08);padding:0.1rem 0.35rem;border-radius:3px;">@mat.NumeroSerie</span>
                                                    }
                                                    else
                                                    {
                                                        <span style="color:#9ca3af;font-size:0.8rem;">—</span>
                                                    }
                                                </td>
                                                <td style="padding:0.55rem 0.75rem;border-bottom:1px solid rgba(0,0,0,0.05);font-weight:600;color:#1f2937;font-size:0.88rem;">@mat.Designation</td>
                                                <td style="padding:0.55rem 0.75rem;border-bottom:1px solid rgba(0,0,0,0.05);text-align:right;font-weight:700;color:#253C45;font-size:0.9rem;">@mat.Quantite.ToString("F2")</td>
                                                @if (TypeBon == "BEM")
                                                {
                                                    <td style="padding:0.55rem 0.75rem;border-bottom:1px solid rgba(0,0,0,0.05);text-align:center;">
                                                        <span style="font-size:0.82rem;font-weight:700;padding:0.15rem 0.45rem;border-radius:4px;background:@(mat.QuantiteDisponible > 0 ? "rgba(0,177,147,0.1)" : "rgba(220,38,38,0.08)");color:@(mat.QuantiteDisponible > 0 ? "#00B193" : "#dc2626");">
                                                            @mat.QuantiteDisponible.ToString("F2")
                                                        </span>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div style="display:flex;justify-content:flex-end;align-items:center;gap:0.35rem;padding:0.4rem 0.5rem 0;">
                                <span style="font-size:0.8rem;color:#6b7280;">Total :</span>
                                <span style="font-size:0.88rem;font-weight:700;color:#253C45;">@materiels.Sum(m => m.Quantite).ToString("F2")</span>
                            </div>
                        }
                        else
                        {
                            <div style="text-align:center;padding:1.5rem;color:#9ca3af;font-size:0.82rem;font-style:italic;">
                                <RadzenIcon Icon="inventory_2" Style="font-size:1.5rem;color:#d1d5db;display:block;margin:0 auto 0.4rem;" />
                                Aucun matériel
                            </div>
                        }
                    </div>

                </RadzenStack>
            </div>

            @* Colonne droite *@
            <div style="flex: 5; background: #fafbfc; display: flex; flex-direction: column;">
                <RadzenStack Gap="0">

                    @* Timeline approbations *@
                    @if (approbations.Any())
                    {
                        <RadzenStack Style="padding: 0.75rem 1.25rem; flex: 1;" Gap="0.6rem">
                            <RadzenText TextStyle="TextStyle.Caption" FontWeight="FontWeight.Bold"
                                        Style="color: #253C45; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.7rem; border-bottom: 1px solid rgba(0,0,0,0.07); padding-bottom: 0.4rem;">
                                Approbations
                            </RadzenText>
                            <div style="position: relative;">
                                @* Ligne verticale de la timeline *@
                                <div style="position: absolute; left: 10px; top: 12px; bottom: 12px; width: 2px; background: #e5e7eb; z-index: 0;"></div>
                                @foreach (var appro in approbations)
                                {
                                    var iconColor = appro.IsApproved ? "#00B193" : appro.IsRejected ? "#dc2626" : appro.IsCurrent ? "#3b82f6" : "#d1d5db";
                                    var bgColor   = appro.IsApproved ? "#00B193" : appro.IsRejected ? "#dc2626" : appro.IsCurrent ? "#3b82f6" : "#ffffff";
                                    var iconName  = appro.IsApproved ? "check" : appro.IsRejected ? "close" : appro.IsCurrent ? "schedule" : "radio_button_unchecked";
                                    var iconTextColor = (appro.IsApproved || appro.IsRejected || appro.IsCurrent) ? "white" : iconColor;
                                    <div style="display: flex; align-items: flex-start; gap: 0.65rem; padding: 0.45rem 0; position: relative; z-index: 1;">
                                        <div style="@($"width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: {bgColor}; border: 2px solid {iconColor}; border-radius: 50%; margin-top: 0.05rem;")">
                                            <RadzenIcon Icon="@iconName" Style="@($"color: {iconTextColor}; font-size: 0.75rem;")" />
                                        </div>
                                        <div style="flex: 1; min-width: 0;">
                                            <div style="font-weight: 600; font-size: 0.92rem; color: #1f2937; line-height: 1.3;">@appro.NomEtape</div>
                                            @if ((appro.IsApproved || appro.IsRejected) && !string.IsNullOrEmpty(appro.Approbateur))
                                            {
                                                <div style="font-size: 0.8rem; color: #6b7280; margin-top: 0.1rem;">
                                                    @appro.Approbateur &bull; @(appro.DateAction?.ToString("dd/MM HH:mm") ?? "")
                                                </div>
                                            }
                                            @if (appro.IsCurrent)
                                            {
                                                <div style="font-size: 0.8rem; color: #3b82f6; font-weight: 600; margin-top: 0.1rem;">
                                                    En attente
                                                    @if (!string.IsNullOrEmpty(appro.Approbateur))
                                                    {
                                                        <span> — <strong>@appro.Approbateur</strong></span>
                                                    }
                                                </div>
                                            }
                                            @if (!appro.IsApproved && !appro.IsRejected && !appro.IsCurrent)
                                            {
                                                <div style="font-size: 0.8rem; color: #9ca3af; margin-top: 0.1rem;">
                                                    En attente
                                                    @if (!string.IsNullOrEmpty(appro.Approbateur))
                                                    {
                                                        <span> — @appro.Approbateur</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </RadzenStack>
                    }

                    @* Zone commentaire *@
                    @if (ShowActions)
                    {
                        <RadzenStack Style="padding: 0.75rem 1.25rem; background: rgba(0,177,147,0.06); border-top: 2px solid rgba(0,177,147,0.25); margin-top: auto;" Gap="0.4rem">
                            <RadzenText TextStyle="TextStyle.Caption" FontWeight="FontWeight.Bold" Style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: #008f76;">
                                Commentaire
                            </RadzenText>
                            <RadzenTextArea @bind-Value="commentaire" Rows="3" Style="width: 100%;"
                                            Placeholder="@L["Dlg_PlOptComment"].Value" />
                            @if (showRejectError)
                            {
                                <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Lighter" Size="AlertSize.Small" AllowClose="false">
                                    Le motif du rejet est obligatoire.
                                </RadzenAlert>
                            }
                        </RadzenStack>
                    }

                </RadzenStack>
            </div>
        </div>

        @* ─── Footer ─── *@
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem"
                     Style="padding: 0.75rem 1.25rem; border-top: 1px solid rgba(0,0,0,0.08); background: #f4f5f7; flex-shrink: 0;">
            <RadzenButton Text="@L["Btn_Close"].Value" Icon="close" ButtonStyle="ButtonStyle.Light"
                          Click="@Close" Disabled="@isProcessing" />
            @if (ShowActions)
            {
                <div style="flex: 1;"></div>
                <RadzenButton Text="@L["Btn_Reject"].Value" Icon="cancel" ButtonStyle="ButtonStyle.Danger"
                              Click="@ClickReject" Disabled="@isProcessing" />
                <RadzenButton Text="@L["Dlg_ConfirmApproval"].Value" Icon="check_circle" ButtonStyle="ButtonStyle.Success"
                              Click="@ClickApprove" Disabled="@isProcessing" />
            }
        </RadzenStack>

    </div>
}

@code {
    [Parameter] public int BonId { get; set; }
    [Parameter] public string TypeBon { get; set; } = "BEM";
    [Parameter] public bool ShowActions { get; set; } = true;

    private bool isLoading = true;
    private bool isProcessing = false;
    private string? errorMessage;
    private bool showRejectError = false;
    private string? commentaire;

    private string numeroReference = "";
    private string? demandeur;
    private string? entreprise;
    private string? raison;
    private string? description;
    private string? provenance;
    private string? destination;
    private DateTime dateCreation;
    private string statutCode = "";
    private string statutLibelle = "";
    private List<MaterielInfo> materiels = new();
    private List<ApprobationInfo> approbations = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadBonDetailsAsync();
    }

    private async Task LoadBonDetailsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (TypeBon == "BEM")
            {
                var bon = await BonEntreeService.GetAsync(BonId);
                if (bon == null) { errorMessage = "Bon d'entrée non trouvé"; return; }

                numeroReference = bon.NumeroReference;
                demandeur = bon.NomDemandeur;
                entreprise = bon.NomCompagnie;
                raison = bon.ReasonOnSite;
                description = raison;
                provenance = bon.Provenance;
                destination = bon.Destination;
                dateCreation = bon.DateCreation;
                statutCode = bon.StatutActuel;
                statutLibelle = GetStatutLibelle(bon.StatutActuel);

                materiels = bon.Materiels?.Select(m => new MaterielInfo
                {
                    Designation = m.Designation,
                    NumeroSerie = m.CodeProduitSerial,
                    Quantite = m.Quantite,
                    QuantiteDisponible = m.QuantiteDisponible
                }).ToList() ?? new();

                var approList = await BonEntreeService.GetApprobationsAsync(BonId);
                approbations = approList.Select(a => new ApprobationInfo
                {
                    NomEtape = a.NomEtape ?? "Étape",
                    Approbateur = a.NomApprobateur,
                    DateAction = a.DateAction,
                    IsApproved = a.Decision is "Approuvé" or "Approuve",
                    IsRejected = a.Decision is "Rejeté" or "Rejete" or "Retourné" or "Retourne",
                    IsCurrent = a.Decision == "En attente"
                }).ToList();
            }
            else
            {
                var bon = await BonSortieService.GetAsync(BonId);
                if (bon == null) { errorMessage = "Bon de sortie non trouvé"; return; }

                numeroReference = bon.NumeroReference;
                demandeur = bon.NomDemandeur;
                entreprise = null;
                raison = bon.MotifSortie;
                description = raison;
                provenance = bon.Provenance;
                destination = bon.Destination;
                dateCreation = bon.DateCreation;
                statutCode = bon.StatutActuel;
                statutLibelle = GetStatutLibelle(bon.StatutActuel);

                materiels = bon.Materiels?.Select(m => new MaterielInfo
                {
                    Designation = m.Designation,
                    NumeroSerie = m.CodeProduitSerial,
                    Quantite = m.Quantite,
                    QuantiteDisponible = 0
                }).ToList() ?? new();

                var approList = await BonSortieService.GetApprobationsAsync(BonId);
                approbations = approList.Select(a => new ApprobationInfo
                {
                    NomEtape = a.NomEtape ?? "Étape",
                    Approbateur = a.NomApprobateur,
                    DateAction = a.DateAction,
                    IsApproved = a.Decision is "Approuvé" or "Approuve",
                    IsRejected = a.Decision is "Rejeté" or "Rejete" or "Retourné" or "Retourne",
                    IsCurrent = a.Decision == "En attente"
                }).ToList();
            }
        }
        catch (Exception ex) { errorMessage = $"Erreur lors du chargement: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private async Task ClickReject()
    {
        if (string.IsNullOrWhiteSpace(commentaire))
        {
            showRejectError = true;
            StateHasChanged();
            return;
        }
        showRejectError = false;
        await ConfirmReject();
    }

    private async Task ClickApprove()
    {
        showRejectError = false;
        await ConfirmApprove();
    }

    private async Task ConfirmApprove()
    {
        isProcessing = true;
        StateHasChanged();
        var currentIndex = approbations.FindIndex(a => a.IsCurrent);
        var isLastStep = currentIndex >= 0 && currentIndex == approbations.Count - 1;
        try
        {
            if (TypeBon == "BEM")
            {
                var request = new ApprovalRequest { BonId = BonId, ReservesEventuelles = commentaire };
                var result = await BonEntreeService.ApproveAsync(request);
                if (result.Success) { DialogService.Close(new DialogResult { Action = isLastStep ? "approved_final" : "approved", Success = true }); }
                else { NotificationService.Notify(NotificationSeverity.Error, "Erreur", result.Message ?? "Erreur inconnue"); isProcessing = false; }
            }
            else
            {
                var request = new BonSortieApprovalRequest { IdBon = BonId, Commentaire = commentaire };
                var result = await BonSortieService.ApproveAsync(request);
                if (result.Success) { DialogService.Close(new DialogResult { Action = isLastStep ? "approved_final" : "approved", Success = true }); }
                else { NotificationService.Notify(NotificationSeverity.Error, "Erreur", result.Message ?? "Erreur inconnue"); isProcessing = false; }
            }
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message); isProcessing = false; }
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(commentaire)) return;
        isProcessing = true;
        StateHasChanged();
        try
        {
            if (TypeBon == "BEM")
            {
                var request = new ApprovalRequest { BonId = BonId, ReservesEventuelles = commentaire };
                var result = await BonEntreeService.RejectAsync(request);
                if (result.Success) { DialogService.Close(new DialogResult { Action = "rejected", Success = true }); }
                else { NotificationService.Notify(NotificationSeverity.Error, "Erreur", result.Message ?? "Erreur inconnue"); isProcessing = false; }
            }
            else
            {
                var request = new RejectRequest { IdBon = BonId, Motif = commentaire! };
                var result = await BonSortieService.RejectAsync(request);
                if (result.Success) { DialogService.Close(new DialogResult { Action = "rejected", Success = true }); }
                else { NotificationService.Notify(NotificationSeverity.Error, "Erreur", result.Message ?? "Erreur inconnue"); isProcessing = false; }
            }
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message); isProcessing = false; }
    }

    private void Close() => DialogService.Close(null);

    private BadgeStyle GetBadgeStyle()
    {
        var upper = statutCode?.ToUpperInvariant() ?? "";
        if (upper.StartsWith("PENDING")) return BadgeStyle.Warning;
        if (upper == "APPROVED") return BadgeStyle.Success;
        if (upper == "REJECTED") return BadgeStyle.Danger;
        if (upper == "DRAFT") return BadgeStyle.Light;
        return BadgeStyle.Warning;
    }

    private string GetStatutLibelle(string code) => code?.ToUpperInvariant() switch
    {
        "DRAFT"                                                                  => L["Status_Draft"].Value,
        "PENDINGSUP" or "PENDING_SUP" or "PENDINGSUPERVISEUR"
        or "PENDINGGM" or "PENDING_GM" or "PENDINGIT" or "PENDING_IT"
        or "PENDINGENV" or "PENDING_ENV" or "PENDINGOPJ" or "PENDING_OPJ"
        or "PENDINGIDENTIFICATION" or "PENDING_ID"                               => L["Status_Pending"].Value,
        "APPROVED"                                                               => L["Status_Approved"].Value,
        "REJECTED"                                                               => L["Status_Rejected"].Value,
        "CANCELLED"                                                              => L["Status_Cancelled"].Value,
        _                                                                        => code ?? "-"
    };

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}";
        return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
    }

    private class MaterielInfo
    {
        public string Designation { get; set; } = "";
        public string? NumeroSerie { get; set; }
        public decimal Quantite { get; set; }
        public decimal QuantiteDisponible { get; set; }
    }

    private class ApprobationInfo
    {
        public string NomEtape { get; set; } = "";
        public string? Approbateur { get; set; }
        public DateTime? DateAction { get; set; }
        public bool IsApproved { get; set; }
        public bool IsRejected { get; set; }
        public bool IsCurrent { get; set; }
    }

    public class DialogResult
    {
        public string Action { get; set; } = "";
        public bool Success { get; set; }
    }
}
