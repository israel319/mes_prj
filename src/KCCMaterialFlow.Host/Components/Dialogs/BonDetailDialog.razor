@* Dialog paysage — détails d'un bon + approbation/rejet *@
@inject IBonEntreeService BonEntreeService
@inject IBonSortieService BonSortieService
@inject DialogService DialogService
@inject NotificationService NotificationService

<div class="kcc-land">
    @if (isLoading)
    {
        <div class="kcc-land__topbar">
            <div class="kcc-land__topbar-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </div>
            <div class="kcc-land__topbar-text">
                <h2 class="kcc-land__title">Chargement...</h2>
            </div>
        </div>
        <div class="kcc-land__loading">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
            <span>Chargement des détails...</span>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="kcc-land__topbar">
            <div class="kcc-land__topbar-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            </div>
            <div class="kcc-land__topbar-text">
                <h2 class="kcc-land__title">Erreur</h2>
            </div>
            <button type="button" class="kcc-land__close" @onclick="@Close" title="Fermer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="kcc-land__error">@errorMessage</div>
        <div class="kcc-land__footer" style="justify-content: flex-end;">
            <button type="button" class="kcc-land__btn kcc-land__btn--ghost" @onclick="@Close">Fermer</button>
        </div>
    }
    else
    {
        @* ─── BANDEAU SUPÉRIEUR (pleine largeur) ─── *@
        <div class="kcc-land__topbar">
            <div class="kcc-land__topbar-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    @if (TypeBon == "BEM")
                    { <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M13.8 12H3"/> }
                    else
                    { <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/> }
                </svg>
            </div>
            <div class="kcc-land__topbar-text">
                <h2 class="kcc-land__title">@numeroReference</h2>
                <p class="kcc-land__desc">@(TypeBon == "BEM" ? "Bon d'Entrée Matériel" : "Bon de Sortie Matériel") &bull; @dateCreation.ToString("dd/MM/yyyy à HH:mm")</p>
            </div>
            <span class="kcc-land__badge @GetStatutCssClass(statutCode)">@statutLibelle</span>
            <button type="button" class="kcc-land__close" @onclick="@Close" title="Fermer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
        </div>

        @* ─── CORPS DEUX COLONNES ─── *@
        <div class="kcc-land__body">

            @* ══════════ COLONNE GAUCHE — Infos du bon ══════════ *@
            <div class="kcc-land__left">

                @* Demandeur + motif *@
                <div class="kcc-land__card">
                    <div class="kcc-land__card-row">
                        <div class="kcc-land__avatar">@GetInitials(demandeur)</div>
                        <div class="kcc-land__card-info">
                            <span class="kcc-land__card-name">@(demandeur ?? "N/A")</span>
                            <span class="kcc-land__card-sub">Demandeur</span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(description))
                    {
                        <div class="kcc-land__motif">
                            <span class="kcc-land__motif-tag">Motif</span>
                            <span class="kcc-land__motif-text">@description</span>
                        </div>
                    }
                </div>

                @* Trajet *@
                <div class="kcc-land__section">
                    <div class="kcc-land__section-head">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                        Trajet
                    </div>
                    <div class="kcc-land__trajet">
                        <div class="kcc-land__trajet-box kcc-land__trajet-box--from">
                            <span class="kcc-land__trajet-label">FROM</span>
                            <span class="kcc-land__trajet-val">@(provenance ?? "N/A")</span>
                        </div>
                        <div class="kcc-land__trajet-arrow">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </div>
                        <div class="kcc-land__trajet-box kcc-land__trajet-box--to">
                            <span class="kcc-land__trajet-label">TO</span>
                            <span class="kcc-land__trajet-val">@(destination ?? "N/A")</span>
                        </div>
                    </div>
                </div>

                @* Matériels *@
                <div class="kcc-land__section kcc-land__section--grow">
                    <div class="kcc-land__section-head">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                        Matériels (@materiels.Count)
                    </div>
                    @if (materiels.Any())
                    {
                        <div class="kcc-land__table-wrap">
                            <table class="kcc-land__table">
                                <thead>
                                    <tr>
                                        <th style="text-align: left;">Désignation</th>
                                        <th style="width: 110px;">N° Série</th>
                                        <th style="width: 50px; text-align: center;">Qté</th>
                                        @if (TypeBon == "BEM")
                                        {
                                            <th style="width: 60px; text-align: center;">Dispo</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var mat in materiels)
                                    {
                                        <tr>
                                            <td style="font-weight: 600;">@mat.Designation</td>
                                            <td style="color: #6b7280;">@(string.IsNullOrEmpty(mat.NumeroSerie) ? "—" : mat.NumeroSerie)</td>
                                            <td style="text-align: center; font-weight: 700;">@mat.Quantite</td>
                                            @if (TypeBon == "BEM")
                                            {
                                                <td style="text-align: center;">
                                                    <span class="kcc-land__dispo @(mat.QuantiteDisponible > 0 ? "kcc-land__dispo--ok" : "kcc-land__dispo--ko")">@mat.QuantiteDisponible</span>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="kcc-land__empty">Aucun matériel</div>
                    }
                </div>
            </div>

            @* ══════════ COLONNE DROITE — Approbations + Actions ══════════ *@
            <div class="kcc-land__right">

                @* Timeline approbations *@
                @if (approbations.Any())
                {
                    <div class="kcc-land__section kcc-land__section--grow">
                        <div class="kcc-land__section-head">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            Approbations
                        </div>
                        <div class="kcc-land__timeline">
                            @foreach (var appro in approbations)
                            {
                                var dotClass = appro.IsApproved ? "kcc-land__dot--ok" : appro.IsRejected ? "kcc-land__dot--ko" : appro.IsCurrent ? "kcc-land__dot--cur" : "";
                                <div class="kcc-land__step">
                                    <div class="kcc-land__dot @dotClass">
                                        @if (appro.IsApproved)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                                        }
                                        else if (appro.IsRejected)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        }
                                        else if (appro.IsCurrent)
                                        {
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                        }
                                    </div>
                                    <div class="kcc-land__step-body">
                                        <span class="kcc-land__step-name">@appro.NomEtape</span>
                                        @if ((appro.IsApproved || appro.IsRejected) && !string.IsNullOrEmpty(appro.Approbateur))
                                        {
                                            <span class="kcc-land__step-detail">@appro.Approbateur &bull; @(appro.DateAction?.ToString("dd/MM HH:mm") ?? "")</span>
                                        }
                                        @if (appro.IsCurrent)
                                        {
                                            <span class="kcc-land__step-detail" style="color: #3b82f6; font-weight: 500;">En attente</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Zone action (commentaire) *@
                @if (ShowActions && actionMode != null)
                {
                    <div class="kcc-land__action @(actionMode == "reject" ? "kcc-land__action--reject" : "")">
                        <div class="kcc-land__section-head" style="padding: 0; border: none; margin-bottom: 0.4rem;">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                @if (actionMode == "reject")
                                { <circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/> }
                                else
                                { <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/> }
                            </svg>
                            @(actionMode == "reject" ? "Motif du rejet" : "Commentaire")
                        </div>
                        <textarea class="kcc-land__textarea" @bind="commentaire" rows="3"
                                  placeholder="@(actionMode == "reject" ? "Expliquez le motif du rejet..." : "Ajoutez un commentaire (optionnel)...")"></textarea>
                        @if (actionMode == "reject" && string.IsNullOrWhiteSpace(commentaire))
                        {
                            <p class="kcc-land__warn">Le motif du rejet est obligatoire.</p>
                        }
                    </div>
                }
            </div>
        </div>

        @* ─── FOOTER (pleine largeur) ─── *@
        @if (ShowActions)
        {
            <div class="kcc-land__footer">
                <button type="button" class="kcc-land__btn kcc-land__btn--ghost" @onclick="@Close" disabled="@isProcessing">Fermer</button>
                <div style="flex: 1;"></div>
                @if (actionMode == null)
                {
                    <button type="button" class="kcc-land__btn kcc-land__btn--danger" @onclick="@(() => SetActionMode("reject"))" disabled="@isProcessing">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
                        Rejeter
                    </button>
                    <button type="button" class="kcc-land__btn kcc-land__btn--primary" @onclick="@(() => SetActionMode("approve"))" disabled="@isProcessing">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                        Approuver
                    </button>
                }
                else if (actionMode == "reject")
                {
                    <button type="button" class="kcc-land__btn kcc-land__btn--ghost" @onclick="@(() => SetActionMode(null))" disabled="@isProcessing">Annuler</button>
                    <button type="button" class="kcc-land__btn kcc-land__btn--danger" @onclick="@ConfirmReject"
                            disabled="@(isProcessing || string.IsNullOrWhiteSpace(commentaire))">
                        Confirmer le rejet
                    </button>
                }
                else if (actionMode == "approve")
                {
                    <button type="button" class="kcc-land__btn kcc-land__btn--ghost" @onclick="@(() => SetActionMode(null))" disabled="@isProcessing">Annuler</button>
                    <button type="button" class="kcc-land__btn kcc-land__btn--primary" @onclick="@ConfirmApprove" disabled="@isProcessing">
                        Confirmer l'approbation
                    </button>
                }
            </div>
        }
        else
        {
            <div class="kcc-land__footer" style="justify-content: flex-end;">
                <button type="button" class="kcc-land__btn kcc-land__btn--ghost" @onclick="@Close">Fermer</button>
            </div>
        }
    }
</div>

<style>
    /* ============================================================
       KCC LANDSCAPE MODAL — Bon Detail Dialog
       Layout paysage : gauche infos, droite approbations
       Couleurs : Vert #00B193 | Cuivre #BB8748 | Slate #253C45
       Border-radius : 0
       ============================================================ */

    .kcc-land { display: flex; flex-direction: column; background: #ffffff; height: 100%; }

    /* ─── TOPBAR ─── */
    .kcc-land__topbar { display: flex; align-items: center; gap: 0.75rem; padding: 1rem 1.5rem; background: #253C45; color: #ffffff; flex-shrink: 0; }
    .kcc-land__topbar-icon { width: 36px; height: 36px; background: rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #fff; }
    .kcc-land__topbar-text { flex: 1; min-width: 0; }
    .kcc-land__title { margin: 0; font-size: 1rem; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
    .kcc-land__desc { margin: 0; font-size: 0.75rem; color: rgba(255,255,255,0.65); }
    .kcc-land__close { width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: transparent; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); cursor: pointer; flex-shrink: 0; }
    .kcc-land__close:hover { background: rgba(255,255,255,0.1); color: #fff; }

    /* Badge statut */
    .kcc-land__badge { padding: 0.2rem 0.65rem; font-size: 0.68rem; font-weight: 600; flex-shrink: 0; text-transform: uppercase; letter-spacing: 0.03em; }
    .kcc-land__badge--pending { background: rgba(245,158,11,0.2); color: #f59e0b; }
    .kcc-land__badge--approved { background: rgba(0,177,147,0.2); color: #00B193; }
    .kcc-land__badge--rejected { background: rgba(220,38,38,0.2); color: #dc2626; }
    .kcc-land__badge--draft { background: rgba(107,114,128,0.2); color: #6b7280; }

    /* ─── BODY 2 COLONNES ─── */
    .kcc-land__body { display: flex; flex: 1; min-height: 0; overflow: hidden; }

    .kcc-land__left { flex: 3; display: flex; flex-direction: column; border-right: 1px solid rgba(0,0,0,0.06); overflow-y: auto; }
    .kcc-land__right { flex: 2; display: flex; flex-direction: column; overflow-y: auto; background: #fafbfc; }

    /* ─── CARTE DEMANDEUR ─── */
    .kcc-land__card { padding: 0.85rem 1.25rem; border-bottom: 1px solid rgba(0,0,0,0.06); background: #f8f9fb; }
    .kcc-land__card-row { display: flex; align-items: center; gap: 0.65rem; }
    .kcc-land__avatar { width: 36px; height: 36px; background: #BB8748; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px; flex-shrink: 0; }
    .kcc-land__card-info { display: flex; flex-direction: column; min-width: 0; }
    .kcc-land__card-name { font-weight: 600; font-size: 0.85rem; color: #1a1a1a; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .kcc-land__card-sub { font-size: 0.7rem; color: #6b7280; }

    /* Motif */
    .kcc-land__motif { display: flex; align-items: flex-start; gap: 0.4rem; margin-top: 0.6rem; padding-top: 0.6rem; border-top: 1px solid rgba(0,0,0,0.04); }
    .kcc-land__motif-tag { font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; padding: 0.15rem 0.35rem; background: rgba(37,60,69,0.06); flex-shrink: 0; margin-top: 0.1rem; }
    .kcc-land__motif-text { font-size: 0.82rem; font-weight: 500; color: #253C45; line-height: 1.4; word-break: break-word; }

    /* ─── SECTIONS ─── */
    .kcc-land__section { padding: 0.75rem 1.25rem; border-bottom: 1px solid rgba(0,0,0,0.04); }
    .kcc-land__section--grow { flex: 1; }
    .kcc-land__section-head { display: flex; align-items: center; gap: 0.35rem; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #253C45; padding-bottom: 0.45rem; border-bottom: 1px solid rgba(0,0,0,0.06); margin-bottom: 0.45rem; }
    .kcc-land__section-head svg { color: #BB8748; flex-shrink: 0; }

    /* ─── TRAJET ─── */
    .kcc-land__trajet { display: flex; align-items: center; gap: 0.5rem; padding: 0.35rem 0; }
    .kcc-land__trajet-box { flex: 1; padding: 0.5rem 0.65rem; border: 1px solid rgba(0,0,0,0.08); background: #ffffff; display: flex; flex-direction: column; gap: 0.1rem; }
    .kcc-land__trajet-box--from { border-left: 3px solid #3b82f6; }
    .kcc-land__trajet-box--to { border-left: 3px solid #00B193; }
    .kcc-land__trajet-label { font-size: 0.55rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #9ca3af; }
    .kcc-land__trajet-val { font-size: 0.82rem; font-weight: 600; color: #1a1a1a; }
    .kcc-land__trajet-arrow { color: #BB8748; flex-shrink: 0; }

    /* ─── TABLE MATÉRIELS ─── */
    .kcc-land__table-wrap { max-height: 220px; overflow-y: auto; }
    .kcc-land__table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
    .kcc-land__table thead th { padding: 0.35rem 0.4rem; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #6b7280; border-bottom: 1px solid rgba(0,0,0,0.08); position: sticky; top: 0; background: #ffffff; }
    .kcc-land__table tbody td { padding: 0.35rem 0.4rem; border-bottom: 1px solid rgba(0,0,0,0.04); color: #1a1a1a; }
    .kcc-land__table tbody tr:last-child td { border-bottom: none; }
    .kcc-land__dispo { font-size: 0.68rem; font-weight: 600; padding: 0.1rem 0.35rem; display: inline-block; }
    .kcc-land__dispo--ok { background: rgba(0,177,147,0.08); color: #00B193; }
    .kcc-land__dispo--ko { background: rgba(220,38,38,0.08); color: #dc2626; }

    .kcc-land__table-wrap::-webkit-scrollbar { width: 3px; }
    .kcc-land__table-wrap::-webkit-scrollbar-track { background: transparent; }
    .kcc-land__table-wrap::-webkit-scrollbar-thumb { background: #d1d5db; }

    /* ─── TIMELINE APPROBATIONS ─── */
    .kcc-land__timeline { display: flex; flex-direction: column; gap: 0; }
    .kcc-land__step { display: flex; align-items: flex-start; gap: 0.55rem; padding: 0.4rem 0; position: relative; }
    .kcc-land__step + .kcc-land__step::before { content: ""; position: absolute; left: 10px; top: -0.3rem; width: 1px; height: 0.7rem; background: rgba(0,0,0,0.1); }
    .kcc-land__dot { width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: #e5e7eb; color: #9ca3af; }
    .kcc-land__dot--ok { background: rgba(0,177,147,0.15); color: #00B193; }
    .kcc-land__dot--ko { background: rgba(220,38,38,0.15); color: #dc2626; }
    .kcc-land__dot--cur { background: rgba(59,130,246,0.15); color: #3b82f6; }
    .kcc-land__step-body { display: flex; flex-direction: column; }
    .kcc-land__step-name { font-weight: 600; font-size: 0.8rem; color: #1a1a1a; }
    .kcc-land__step-detail { font-size: 0.7rem; color: #6b7280; }

    /* ─── ZONE ACTION ─── */
    .kcc-land__action { padding: 0.75rem 1.25rem; background: rgba(0,177,147,0.03); border-top: 1px solid rgba(0,177,147,0.15); margin-top: auto; }
    .kcc-land__action--reject { background: rgba(220,38,38,0.03); border-top-color: rgba(220,38,38,0.15); }
    .kcc-land__textarea { width: 100%; padding: 0.5rem 0.65rem; font-family: inherit; font-size: 0.82rem; border: 1px solid rgba(0,0,0,0.12); background: #ffffff; resize: vertical; margin-top: 0.35rem; box-sizing: border-box; }
    .kcc-land__textarea:focus { outline: 2px solid #00B193; border-color: #00B193; }
    .kcc-land__warn { margin: 0.3rem 0 0; font-size: 0.7rem; color: #BB8748; }

    /* ─── FOOTER ─── */
    .kcc-land__footer { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border-top: 1px solid rgba(0,0,0,0.08); background: #f4f5f7; flex-shrink: 0; }
    .kcc-land__btn { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.5rem 1.1rem; font-size: 0.8rem; font-weight: 600; font-family: inherit; border: 1px solid transparent; cursor: pointer; transition: all 0.1s; }
    .kcc-land__btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .kcc-land__btn--ghost { background: #ffffff; color: #4a4a4a; border-color: rgba(0,0,0,0.12); }
    .kcc-land__btn--ghost:hover:not(:disabled) { background: #ebedf0; }
    .kcc-land__btn--primary { background: #00B193; color: #ffffff; border-color: #00B193; }
    .kcc-land__btn--primary:hover:not(:disabled) { background: #008F76; border-color: #008F76; }
    .kcc-land__btn--danger { background: #dc2626; color: #ffffff; border-color: #dc2626; }
