@namespace KCCMaterialFlow.Module.Shared.Components.Workflow
@using Radzen
@using Radzen.Blazor

@* Sélecteur d'approbateur - Simplifié *@

<RadzenDropDown @bind-Value="@SelectedApprover"
                Data="@Approvers"
                TextProperty="DisplayName"
                ValueProperty="Login"
                Placeholder="@Placeholder"
                Style="@Style"
                Disabled="@Disabled"
                AllowClear="true" />

@code {
    [Parameter] public string? SelectedApprover { get; set; }
    [Parameter] public EventCallback<string?> SelectedApproverChanged { get; set; }
    [Parameter] public IEnumerable<ApproverInfo>? Approvers { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Sélectionner...";
    [Parameter] public string? Style { get; set; }
    [Parameter] public bool Disabled { get; set; }

    public class ApproverInfo
    {
        public string Login { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string? Role { get; set; }
    }
}
