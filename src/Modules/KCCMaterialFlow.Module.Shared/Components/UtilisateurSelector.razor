@using KCCMaterialFlow.Module.Shared.Entities
@using KCCMaterialFlow.Module.Shared.Services
@inject IUtilisateurService UtilisateurService

<RadzenAutoComplete @bind-Value="@_searchText"
                    Data="@_utilisateurs"
                    TextProperty="NomComplet"
                    Placeholder="@Placeholder"
                    Disabled="@Disabled"
                    Style="@Style"
                    Class="@Class"
                    LoadData="@OnLoadData"
                    Change="@OnSearchTextChanged"
                    MinLength="@MinSearchLength"
                    FilterDelay="300"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" />

@if (_selectedUtilisateur != null && ShowSelectedInfo)
{
    <div class="mt-2 p-2 rz-background-color-info-lighter rz-border-radius">
        <div class="rz-text-body2">
            <strong>@_selectedUtilisateur.NomComplet</strong>
        </div>
        @if (!string.IsNullOrEmpty(_selectedUtilisateur.Fonction))
        {
            <div class="rz-text-caption">@_selectedUtilisateur.Fonction</div>
        }
        @if (!string.IsNullOrEmpty(_selectedUtilisateur.Departement))
        {
            <div class="rz-text-caption rz-color-secondary">@_selectedUtilisateur.Departement</div>
        }
    </div>
}

@code {
    private IReadOnlyList<Utilisateur> _utilisateurs = [];
    private Utilisateur? _selectedUtilisateur;
    private string? _searchText;
    private bool _isLoading;

    /// <summary>
    /// Valeur sélectionnée (IdUtilisateur)
    /// </summary>
    [Parameter]
    public int? Value { get; set; }

    /// <summary>
    /// Callback quand la valeur change
    /// </summary>
    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    /// <summary>
    /// Placeholder affiché
    /// </summary>
    [Parameter]
    public string Placeholder { get; set; } = "Rechercher un utilisateur...";

    /// <summary>
    /// Désactive le composant
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Style CSS inline
    /// </summary>
    [Parameter]
    public string? Style { get; set; } = "width: 100%";

    /// <summary>
    /// Classes CSS additionnelles
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Nombre minimum de caractères pour déclencher la recherche
    /// </summary>
    [Parameter]
    public int MinSearchLength { get; set; } = 2;

    /// <summary>
    /// Affiche les informations de l'utilisateur sélectionné
    /// </summary>
    [Parameter]
    public bool ShowSelectedInfo { get; set; } = true;

    /// <summary>
    /// Filtre par département
    /// </summary>
    [Parameter]
    public string? FilterByDepartement { get; set; }

    /// <summary>
    /// Filtre par rôle
    /// </summary>
    [Parameter]
    public string? FilterByRole { get; set; }

    /// <summary>
    /// Callback appelé quand la sélection change
    /// </summary>
    [Parameter]
    public EventCallback<Utilisateur?> OnSelectionChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Value.HasValue)
        {
            _selectedUtilisateur = await UtilisateurService.GetByIdAsync(Value.Value);
            _searchText = _selectedUtilisateur?.NomComplet;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Value.HasValue && (_selectedUtilisateur == null || _selectedUtilisateur.IdUtilisateur != Value.Value))
        {
            _selectedUtilisateur = await UtilisateurService.GetByIdAsync(Value.Value);
            _searchText = _selectedUtilisateur?.NomComplet;
        }
        else if (!Value.HasValue && _selectedUtilisateur != null)
        {
            _selectedUtilisateur = null;
            _searchText = null;
        }
    }

    private async Task OnLoadData(LoadDataArgs args)
    {
        if (_isLoading || string.IsNullOrWhiteSpace(args.Filter) || args.Filter.Length < MinSearchLength)
        {
            _utilisateurs = [];
            return;
        }

        _isLoading = true;
        try
        {
            IReadOnlyList<Utilisateur> results;

            if (!string.IsNullOrEmpty(FilterByDepartement))
            {
                results = await UtilisateurService.GetByDepartementAsync(FilterByDepartement);
                results = results.Where(u => 
                    u.NomComplet.Contains(args.Filter, StringComparison.OrdinalIgnoreCase) ||
                    u.Login.Contains(args.Filter, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }
            else if (!string.IsNullOrEmpty(FilterByRole))
            {
                results = await UtilisateurService.GetByRoleAsync(FilterByRole);
                results = results.Where(u =>
                    u.NomComplet.Contains(args.Filter, StringComparison.OrdinalIgnoreCase) ||
                    u.Login.Contains(args.Filter, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }
            else
            {
                results = await UtilisateurService.SearchAsync(args.Filter);
            }

            _utilisateurs = results;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnSearchTextChanged(object value)
    {
        var text = value?.ToString();
        
        // Chercher l'utilisateur correspondant au texte sélectionné
        var selected = _utilisateurs.FirstOrDefault(u => 
            u.NomComplet.Equals(text, StringComparison.OrdinalIgnoreCase));

        if (selected != null)
        {
            _selectedUtilisateur = selected;
            Value = selected.IdUtilisateur;
            await ValueChanged.InvokeAsync(Value);
            await OnSelectionChanged.InvokeAsync(selected);
        }
        else if (string.IsNullOrWhiteSpace(text))
        {
            _selectedUtilisateur = null;
            Value = null;
            await ValueChanged.InvokeAsync(null);
            await OnSelectionChanged.InvokeAsync(null);
        }
    }

    /// <summary>
    /// Récupère l'utilisateur actuellement sélectionné
    /// </summary>
    public Utilisateur? GetSelectedUtilisateur() => _selectedUtilisateur;

    /// <summary>
    /// Efface la sélection
    /// </summary>
    public async Task ClearAsync()
    {
        _searchText = null;
        _selectedUtilisateur = null;
        Value = null;
        await ValueChanged.InvokeAsync(null);
        await OnSelectionChanged.InvokeAsync(null);
        StateHasChanged();
    }

    /// <summary>
    /// Définit la sélection par login
    /// </summary>
    public async Task SetByLoginAsync(string login)
    {
        var user = await UtilisateurService.GetByLoginAsync(login);
        if (user != null)
        {
            _selectedUtilisateur = user;
            _searchText = user.NomComplet;
            Value = user.IdUtilisateur;
            await ValueChanged.InvokeAsync(Value);
            await OnSelectionChanged.InvokeAsync(user);
            StateHasChanged();
        }
    }
}
