@using KCCMaterialFlow.Module.Shared.Entities
@using KCCMaterialFlow.Module.Shared.Services
@inject IDepartementService DepartementService

<RadzenDropDown @bind-Value="@Value"
                Data="@_departements"
                TextProperty="NomDepartement"
                ValueProperty="IdDepartement"
                Placeholder="@Placeholder"
                AllowClear="@AllowClear"
                Disabled="@Disabled"
                Style="@Style"
                Class="@Class"
                Change="@OnValueChanged"
                LoadData="@LoadData"
                AllowFiltering="true"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                FilterOperator="StringFilterOperator.Contains" />

@code {
    private IReadOnlyList<Departement> _departements = [];
    private bool _isLoading;

    /// <summary>
    /// Valeur sélectionnée (IdDepartement)
    /// </summary>
    [Parameter]
    public int? Value { get; set; }

    /// <summary>
    /// Callback quand la valeur change
    /// </summary>
    [Parameter]
    public EventCallback<int?> ValueChanged { get; set; }

    /// <summary>
    /// Placeholder affiché quand aucune valeur n'est sélectionnée
    /// </summary>
    [Parameter]
    public string Placeholder { get; set; } = "Sélectionner un département...";

    /// <summary>
    /// Permet d'effacer la sélection
    /// </summary>
    [Parameter]
    public bool AllowClear { get; set; } = true;

    /// <summary>
    /// Désactive le composant
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Style CSS inline
    /// </summary>
    [Parameter]
    public string? Style { get; set; } = "width: 100%";

    /// <summary>
    /// Classes CSS additionnelles
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Callback appelé quand la sélection change
    /// </summary>
    [Parameter]
    public EventCallback<Departement?> OnSelectionChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadDepartements();
    }

    private async Task LoadDepartements()
    {
        if (_isLoading) return;
        
        _isLoading = true;
        try
        {
            _departements = await DepartementService.GetAllAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadData(LoadDataArgs args)
    {
        if (!_departements.Any())
        {
            await LoadDepartements();
        }
    }

    private async Task OnValueChanged(object value)
    {
        var newValue = value as int?;
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);

        // Notifier avec l'objet Departement complet
        var selectedDept = newValue.HasValue 
            ? _departements.FirstOrDefault(d => d.IdDepartement == newValue.Value)
            : null;
        await OnSelectionChanged.InvokeAsync(selectedDept);
    }

    /// <summary>
    /// Récupère le département actuellement sélectionné
    /// </summary>
    public Departement? GetSelectedDepartement()
    {
        return Value.HasValue 
            ? _departements.FirstOrDefault(d => d.IdDepartement == Value.Value)
            : null;
    }

    /// <summary>
    /// Force le rechargement des données
    /// </summary>
    public async Task RefreshAsync()
    {
        DepartementService.InvalidateCache();
        await LoadDepartements();
        StateHasChanged();
    }
}
