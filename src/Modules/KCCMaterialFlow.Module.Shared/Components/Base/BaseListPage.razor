@namespace KCCMaterialFlow.Module.Shared.Components.Base
@using Radzen
@using Radzen.Blazor
@typeparam TItem where TItem : class
@inject NavigationManager Navigation

@* Composant de base pour les pages de liste avec DataGrid, recherche et pagination *@

<PageHeader Title="@Title" BreadcrumbItems="@BreadcrumbItems">
    <Actions>
        @if (ShowCreateButton)
        {
            <RadzenButton Text="@CreateButtonText" 
                          ButtonStyle="ButtonStyle.Primary" 
                          Icon="add"
                          Click="@HandleCreate" />
        }
        @HeaderActions
    </Actions>
</PageHeader>

<RadzenCard class="mt-3">
    @* Barre de recherche et filtres *@
    @if (ShowSearchBar)
    {
        <div class="row mb-3">
            <div class="col-md-4">
                <RadzenTextBox @bind-Value="@SearchTerm" 
                               Placeholder="@SearchPlaceholder"
                               class="w-100"
                               Change="@OnSearchChanged" />
            </div>
            <div class="col-md-8 d-flex justify-content-end gap-2">
                @FilterContent
                @if (ShowRefreshButton)
                {
                    <RadzenButton Icon="refresh" 
                                  ButtonStyle="ButtonStyle.Light"
                                  Click="@HandleRefresh" />
                }
                @if (ShowExportButton)
                {
                    <RadzenButton Text="Exporter" 
                                  Icon="download"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@HandleExport" />
                }
            </div>
        </div>
    }

    @* Message d'erreur *@
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="mb-3">
            @ErrorMessage
        </RadzenAlert>
    }

    @* DataGrid *@
    <DataGrid TItem="TItem"
              Items="@Items"
              IsLoading="@IsLoading"
              TotalCount="@TotalCount"
              PageSize="@PageSize"
              CurrentPage="@CurrentPage"
              AllowSorting="@AllowSorting"
              AllowPaging="@AllowPaging"
              AllowFiltering="@AllowFiltering"
              EmptyMessage="@EmptyMessage"
              OnPageChanged="@HandlePageChanged"
              OnSortChanged="@HandleSortChanged"
              OnRowSelect="@HandleRowSelect">
        @GridColumns
    </DataGrid>
</RadzenCard>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public List<BreadcrumbItem>? BreadcrumbItems { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    [Parameter] public RenderFragment? FilterContent { get; set; }
    [Parameter] public RenderFragment? GridColumns { get; set; }

    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int PageSize { get; set; } = 20;
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string EmptyMessage { get; set; } = "Aucun élément trouvé.";

    [Parameter] public bool ShowSearchBar { get; set; } = true;
    [Parameter] public bool ShowCreateButton { get; set; } = true;
    [Parameter] public bool ShowRefreshButton { get; set; } = true;
    [Parameter] public bool ShowExportButton { get; set; } = false;
    [Parameter] public bool AllowSorting { get; set; } = true;
    [Parameter] public bool AllowPaging { get; set; } = true;
    [Parameter] public bool AllowFiltering { get; set; } = false;

    [Parameter] public string CreateButtonText { get; set; } = "Nouveau";
    [Parameter] public string? CreateNavigationUrl { get; set; }
    [Parameter] public string SearchPlaceholder { get; set; } = "Rechercher...";
    [Parameter] public string SearchTerm { get; set; } = string.Empty;

    [Parameter] public EventCallback OnCreate { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback OnExport { get; set; }
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    [Parameter] public EventCallback<SortChangedEventArgs> OnSortChanged { get; set; }
    [Parameter] public EventCallback<TItem> OnRowSelect { get; set; }

    private async Task HandleCreate()
    {
        if (OnCreate.HasDelegate)
        {
            await OnCreate.InvokeAsync();
        }
        else if (!string.IsNullOrEmpty(CreateNavigationUrl))
        {
            Navigation.NavigateTo(CreateNavigationUrl);
        }
    }

    private async Task HandleRefresh()
    {
        await OnRefresh.InvokeAsync();
    }

    private async Task HandleExport()
    {
        await OnExport.InvokeAsync();
    }

    private async Task OnSearchChanged()
    {
        await OnSearch.InvokeAsync(SearchTerm);
    }

    private async Task HandlePageChanged(int page)
    {
        CurrentPage = page;
        await OnPageChanged.InvokeAsync(page);
    }

    private async Task HandleSortChanged(SortChangedEventArgs args)
    {
        await OnSortChanged.InvokeAsync(args);
    }

    private async Task HandleRowSelect(TItem item)
    {
        await OnRowSelect.InvokeAsync(item);
    }
}
