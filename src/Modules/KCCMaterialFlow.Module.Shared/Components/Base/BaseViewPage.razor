@namespace KCCMaterialFlow.Module.Shared.Components.Base
@using Radzen
@using Radzen.Blazor
@typeparam TModel where TModel : class
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@* Composant de base pour les pages de visualisation read-only *@

<PageHeader Title="@Title" BreadcrumbItems="@BreadcrumbItems" />

<RadzenCard class="mt-3">
    @if (IsLoading)
    {
        <LoadingSpinner Text="Chargement..." />
    }
    else if (Model == null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat">
            @NotFoundMessage
        </RadzenAlert>
    }
    else
    {
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" class="mb-3">
                @ErrorMessage
            </RadzenAlert>
        }

        <div class="view-content">
            @ChildContent
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            @if (ShowBackButton)
            {
                <RadzenButton Text="@BackButtonText" 
                              ButtonStyle="ButtonStyle.Light" 
                              Icon="arrow_back"
                              Click="@HandleBack" />
            }

            @if (ShowEditButton && CanEdit)
            {
                <RadzenButton Text="Modifier" 
                              ButtonStyle="ButtonStyle.Primary" 
                              Icon="edit"
                              Click="@HandleEdit" />
            }

            @if (ShowPrintButton)
            {
                <RadzenButton Text="Imprimer" 
                              ButtonStyle="ButtonStyle.Secondary" 
                              Icon="print"
                              Click="@HandlePrint" />
            }

            @AdditionalButtons
        </div>
    }
</RadzenCard>

@code {
    [Parameter] public TModel? Model { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public List<BreadcrumbItem>? BreadcrumbItems { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? AdditionalButtons { get; set; }

    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string NotFoundMessage { get; set; } = "Élément non trouvé.";

    [Parameter] public bool ShowBackButton { get; set; } = true;
    [Parameter] public bool ShowEditButton { get; set; } = true;
    [Parameter] public bool ShowPrintButton { get; set; } = false;
    [Parameter] public bool CanEdit { get; set; } = true;

    [Parameter] public string BackButtonText { get; set; } = "Retour";
    [Parameter] public string? BackNavigationUrl { get; set; }
    [Parameter] public string? EditNavigationUrl { get; set; }

    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnPrint { get; set; }

    private async Task HandleBack()
    {
        if (OnBack.HasDelegate)
        {
            await OnBack.InvokeAsync();
        }
        else if (!string.IsNullOrEmpty(BackNavigationUrl))
        {
            Navigation.NavigateTo(BackNavigationUrl);
        }
        else
        {
            // Retour via historique du navigateur par défaut
            await JSRuntime.InvokeVoidAsync("history.back");
        }
    }

    private async Task HandleEdit()
    {
        if (OnEdit.HasDelegate)
        {
            await OnEdit.InvokeAsync();
        }
        else if (!string.IsNullOrEmpty(EditNavigationUrl))
        {
            Navigation.NavigateTo(EditNavigationUrl);
        }
    }

    private async Task HandlePrint()
    {
        await OnPrint.InvokeAsync();
    }
}
