@* Formulaire officiel SEC-FM-122(B), Rev-3 - BON DE SORTIE DE MATÉRIEL / PROPERTY REMOVAL PERMIT *@
@page "/bon-sortie/{Id:int}/print"
@attribute [Authorize]
@using KCCMaterialFlow.Module.BonSortie.Services
@using KCCMaterialFlow.Module.BonSortie.Entities
@inject IBonSortieService BonSortieService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Impression BSM @Id</PageTitle>

@if (isLoading)
{
    <div style="text-align:center;padding:50px;">Chargement...</div>
}
else if (bon == null)
{
    <div style="text-align:center;padding:50px;">Bon non trouvé (ID: @Id)</div>
}
else
{
    <div class="print-controls">
        <button @onclick="GoBack">← RETOUR</button>
        <button @onclick="PrintFormulaire">🖨 IMPRIMER</button>
    </div>

    <div class="a4-paper" id="printArea">
        @* ===== EN-TÊTE ===== *@
        <table class="header-tbl">
            <tr>
                <td style="width:20%"><small>Expire date:</small></td>
                <td style="width:60%;text-align:center"><img src="/images/kcc-logo.png" style="height:40px" /></td>
                <td style="width:20%;text-align:right">
                    <div class="validity-box">
                        <small>Date validité</small><br/>
                        <strong>@bon.DateExpiration.ToString("dd/MM/yyyy")</strong>
                    </div>
                </td>
            </tr>
        </table>
        <div style="text-align:right;font-size:9px;margin-bottom:5px">No : @bon.NumeroReference</div>

        @* ===== TITRE ===== *@
        <div class="title-bar">
            <strong>BON DE SORTIE DE MATÉRIEL</strong><br/>
            <span>PROPERTY REMOVAL PERMIT</span>
        </div>

        @* ===== INFORMATIONS DEMANDEUR ===== *@
        <table class="info-tbl">
            <tr><td class="lbl">Name/<u>Nom:</u></td><td>@bon.NomDemandeur</td></tr>
            <tr><td class="lbl">Function/<u>Fonction:</u></td><td>@bon.FonctionDemandeur</td></tr>
            <tr><td class="lbl">Department/<u>Département:</u></td><td>@bon.DepartementDemandeur</td></tr>
        </table>

        @* ===== TABLEAU DES MATÉRIELS ===== *@
        <table class="mat-tbl">
            <thead>
                <tr>
                    <th style="width:10%">QTY</th>
                    <th style="width:40%">DESCRIPTION</th>
                    <th style="width:25%">FROM</th>
                    <th style="width:25%">TO</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mat in bon.Materiels.Take(6))
                {
                    <tr>
                        <td style="text-align:center">@mat.Quantite.ToString("0.00")</td>
                        <td>@mat.Designation</td>
                        <td>@bon.Provenance</td>
                        <td>@bon.Destination</td>
                    </tr>
                }
                @for (int i = bon.Materiels.Count; i < 6; i++)
                {
                    <tr><td>&nbsp;</td><td></td><td></td><td></td></tr>
                }
                <tr class="total-row">
                    <td style="text-align:center;font-weight:bold">TOTAL</td>
                    <td></td>
                    <td style="text-align:center">@bon.Materiels.Sum(x => x.Quantite).ToString("0.00")</td>
                    <td></td>
                </tr>
            </tbody>
        </table>

        @* ===== MOTIF ===== *@
        <div class="motif-section">
            <span class="motif-bullet">•</span>
            <span class="motif-label">MOTIF:</span>
            <span class="motif-value">@bon.MotifSortie</span>
        </div>

        @* ===== SIGNATURES (sans bordures comme le formulaire officiel) ===== *@
        <table class="sig-tbl">
            <tr>
                <td>
                    <strong>Head of Department</strong><br/>
                    <small>Responsable du Département</small><br/>
                    <em>(Name /Nom Date – Signature )</em>
                </td>
                <td>
                    <strong>Head of KCC Department</strong><br/>
                    <small>Responsable du Département KCC</small><br/>
                    <em>(Name /Nom Date – Signature )</em>
                </td>
                <td>
                    <strong>Security Department</strong><br/>
                    <small>Département de Sécurité</small><br/>
                    <em>(Name /Nom Date– Signature )</em>
                </td>
            </tr>
        </table>

        @* ===== NOTE + QR CODE (QR en bas à droite comme demandé) ===== *@
        <table class="note-tbl">
            <tr>
                <td class="note-content">
                    <span style="color:red;font-weight:bold">NOTE:</span>
                    <ul>
                        <li><strong>This document is valid until expiry date</strong><br/>
                            <em>La validité de ce document est liée à sa date d'expiration.</em></li>
                        <li><strong>The owner of the document is responsible that the details of listed equipment are accurate.</strong><br/>
                            <em>Le signataire du document certifie que l'équipement listé est correct.</em></li>
                    </ul>
                </td>
                <td class="qr-box">
                    @if (!string.IsNullOrEmpty(bon.QRCodeBase64))
                    {
                        <img src="@bon.QRCodeBase64" alt="QR" style="width:70px;height:70px;border:1px solid #000" />
                    }
                    else
                    {
                        <div style="width:70px;height:70px;border:1px dashed #999;text-align:center;line-height:70px;font-size:8px">QR Code</div>
                    }
                </td>
            </tr>
        </table>

        @* ===== PIED DE PAGE ===== *@
        <div class="footer-bar">
            <span>SEC-FM-122(B), Rev-3</span>
            <span>CONFIDENTIEL</span>
            <span>Page 1 sur 1</span>
        </div>
    </div>
}
<script>
    function printFormulaire() {
        var content = document.getElementById('printArea').outerHTML;
        var printWindow = window.open('', '_blank', 'width=800,height=600');
        printWindow.document.write('<html><head><title>BSM - Impression</title>');
        printWindow.document.write('<style>');
        printWindow.document.write('* { margin: 0; padding: 0; box-sizing: border-box; }');
        printWindow.document.write('body { font-family: Arial, sans-serif; font-size: 13.5px; }');
        printWindow.document.write('.a4-paper { width: 210mm; height: 297mm; padding: 8mm 10mm; background: white; display: flex; flex-direction: column; }');
        printWindow.document.write('.header-tbl { width: 100%; border-collapse: collapse; }');
        printWindow.document.write('.validity-box { border: 1px solid #000; padding: 3px 8px; display: inline-block; }');
        printWindow.document.write('.title-bar { background: #d9d9d9; padding: 8px; text-align: center; border: 1px solid #000; font-size: 12px; }');
        printWindow.document.write('.info-tbl { width: 100%; border-collapse: collapse; }');
        printWindow.document.write('.info-tbl td { border: 1px solid #000; padding: 6px 8px; font-size: 12.5px; height: 12mm; }');
        printWindow.document.write('.info-tbl .lbl { background: #f5f5f5; font-weight: bold; width: 25%; }');
        printWindow.document.write('.mat-tbl { width: 100%; border-collapse: collapse; margin-top: 8px; flex-grow: 1; }');
        printWindow.document.write('.mat-tbl th, .mat-tbl td { border: 1px solid #000; padding: 4px 6px; font-size: 12.5px; }');
        printWindow.document.write('.mat-tbl th { background: #d9d9d9; text-align: center; height: 12mm; }');
        printWindow.document.write('.mat-tbl td { height: 15mm; vertical-align: middle; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }');
        printWindow.document.write('.total-row { background: #f5f5f5; }');
        printWindow.document.write('.motif-section { margin-top: 10px; font-size: 12px; }');
        printWindow.document.write('.motif-bullet { font-weight: bold; }');
        printWindow.document.write('.motif-label { font-weight: bold; }');
        printWindow.document.write('.motif-value { margin-left: 5px; }');
        printWindow.document.write('.sig-tbl { width: 100%; margin-top: 15px; border-collapse: collapse; }');
        printWindow.document.write('.sig-tbl td { text-align: center; padding: 8px 5px; vertical-align: top; font-size: 12.5px; width: 33.33%; border: none; height: 60px; }');
        printWindow.document.write('.sig-tbl em { font-size: 8px; }');
        printWindow.document.write('.note-tbl { width: 100%; margin-top: 10px; border-collapse: collapse; }');
        printWindow.document.write('.note-content { vertical-align: top; font-size: 11.5px; }');
        printWindow.document.write('.note-content ul { margin: 3px 0 0 15px; padding: 0; }');
        printWindow.document.write('.note-content li { margin-bottom: 3px; }');
        printWindow.document.write('.qr-box { width: 80px; vertical-align: top; text-align: right; }');
        printWindow.document.write('.footer-bar { display: flex; justify-content: space-between; margin-top: auto; padding-top: 5px; border-top: 1px solid #999; font-size: 9px; }');
        printWindow.document.write('@@media print { @@page { size: A4; margin: 0; } body { margin: 0; } .a4-paper { margin: 0; box-shadow: none; } }');
        printWindow.document.write('</style>');
        printWindow.document.write('</head><body>');
        printWindow.document.write(content);
        printWindow.document.write('</body></html>');
        printWindow.document.close();
        printWindow.focus();
        setTimeout(function() { printWindow.print(); }, 500);
    }
</script>

@code {
    [Parameter] public int Id { get; set; }
    private BonSortie? bon;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            bon = await BonSortieService.GetAsync(Id);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    private async Task PrintFormulaire()
    {
        await JS.InvokeVoidAsync("printFormulaire");
    }
}
