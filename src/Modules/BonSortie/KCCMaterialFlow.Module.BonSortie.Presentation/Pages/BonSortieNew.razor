    private void AddMaterielManuel()
    {
        if (string.IsNullOrWhiteSpace(newMaterielDesignation))
            return;

        var newMat = new MaterielSelectable
        {
            CodeProduitSerial = newMaterielCode,
            Designation = newMaterielDesignation.Trim(),
            QuantiteASortir = Math.Max(1, newMaterielQte),
            QuantiteDisponible = Math.Max(1, newMaterielQte),
            EstSelectionne = true
        };

        selectedMateriels.Add(newMat);

        // Réinitialiser les champs
        newMaterielCode = string.Empty;
        newMaterielDesignation = string.Empty;
        newMaterielQte = 1;
    }

    /// <summary>
    /// Ajoute une ligne vide dans la grille pour saisie inline (mode interne)
    /// </summary>
    private void AddEmptyMateriel()
    {
        var newMat = new MaterielSelectable
        {
            CodeProduitSerial = string.Empty,
            Designation = string.Empty,
            QuantiteASortir = 1,
            QuantiteDisponible = 9999, // Pas de limite pour les bons internes
            EstSelectionne = true
        };
        selectedMateriels.Add(newMat);
        // Forcer le rafraîchissement de la grille en créant une nouvelle référence de liste
        selectedMateriels = new List<MaterielSelectable>(selectedMateriels);
    }

    private void RemoveMateriel(MaterielSelectable mat)
    {
        selectedMateriels.Remove(mat);
        // Forcer le rafraîchissement de la grille
        selectedMateriels = new List<MaterielSelectable>(selectedMateriels);
    }

