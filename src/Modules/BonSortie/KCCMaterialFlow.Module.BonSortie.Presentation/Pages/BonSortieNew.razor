    // === LIFECYCLE ===
    protected override async Task OnInitializedAsync()
    {
        // Vérifier l'activité BSM_CREER
        if (!CurrentUserService.HasActivite("BSM_CREER"))
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        await LoadReferenceDataAsync();
        InitializeUserData();

        // Si on vient du bouton "Créer BSE" d'un BEM, pré-charger automatiquement
        if (PreselectedBemId.HasValue && PreselectedBemId.Value > 0)
        {
            await HandlePreselectedBemAsync(PreselectedBemId.Value);
        }
        else
        {
            // Mode INTERNE par défaut : ajouter une ligne vide pour commencer
            AddEmptyMateriel();
        }

        isLoading = false;
    }

    /// <summary>
    /// Gère le pré-chargement d'un BEM depuis le paramètre URL (bouton "Créer BSE")
    /// </summary>
    private async Task HandlePreselectedBemAsync(int bemId)
    {
        fromBemLink = true;

        // Charger les détails du BEM
        selectedBemDetails = await BonEntreeLockService.GetDetailsForSortieAsync(bemId);

        if (selectedBemDetails == null)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "BEM non trouvé",
                $"Le bon d'entrée #{bemId} n'est pas disponible pour sortie.");
            fromBemLink = false;
            return;
        }

        // Pré-remplir les matériels disponibles et les sélectionner tous
        materielsBemSelectables = selectedBemDetails.Materiels
            .Where(m => m.QuantiteDisponible > 0)
            .Select(m => new MaterielSelectable
            {
                MaterielEntreeId = m.IdMateriel,
                BonEntreeId = selectedBemDetails.IdBon,
                CodeProduitSerial = m.CodeProduitSerial,
                Designation = m.Designation,
                QuantiteInitiale = m.QuantiteInitiale,
                QuantiteDisponible = m.QuantiteDisponible,
                QuantiteASortir = m.QuantiteDisponible, // Pré-sélectionner toute la quantité disponible
                EstSelectionne = true // Tous sélectionnés par défaut
            }).ToList();

        // Copier vers les matériels sélectionnés
        selectedMateriels = materielsBemSelectables.ToList();

        // Auto-remplir FROM depuis la destination du BEM
        var matchedSite = sites.FirstOrDefault(s => s.Nom.Equals(selectedBemDetails.Destination, StringComparison.OrdinalIgnoreCase));
        if (matchedSite != null)
        {
            siteFromId = matchedSite.IdSite;
            destinationFromBem = true;
            // Si TO était égal au nouveau FROM, le réinitialiser
            if (siteToId.HasValue && siteToId.Value == siteFromId.Value)
            {
                siteToId = null;
            }
        }

        // Déterminer et pré-sélectionner le motif en fonction du HostDepartment
        AutoSelectMotifFromBem();

        NotificationService.Notify(NotificationSeverity.Info, "BEM lié",
            $"Bon d'entrée {selectedBemDetails.NumeroReference} pré-chargé avec {selectedMateriels.Count} matériel(s).");
    }

    /// <summary>
    /// Sélectionne automatiquement le motif approprié basé sur le HostDepartment du BEM
    /// </summary>
    private void AutoSelectMotifFromBem()
    {
        if (selectedBemDetails == null) return;

        var hostDept = selectedBemDetails.HostDepartment?.Trim().ToUpperInvariant() ?? "";

        // Définir les motifs autorisés et sélectionner le premier applicable
        if (hostDept.Contains("IT") || hostDept.Contains("INFORMATIQUE"))
        {
            allowedMotifGroupsByBem = new HashSet<string> { "INFO" };
            SelectMotifGroup("INFO");
        }
        else if (hostDept.Contains("ENV") || hostDept.Contains("ENVIRONNEMENT"))
        {
            allowedMotifGroupsByBem = new HashSet<string> { "RESIDU", "RADIO_PROT", "MODIF" };
            // Sélectionner RESIDU par défaut pour ENV
            SelectMotifGroup("RESIDU");
        }
        else
        {
            // Département standard : autoriser FIN_CHANTIER par défaut
            allowedMotifGroupsByBem = new HashSet<string> { "FIN_CHANTIER", "CIRC", "PRET" };
            SelectMotifGroup("FIN_CHANTIER");
        }

        motif.RecalculateActiveGroup();
    }
    
    private async Task LoadReferenceDataAsync()
    {
        sites = (await ReferenceDataService.GetSitesAsync()).OrderBy(s => s.OrdreAffichage).ToList();
        
        var chkList = (await ReferenceDataService.GetCheckpointsAsync()).OrderBy(c => c.OrdreDefaut).ToList();
        checkpoints = chkList.Select(c => new CheckpointSelection { Checkpoint = c }).ToList();
        
        bemsDisponiblesAll = (await BonEntreeLockService.GetAllAvailableForSortieAsync()).ToList();
        ApplyBemFilterByMotif();
    }
    
    private void InitializeUserData()
    {
        var currentUser = CurrentUserService.GetCurrentUser();
        if (currentUser != null)
        {
            model.NomDemandeur = currentUser.DisplayName ?? currentUser.Login;
            model.FonctionDemandeur = currentUser.Function ?? string.Empty;
            model.DepartementDemandeur = currentUser.Department ?? string.Empty;
        }
    }
    
    // === MOTIF ===
    private void OnMotifChanged()
    {
        motif.RecalculateActiveGroup();

        if (motif.ActiveGroup != null && !IsGroupAllowed(motif.ActiveGroup))
        {
            ClearMotifSelection();
            NotificationService.Notify(NotificationSeverity.Warning, "Motif", "Ce motif n'est pas autorisé pour le département du BEM sélectionné.");
        }

        ApplyBemFilterByMotif();
    }
    
    private bool IsExterne() => motif.IsExterne();
    
    // === BEM ===
    private async Task OnBemSelectedRadzen(object args)
    {
        if (args is int bemId && bemId > 0)
        {
            selectedBemDetails = await BonEntreeLockService.GetDetailsForSortieAsync(bemId);
            
            if (selectedBemDetails != null)
            {
                materielsBemSelectables = selectedBemDetails.Materiels
                    .Where(m => m.QuantiteDisponible > 0)
                    .Select(m => new MaterielSelectable
                    {
                        MaterielEntreeId = m.IdMateriel,
                        BonEntreeId = selectedBemDetails.IdBon,
                        CodeProduitSerial = m.CodeProduitSerial,
                        Designation = m.Designation,
                        QuantiteInitiale = m.QuantiteInitiale,
                        QuantiteDisponible = m.QuantiteDisponible,
                        QuantiteASortir = Math.Min(1, m.QuantiteDisponible)
                    }).ToList();
                
                // Auto-remplir FROM depuis la destination du BEM (provenance = là où le matériel se trouve)
                var matchedSite = sites.FirstOrDefault(s => s.Nom.Equals(selectedBemDetails.Destination, StringComparison.OrdinalIgnoreCase));
                if (matchedSite != null)
                {
                    siteFromId = matchedSite.IdSite;
                    destinationFromBem = true;
                    // Si TO était égal au nouveau FROM, le réinitialiser
                    if (siteToId.HasValue && siteToId.Value == siteFromId.Value)
                    {
                        siteToId = null;
                    }
                }
                
                selectedMateriels.Clear();

                ApplyMotifConstraintsFromSelectedBem();
            }
        }
        else
        {
            selectedBemDetails = null;
            materielsBemSelectables.Clear();
            selectedMateriels.Clear();
            siteFromId = null;
            destinationFromBem = false;
            allowedMotifGroupsByBem = null;
        }
    }

    private void ApplyMotifConstraintsFromSelectedBem()
    {
        allowedMotifGroupsByBem = ResolveAllowedMotifGroupsFromSelectedBem();

        if (allowedMotifGroupsByBem == null || allowedMotifGroupsByBem.Count == 0)
        {
            return;
        }

        if (allowedMotifGroupsByBem.SetEquals(new[] { "INFO" }))
        {
            SelectMotifGroup("INFO");
            NotificationService.Notify(NotificationSeverity.Info, "Motif", "BEM IT détecté : motif Informatique coché automatiquement.");
            ApplyBemFilterByMotif();
            return;
        }

        if (motif.ActiveGroup != null && !allowedMotifGroupsByBem.Contains(motif.ActiveGroup))
        {
            ClearMotifSelection();
        }
    }

    private HashSet<string>? ResolveAllowedMotifGroupsFromSelectedBem()
    {
        var hostDept = selectedBemDetails?.HostDepartment?.Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(hostDept))
        {
            return null;
        }

        if (hostDept.Contains("IT"))
        {
            return ["INFO"];
        }

        if (hostDept.Contains("ENV"))
        {
            return ["RESIDU", "RADIO_PROT", "MODIF"];
        }

        return null;
    }

    private bool IsGroupAllowed(string group)
    {
        return allowedMotifGroupsByBem == null || allowedMotifGroupsByBem.Contains(group);
    }

    private void ClearMotifSelection()
    {
        motif.FinChantier = false;
        motif.FinContrat = false;
        motif.MaterielUsage = false;
        motif.MaterielDeclasse = false;
        motif.Residu = false;
        motif.Dechet = false;
        motif.Emballage = false;
        motif.MaterielDesaffecte = false;
        motif.RadioProtection = false;
        motif.Troxilaire = false;
        motif.Modification = false;
        motif.Reparation = false;
        motif.Renovation = false;
        motif.Informatique = false;
        motif.Circulaire = false;
        motif.PriseEnPret = false;
        motif.RecalculateActiveGroup();
    }

    private void SelectMotifGroup(string group)
    {
        ClearMotifSelection();

        switch (group)
        {
            case "INFO":
                motif.Informatique = true;
                break;
            case "CIRC":
                motif.Circulaire = true;
                break;
            case "PRET":
                motif.PriseEnPret = true;
                break;
            case "RESIDU":
                motif.Residu = true;
                break;
            case "RADIO_PROT":
                motif.RadioProtection = true;
                break;
            case "MODIF":
                motif.Modification = true;
                break;
            case "FIN_CHANTIER":
                motif.FinChantier = true;
                break;
        }

        motif.RecalculateActiveGroup();
    }

    private void ApplyBemFilterByMotif()
    {
        expectedHostDepartmentFilter = ResolveExpectedHostDepartmentFromMotif();

        if (string.IsNullOrWhiteSpace(expectedHostDepartmentFilter))
        {
            bemsDisponibles = bemsDisponiblesAll.ToList();
        }
        else
        {
            bemsDisponibles = bemsDisponiblesAll
                .Where(b => !string.IsNullOrWhiteSpace(b.HostDepartment)
                         && b.HostDepartment.Contains(expectedHostDepartmentFilter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        if (selectedBemDetails != null && !bemsDisponibles.Any(b => b.IdBon == selectedBemDetails.IdBon))
        {
            selectedBemDetails = null;
            materielsBemSelectables.Clear();
            selectedMateriels.Clear();
            siteFromId = null;
            destinationFromBem = false;
        }
    }

    private string? ResolveExpectedHostDepartmentFromMotif()
    {
        var raisonCode = motif.GetRaisonSortieCode()?.Trim().ToUpperInvariant();
        if (raisonCode == "INFO") return "IT";
        if (raisonCode is "RESIDU" or "RADIO_PROT" or "MODIF") return "ENV";
        return null;
    }

    /// <summary>
    /// Handler appelé lorsque le site FROM change - réinitialise TO si égal à FROM.
    /// </summary>
    private void OnSiteFromChanged(object args)
    {
        // Si TO est maintenant égal à FROM, le réinitialiser
        if (siteToId.HasValue && siteFromId.HasValue && siteToId.Value == siteFromId.Value)
        {
            siteToId = null;
        }
    }

