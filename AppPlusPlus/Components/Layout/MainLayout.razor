@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionService PermissionService
@implements IDisposable
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.Globalization

<MudThemeProvider Theme="_appTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_isLoginPage || !_isAuthenticated)
{
    @Body
}
else
{
    <div class="app-layout">

        <!-- ══════════════ SIDEBAR ══════════════ -->
        <aside class="sidebar @(_sidebarCollapsed ? "sidebar--collapsed" : "")">

            <!-- Brand -->
            <div class="sb-brand">
                <div class="sb-brand-icon">
                    <i class="ti ti-rocket"></i>
                </div>
                @if (!_sidebarCollapsed)
                {
                    <div class="sb-brand-text">
                        <p class="sb-brand-name">@AppSettings.AppName</p>
                        <p class="sb-brand-sub">Gestion commerciale</p>
                    </div>
                }
            </div>

            <!-- Nav -->
            <nav class="sb-nav">

                @* ── PRINCIPAL ── *@
                @if (!_sidebarCollapsed)
                {
                    <p class="sb-section-label">PRINCIPAL</p>
                }

                @if (CanRead(AppFunctions.Dashboard))
                {
                    <a href="/" title="@(_sidebarCollapsed ? "Tableau de bord" : null)"
                       class="sb-item @(IsNavActive("/") ? "sb-item--active" : "")">
                        <i class="ti ti-layout-dashboard sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Tableau de bord</span> }
                    </a>
                }

                @if (CanRead(AppFunctions.Vente) || CanRead(AppFunctions.Facturation))
                {
                    <a href="/vente" title="@(_sidebarCollapsed ? "Ventes" : null)"
                       class="sb-item @(IsNavActive("/vente") ? "sb-item--active" : "")">
                        <i class="ti ti-receipt sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Ventes</span> }
                    </a>
                }

                @if (CanRead(AppFunctions.Stock) || CanRead(AppFunctions.Approvisionnement))
                {
                    <a href="/stock" title="@(_sidebarCollapsed ? "Articles" : null)"
                       class="sb-item @(IsNavActive("/stock", "/gestion/article", "/gestion/approvisionnement", "/gestion/transformation", "/gestion/parametre-article") ? "sb-item--active" : "")">
                        <i class="ti ti-box-seam sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Articles</span> }
                    </a>
                }

                @if (CanRead(AppFunctions.CommandesClients) || CanRead(AppFunctions.CommandesInternes))
                {
                    <a href="/commandes" title="@(_sidebarCollapsed ? "Commandes" : null)"
                       class="sb-item @(IsNavActive("/commandes", "/gestion/commande", "/gestion/client", "/gestion/vente") ? "sb-item--active" : "")">
                        <i class="ti ti-shopping-cart sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Commandes</span> }
                    </a>
                }

                @* ── ANALYSE ── *@
                @if (!_sidebarCollapsed)
                {
                    <p class="sb-section-label">ANALYSE</p>
                }

                @if (CanRead(AppFunctions.Rapports))
                {
                    <a href="/rapports" title="@(_sidebarCollapsed ? "Rapports" : null)"
                       class="sb-item @(IsNavActive("/rapports", "/rapport") ? "sb-item--active" : "")">
                        <i class="ti ti-chart-bar sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Rapports</span> }
                    </a>
                }

                @* ── SYSTÈME ── *@
                @if (!_sidebarCollapsed)
                {
                    <p class="sb-section-label">SYSTÈME</p>
                }

                @if (CanRead(AppFunctions.Administration))
                {
                    <a href="/administration" title="@(_sidebarCollapsed ? "Administration" : null)"
                       class="sb-item @(IsNavActive("/administration", "/admin/") ? "sb-item--active" : "")">
                        <i class="ti ti-settings-2 sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Administration</span> }
                    </a>
                }

                @if (CanRead(AppFunctions.Parametres))
                {
                    <a href="/settings" title="@(_sidebarCollapsed ? "Paramètres" : null)"
                       class="sb-item @(IsNavActive("/settings") ? "sb-item--active" : "")">
                        <i class="ti ti-adjustments sb-icon"></i>
                        @if (!_sidebarCollapsed) { <span>Paramètres</span> }
                    </a>
                }

            </nav>

            <!-- Footer : collapse + logout -->
            <div class="sb-footer">
                <button class="sb-footer-btn" @onclick="@(() => _sidebarCollapsed = !_sidebarCollapsed)"
                        title="@(_sidebarCollapsed ? "Développer" : "Réduire")">
                    <i class="ti @(_sidebarCollapsed ? "ti-chevron-right" : "ti-chevron-left") sb-icon"></i>
                    @if (!_sidebarCollapsed) { <span>Réduire</span> }
                </button>
                <a href="/auth/logout" class="sb-footer-btn sb-footer-btn--danger"
                   title="@(_sidebarCollapsed ? "Déconnexion" : null)">
                    <i class="ti ti-logout sb-icon"></i>
                    @if (!_sidebarCollapsed) { <span>Déconnexion</span> }
                </a>
            </div>
        </aside>

        <!-- ══════════════ MAIN AREA ══════════════ -->
        <div class="main-area">

            <!-- TOPBAR -->
            <header class="topbar">
                <!-- Page title + date -->
                <div class="topbar-title">
                    <h1 class="topbar-page-name">@_pageTitle</h1>
                    <div class="topbar-date">
                        <i class="ti ti-calendar-event" style="font-size:13px;"></i>
                        <span>@_todayLabel</span>
                    </div>
                </div>

                <!-- Spacer -->
                <div style="flex:1;"></div>

                <!-- Action buttons -->
                <div class="topbar-actions">
                    <button class="topbar-btn" title="Aide">
                        <i class="ti ti-help"></i>
                    </button>
                    <button class="topbar-btn position-relative" title="Notifications">
                        <i class="ti ti-bell"></i>
                    </button>
                </div>

                <!-- User dropdown (Blazor-managed) -->
                <div class="dropdown" tabindex="-1" @onfocusout="@(() => _profileOpen = false)">
                    <div class="topbar-user" role="button" tabindex="0" @onclick="@(() => _profileOpen = !_profileOpen)"
                         @onclick:stopPropagation>
                        <div class="topbar-avatar">
                            <i class="ti ti-user"></i>
                        </div>
                        <div class="topbar-user-info">
                            <span class="topbar-user-name">@_currentUserName</span>
                            <span class="topbar-user-role">@_currentUserRole</span>
                        </div>
                        <i class="ti ti-chevron-down" style="font-size:14px;color:#a3a3a3;"></i>
                    </div>
                    <div class="dropdown-menu dropdown-menu-end p-0 @(_profileOpen ? "show" : "")" style="min-width:200px;">
                        <div class="d-flex gap-3 align-items-center border-bottom px-3 py-3">
                            <div class="avatar avatar-md" style="background:rgba(0,177,147,0.12);">
                                <span class="avatar-initials" style="color:#00B193;font-size:14px;">
                                    <i class="ti ti-user"></i>
                                </span>
                            </div>
                            <div>
                                <p class="mb-0 small fw-semibold">@_currentUserName</p>
                                <p class="mb-0 small text-muted">@_currentUserRole</p>
                            </div>
                        </div>
                        <div class="p-2 d-flex flex-column gap-1 small">
                            <a href="/profile" class="dropdown-item">
                                <i class="ti ti-user me-2"></i> Mon profil
                            </a>
                            @if (CanRead(AppFunctions.Parametres))
                            {
                                <a href="/settings" class="dropdown-item">
                                    <i class="ti ti-adjustments me-2"></i> Paramètres
                                </a>
                            }
                            <hr class="my-1" />
                            <a href="/auth/logout" class="dropdown-item text-danger">
                                <i class="ti ti-logout me-2"></i> Déconnexion
                            </a>
                        </div>
                    </div>
                </div>
            </header>

            <!-- CONTENT -->
            <main class="page-content">
                <div class="page-shell">
                    @if (_hasCurrentRouteAccess)
                    {
                        @Body
                    }
                    else
                    {
                        <div class="card mx-auto mt-5" style="max-width:720px;">
                            <div class="card-body text-center p-5">
                                <i class="ti ti-lock" style="font-size:42px;color:#f59e0b;"></i>
                                <h5 class="fw-bold mt-3">Accès refusé</h5>
                                <p class="text-muted mx-auto" style="max-width:520px;">
                                    Votre rôle ne possède pas la fonction nécessaire pour afficher cette page.
                                </p>
                                <button class="btn btn-primary" @onclick="@(() => Nav.NavigateTo(GetFirstAccessibleRoute()))">
                                    <i class="ti ti-home me-1"></i> Retour
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </main>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    // MudBlazor Theme with new color palette
    private readonly MudTheme _appTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#253C45",
            Secondary = "#00B193",
            Tertiary = "#3b82f6",
            Error = "#A61B0C",
            Warning = "#f59e0b",
            Success = "#00B193",
            Info = "#3b82f6",
            Background = "#f8fafc",
            Surface = "#ffffff",
            AppbarBackground = "#253C45",
            AppbarText = "#ffffff",
            DrawerBackground = "#253C45",
            DrawerText = "rgba(255,255,255,0.75)",
            DrawerIcon = "rgba(255,255,255,0.6)"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "0"
        }
    };

    private bool _sidebarCollapsed = true;
    private bool _profileOpen;
    private string _pageTitle = "Tableau de bord";
    private string _todayLabel = "";
    private string _currentUserName = "Utilisateur";
    private string _currentUserRole = "Aucun rôle";
    private string _currentPath = "/";
    private bool _isAuthenticated;
    private bool _isAdministrator;
    private bool _hasCurrentRouteAccess = true;
    private PermissionSnapshot _permissions = PermissionSnapshot.Empty;

    private bool _isLoginPage => _currentPath.StartsWith("/login", StringComparison.OrdinalIgnoreCase);

    // Map URL prefixes to breadcrumb labels
    private static readonly (string prefix, string label, string icon)[] _routes = new[]
    {
        // Ventes
        ("/vente/facturation", "Ventes > Facturation", "shopping_cart_checkout"),
        ("/vente/facture/print", "Ventes > Impression facture", "print"),
        ("/vente/livraison", "Ventes > Livraison", "local_shipping"),
        ("/vente/payement", "Ventes > Paiements", "payments"),
        ("/vente", "Ventes", "point_of_sale"),
        // Articles
        ("/gestion/article/nouveau", "Articles > Nouvel article", "add_circle"),
        ("/gestion/article/modifier", "Articles > Modifier article", "edit"),
        ("/gestion/article", "Articles > Catalogue", "category"),
        ("/gestion/approvisionnement", "Articles > Approvisionnement", "add_shopping_cart"),
        ("/gestion/parametre-article", "Articles > Paramètres article", "tune"),
        ("/gestion/transformation", "Articles > Transformation", "transform"),
        ("/stock", "Articles", "inventory_2"),
        // Commandes
        ("/gestion/commande", "Commandes > Commandes internes", "assignment"),
        ("/gestion/client", "Commandes > Clients", "people"),
        ("/gestion/vente", "Commandes > Commandes clients", "storefront"),
        ("/commandes", "Commandes & Clients", "shopping_cart"),
        // Rapports
        ("/rapport/appro-ben", "Rapports > Appro & B\u00e9n\u00e9fice", "analytics"),
        ("/rapport/commande", "Rapports > Commandes", "list_alt"),
        ("/rapport/stock", "Rapports > Stock", "inventory"),
        ("/rapport/vente-mois", "Rapports > Ventes mensuelles", "calendar_month"),
        ("/rapport/vente-appro", "Rapports > Ventes & Appro", "compare_arrows"),
        ("/rapport/vente", "Rapports > Ventes", "trending_up"),
        ("/rapports", "Rapports", "assessment"),
        // Administration
        ("/admin/facture", "Administration > Gestion factures", "receipt"),
        ("/admin/livraison-payement", "Administration > Gestion livraisons", "local_shipping"),
        ("/admin/periode-gestion", "Administration > P\u00e9riodes", "date_range"),
        ("/admin/utilisateur", "Administration > Utilisateurs", "manage_accounts"),
        ("/admin/taux", "Administration > Taux", "percent"),
        ("/admin/versement", "Administration > Versements", "account_balance"),
        ("/administration", "Administration", "admin_panel_settings"),
    };

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        _currentPath = new Uri(Nav.Uri).AbsolutePath;
        UpdatePageTitle(Nav.Uri);
        _todayLabel = DateTime.Now.ToString("dddd d MMMM yyyy", new CultureInfo("fr-FR"));
        await RefreshSecurityStateAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender) => Task.CompletedTask;

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentPath = new Uri(e.Location).AbsolutePath;
        UpdatePageTitle(e.Location);
        _profileOpen = false;
        await RefreshSecurityStateAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void UpdatePageTitle(string url)
    {
        var path = new Uri(url).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        foreach (var (prefix, label, _) in _routes)
        {
            if (path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            {
                // Keep only the last segment after " > " for the topbar title
                var parts = label.Split(" > ");
                _pageTitle = parts[^1];
                return;
            }
        }
        _pageTitle = "Tableau de bord";
    }

    // IsNavActive helper — returns true if current path matches any of the given prefixes
    private bool IsNavActive(params string[] prefixes)
    {
        var path = _currentPath.TrimEnd('/').ToLowerInvariant();
        foreach (var prefix in prefixes)
        {
            var rawPrefix = prefix.ToLowerInvariant();
            var p = rawPrefix.TrimEnd('/');
            if (rawPrefix == "/")
            {
                if (path == "") return true;
            }
            else if (path == p || path.StartsWith(p + "/"))
            {
                return true;
            }
        }
        return false;
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await RefreshSecurityStateAsync(task);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshSecurityStateAsync(Task<AuthenticationState>? authTask = null)
    {
        var authState = authTask is null
            ? await AuthStateProvider.GetAuthenticationStateAsync()
            : await authTask;

        var user = authState.User;
        _isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (user.Identity?.IsAuthenticated == true)
        {
            var login = user.FindFirst("login")?.Value
                ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            _currentUserName = user.FindFirst("login")?.Value
                ?? user.FindFirst(ClaimTypes.Name)?.Value
                ?? "Utilisateur";
            _currentUserRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "Aucun rôle";
            _isAdministrator = AppFunctions.Normalize(_currentUserRole) == "administrateur";
            _permissions = await PermissionService.GetPermissionsAsync(login);
            _hasCurrentRouteAccess = HasRouteReadAccess(_currentPath);

            // Redirect to first accessible page if current route is not allowed
            if (!_hasCurrentRouteAccess)
            {
                var target = GetFirstAccessibleRoute();
                if (target != _currentPath)
                {
                    Nav.NavigateTo(target);
                    return;
                }
            }

            return;
        }

        _currentUserName = "Invité";
        _currentUserRole = "Non connecté";
        _isAdministrator = false;
        _permissions = PermissionSnapshot.Empty;
        _hasCurrentRouteAccess = true;
    }

    private bool CanRead(string functionName) => _isAdministrator || _permissions.CanRead(functionName);

    private string GetFirstAccessibleRoute()
    {
        if (CanRead(AppFunctions.Dashboard)) return "/";
        if (CanRead(AppFunctions.Vente) || CanRead(AppFunctions.Facturation)) return "/vente";
        if (CanRead(AppFunctions.Stock) || CanRead(AppFunctions.Approvisionnement)) return "/stock";
        if (CanRead(AppFunctions.CommandesClients) || CanRead(AppFunctions.CommandesInternes)) return "/commandes";
        if (CanRead(AppFunctions.Rapports)) return "/rapports";
        if (CanRead(AppFunctions.Administration)) return "/administration";
        if (CanRead(AppFunctions.Parametres)) return "/settings";
        return "/profile";
    }

    private bool HasRouteReadAccess(string path)
    {
        var normalizedPath = (path ?? "/").Trim().ToLowerInvariant();

        if (normalizedPath.StartsWith("/commandes"))
            return CanRead(AppFunctions.CommandesClients) || CanRead(AppFunctions.CommandesInternes);

        var requiredFunction = GetRequiredFunction(path);
        return string.IsNullOrWhiteSpace(requiredFunction) || CanRead(requiredFunction);
    }

    private static string? GetRequiredFunction(string path)
    {
        var normalizedPath = (path ?? "/").Trim().ToLowerInvariant();

        if (normalizedPath.StartsWith("/login") || normalizedPath.StartsWith("/profile"))
            return null;

        if (normalizedPath == "/")
            return AppFunctions.Dashboard;

        if (normalizedPath.StartsWith("/settings"))
            return AppFunctions.Parametres;

        if (normalizedPath.StartsWith("/administration") || normalizedPath.StartsWith("/admin/"))
            return AppFunctions.Administration;

        if (normalizedPath.StartsWith("/rapports") || normalizedPath.StartsWith("/rapport/"))
            return AppFunctions.Rapports;

        if (normalizedPath.StartsWith("/vente/facturation") || normalizedPath.StartsWith("/vente/facture/print"))
            return AppFunctions.Facturation;

        if (normalizedPath.StartsWith("/vente"))
            return AppFunctions.Vente;

        if (normalizedPath.StartsWith("/stock")
            || normalizedPath.StartsWith("/gestion/article")
            || normalizedPath.StartsWith("/gestion/transformation")
            || normalizedPath.StartsWith("/gestion/parametre-article"))
            return AppFunctions.Stock;

        if (normalizedPath.StartsWith("/gestion/approvisionnement"))
            return AppFunctions.Approvisionnement;

        if (normalizedPath.StartsWith("/gestion/commande"))
            return AppFunctions.CommandesInternes;

        if (normalizedPath.StartsWith("/gestion/client")
            || normalizedPath.StartsWith("/gestion/vente"))
            return AppFunctions.CommandesClients;

        return null;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}
