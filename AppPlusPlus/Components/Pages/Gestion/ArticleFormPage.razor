@page "/gestion/article/nouveau"
@page "/gestion/article/modifier/{IdArticle}"
@rendermode InteractiveServer
@using MudBlazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>@AppSettings.AppName — @(_isEdit ? "Modifier article" : "Nouvel article")</PageTitle>

<div class="card mb-2">
    <div class="card-body py-2">
        <div class="d-flex align-items-center justify-content-between">
            <h5 style="font-weight:700;" class="m-0">
                @(_isEdit ? "Modifier article" : "Nouvel article")
            </h5>
            <div class="d-flex" style="gap:0.5rem;">
                <button type="button" class="btn btn-primary btn-sm" @onclick="@OnSave">
                    <i class="bi bi-check-lg me-1"></i>Enregistrer
                </button>
                <button type="button" class="btn btn-secondary btn-sm" @onclick="@OnCancel">
                    <i class="bi bi-arrow-left me-1"></i>Annuler
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body py-3">
        <!-- Ligne 1 : Code, Description, Prix, Monnais, Seuil, Commentaire -->
        <div class="row g-2 mb-2">
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Code</label>
                <input type="text" @bind="_article.IdArticle" maxlength="100" readonly="@_isEdit" class="form-control form-control-sm" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Description</label>
                <input type="text" @bind="_article.Description" maxlength="50" class="form-control form-control-sm" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Prix</label>
                <MudNumericField @bind-Value="_article.Price" T="double" Format="N2" Margin="Margin.Dense" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Monnais</label>
                <MudSelect @bind-Value="_article.IdMonais" T="int" Margin="Margin.Dense" Dense="true">
                    @foreach (var m in _monnaies)
                    {
                        <MudSelectItem T="int" Value="@m.IdMonais">@m.DescriptionMonais</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Seuil alerte</label>
                <MudNumericField @bind-Value="_article.Soeuil" T="int" Min="0" Margin="Margin.Dense" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label mb-1">Commentaire</label>
                <input type="text" @bind="_article.DescriptionI" maxlength="50" class="form-control form-control-sm" />
            </div>
        </div>

        <!-- Ligne 2 : Marque, Type, Category, Mesure -->
        <div class="row g-2 mb-2">
            <div class="col-6 col-md-3">
                <label class="form-label mb-1">Marque</label>
                <MudSelect @bind-Value="_article.IdMarque" T="int" Margin="Margin.Dense" Dense="true">
                    @foreach (var m in _marques)
                    {
                        <MudSelectItem T="int" Value="@m.IdMarque">@m.DescriptionMarque</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1">Type</label>
                <MudSelect @bind-Value="_article.IdType" T="int" Margin="Margin.Dense" Dense="true">
                    @foreach (var t in _types)
                    {
                        <MudSelectItem T="int" Value="@t.IdType">@t.DescriptionType</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1">Catégorie</label>
                <MudSelect @bind-Value="_article.IdCategory" T="int" Margin="Margin.Dense" Dense="true">
                    @foreach (var c in _categories)
                    {
                        <MudSelectItem T="int" Value="@c.IdCategory">@c.DescriptionCategory</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label mb-1">Mesure</label>
                <MudSelect @bind-Value="_article.IdMesure" T="int" Margin="Margin.Dense" Dense="true">
                    @foreach (var m in _mesures)
                    {
                        <MudSelectItem T="int" Value="@m.IdMesure">@m.DescriptionMesure</MudSelectItem>
                    }
                </MudSelect>
            </div>
        </div>

        <!-- Ligne 3 : Localisations -->
        <div class="row g-2">
            <div class="col-12">
                <label class="form-label mb-1">Localisations</label>
                @if (_isEdit)
                {
                    <div class="d-flex flex-wrap gap-2 p-2 border" style="min-height:40px;">
                        @if (_articleStocks.Any())
                        {
                            @foreach (var stock in _articleStocks)
                            {
                                var locName = _localisations.FirstOrDefault(l => l.IdLocalisation == stock.IdLocalisation)?.DescriptionLocalisation ?? "?";
                                <span class="badge bg-primary">@locName (Stock: @stock.Qte)</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Aucune localisation assignée</span>
                        }
                    </div>
                    <small class="text-muted">Les localisations sont gérées via l'approvisionnement</small>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-3 p-2 border" style="min-height:40px;">
                        @foreach (var loc in _localisations)
                        {
                            <MudCheckBox T="bool"
                                         Value="@IsLocalisationSelected(loc.IdLocalisation)"
                                         ValueChanged="@((bool val) => OnLocalisationToggle(loc.IdLocalisation, val))"
                                         Color="Color.Primary" Dense="true"
                                         Label="@loc.DescriptionLocalisation" />
                        }
                    </div>
                    <small class="text-muted">@_selectedLocalisations.Count localisation(s) sélectionnée(s) - L'article sera créé dans chaque localisation</small>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? IdArticle { get; set; }

    bool _isEdit;
    Article _article = new();
    HashSet<int> _selectedLocalisations = new();
    List<Stock> _articleStocks = new();

    List<ArticleCategory> _categories = new();
    List<ArticleType> _types = new();
    List<ArticleMarque> _marques = new();
    List<Mesure> _mesures = new();
    List<Money> _monnaies = new();
    List<Localisation> _localisations = new();

    bool IsLocalisationSelected(int locId) => _selectedLocalisations.Contains(locId);

    void OnLocalisationToggle(int locId, bool selected)
    {
        if (selected)
            _selectedLocalisations.Add(locId);
        else
            _selectedLocalisations.Remove(locId);
    }

    protected override async Task OnInitializedAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();

        _categories = await ctx.ArticleCategories.OrderBy(c => c.DescriptionCategory).ToListAsync();
        _types = await ctx.ArticleTypes.OrderBy(t => t.DescriptionType).ToListAsync();
        _marques = await ctx.ArticleMarques.OrderBy(m => m.DescriptionMarque).ToListAsync();
        _mesures = await ctx.Mesures.OrderBy(m => m.DescriptionMesure).ToListAsync();
        _monnaies = await ctx.Moneys.OrderBy(m => m.DescriptionMonais).ToListAsync();
        _localisations = await ctx.Localisations.OrderBy(l => l.DescriptionLocalisation).ToListAsync();

        // Pre-select from query param if present
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (int.TryParse(query["localisationId"], out var locId))
        {
            _selectedLocalisations.Add(locId);
        }

        if (!string.IsNullOrEmpty(IdArticle))
        {
            var existing = await ctx.Articles.FirstOrDefaultAsync(a => a.IdArticle == IdArticle);
            if (existing != null)
            {
                _isEdit = true;
                _article = existing;

                // Load article stocks from T_Stock
                _articleStocks = await ctx.Stocks
                    .Where(s => s.IdArticle == IdArticle)
                    .ToListAsync();
            }
        }
    }

    async Task OnCancel()
    {
        await JS.InvokeVoidAsync("appNavigation.backOrFallback", "/stock");
    }

    async Task OnSave()
    {
        if (string.IsNullOrWhiteSpace(_article.IdArticle) || string.IsNullOrWhiteSpace(_article.Description))
        {
            Snackbar.Add("Le code et la description sont obligatoires.", Severity.Warning);
            return;
        }

        _article.User = "Admin";
        _article.Cumputer = Environment.MachineName;

        await using var ctx = await DbFactory.CreateDbContextAsync();

        if (_isEdit)
        {
            _article.DateEditing = DateOnly.FromDateTime(DateTime.Today);
            ctx.Articles.Attach(_article);
            ctx.Entry(_article).State = EntityState.Modified;
            ctx.Entry(_article).Property(a => a.Id).IsModified = false;
            ctx.Entry(_article).Property(a => a.TotalPrice).IsModified = false;
            await ctx.SaveChangesAsync();
            Snackbar.Add($"Article « {_article.Description} » mis à jour.", Severity.Success);
        }
        else
        {
            if (!_selectedLocalisations.Any())
            {
                Snackbar.Add("Veuillez sélectionner au moins une localisation.", Severity.Warning);
                return;
            }

            // Check if article code already exists
            var exists = await ctx.Articles.AnyAsync(a => a.IdArticle == _article.IdArticle);
            if (exists)
            {
                Snackbar.Add($"Le code article « {_article.IdArticle} » existe déjà.", Severity.Warning);
                return;
            }

            // Check if article description already exists
            var descExists = await ctx.Articles.AnyAsync(a => a.Description == _article.Description);
            if (descExists)
            {
                Snackbar.Add($"Un article avec la description « {_article.Description} » existe déjà.", Severity.Warning);
                return;
            }

            // Create ONE article (without localisation - managed via Stock table)
            var newArticle = new Article
            {
                IdArticle = _article.IdArticle,
                Description = _article.Description,
                DescriptionI = _article.DescriptionI,
                IdMarque = _article.IdMarque,
                IdType = _article.IdType,
                IdCategory = _article.IdCategory,
                IdMesure = _article.IdMesure,
                IdMonais = _article.IdMonais,
                Price = _article.Price,
                Soeuil = _article.Soeuil,
                Qte = 0,
                DateSys = DateOnly.FromDateTime(DateTime.Today),
                User = _article.User,
                Cumputer = _article.Cumputer
            };
            ctx.Articles.Add(newArticle);

            // Create Stock entries for each selected localisation
            foreach (var locId in _selectedLocalisations)
            {
                ctx.Stocks.Add(new Stock
                {
                    IdArticle = _article.IdArticle,
                    IdLocalisation = locId,
                    Qte = 0,
                    Seuil = _article.Soeuil,
                    DateSys = DateOnly.FromDateTime(DateTime.Today),
                    UserLogin = _article.User
                });
            }

            await ctx.SaveChangesAsync();
            Snackbar.Add($"Article créé et associé à {_selectedLocalisations.Count} localisation(s).", Severity.Success);
        }

        Navigation.NavigateTo("/stock");
    }
}
