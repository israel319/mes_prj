@page "/"
@using MudBlazor
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>@AppSettings.AppName — Tableau de bord</PageTitle>

@if (!_loaded)
{
    <div class="d-flex align-items-center justify-content-center" style="min-height:400px;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Chargement…</span>
        </div>
    </div>
}
else
{
<div class="w-100" style="max-width:1400px;margin:0 auto;">
    <!-- ═══════════════ EN-TÊTE ═══════════════ -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-2">
        <div>
            <h1 class="fs-3 mb-1 fw-bold">Tableau de bord</h1>
            <p class="text-muted small mb-0">
                Vue d'ensemble de l'activité · @DateTime.Today.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))
            </p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" @onclick="@(() => Navigation.NavigateTo("/vente/facturation"))">
                <i class="ti ti-plus me-1"></i> Nouvelle facture
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => Navigation.NavigateTo("/rapports"))">
                <i class="ti ti-chart-bar me-1"></i> Rapports
            </button>
        </div>
    </div>

    <!-- ═══════════════ 4 KPI PRINCIPAUX (style InApp) ═══════════════ -->
    <div class="row g-3 mb-2">
        @foreach (var kpi in _kpis)
        {
            <div class="col-lg-3 col-12">
                <div class="card p-4" style="@($"background:{kpi.BgColor};border:1px solid {kpi.Color}25 !important;")">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md" style="@($"background:{kpi.Color};color:#fff;")">
                            <i class="ti @kpi.TablerIcon fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6">@kpi.Label</h2>
                            <h3 class="fw-bold mb-0" style="@kpi.ValueStyle">@kpi.Value</h3>
                            @if (!string.IsNullOrEmpty(kpi.Trend))
                            {
                                <p class="mb-0 small" style="@($"color:{kpi.Color};")">
                                    <i class="ti @(kpi.TrendUp ? "ti-trending-up" : "ti-trending-down") me-1"></i>@kpi.Trend depuis le mois dernier
                                </p>
                            }
                            else
                            {
                                <p class="text-muted mb-0 small">@kpi.SubLabel</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ═══════════════ 3 CARTES MÉTRIQUES (style InApp) ═══════════════ -->
    <div class="row g-3 mb-2">
        <div class="col-lg-4 col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h3 class="fw-bold h4">@(_totalRevenueYear.ToString("N0")) Fc</h3>
                            <span class="text-muted">Revenus @DateTime.Today.Year</span>
                        </div>
                        <i class="ti ti-report-analytics fs-1 text-primary"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">Total annuel</span>
                        <a href="/rapports" class="link-primary text-decoration-underline">Voir</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h3 class="fw-bold h4">@(_factsMonthCount) factures</h3>
                            <span class="text-muted">Ce mois-ci</span>
                        </div>
                        <i class="ti ti-file-text fs-1 text-success"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">Factures émises</span>
                        <a href="/vente" class="link-primary text-decoration-underline">Voir</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h3 class="fw-bold h4">@(_cmdsEnAttente) en attente</h3>
                            <span class="text-muted">Commandes</span>
                        </div>
                        <i class="ti ti-shopping-cart fs-1 text-warning"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">À traiter</span>
                        <a href="/commandes" class="link-primary text-decoration-underline">Voir</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════ GRAPHIQUES : Revenus + Statuts factures ═══════════════ -->
    <div class="row g-3 mb-2">
        <!-- Graphique revenus mensuels -->
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center bg-transparent px-4 py-3">
                    <h3 class="h5 mb-0">Ventes vs Approvisionnements</h3>
                    <span class="badge bg-info-subtle text-info border border-info">@($"{_totalRevenueYear:N0} Fc")</span>
                </div>
                <div class="card-body p-4">
                    <MudChart ChartType="ChartType.Bar" ChartSeries="@_barSeries" XAxisLabels="@_barLabels"
                              Width="100%" Height="260px" ChartOptions="@_barOptions" />
                </div>
            </div>
        </div>

        <!-- Répartition statuts factures (Donut) -->
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center bg-transparent px-4 py-3">
                    <h3 class="h5 mb-0">Statuts des factures (ce mois)</h3>
                </div>
                <div class="card-body p-4">
                    <MudChart ChartType="ChartType.Donut" InputData="@_donutData" InputLabels="@_donutLabels"
                              Width="260px" Height="260px" />
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════ TOP ARTICLES + STOCK FAIBLE + DERNIÈRES VENTES (style InApp) ═══════════════ -->
    <div class="row g-3 mb-2">
        <!-- Top articles vendus -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
                    <h4 class="mb-0 h5">Top articles vendus</h4>
                    <span class="small text-muted">Ce mois</span>
                </div>
                <ul class="list-group list-group-flush">
                    @if (!_topArticles.Any())
                    {
                        <li class="list-group-item text-center text-muted py-5">
                            <i class="ti ti-inbox d-block mb-2" style="font-size:32px;"></i>
                            Aucune vente ce mois
                        </li>
                    }
                    else
                    {
                        @foreach (var a in _topArticles.Take(5))
                        {
                            <li class="list-group-item d-flex align-items-center gap-3">
                                <div class="icon-shape icon-sm @(a.Rank == 1 ? "bg-warning" : a.Rank == 2 ? "bg-secondary" : a.Rank == 3 ? "bg-danger-subtle" : "bg-light") text-white"
                                     style="@(a.Rank <= 3 ? "" : "color:#64748b !important;")">
                                    <span class="fw-bold" style="font-size:12px;">@a.Rank</span>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1">@a.Description</p>
                                    <div class="d-flex align-items-center gap-2 text-muted">
                                        <small class="fw-semibold">@a.Montant.ToString("N0") Fc </small>
                                        <small>•</small>
                                        <small>@a.QteVendue.ToString("N0") unités</small>
                                    </div>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <!-- Alertes stock faible -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
                    <h4 class="mb-0 h5">Stock faible</h4>
                    @if (_lowStockArticles.Any())
                    {
                        <span class="badge bg-warning-subtle text-warning border border-warning">@_lowStockArticles.Count</span>
                    }
                </div>
                <ul class="list-group list-group-flush">
                    @if (!_lowStockArticles.Any())
                    {
                        <li class="list-group-item text-center py-5">
                            <i class="ti ti-circle-check d-block mb-2 text-success" style="font-size:32px;"></i>
                            <span class="text-muted">Tous les stocks sont bons</span>
                        </li>
                    }
                    else
                    {
                        @foreach (var a in _lowStockArticles.Take(5))
                        {
                            <li class="list-group-item d-flex align-items-center gap-3">
                                <div class="icon-shape icon-sm bg-light">
                                    <i class="ti ti-box-seam" style="color:#64748b;"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1">@a.Description</p>
                                    <small class="text-muted">Seuil : @a.Seuil</small>
                                </div>
                                <div class="d-flex flex-column align-items-center">
                                    <span class="fw-semibold text-primary">@a.Qte.ToString("N0")</span>
                                    <small class="text-muted">En stock</small>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <!-- Dernières ventes -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
                    <h4 class="mb-0 h5">Dernières ventes</h4>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo("/vente"))">
                        <i class="ti ti-eye me-1"></i> Tout voir
                    </button>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var f in _recentFacts.Take(5))
                    {
                        <li class="list-group-item d-flex align-items-center gap-3">
                            <div class="icon-shape icon-sm bg-light">
                                <i class="ti ti-receipt" style="color:#64748b;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <p class="mb-1">@f.Client</p>
                                <div class="d-flex align-items-center gap-2 text-muted">
                                    <small class="fw-semibold">@f.Total.ToString("N0") Fc</small>
                                    <small>•</small>
                                    <small>@f.Date.ToString("dd/MM/yyyy")</small>
                                </div>
                            </div>
                            <span class="badge @GetStatusBadgeClass(f.StatusLabel)">@f.StatusLabel</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- ═══════════════ STATISTIQUES RAPIDES + RACCOURCIS ═══════════════ -->
    <div class="row g-3 mb-2">
        <!-- Statistiques rapides -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-transparent px-4 py-3">
                    <h4 class="mb-0 h5">Statistiques rapides</h4>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var stat in _quickStats)
                    {
                        <li class="list-group-item d-flex align-items-center justify-content-between px-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-shape icon-sm" style="@($"background:{stat.BgColor};color:{stat.Color};")">
                                    <i class="ti @stat.TablerIcon"></i>
                                </div>
                                <span>@stat.Label</span>
                            </div>
                            <span class="fw-bold">@stat.Value</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Raccourcis rapides -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-transparent px-4 py-3">
                    <h4 class="mb-0 h5">Accès rapides</h4>
                </div>
                <div class="card-body p-4">
                    <div class="row g-2">
                        @foreach (var shortcut in _shortcuts)
                        {
                            <div class="col-md-6">
                                <button class="btn btn-light border w-100 d-flex align-items-center gap-2 py-3 px-3"
                                        @onclick="@(() => Navigation.NavigateTo(shortcut.Path))">
                                    <i class="ti @shortcut.TablerIcon fs-5 text-primary"></i>
                                    <span>@shortcut.Label</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}

@code {
    /* ───── Records pour l'affichage ───── */
    record KpiData(string Label, string Value, string SubLabel, string TablerIcon,
                   string Color, string BgColor, string ValueStyle = "",
                   string Trend = "", bool TrendUp = true);

    record MonthlyData(string Month, decimal Ventes, decimal Appros);
    record StatusData(string Label, int Count);
    record StockAlert(string Description, decimal Qte, int Seuil, double Pct);
    record TopArticle(int Rank, string Description, double QteVendue, double Montant);
    record RecentFact(int Id, string Client, DateOnly Date, decimal Total, string StatusLabel);
    record QuickStat(string Label, string Value, string TablerIcon, string Color, string BgColor);
    record ShortcutItem(string Label, string TablerIcon, string Path);

    /* ───── State ───── */
    bool _loaded;
    List<KpiData> _kpis = new();
    List<MonthlyData> _revenueData = new();
    List<StatusData> _statusData = new();
    decimal _totalRevenueYear;
    int _factsMonthCount;
    int _cmdsEnAttente;
    List<StockAlert> _lowStockArticles = new();
    List<TopArticle> _topArticles = new();
    List<RecentFact> _recentFacts = new();
    List<QuickStat> _quickStats = new();
    List<ShortcutItem> _shortcuts = new();

    /* ───── MudChart: Bar ───── */
    string[] _barLabels = Array.Empty<string>();
    List<ChartSeries> _barSeries = new();
    ChartOptions _barOptions = new() { YAxisTicks = 5 };

    /* ───── MudChart: Donut ───── */
    double[] _donutData = Array.Empty<double>();
    string[] _donutLabels = Array.Empty<string>();

    string GetStatusBadgeClass(string status) => status switch
    {
        "Nouvelle" => "bg-primary-subtle text-primary",
        "Validée"  => "bg-info-subtle text-info",
        "Payée"    => "bg-success-subtle text-success",
        "Annulée"  => "bg-danger-subtle text-danger",
        _          => "bg-light text-muted"
    };

    /* ───── Chargement ───── */
    protected override async Task OnInitializedAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var today = DateTime.Today;
        var year  = today.Year;
        var month = today.Month;

        var firstOfYear  = new DateOnly(year, 1, 1);
        var lastOfYear   = new DateOnly(year, 12, 31);
        var firstOfMonth = new DateOnly(year, month, 1);
        var todayDate    = DateOnly.FromDateTime(today);

        /* --- Factures année & mois --- */
        var factsYear = await ctx.Facts
            .Where(f => f.Date >= firstOfYear && f.Date <= lastOfYear)
            .ToListAsync();

        var factsMonth     = factsYear.Where(f => f.Date.Month == month).ToList();
        var factsToday     = factsYear.Where(f => f.Date == todayDate).ToList();
        var factsPrevMonth = factsYear.Where(f => f.Date.Month == month - 1).ToList();

        var venteMois     = factsMonth.Sum(f => f.Total ?? 0);
        var ventePrevMois = factsPrevMonth.Sum(f => f.Total ?? 0);
        var venteToday    = factsToday.Sum(f => f.Total ?? 0);
        _factsMonthCount  = factsMonth.Count;

        /* --- Appros année & mois --- */
        var approsYear = await ctx.Appros
            .Where(a => a.Date >= firstOfYear && a.Date <= lastOfYear)
            .ToListAsync();
        var approsMois  = approsYear.Where(a => a.Date.Month == month).ToList();
        var totalAppros = approsMois.Sum(a => (a.PA ?? 0) * a.Qte);

        /* --- Commandes en attente --- */
        _cmdsEnAttente = await ctx.Cmds.CountAsync(c => c.Status != null && c.Status == 0);

        /* --- Bénéfice réel = somme des BenTotal des appros du mois --- */
        var benefice = approsMois.Sum(a => a.BenTotal ?? 0);

        /* --- Tendances --- */
        var trendVente = ventePrevMois > 0
            ? ((venteMois - ventePrevMois) / ventePrevMois * 100).ToString("+0;-0") + "%"
            : "";
        var trendVenteUp = venteMois >= ventePrevMois;

        /* ═══ KPI ═══ */
        _kpis = new()
        {
            new("Ventes aujourd'hui", venteToday.ToString("N0") + " Fc", $"{factsToday.Count} facture(s)",
                "ti-report-analytics", "#00B193", "#d4f5ef"),
            new("Appros du mois", totalAppros.ToString("N0") + " Fc", $"{approsMois.Count} approvisionnement(s)",
                "ti-truck-delivery", "#3b82f6", "#dbeafe"),
            new("Bénéfice", benefice.ToString("N0") + " Fc", "(PV − PA) × Qté",
                "ti-coins", "#253C45", "#e8edef",
                benefice >= 0 ? "" : "color:#A61B0C;"),
            new("Ventes du mois", venteMois.ToString("N0") + " Fc", "Chiffre d'affaires mensuel",
                "ti-receipt", "#f59e0b", "#fef3c7", "", trendVente, trendVenteUp),
        };

        /* ═══ Graphique revenus + appros mensuels ═══ */
        var monthNames = new[] { "Jan", "Fév", "Mar", "Avr", "Mai", "Jun",
                                 "Jul", "Aoû", "Sep", "Oct", "Nov", "Déc" };
        _revenueData = Enumerable.Range(1, 12)
            .Select(m => new MonthlyData(
                monthNames[m - 1],
                factsYear.Where(f => f.Date.Month == m).Sum(f => f.Total ?? 0),
                approsYear.Where(a => a.Date.Month == m).Sum(a => (a.PA ?? 0) * a.Qte)))
            .ToList();
        _totalRevenueYear = factsYear.Sum(f => f.Total ?? 0);

        _barLabels = _revenueData.Select(r => r.Month).ToArray();
        _barSeries = new()
        {
            new ChartSeries { Name = "Ventes", Data = _revenueData.Select(r => (double)r.Ventes).ToArray() },
            new ChartSeries { Name = "Appros", Data = _revenueData.Select(r => (double)r.Appros).ToArray() },
        };

        /* ═══ Donut statuts factures du mois ═══ */
        var nbNew     = factsMonth.Count(f => f.Status == 0);
        var nbValid   = factsMonth.Count(f => f.Status == 1);
        var nbPaid    = factsMonth.Count(f => f.Status == 2);
        var nbCancel  = factsMonth.Count(f => f.Status == 3);
        _statusData = new()
        {
            new("Nouvelles", nbNew),
            new("Validées", nbValid),
            new("Payées", nbPaid),
            new("Annulées", nbCancel),
        };

        _donutData = _statusData.Select(s => (double)s.Count).ToArray();
        _donutLabels = _statusData.Select(s => s.Label).ToArray();

        /* ═══ Alertes stock ═══ */
        var articles = await ctx.Articles.ToListAsync();
        _lowStockArticles = articles
            .Where(a => (a.Qte ?? 0) <= a.Soeuil && a.Soeuil > 0)
            .OrderBy(a => a.Qte ?? 0)
            .Take(20)
            .Select(a => new StockAlert(
                a.Description,
                a.Qte ?? 0,
                a.Soeuil,
                a.Soeuil > 0 ? (double)((a.Qte ?? 0) / a.Soeuil) * 100 : 0))
            .ToList();

        /* ═══ Top articles vendus ce mois ═══ */
        var factIds = factsMonth.Select(f => f.Id).ToHashSet();
        var detailsMonth = await ctx.FactDetails
            .Where(d => d.IdFact != null && factIds.Contains(d.IdFact.Value))
            .ToListAsync();

        var articleDict = articles.ToDictionary(a => a.IdArticle, a => a.Description);
        _topArticles = detailsMonth
            .Where(d => d.IdArticle != null)
            .GroupBy(d => d.IdArticle!)
            .Select(g => new
            {
                IdArticle = g.Key,
                QteVendue = g.Sum(d => d.Qte ?? 0),
                Montant = g.Sum(d => (d.Qte ?? 0) * (d.Pu ?? 0))
            })
            .OrderByDescending(g => g.Montant)
            .Take(8)
            .Select((g, i) => new TopArticle(
                i + 1,
                articleDict.GetValueOrDefault(g.IdArticle, g.IdArticle),
                g.QteVendue,
                g.Montant))
            .ToList();

        /* ═══ Dernières factures ═══ */
        _recentFacts = factsYear
            .OrderByDescending(f => f.DateSys)
            .Take(8)
            .Select(f => new RecentFact(
                f.Id,
                string.IsNullOrWhiteSpace(f.DescriptionName) ? "—" : f.DescriptionName,
                f.Date,
                f.Total ?? 0,
                f.Status switch { 0 => "Nouvelle", 1 => "Validée", 2 => "Payée", 3 => "Annulée", _ => "—" }))
            .ToList();

        /* ═══ Statistiques rapides ═══ */
        var totalClients    = await ctx.Customers.CountAsync();
        var clientsPerm     = await ctx.Customers.CountAsync(c => c.IsPermanent == true);
        var totalArticles   = articles.Count;
        var totalCommandes  = await ctx.Cmds.CountAsync();

        _quickStats = new()
        {
            new("Clients enregistrés", totalClients.ToString(), "ti-users", "#00B193", "#d4f5ef"),
            new("Clients permanents", clientsPerm.ToString(), "ti-heart", "#00B193", "#d4f5ef"),
            new("Articles en catalogue", totalArticles.ToString(), "ti-box-seam", "#3b82f6", "#dbeafe"),
            new("Factures ce mois", factsMonth.Count.ToString(), "ti-file-text", "#f59e0b", "#fef3c7"),
            new("Commandes totales", totalCommandes.ToString(), "ti-shopping-cart", "#253C45", "#e8edef"),
            new("Bénéfice net mois", benefice.ToString("N0") + " Fc", "ti-trending-up", benefice >= 0 ? "#00B193" : "#A61B0C", benefice >= 0 ? "#d4f5ef" : "#fee2e2"),
        };

        /* ═══ Raccourcis ═══ */
        _shortcuts = new()
        {
            new("Nouvelle facture",  "ti-plus",            "/vente/facturation"),
            new("Gestion stock",     "ti-box-seam",        "/stock"),
            new("Commandes",         "ti-shopping-cart",    "/commandes"),
            new("Rapports",          "ti-chart-bar",        "/rapports"),
            new("Administration",    "ti-settings-2",       "/administration"),
            new("Paramètres",        "ti-adjustments",      "/settings"),
        };

        _loaded = true;
    }
}
