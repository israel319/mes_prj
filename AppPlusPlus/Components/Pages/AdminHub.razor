                        </div>
                    </div>

                    <div class="card"><div class="card-body p-0">
                        <MudDataGrid Items="@_factAdminData" T="Fact" Loading="@_factAdminLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="10"
                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.Id" Title="N° Facture" />
