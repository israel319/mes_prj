            @* ══════════════════ GESTION LIVRAISONS ══════════════════ *@
            @if (_tab == 6)
            {
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="d-flex gap-2 align-items-center">
                            <span class="text-muted">Du</span>
                            <MudDatePicker @bind-Date="_livCmdDateFrom" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:150px;" />
                            <span class="text-muted">Au</span>
                            <MudDatePicker @bind-Date="_livCmdDateTo" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:150px;" />
                            <button class="btn btn-info btn-sm" @onclick="@LoadLivraisonCommandes"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                        </div>
                    </div>

                    <h6 class="mb-2">Livraisons</h6>

                    <div class="card mb-2"><div class="card-body p-0">
                        <MudDataGrid Items="@_adminLivraisons" T="Livraison" Loading="@_livCmdLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
