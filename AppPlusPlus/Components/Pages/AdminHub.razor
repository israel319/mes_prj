@page "/administration"
@page "/admin"
@rendermode InteractiveServer
@using MudBlazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject MudBlazor.IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject RolePermissionService RolePermissionService

<PageTitle>@AppSettings.AppName — Administration</PageTitle>

@if (!_loaded)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height:200px;"><div class="spinner-border text-primary" role="status"></div></div>
}
else
{
    <div>
        <div class="d-flex flex-wrap align-items-center justify-content-between mb-2 hub-header">
            <div class="d-flex align-items-center gap-3">
                <div class="hub-icon" style="background:rgba(37,60,69,.12);color:#253C45;">
                    <i class="bi bi-gear fs-4"></i>
                </div>
                <div>
                    <h2 class="fw-bold mb-0 fs-5">Administration</h2>
                    <small class="text-muted">Utilisateurs, rôles, activités et données de base</small>
                </div>
            </div>
        </div>

        <div class="card hub-tabs-shell">
            <ul class="nav nav-tabs px-3 pt-1">
                <li class="nav-item"><button class="nav-link @(_tab == 0 ? "active" : "")" @onclick="@(() => _tab = 0)"><i class="bi bi-people me-1"></i>Utilisateurs</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 1 ? "active" : "")" @onclick="@(() => _tab = 1)"><i class="bi bi-truck me-1"></i>Fournisseurs</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 2 ? "active" : "")" @onclick="@(() => _tab = 2)"><i class="bi bi-percent me-1"></i>Taux de change</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 3 ? "active" : "")" @onclick="@(() => _tab = 3)"><i class="bi bi-calendar-event me-1"></i>Périodes</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 4 ? "active" : "")" @onclick="@(() => _tab = 4)"><i class="bi bi-bank me-1"></i>Versements</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 5 ? "active" : "")" @onclick="@(() => _tab = 5)"><i class="bi bi-receipt me-1"></i>Gestion factures</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 6 ? "active" : "")" @onclick="@(() => _tab = 6)"><i class="bi bi-truck me-1"></i>Gestion livraisons</button></li>
                <li class="nav-item"><button class="nav-link @(_tab == 7 ? "active" : "")" @onclick="@(() => _tab = 7)"><i class="bi bi-building me-1"></i>Localisations</button></li>
            </ul>

            @* ══════════════════ UTILISATEURS ══════════════════ *@
            @if (_tab == 0)
            {
                <div class="card-body">
                    <div class="d-flex justify-content-end gap-2 mb-2">
                        <button class="btn btn-primary" @onclick="@OnAddUser"><i class="bi bi-person-plus me-1"></i>Ajouter</button>
                    </div>

                    <div class="card"><div class="card-body p-0">
                        <MudDataGrid Items="@_userData" T="User" Loading="@_userLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="10"
                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.Login" Title="Login" />
                                <PropertyColumn Property="x => x.Name" Title="Nom" />
                                <TemplateColumn Title="Rôle">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.RoleId.HasValue ? Color.Info : Color.Default)">
                                            @(context.Item.Role?.DescriptionRole ?? "Non attribué")
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Email" Title="Email" />
                                <TemplateColumn Title="Statut">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.Activated == true ? Color.Success : Color.Error)">
                                            @(context.Item.Activated == true ? "Actif" : "Inactif")
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Localisations">
                                    <CellTemplate>
                                        @{
                                            var locs = _userLocalisationsMap.GetValueOrDefault(context.Item.Login, new List<string>());
                                        }
                                        @if (locs.Any())
                                        {
                                            @foreach (var loc in locs)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="me-1 mb-1">@loc</MudChip>
                                            }
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Non assignée</MudChip>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Info" Size="Size.Small" OnClick="@(() => OnManageUserAccess(context.Item))" Title="Gérer accès" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OnEditUser(context.Item))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDeleteUser(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="User" />
                            </PagerContent>
                        </MudDataGrid>
                    </div></div>
                </div>
            }

            @if (false)
            {
            @* ══════════════════ ACCÈS UTILISATEURS ══════════════════ *@
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="card mb-2"><div class="card-body">
                        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3">
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="d-flex flex-column gap-1" style="min-width:280px;">
                                    <label class="form-label fw-bold">Utilisateur</label>
                                    <MudSelect T="string" Value="_selectedUserLogin"
                                               ValueChanged="@(async val => { _selectedUserLogin = val; await OnSelectedUserChanged(); })"
                                               Placeholder="Sélectionner un utilisateur"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:280px;">
                                        @foreach (var u in _userData)
                                        {
                                            <MudSelectItem T="string" Value="@u.Login">@u.Login</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <div class="d-flex flex-column gap-1" style="min-width:280px;">
                                    <label class="form-label fw-bold">Rôle de l'utilisateur</label>
                                    <MudSelect T="int?" Value="_selectedUserRoleId"
                                               ValueChanged="@(async val => { _selectedUserRoleId = val; await OnSelectedUserRoleChanged(); })"
                                               Placeholder="Sélectionner un rôle"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:280px;">
                                        @foreach (var r in _roleData)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)r.RoleId)">@r.DescriptionRole</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-light" @onclick="@LoadUserAccessRows"><i class="bi bi-arrow-clockwise me-1"></i>Actualiser</button>
                                <button class="btn btn-primary" disabled="@(string.IsNullOrWhiteSpace(_selectedUserLogin))" @onclick="@SaveUserAccess"><i class="bi bi-floppy me-1"></i>Enregistrer accès utilisateur</button>
                            </div>
                        </div>

                        <div class="alert alert-info mt-3 d-flex align-items-center gap-2">
                            <i class="bi bi-info-circle" style="font-size:18px;"></i>
                            Les activités sont gérées par rôle : si vous modifiez les permissions ci-dessous, tous les utilisateurs ayant ce rôle seront impactés.
                        </div>
                    </div></div>

                    @if (string.IsNullOrWhiteSpace(_selectedUserLogin))
                    {
                        <div class="card mb-2"><div class="card-body">
                            <span class="text-muted">Sélectionnez un utilisateur pour gérer ses activités.</span>
                        </div></div>
                    }
                    else
                    {
                        <div class="card mb-2"><div class="card-body">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <div>
                                    <h6 class="fw-bold">Activités visibles pour @(_selectedUserLogin)</h6>
                                    <p class="text-muted mb-0">
                                        Cochez les droits autorisés (Lecture, Écriture, Suppression).
                                    </p>
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                    @(_roleData.FirstOrDefault(r => r.RoleId == _selectedUserRoleId)?.DescriptionRole ?? "Sans rôle")
                                </MudChip>
                            </div>

                            <MudDataGrid Items="@_userAccessRows" T="RolePermissionRow" Loading="@_userAccessLoading"
                                         Dense="true" Hover="true" Bordered="true" Elevation="0"
                                         RowsPerPage="10" Style="width:100%;">
                                <Columns>
                                    <PropertyColumn Property="x => x.FonctionLabel" Title="Fonction" />
                                    <TemplateColumn Title="Lecture" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.CanRead" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <TemplateColumn Title="Écriture" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.CanWrite" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <TemplateColumn Title="Suppression" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.CanDelete" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <PagerContent>
                                    <MudDataGridPager T="RolePermissionRow" />
                                </PagerContent>
                            </MudDataGrid>
                        </div></div>
                    }
                </div>
            </div>

            @* ══════════════════ RÔLES & PERMISSIONS ══════════════════ *@
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="card mb-2"><div class="card-body">
                        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3">
                            <div class="d-flex flex-column gap-1" style="min-width:320px;">
                                <label class="form-label fw-bold">Rôle à configurer</label>
                                <MudSelect T="int?" Value="_selectedRoleId"
                                           ValueChanged="@(async val => { _selectedRoleId = val; await OnSelectedRoleChanged(); })"
                                           Placeholder="Sélectionner un rôle"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:320px;">
                                    @foreach (var r in _roleData)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)r.RoleId)">@r.DescriptionRole</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>

                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-info" disabled="@(!_selectedRoleId.HasValue)" @onclick="@ApplyDefaultPermissions" title="Appliquer les permissions par défaut basées sur le nom du rôle">
                                    <i class="bi bi-magic me-1"></i>Permissions par défaut
                                </button>
                                <button class="btn btn-light" @onclick="@(() => LoadRolePermissions())"><i class="bi bi-arrow-clockwise me-1"></i>Actualiser</button>
                                <button class="btn btn-primary" disabled="@(!_selectedRoleId.HasValue)" @onclick="@SaveRolePermissions"><i class="bi bi-floppy me-1"></i>Enregistrer les permissions</button>
                            </div>
                        </div>
                    </div></div>

                    @if (!_selectedRoleId.HasValue)
                    {
                        <div class="card mb-2"><div class="card-body">
                            <span class="text-muted">Aucun rôle disponible pour le moment.</span>
                        </div></div>
                    }
                    else
                    {
                        <div class="card mb-2"><div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <h6 class="fw-bold">Fonctions du rôle</h6>
                                    <p class="text-muted mb-0">
                                        Active les accès selon le rôle sélectionné. Un utilisateur hérite automatiquement des fonctions de son rôle.
                                    </p>
                                </div>
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                    @(_roleData.FirstOrDefault(r => r.RoleId == _selectedRoleId)?.DescriptionRole ?? "Rôle")
                                </MudChip>
                            </div>

                            <MudDataGrid Items="@_rolePermissionRows" T="RolePermissionRow" Loading="@_rolePermissionLoading"
                                         Dense="true" Hover="true" Bordered="true" Elevation="0"
                                         RowsPerPage="10" Style="width:100%;">
                                <Columns>
                                    <PropertyColumn Property="x => x.FonctionLabel" Title="Fonction" />
                                    <TemplateColumn Title="Lecture" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.CanRead" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <TemplateColumn Title="Écriture" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.CanWrite" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                    <TemplateColumn Title="Suppression" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.CanDelete" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <PagerContent>
                                    <MudDataGridPager T="RolePermissionRow" />
                                </PagerContent>
                            </MudDataGrid>
                        </div></div>
                    }
                </div>
            </div>

            @* ══════════════════ RÉFÉRENTIEL ACTIVITÉS ══════════════════ *@
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="card mb-2"><div class="card-body">
                        <div class="d-flex align-items-end gap-3 flex-wrap">
                            <div class="d-flex flex-column gap-1" style="min-width:250px;">
                                <label class="form-label fw-bold">Fonction</label>
                                <MudSelect T="int?" @bind-Value="_newActivityFonctionId"
                                           Placeholder="Choisir une fonction"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:250px;">
                                    @foreach (var f in _fonctionData)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)f.IdFonction)">@f.DescriptionFonction</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>

                            <div class="d-flex flex-column gap-1" style="min-width:260px;">
                                <label class="form-label fw-bold">Code activité</label>
                                <input type="text" @bind="_newActivityCode" class="form-control" placeholder="ex: vente_read" style="width:260px;" />
                            </div>

                            <div class="d-flex flex-column gap-1" style="min-width:360px;">
                                <label class="form-label fw-bold">Description</label>
                                <input type="text" @bind="_newActivityLabel" class="form-control" placeholder="ex: Consulter Vente" style="width:360px;" />
                            </div>

                            <button class="btn btn-primary" @onclick="@AddActivity"><i class="bi bi-plus-lg me-1"></i>Ajouter activité</button>
                        </div>
                    </div></div>

                    <div class="card"><div class="card-body p-0">
                        <MudDataGrid Items="@_activityData" T="Activity" Loading="@_activityLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="12"
                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.ActivityId" Title="#" />
                                <TemplateColumn Title="Fonction">
                                    <CellTemplate>@context.Item.Fonction?.DescriptionFonction</CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Code" Title="Code" />
                                <PropertyColumn Property="x => x.DescriptionActivity" Title="Activité" />
                                <TemplateColumn Title="Actif">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                                            @(context.Item.IsActive ? "Oui" : "Non")
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Sync" Color="Color.Default" Size="Size.Small" OnClick="@(() => ToggleActivityState(context.Item))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteActivity(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Activity" />
                            </PagerContent>
                        </MudDataGrid>
                    </div></div>
                </div>
            </div>

            @* ══════════════════ ACTIVITÉS UTILISATEUR ══════════════════ *@
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    <div class="card mb-2"><div class="card-body">
                        <div class="d-flex align-items-end justify-content-between flex-wrap gap-3">
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="d-flex flex-column gap-1" style="min-width:260px;">
                                    <label class="form-label fw-bold">Utilisateur</label>
                                    <MudSelect T="string" Value="_selectedActivityUserLogin"
                                               ValueChanged="@(async val => { _selectedActivityUserLogin = val; await OnActivityUserChanged(); })"
                                               Placeholder="Choisir un utilisateur"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:260px;">
                                        @foreach (var u in _userData)
                                        {
                                            <MudSelectItem T="string" Value="@u.Login">@u.Login</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>

                                <div class="d-flex flex-column gap-1" style="min-width:260px;">
                                    <label class="form-label fw-bold">Filtrer par fonction</label>
                                    <MudSelect T="int?" Value="_activityFilterFonctionId"
                                               ValueChanged="@(val => { _activityFilterFonctionId = val; ApplyActivityUserFilter(); })"
                                               Placeholder="Toutes les fonctions"
                                               Clearable="true"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:260px;">
                                        @foreach (var f in _fonctionData)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)f.IdFonction)">@f.DescriptionFonction</MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </div>

                            <button class="btn btn-primary" disabled="@(string.IsNullOrWhiteSpace(_selectedActivityUserLogin))" @onclick="@SaveUserActivities"><i class="bi bi-floppy me-1"></i>Enregistrer activités</button>
                        </div>
                    </div></div>

                    @if (string.IsNullOrWhiteSpace(_selectedActivityUserLogin))
                    {
                        <div class="card mb-2"><div class="card-body">
                            <span class="text-muted">Sélectionnez un utilisateur pour définir ses activités.</span>
                        </div></div>
                    }
                    else
                    {
                        <div class="card"><div class="card-body p-0">
                            <MudDataGrid Items="@_userActivityRows" T="UserActivityRow" Loading="@_userActivitiesLoading"
                                         Dense="true" Hover="true" Bordered="true" Elevation="0"
                                         RowsPerPage="12" Style="width:100%;">
                                <Columns>
                                    <PropertyColumn Property="x => x.FonctionLabel" Title="Fonction" />
                                    <PropertyColumn Property="x => x.ActivityCode" Title="Code" />
                                    <PropertyColumn Property="x => x.ActivityLabel" Title="Activité" />
                                    <TemplateColumn Title="Autorisé" Sortable="false" Filterable="false">
                                        <CellTemplate>
                                            <MudCheckBox T="bool" @bind-Value="context.Item.IsGranted" Dense="true" />
                                        </CellTemplate>
                                    </TemplateColumn>
                                </Columns>
                                <PagerContent>
                                    <MudDataGridPager T="UserActivityRow" />
                                </PagerContent>
                            </MudDataGrid>
                        </div></div>
                    }
                </div>
            </div>
            }

            @* ══════════════════ FOURNISSEURS ══════════════════ *@
            @if (_tab == 1)
            {
                <div class="card-body">
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex justify-content-end">
                            <button class="btn btn-primary" @onclick="@OnAddSupplier"><i class="bi bi-person-plus me-1"></i>Nouveau fournisseur</button>
                        </div>

                        <MudDataGrid Items="@_supplierData" T="Supplier" Loading="@_supplierLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="15"
                                     Style="width:100%;cursor:pointer;"
                                     RowClick="@(args => OnEditSupplier(args.Item))">
                            <Columns>
                                <PropertyColumn Property="x => x.SupplierId" Title="ID" />
                                <PropertyColumn Property="x => x.SupplierNumber" Title="N° Fournisseur" />
                                <PropertyColumn Property="x => x.SupplierName" Title="Nom" />
                                <PropertyColumn Property="x => x.Contact" Title="Contact" />
                                <PropertyColumn Property="x => x.Email" Title="Email" />
                                <PropertyColumn Property="x => x.Adresse" Title="Adresse" />
                                <PropertyColumn Property="x => x.CcAmountToPay" Title="Montant à payer" Format="N2" />
                                <PropertyColumn Property="x => x.CcAmountPay" Title="Montant payé" Format="N2" />
                                <PropertyColumn Property="x => x.CreationDate" Title="Date création" Format="dd/MM/yyyy" />
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <div class="d-flex gap-0 justify-content-center">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                                           OnClick="@(() => OnEditSupplier(context.Item))" Title="Modifier" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                           OnClick="@(() => OnDeleteSupplier(context.Item))" Title="Supprimer" />
                                        </div>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Supplier" />
                            </PagerContent>
                        </MudDataGrid>
                    </div>
                </div>
            }

            @* ══════════════════ TAUX DE CHANGE ══════════════════ *@
            @if (_tab == 2)
            {
                <div class="card-body">
                    <div class="d-flex justify-content-end gap-2 mb-2">
                        <button class="btn btn-primary" @onclick="@OnAddTaux"><i class="bi bi-plus-circle me-1"></i>Ajouter</button>
                    </div>

                    <div class="card"><div class="card-body p-0">
                        <MudDataGrid Items="@_tauxData" T="Taux" Loading="@_tauxLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     RowsPerPage="10" Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.Id" Title="N°" />
                                <PropertyColumn Property="x => x.TauxValue" Title="Taux" Format="N2" />
                                <PropertyColumn Property="x => x.RateLow" Title="Taux bas" Format="N2" />
                                <PropertyColumn Property="x => x.RateUp" Title="Taux haut" Format="N2" />
                                <PropertyColumn Property="x => x.Date" Title="Date" Format="dd/MM/yyyy" />
                                <PropertyColumn Property="x => x.Comment" Title="Commentaire" />
                                <PropertyColumn Property="x => x.UserLogin" Title="Utilisateur" />
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OnEditTaux(context.Item))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDeleteTaux(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Taux" />
                            </PagerContent>
                        </MudDataGrid>
                    </div></div>
                </div>
            }

            @* ══════════════════ PÉRIODES ══════════════════ *@
            @if (_tab == 3)
            {
                <div class="card-body">
                    <div class="d-flex justify-content-end gap-2 mb-2">
