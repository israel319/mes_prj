                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.LivraisonId" Title="N°" />
                                <PropertyColumn Property="x => x.Porteur" Title="Porteur" />
                                <PropertyColumn Property="x => x.ClientId" Title="Client" />
                                <PropertyColumn Property="x => x.Date" Title="Date" Format="dd/MM/yyyy" />
                                <PropertyColumn Property="x => x.UserLogin" Title="Utilisateur" />
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDeleteAdminLivraison(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Livraison" />
                            </PagerContent>
                        </MudDataGrid>
                    </div></div>

                    <h6 class="mb-2">Payements (Commandes)</h6>

                    <div class="card"><div class="card-body p-0">
                        <MudDataGrid Items="@_adminCommandes" T="Commande" Loading="@_livCmdLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="5"
                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.CommandeId" Title="N° Cmd" />
                                <PropertyColumn Property="x => x.CommandeDescription" Title="Description" />
                                <PropertyColumn Property="x => x.MontantTotal" Title="Total" Format="N2" />
                                <PropertyColumn Property="x => x.MontantPaye" Title="Payé" Format="N2" />
                                <TemplateColumn Title="Reste">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.MontantRest == 0 ? Color.Success : Color.Warning)">
                                            @context.Item.MontantRest.ToString("N2")
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.CreationDate" Title="Date" Format="dd/MM/yyyy" />
                                <PropertyColumn Property="x => x.UserLogin" Title="Utilisateur" />
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDeleteAdminCommande(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Commande" />
                            </PagerContent>
                        </MudDataGrid>
                    </div></div>
                </div>
            }

            @* ══════════════════ LOCALISATIONS ══════════════════ *@
            @if (_tab == 7)
            {
                <div class="card-body">
                    <div class="d-flex justify-content-end gap-2 mb-2">
                        <button class="btn btn-primary btn-sm" @onclick="@OnAddLocalisation"><i class="bi bi-plus-lg me-1"></i>Ajouter</button>
                    </div>

                    <div class="card"><div class="card-body p-0">
                        <MudDataGrid Items="@_localisations" T="Localisation" Loading="@_localisationsLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="10"
                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.IdLocalisation" Title="ID" />
                                <PropertyColumn Property="x => x.DescriptionLocalisation" Title="Description" />
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OnViewLocalisation(context.Item))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OnEditLocalisation(context.Item))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => OnDeleteLocalisation(context.Item))" />
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Localisation" />
                            </PagerContent>
                        </MudDataGrid>
                    </div></div>
                </div>
            }
        </div>
    </div>
}

@code {
    /* ── Hub ── */
    int _tab;
    bool _loaded;

    /* ── Utilisateurs ── */
    List<User> _userData = new();
    Dictionary<string, List<string>> _userLocalisationsMap = new();
    bool _userLoading;
    string? _selectedUserLogin;
    int? _selectedUserRoleId;
    List<RolePermissionRow> _userAccessRows = new();
    bool _userAccessLoading;

    /* ── Rôles & permissions ── */
    List<Role> _roleData = new();
    List<RolePermissionRow> _rolePermissionRows = new();
    int? _selectedRoleId;
    bool _rolePermissionLoading;

    /* ── Référentiel activités ── */
    List<Fonction> _fonctionData = new();
    List<Activity> _activityData = new();
    bool _activityLoading;
    int? _newActivityFonctionId;
    string _newActivityCode = string.Empty;
    string _newActivityLabel = string.Empty;

    /* ── Activités utilisateur ── */
    string? _selectedActivityUserLogin;
    int? _activityFilterFonctionId;
    bool _userActivitiesLoading;
    List<UserActivityRow> _allUserActivityRows = new();
    List<UserActivityRow> _userActivityRows = new();

    /* ── Fournisseurs ── */
    List<Supplier> _supplierData = new();
    bool _supplierLoading;

    /* ── Taux ── */
    List<Taux> _tauxData = new();
    bool _tauxLoading;

    /* ── Périodes ── */
    List<Periode> _periodeData = new();
    bool _periodeLoading;

    /* ── Versements ── */
    List<ApproExpense> _versementData = new();
    bool _versementLoading;
    DateTime? _versDateFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _versDateTo = DateTime.Today;

    /* ── Gestion factures ── */
    List<Fact> _factAdminData = new();
    bool _factAdminLoading;
    DateTime? _factDateFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _factDateTo = DateTime.Today;

    /* ── Gestion livraisons & commandes ── */
    List<Livraison> _adminLivraisons = new();
    List<Commande> _adminCommandes = new();
    bool _livCmdLoading;
    DateTime? _livCmdDateFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _livCmdDateTo = DateTime.Today;

    /* ── Localisations ── */
    List<Localisation> _localisations = new();
    bool _localisationsLoading;

    /* ════════════════════════════════════════════════════════════
       INIT
       ════════════════════════════════════════════════════════════ */

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadUsers(),
            LoadLocalisations(),
            LoadRolePermissions(false),
            LoadFonctions(),
            LoadActivities(),
            LoadSuppliers(),
            LoadTaux(),
            LoadPeriodes(),
            LoadVersements(),
            LoadAdminFactures(),
            LoadLivraisonCommandes()
        );

        await InitializeUserAccessPanel();
        await InitializeUserActivitiesPanel();
        _loaded = true;
    }

    /* ════════════════════════════════════════════════════════════
       UTILISATEURS
       ════════════════════════════════════════════════════════════ */

    async Task LoadUsers()
    {
        _userLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        _userData = await ctx.Users
            .Include(u => u.Role)
            .OrderBy(u => u.Login)
            .ToListAsync();

        // Load user localisations
        var allUserLocs = await ctx.UserLocalisations
            .Where(ul => ul.Activate == true)
            .ToListAsync();

        var locDict = await ctx.Localisations.ToDictionaryAsync(l => l.IdLocalisation, l => l.DescriptionLocalisation ?? "");

        _userLocalisationsMap = allUserLocs
            .Where(ul => ul.UserId != null && ul.LocalisationId.HasValue)
            .GroupBy(ul => ul.UserId!)
            .ToDictionary(
                g => g.Key,
                g => g.Select(ul => locDict.GetValueOrDefault(ul.LocalisationId!.Value, "")).ToList()
            );

        _userLoading = false;
    }

    async Task OnAddUser()
    {
        var parameters = new DialogParameters<UserForm>();
        var options = new MudBlazor.DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserForm>("Nouvel utilisateur", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadUsers();
            await InitializeUserAccessPanel();
        }
    }

    async Task OnEditUser(User item)
    {
        var parameters = new DialogParameters<UserForm> { { x => x.UserLogin, item.Login } };
        var options = new MudBlazor.DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserForm>("Modifier l'utilisateur", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadUsers();
            await InitializeUserAccessPanel();
        }
    }

    async Task OnManageUserAccess(User item)
    {
        var parameters = new DialogParameters<UserAccessForm> { { x => x.UserLogin, item.Login } };
        var options = new MudBlazor.DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserAccessForm>($"Accès utilisateur — {item.Login}", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadUsers();
        }
    }

    async Task OnDeleteUser(User item)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Confirmation",
            $"Supprimer l'utilisateur '{item.Login}' ?",
            yesText: "Supprimer",
            cancelText: "Annuler");
        if (confirm == true)
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            ctx.Users.Remove(item);
            await ctx.SaveChangesAsync();
            await LoadUsers();
            await InitializeUserAccessPanel();
        }
    }

    async Task InitializeUserAccessPanel()
    {
        if (!_userData.Any())
        {
            _selectedUserLogin = null;
            _selectedUserRoleId = null;
            _userAccessRows = new();
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedUserLogin) || !_userData.Any(u => u.Login == _selectedUserLogin))
        {
            _selectedUserLogin = _userData.First().Login;
        }

        var user = _userData.FirstOrDefault(u => u.Login == _selectedUserLogin);
        _selectedUserRoleId = user?.RoleId;

        await LoadUserAccessRows();
    }

    async Task OnSelectedUserChanged()
    {
        var user = _userData.FirstOrDefault(u => u.Login == _selectedUserLogin);
        _selectedUserRoleId = user?.RoleId;
        await LoadUserAccessRows();
    }

    async Task OnSelectedUserRoleChanged()
    {
        await LoadUserAccessRows();
    }

    async Task LoadUserAccessRows()
    {
        _userAccessLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var fonctions = await ctx.Fonctions
            .OrderBy(f => f.DescriptionFonction)
            .ToListAsync();

        if (!_selectedUserRoleId.HasValue)
        {
            _userAccessRows = fonctions
                .Select(f => new RolePermissionRow
                {
                    FonctionId = f.IdFonction,
                    FonctionLabel = f.DescriptionFonction ?? $"Fonction #{f.IdFonction}",
                    CanRead = false,
                    CanWrite = false,
                    CanDelete = false
                })
                .ToList();

            _userAccessLoading = false;
            return;
        }

        var permissions = await ctx.Permissions
            .Where(p => p.RoleId == _selectedUserRoleId.Value)
            .ToListAsync();

        _userAccessRows = fonctions
            .Select(f =>
            {
                var permission = permissions.FirstOrDefault(p => p.FonctionId == f.IdFonction);
                return new RolePermissionRow
                {
                    FonctionId = f.IdFonction,
                    FonctionLabel = f.DescriptionFonction ?? $"Fonction #{f.IdFonction}",
                    CanRead = permission?.CanRead ?? false,
                    CanWrite = permission?.CanWrite ?? false,
                    CanDelete = permission?.CanDelete ?? false
                };
            })
            .ToList();

        _userAccessLoading = false;
    }

    async Task SaveUserAccess()
    {
        if (string.IsNullOrWhiteSpace(_selectedUserLogin))
        {
            Snackbar.Add("Sélectionnez un utilisateur.", Severity.Warning);
            return;
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            var user = await ctx.Users.FirstOrDefaultAsync(u => u.Login == _selectedUserLogin);
            if (user is null)
            {
                Snackbar.Add("Utilisateur introuvable.", Severity.Error);
                return;
            }

            user.RoleId = _selectedUserRoleId;
            await ctx.SaveChangesAsync();

            if (_selectedUserRoleId.HasValue)
            {
                var existing = await ctx.Permissions
                    .Where(p => p.RoleId == _selectedUserRoleId.Value)
                    .ToListAsync();

                if (existing.Any())
                {
                    ctx.Permissions.RemoveRange(existing);
                    await ctx.SaveChangesAsync();
                }

                var newPermissions = _userAccessRows
                    .Where(p => p.CanRead || p.CanWrite || p.CanDelete)
                    .Select(p => new Permission
                    {
                        RoleId = _selectedUserRoleId.Value,
                        FonctionId = p.FonctionId,
                        CanRead = p.CanRead || p.CanWrite || p.CanDelete,
                        CanWrite = p.CanWrite,
                        CanDelete = p.CanDelete
                    })
                    .ToList();

                if (newPermissions.Any())
                {
                    await ctx.Permissions.AddRangeAsync(newPermissions);
                    await ctx.SaveChangesAsync();
                }
            }

            Snackbar.Add("Rôle et activités enregistrés.", Severity.Success);
            await LoadUsers();
            await LoadRolePermissions();
            await InitializeUserAccessPanel();
        }
        catch (Exception ex)
        {
            var message = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(message, Severity.Error);
        }
    }

    async Task LoadFonctions()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        _fonctionData = await ctx.Fonctions
            .OrderBy(f => f.DescriptionFonction)
            .ToListAsync();

        if (!_newActivityFonctionId.HasValue && _fonctionData.Any())
        {
            _newActivityFonctionId = _fonctionData.First().IdFonction;
        }
    }

    async Task LoadActivities()
    {
        _activityLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        _activityData = await ctx.Activities
            .Include(a => a.Fonction)
            .OrderBy(a => a.Fonction!.DescriptionFonction)
            .ThenBy(a => a.DescriptionActivity)
            .ToListAsync();
        _activityLoading = false;
    }

    async Task AddActivity()
    {
        if (!_newActivityFonctionId.HasValue || string.IsNullOrWhiteSpace(_newActivityCode) || string.IsNullOrWhiteSpace(_newActivityLabel))
        {
            Snackbar.Add("Fonction, code et description sont obligatoires.", Severity.Warning);
            return;
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var code = _newActivityCode.Trim().ToLowerInvariant();

            var exists = await ctx.Activities.AnyAsync(a => a.Code == code);
            if (exists)
            {
                Snackbar.Add("Ce code existe déjà.", Severity.Warning);
                return;
            }

            ctx.Activities.Add(new Activity
            {
                FonctionId = _newActivityFonctionId.Value,
                Code = code,
                DescriptionActivity = _newActivityLabel.Trim(),
                IsActive = true
            });

            await ctx.SaveChangesAsync();
            _newActivityCode = string.Empty;
            _newActivityLabel = string.Empty;

            Snackbar.Add("Activité ajoutée.", Severity.Success);
            await LoadActivities();
            await LoadUserActivities();
        }
        catch (Exception ex)
        {
            var message = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(message, Severity.Error);
        }
    }

    async Task ToggleActivityState(Activity activity)
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var entity = await ctx.Activities.FirstOrDefaultAsync(a => a.ActivityId == activity.ActivityId);
        if (entity is null) return;

        entity.IsActive = !entity.IsActive;
        await ctx.SaveChangesAsync();
        await LoadActivities();
        await LoadUserActivities();
    }

    async Task DeleteActivity(Activity activity)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Confirmation",
            $"Supprimer l'activité '{activity.DescriptionActivity}' ?",
            yesText: "Supprimer",
            cancelText: "Annuler");
        if (confirm != true) return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var entity = await ctx.Activities.FirstOrDefaultAsync(a => a.ActivityId == activity.ActivityId);
            if (entity is null) return;

            var links = await ctx.UserActivities.Where(ua => ua.ActivityId == entity.ActivityId).ToListAsync();
            if (links.Any()) ctx.UserActivities.RemoveRange(links);

            ctx.Activities.Remove(entity);
            await ctx.SaveChangesAsync();

            Snackbar.Add("Activité supprimée.", Severity.Success);
            await LoadActivities();
            await LoadUserActivities();
        }
        catch (Exception ex)
        {
            var message = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(message, Severity.Error);
        }
    }

    async Task InitializeUserActivitiesPanel()
    {
        if (!_userData.Any())
        {
            _selectedActivityUserLogin = null;
            _allUserActivityRows = new();
            _userActivityRows = new();
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedActivityUserLogin) || !_userData.Any(u => u.Login == _selectedActivityUserLogin))
        {
            _selectedActivityUserLogin = _userData.First().Login;
        }

        await LoadUserActivities();
    }

    async Task OnActivityUserChanged()
    {
        await LoadUserActivities();
    }

    void ApplyActivityUserFilter()
    {
        _userActivityRows = _allUserActivityRows
            .Where(a => !_activityFilterFonctionId.HasValue || a.FonctionId == _activityFilterFonctionId.Value)
            .ToList();
    }

    async Task LoadUserActivities()
    {
        if (string.IsNullOrWhiteSpace(_selectedActivityUserLogin))
        {
            _allUserActivityRows = new();
            _userActivityRows = new();
            return;
        }

        _userActivitiesLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var activities = await ctx.Activities
            .Include(a => a.Fonction)
            .Where(a => a.IsActive)
            .OrderBy(a => a.Fonction!.DescriptionFonction)
            .ThenBy(a => a.DescriptionActivity)
            .ToListAsync();

        var grantedIds = await ctx.UserActivities
            .Where(ua => ua.UserLogin == _selectedActivityUserLogin && ua.IsGranted)
            .Select(ua => ua.ActivityId)
            .ToListAsync();

        var grantedSet = grantedIds.ToHashSet();

        _allUserActivityRows = activities
            .Select(a => new UserActivityRow
            {
                ActivityId = a.ActivityId,
                FonctionId = a.FonctionId,
                FonctionLabel = a.Fonction?.DescriptionFonction ?? "-",
                ActivityCode = a.Code,
                ActivityLabel = a.DescriptionActivity,
                IsGranted = grantedSet.Contains(a.ActivityId)
            })
            .ToList();

        ApplyActivityUserFilter();
        _userActivitiesLoading = false;
    }

    async Task SaveUserActivities()
    {
        if (string.IsNullOrWhiteSpace(_selectedActivityUserLogin))
            return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var existing = await ctx.UserActivities
                .Where(ua => ua.UserLogin == _selectedActivityUserLogin)
                .ToListAsync();

            if (existing.Any())
            {
                ctx.UserActivities.RemoveRange(existing);
                await ctx.SaveChangesAsync();
            }

            var rows = _allUserActivityRows
                .Where(a => a.IsGranted)
                .Select(a => new UserActivity
                {
                    UserLogin = _selectedActivityUserLogin,
                    ActivityId = a.ActivityId,
                    IsGranted = true,
                    AssignedDate = DateTime.Now
                })
                .ToList();

            if (rows.Any())
            {
                await ctx.UserActivities.AddRangeAsync(rows);
                await ctx.SaveChangesAsync();
            }

            Snackbar.Add("Activités enregistrées.", Severity.Success);
            await LoadUserActivities();
        }
        catch (Exception ex)
        {
            var message = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(message, Severity.Error);
        }
    }

    async Task LoadRolePermissions(bool preserveSelection = true)
    {
        _rolePermissionLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();

        _roleData = await ctx.Roles
            .Where(r => r.IsActive)
            .OrderBy(r => r.DescriptionRole)
            .ToListAsync();

        if (!_roleData.Any())
        {
            _selectedRoleId = null;
            _rolePermissionRows = new();
            _rolePermissionLoading = false;
            return;
        }

        if (!preserveSelection || !_selectedRoleId.HasValue || !_roleData.Any(r => r.RoleId == _selectedRoleId.Value))
        {
            _selectedRoleId = _roleData.First().RoleId;
        }

        var fonctions = await ctx.Fonctions
            .OrderBy(f => f.DescriptionFonction)
            .ToListAsync();

        var permissions = await ctx.Permissions
            .Where(p => p.RoleId == _selectedRoleId.Value)
            .ToListAsync();

        _rolePermissionRows = fonctions
            .Select(f =>
            {
                var permission = permissions.FirstOrDefault(p => p.FonctionId == f.IdFonction);
                return new RolePermissionRow
                {
                    FonctionId = f.IdFonction,
                    FonctionLabel = f.DescriptionFonction ?? $"Fonction #{f.IdFonction}",
                    CanRead = permission?.CanRead ?? false,
                    CanWrite = permission?.CanWrite ?? false,
                    CanDelete = permission?.CanDelete ?? false
                };
            })
            .ToList();

        _rolePermissionLoading = false;
    }

    async Task OnSelectedRoleChanged()
    {
        await LoadRolePermissions();
    }

    async Task SaveRolePermissions()
    {
        if (!_selectedRoleId.HasValue)
            return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            var existing = await ctx.Permissions
                .Where(p => p.RoleId == _selectedRoleId.Value)
                .ToListAsync();

            if (existing.Any())
            {
                ctx.Permissions.RemoveRange(existing);
                await ctx.SaveChangesAsync();
            }

            var newPermissions = _rolePermissionRows
                .Where(p => p.CanRead || p.CanWrite || p.CanDelete)
                .Select(p => new Permission
                {
                    RoleId = _selectedRoleId.Value,
                    FonctionId = p.FonctionId,
                    CanRead = p.CanRead || p.CanWrite || p.CanDelete,
                    CanWrite = p.CanWrite,
                    CanDelete = p.CanDelete
                })
                .ToList();

            if (newPermissions.Any())
            {
                await ctx.Permissions.AddRangeAsync(newPermissions);
                await ctx.SaveChangesAsync();
            }

            Snackbar.Add("Les fonctions du rôle ont été mises à jour.", Severity.Success);
            await LoadRolePermissions();
        }
        catch (Exception ex)
        {
            var message = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(message, Severity.Error);
        }
    }

    async Task ApplyDefaultPermissions()
    {
        if (!_selectedRoleId.HasValue) return;

        var confirm = await DialogService.ShowMessageBox("Permissions par défaut",
            "Voulez-vous appliquer les permissions par défaut pour ce rôle ?\nCela remplacera les permissions actuelles.",
            yesText: "Appliquer", cancelText: "Annuler");

        if (confirm == true)
        {
            try
            {
                await RolePermissionService.SetDefaultPermissionsForRoleAsync(_selectedRoleId.Value, overwrite: true);
                Snackbar.Add("Permissions par défaut appliquées", Severity.Success);
                await LoadRolePermissions();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
            }
        }
    }

