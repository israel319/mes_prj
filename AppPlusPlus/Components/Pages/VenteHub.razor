    async Task LoadLivraisons()
    {
        _livLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var livQuery = ctx.Livraisons
            .Include(l => l.Customer)
            .Include(l => l.Commande)
            .Include(l => l.Details)
            .Include(l => l.Fact).ThenInclude(f => f!.Payments)
            .AsQueryable();

        // Filter by user's localisations if not admin
        if (_currentUserLocalisations.Any())
        {
            livQuery = livQuery.Where(l => l.Details.Any(d => d.LocalisationId.HasValue && _currentUserLocalisations.Contains(d.LocalisationId.Value)));
        }

        _livData = await livQuery
            .OrderByDescending(l => l.Date)
            .ToListAsync();

        _livLoading = false;
    }

