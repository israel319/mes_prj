    async Task ExportFacturesExcel()
    {
        using var workbook = new ClosedXML.Excel.XLWorkbook();
        var ws = workbook.Worksheets.Add("Factures");

        string[] headers = { "N° Fact", "Client", "Articles", "Qté", "Total", "Date", "Status", "Login" };
        for (int i = 0; i < headers.Length; i++)
        {
            var cell = ws.Cell(1, i + 1);
            cell.Value = headers[i];
            cell.Style.Font.Bold = true;
            cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#4472C4");
            cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.White;
        }

        int row = 2;
        foreach (var r in _factFiltered)
        {
            ws.Cell(row, 1).Value = r.Id;
            ws.Cell(row, 2).Value = r.Client;
            ws.Cell(row, 3).Value = r.Articles;
            ws.Cell(row, 4).Value = r.TotalQte;
            ws.Cell(row, 5).Value = r.Total;
            ws.Cell(row, 5).Style.NumberFormat.Format = "#,##0.00";
            ws.Cell(row, 6).Value = r.Date.ToString("dd/MM/yyyy");
            ws.Cell(row, 7).Value = r.DisplayStatus switch { 0 => "Brouillon", 1 => "Validée", 2 => "Payée", 3 => "Annulée", 4 => "Partiel", _ => "—" };
            ws.Cell(row, 8).Value = r.Login;
            row++;
        }

        ws.Columns().AdjustToContents();

        using var ms = new System.IO.MemoryStream();
        workbook.SaveAs(ms);
        var bytes = ms.ToArray();
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"Factures_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";

        await JS.InvokeVoidAsync("eval", $@"
            var a = document.createElement('a');
            a.href = 'data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';
            a.download = '{fileName}';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        ");
    }

    class FactRow
    {
        public int Id { get; set; }
        public string Client { get; set; } = "";
        public string Articles { get; set; } = "";
        public double TotalQte { get; set; }
        public double Total { get; set; }
        public double Paye { get; set; }
        public double Solde { get; set; }
        public DateOnly Date { get; set; }
        public int Status { get; set; }
        public string Login { get; set; } = "";
        /// <summary>Statut calculé dynamiquement : 0=Brouillon, 1=Validée, 2=Payée, 3=Annulée, 4=Partiel</summary>
        public int DisplayStatus => Status == 3 ? 3 : Status == 0 ? 0 : Solde <= 0 ? 2 : Paye > 0 ? 4 : 1;
    }

