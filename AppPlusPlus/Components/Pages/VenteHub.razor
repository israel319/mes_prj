@page "/vente"
@rendermode InteractiveServer
@using MudBlazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject MudBlazor.IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject PermissionService PermissionService
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<PageTitle>@AppSettings.AppName — Ventes</PageTitle>

@if (!_loaded)
{
    <div class="d-flex align-items-center justify-content-center" style="min-height:200px;">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement…</span></div>
    </div>
}
else
{
    @if (!_hasSalesReadAccess)
    {
        <div class="card mx-auto mt-4" style="max-width:720px;">
            <div class="card-body text-center py-5">
                <i class="bi bi-lock" style="font-size:42px;color:#f59e0b;"></i>
                <h5 class="fw-bold mt-3">Accès refusé</h5>
                <p class="text-muted mx-auto" style="max-width:520px;">
                    Votre rôle ne possède pas les droits de lecture sur les ventes.
                </p>
            </div>
        </div>
    }
    else
    {
    <!-- En-tête -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-2 hub-header">
        <div class="d-flex align-items-center gap-3 min-w-0">
            <div class="hub-icon" style="background:#d4f5ef;color:#00B193;">
                <i class="bi bi-receipt"></i>
            </div>
            <div class="d-flex flex-column min-w-0">
                <h5 class="fw-bold mb-0">Ventes</h5>
                <small class="text-muted hub-subtitle">Gestion des factures, livraisons et paiements</small>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2">
            @switch (_tab)
            {
                case 0:
                    @if (_canFacturationWrite)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="@(() => Navigation.NavigateTo("/vente/facturation"))">
                            <i class="bi bi-plus-lg me-1"></i> Nouvelle facture
                        </button>
                    }
                    break;
                case 1:
                    @if (_canLivraisonWrite)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="@OnAddLivraison">
                            <i class="bi bi-truck me-1"></i> Nouvelle livraison
                        </button>
                    }
                    break;
            }
        </div>
    </div>

    <!-- Onglets -->
    <div class="card hub-tabs-shell">
        <ul class="nav nav-tabs px-3 pt-2">
            @if (_canVenteRead || _canFacturationRead)
            {
                <li class="nav-item"><button class="nav-link @(_tab == 0 ? "active" : "")" @onclick="@(async () => await OnTabChange(0))"><i class="bi bi-file-text me-1"></i>Factures</button></li>
            }
            @if (_canLivraisonRead)
            {
                <li class="nav-item"><button class="nav-link @(_tab == 1 ? "active" : "")" @onclick="@(async () => await OnTabChange(1))"><i class="bi bi-truck me-1"></i>Livraisons</button></li>
            }
            @if (_canPaiementRead)
            {
                <li class="nav-item"><button class="nav-link @(_tab == 2 ? "active" : "")" @onclick="@(async () => await OnTabChange(2))"><i class="bi bi-cash me-1"></i>Paiements</button></li>
            }
        </ul>
                @* ══════════════════ FACTURES ══════════════════ *@
                @if (_tab == 0 && (_canVenteRead || _canFacturationRead))
                {
                    <div class="card-body hub-tab-card">
                        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                            <h5 class="fw-bold mb-0 hub-section-title">
                                Factures : @_factFiltered.Count()
                            </h5>
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-primary btn-sm" @onclick="@ExportFacturesExcel" disabled="@(!_factData.Any())">
                                    <i class="bi bi-file-earmark-excel me-1"></i> Exporter Excel
                                </button>
                            </div>
                        </div>

                        <div class="row g-2 mb-2 hub-filter-row">
                            <div class="col-12 col-md-8 col-lg-9">
                                <MudTextField T="string" Value="_factSearch"
                                              ValueChanged="@(val => { _factSearch = val; ApplyFactFilter(); })"
                                              Immediate="true"
                                              Placeholder="Rechercher (n°, client, article…)"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:100%;" />
                            </div>
                            <div class="col-12 col-md-4 col-lg-3">
                                <MudSelect T="int?" Value="_factStatusFilter"
                                           ValueChanged="@(val => { _factStatusFilter = val; ApplyFactFilter(); })"
                                           Placeholder="Tous les status" Clearable="true"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:100%;">
                                    @foreach (var opt in _factStatusOptions)
                                    {
                                        <MudSelectItem T="int?" Value="@opt.Key">@opt.Value</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                        </div>

                        <MudDataGrid Items="@_factFiltered" T="FactRow" Loading="@_factLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     RowsPerPage="13"
                                     Style="width:100%;cursor:pointer;"
                                     RowClick="@OnFactRowClick">
                            <Columns>
                                <PropertyColumn Property="x => x.Id" Title="N° Fact" />
                                <PropertyColumn Property="x => x.Client" Title="Client" />
                                <PropertyColumn Property="x => x.Articles" Title="Article" />
                                <PropertyColumn Property="x => x.TotalQte" Title="Qté" Format="N0" />
                                <PropertyColumn Property="x => x.Total" Title="Total" Format="N2" />
                                <TemplateColumn Title="Payé">
                                    <CellTemplate>
                                        <MudText Style="@(context.Item.Paye > 0 ? "font-weight:600;color:var(--mud-palette-success);" : "")">@context.Item.Paye.ToString("N2")</MudText>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Solde">
                                    <CellTemplate>
                                        @if (context.Item.DisplayStatus >= 1 && context.Item.DisplayStatus != 3)
                                        {
                                            <MudText Style="@(context.Item.Solde > 0 ? "font-weight:600;color:var(--mud-palette-error);" : "color:var(--mud-palette-success);")">@context.Item.Solde.ToString("N2")</MudText>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Date" Title="Date" Format="dd/MM/yyyy" />
                                <TemplateColumn Title="Status">
                                    <CellTemplate>
                                        @{ var (label, chipColor) = context.Item.DisplayStatus switch { 0 => ("Brouillon", Color.Default), 1 => ("Validée", Color.Info), 2 => ("Payée", Color.Success), 3 => ("Annulée", Color.Error), 4 => ("Partiel", Color.Warning), _ => ("—", Color.Secondary) }; }
                                        <MudChip T="string" Size="Size.Small" Color="@chipColor">@label</MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Login" Title="Login" />
                                <TemplateColumn Title="" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <div @onclick:stopPropagation="true">
                                        @if (context.Item.DisplayStatus == 0 && _canFacturationWrite)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                                           OnClick="@(() => Navigation.NavigateTo($"/vente/facturation/{context.Item.Id}"))"
                                                           Title="Modifier le brouillon" />
                                        }
                                        @if ((context.Item.DisplayStatus == 1 || context.Item.DisplayStatus == 4) && _canFacturationWrite)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Size="Size.Small"
                                                           OnClick="@(() => OnPayerFacture(context.Item))"
                                                           Title="Enregistrer un paiement" />
                                        }
                                        else if (context.Item.DisplayStatus == 2)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small"
                                                           OnClick="@(() => OnPayerFacture(context.Item))"
                                                           Title="Historique paiements" />
                                        }
                                        @if (_canFacturationDelete)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                           OnClick="@(() => OnDeleteFacture(context.Item))" />
                                        }
                                        </div>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="FactRow" />
                            </PagerContent>
                        </MudDataGrid>
                    </div>
                }

                @* ══════════════════ LIVRAISONS ══════════════════ *@
                @if (_tab == 1 && _canLivraisonRead)
                {
                    <div class="card-body hub-tab-card">
                        <MudDataGrid Items="@_livData" T="Livraison" Loading="@_livLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     Filterable="true" RowsPerPage="10"
                                     Style="width:100%;">
                            <Columns>
                                <PropertyColumn Property="x => x.LivraisonId" Title="N°" />
                                <TemplateColumn Title="Client">
                                    <CellTemplate>
                                        @(context.Item.Customer?.CustomerName ?? "—")
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Commande">
                                    <CellTemplate>
                                        @if (context.Item.CommandeId.HasValue)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@($"C-{context.Item.CommandeId}")</MudChip>
                                        }
                                        else
                                        {
                                            <span style="color:#aaa;">—</span>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Porteur" Title="Porteur" />
                                <TemplateColumn Title="Articles" Sortable="false">
                                    <CellTemplate>
                                        @(context.Item.Details.Count)
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Montant" Sortable="false">
                                    <CellTemplate>
                                        @(context.Item.Details.Sum(d => d.MontantPaye ?? 0).ToString("N2"))
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Statut">
                                    <CellTemplate>
                                        @{
                                            string lbl; Color sty;
                                            if (context.Item.Fact != null)
                                            {
                                                var fTotal = (double)(context.Item.Fact.TotalApresReduction ?? context.Item.Fact.Total ?? 0);
                                                var fPaye  = context.Item.Fact.Payments?.Sum(p => (double)p.Amount) ?? 0;
                                                if (fPaye >= fTotal && fTotal > 0) { lbl = "Payée"; sty = Color.Success; }
                                                else if (fPaye > 0) { lbl = "Partiel"; sty = Color.Warning; }
                                                else { lbl = "Facturée"; sty = Color.Default; }
                                            }
                                            else
                                            {
                                                (lbl, sty) = (context.Item.Status ?? 0) switch
                                                {
                                                    1 => ("Livrée", Color.Info),
                                                    _ => ("En attente", Color.Warning)
                                                };
                                            }
                                        }
                                        <MudChip T="string" Size="Size.Small" Color="@sty">@lbl</MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <PropertyColumn Property="x => x.Date" Title="Date" Format="dd/MM/yyyy" />
                                <TemplateColumn Title="Facture" Sortable="false">
                                    <CellTemplate>
                                        @if (context.Item.Fact != null)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@($"F-{context.Item.Fact.Id}")</MudChip>
                                        }
                                        else
                                        {
                                            <span style="color:#aaa;">—</span>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        <div class="d-flex gap-0 justify-content-center">
                                            @if ((context.Item.Status ?? 0) == 0 && _canLivraisonWrite)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Info" Size="Size.Small"
                                                               OnClick="@(() => OnMarquerLivree(context.Item))" Title="Marquer comme livrée" />
                                            }
                                            @if ((context.Item.Status ?? 0) <= 1 && context.Item.Fact == null && _canLivraisonWrite)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Size="Size.Small"
                                                               OnClick="@(() => OnPayerLivraison(context.Item))" Title="Payer → génère la facture" />
                                            }
                                            @if (_canLivraisonWrite)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                                                               OnClick="@(() => OnEditLivraison(context.Item))" Title="Modifier" />
                                            }
                                            @if (_canLivraisonDelete)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                               OnClick="@(() => OnDeleteLivraison(context.Item))" Title="Supprimer"
                                                               Disabled="@(context.Item.Fact != null)" />
                                            }
                                        </div>
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="Livraison" />
                            </PagerContent>
                        </MudDataGrid>
                    </div>
                }

                @* ══════════════════ PAIEMENTS ══════════════════ *@
                @if (_tab == 2 && _canPaiementRead)
                {
                    <div class="card-body hub-tab-card">
                        <MudDataGrid Items="@_payData" T="FactureView" Loading="@_payLoading"
                                     Dense="true" Hover="true" Bordered="true" Elevation="0"
                                     RowsPerPage="10"
                                     Style="width:100%;">
                            <ChildRowContent>
                                @if (context.Item.Payments.Any())
                                {
                                    <h6 class="fw-semibold mb-2">
                                        Historique des paiements
                                    </h6>
                                    <MudSimpleTable Dense="true" Bordered="true" Style="margin-bottom:8px;">
                                        <thead>
                                            <tr>
                                                <th>N°</th>
                                                <th>Date</th>
                                                <th style="text-align:right;">Montant</th>
                                                <th>Note</th>
                                                <th>Utilisateur</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var p in context.Item.Payments)
                                            {
                                                <tr>
                                                    <td>@p.Id</td>
                                                    <td>@p.Date.ToString("dd/MM/yyyy")</td>
                                                    <td style="text-align:right;">@p.Amount.ToString("N2")</td>
                                                    <td>@p.Note</td>
                                                    <td>@p.User</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                                else
                                {
                                    <p class="text-muted small">Aucun paiement enregistré.</p>
                                }
                            </ChildRowContent>
                            <Columns>
                                <HierarchyColumn T="FactureView" />
                                <TemplateColumn Title="Facture" Filterable="false">
                                    <CellTemplate>
                                        <strong>F-@context.Item.Facture.Id</strong>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Client">
                                    <CellTemplate>
                                        @(context.Item.ClientName)
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Commande">
                                    <CellTemplate>
                                        @if (context.Item.Facture.CommandeId.HasValue)
                                        {
                                            <span>N° @context.Item.Facture.CommandeId</span>
                                        }
                                        else
                                        {
                                            <span style="color:#aaa;">Directe</span>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Total">
                                    <CellTemplate>
                                        @((context.Item.Facture.TotalApresReduction ?? context.Item.Facture.Total ?? 0).ToString("N2"))
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Payé">
                                    <CellTemplate>
                                        @context.Item.TotalPaye.ToString("N2")
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Reste">
                                    <CellTemplate>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.Item.Reste <= 0 ? Color.Success : Color.Error)">
                                            @context.Item.Reste.ToString("N2")
                                        </MudChip>
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="Statut">
                                    <CellTemplate>
                                        @if (context.Item.Facture.Status == 3)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Annulée</MudChip>
                                        }
                                        else if (context.Item.Reste <= 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Payée</MudChip>
                                        }
                                        else if (context.Item.TotalPaye > 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Partiel</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Impayée</MudChip>
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                                <TemplateColumn Title="" Sortable="false" Filterable="false">
                                    <CellTemplate>
                                        @if (context.Item.Reste > 0 && _canFacturationWrite)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Payments" Color="Color.Primary" Size="Size.Small"
                                                           OnClick="@(() => OnPayerPaiement(context.Item))"
                                                           Title="Enregistrer un paiement" />
                                        }
                                    </CellTemplate>
                                </TemplateColumn>
                            </Columns>
                            <PagerContent>
                                <MudDataGridPager T="FactureView" />
                            </PagerContent>
                        </MudDataGrid>
                    </div>
                }
            </div>
    }
}

@code {
    /* ── Hub ── */
    int _tab;
    bool _loaded;
    bool _hasSalesReadAccess;
    bool _canVenteRead;
    bool _canFacturationRead;
    bool _canLivraisonRead;
    bool _canPaiementRead;
    bool _canFacturationWrite;
    bool _canFacturationDelete;
    bool _canLivraisonWrite;
    bool _canLivraisonDelete;
    List<int> _currentUserLocalisations = new();

    /* ── Facture state ── */
    List<FactRow> _factData = new();
    bool _factLoading;
    string _factSearch = "";
    int? _factStatusFilter;

    List<KeyValuePair<int, string>> _factStatusOptions = new()
    {
        new(0, "Brouillon"),
        new(1, "Validée"),
        new(2, "Payée"),
        new(3, "Annulée"),
        new(4, "Partiel"),
    };

    List<FactRow> _factFiltered = new();

    void ApplyFactFilter()
    {
        _factFiltered = _factData.Where(r =>
        {
            if (_factStatusFilter.HasValue && r.DisplayStatus != _factStatusFilter.Value)
                return false;
            if (!string.IsNullOrWhiteSpace(_factSearch))
            {
                var s = _factSearch.Trim();
                return r.Id.ToString().Contains(s, StringComparison.OrdinalIgnoreCase)
                    || r.Client.Contains(s, StringComparison.OrdinalIgnoreCase)
                    || r.Articles.Contains(s, StringComparison.OrdinalIgnoreCase)
                    || r.Login.Contains(s, StringComparison.OrdinalIgnoreCase);
            }
            return true;
        }).ToList();
    }

    /* ── Livraison state ── */
    List<Livraison> _livData = new();
    bool _livLoading;

    /* ── Paiement state ── */
    List<FactureView> _payData = new();
    bool _payLoading;

    /* ════════════════════════════════════════════════════════════
       INIT
       ════════════════════════════════════════════════════════════ */

    protected override async Task OnInitializedAsync()
    {
        await LoadSecurityAsync();

        var tasks = new List<Task>();
        if (_canVenteRead || _canFacturationRead) tasks.Add(LoadFactures());
        if (_canLivraisonRead) tasks.Add(LoadLivraisons());
        if (_canPaiementRead) tasks.Add(LoadPaiements());

        if (tasks.Any())
        {
            await Task.WhenAll(tasks);
        }

        _loaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedTab = await JS.InvokeAsync<int>("tabNavigation.getTab", "vente", 0);
                if (savedTab != _tab)
                {
                    _tab = savedTab;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    async Task OnTabChange(int tabIndex)
    {
        _tab = tabIndex;
        try
        {
            await JS.InvokeVoidAsync("tabNavigation.saveTab", "vente", tabIndex);
        }
        catch { }
    }

    async Task LoadSecurityAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            _hasSalesReadAccess = false;
            return;
        }

        var login = user.FindFirst("login")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var permissions = await PermissionService.GetPermissionsAsync(login);
        var isAdmin = AppFunctions.Normalize(user.FindFirst(ClaimTypes.Role)?.Value) == "administrateur";

        _canVenteRead = isAdmin || permissions.CanRead(AppFunctions.Vente);
        _canFacturationRead = isAdmin || permissions.CanRead(AppFunctions.Facturation);
        _canLivraisonRead = isAdmin || permissions.CanRead(AppFunctions.Livraison);
        _canPaiementRead = _canFacturationRead;

        _hasSalesReadAccess = _canVenteRead || _canFacturationRead || _canLivraisonRead;

        _canFacturationWrite = isAdmin || permissions.CanWrite(AppFunctions.Facturation);
        _canFacturationDelete = isAdmin || permissions.CanDelete(AppFunctions.Facturation);
        _canLivraisonWrite = isAdmin || permissions.CanWrite(AppFunctions.Livraison) || permissions.CanWrite(AppFunctions.Vente);
        _canLivraisonDelete = isAdmin || permissions.CanDelete(AppFunctions.Livraison) || permissions.CanDelete(AppFunctions.Vente);

        // Fetch user's assigned localisations from T_User_Localisations
        if (!isAdmin && !string.IsNullOrEmpty(login))
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            _currentUserLocalisations = await ctx.UserLocalisations
                .Where(ul => ul.UserId != null && ul.UserId.ToLower() == login.ToLower() && ul.Activate == true && ul.LocalisationId.HasValue)
                .Select(ul => ul.LocalisationId!.Value)
                .ToListAsync();
        }
    }

    /* ════════════════════════════════════════════════════════════
       FACTURES
       ════════════════════════════════════════════════════════════ */

    async Task LoadFactures()
    {
        _factLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var articleNames = await ctx.Articles.ToDictionaryAsync(a => a.IdArticle, a => a.Description ?? a.IdArticle);

        var factsQuery = ctx.Facts
            .Include(f => f.Details)
            .AsQueryable();

        // Filter by user's localisations if not admin
        if (_currentUserLocalisations.Any())
        {
            factsQuery = factsQuery.Where(f => f.Details.Any(d => d.Localisationid.HasValue && _currentUserLocalisations.Contains(d.Localisationid.Value)));
        }

        var facts = await factsQuery
            .OrderByDescending(f => f.Date)
            .ThenByDescending(f => f.Id)
            .ToListAsync();

        var paymentsByFact = await ctx.Payments
            .GroupBy(p => p.IdFact)
            .Select(g => new { IdFact = g.Key, Total = g.Sum(x => x.Amount) })
            .ToDictionaryAsync(x => x.IdFact, x => (double)x.Total);

        _factData = facts.Select(f =>
        {
            var articlesStr = f.Details.Any()
                ? string.Join(", ", f.Details
                    .Where(d => d.IdArticle != null)
                    .Select(d => articleNames.GetValueOrDefault(d.IdArticle!, d.IdArticle!)))
                : f.DescriptionArticle ?? "";

            var total = (double)(f.TotalApresReduction ?? f.Total ?? 0);
            var paye = paymentsByFact.GetValueOrDefault(f.Id);

            return new FactRow
            {
                Id = f.Id,
                Client = f.DescriptionName,
                Articles = articlesStr,
                TotalQte = f.Details.Sum(d => d.Qte ?? 0),
                Total = total,
                Paye = paye,
                Solde = total - paye,
                Date = f.Date,
                Status = f.Status,
                Login = f.User,
            };
        }).ToList();

        _factLoading = false;
        ApplyFactFilter();
    }

    async Task OnFactRowClick(DataGridRowClickEventArgs<FactRow> args)
    {
        var parameters = new DialogParameters<FactureDetail> { { x => x.FactId, args.Item.Id } };
