@using MudBlazor
@inject IDbContextFactory<AppDbContext> DbFactory

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column gap-3">

            <div>
                <label class="form-label">Commentaire / Description</label>
                <input type="text" class="form-control" @bind="_periode.Comment" maxlength="200" />
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Date début</label>
                    <MudDatePicker @bind-Date="_fromDate" DateFormat="dd/MM/yyyy"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Date fin</label>
                    <MudDatePicker @bind-Date="_toDate" DateFormat="dd/MM/yyyy"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
            </div>

            <div>
                <label class="form-label">Activée</label>
                <MudSwitch @bind-Value="_activated" T="bool" Color="Color.Primary" />
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="OnSubmit">
            <i class="bi bi-check-lg me-1"></i>Enregistrer
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? PeriodeId { get; set; }

    Periode _periode = new() { Activated = true };
    bool _activated = true;
    DateTime? _fromDate = DateTime.Today;
    DateTime? _toDate = DateTime.Today.AddMonths(1);

    protected override async Task OnInitializedAsync()
    {
        if (PeriodeId.HasValue)
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var existing = await ctx.Periodes.FindAsync(PeriodeId.Value);
            if (existing != null)
            {
                _periode = existing;
                _activated = _periode.Activated ?? true;
                _fromDate = _periode.FromDate;
                _toDate = _periode.ToDate;
            }
        }
    }

    void Cancel() => MudDialog.Close();

    async Task OnSubmit()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        _periode.Activated = _activated;
        _periode.FromDate = _fromDate;
        _periode.ToDate = _toDate;
        _periode.UserLogin = "Admin";
        _periode.DateSys = DateOnly.FromDateTime(DateTime.Now);
        if (PeriodeId.HasValue)
            ctx.Periodes.Update(_periode);
        else
            ctx.Periodes.Add(_periode);
        await ctx.SaveChangesAsync();
        MudDialog.Close(DialogResult.Ok(true));
    }
}
