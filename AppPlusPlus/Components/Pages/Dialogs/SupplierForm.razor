@using MudBlazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column gap-3" style="min-width:540px;">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">N° Fournisseur</label>
                    <input type="text" class="form-control" @bind="_item.SupplierNumber" placeholder="Ex: FRN001" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Nom *</label>
                    <input type="text" class="form-control" @bind="_item.SupplierName" placeholder="Nom du fournisseur" />
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Contact / Téléphone</label>
                    <input type="text" class="form-control" @bind="_item.Contact" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input type="text" class="form-control" @bind="_item.Email" />
                </div>
            </div>

            <div>
                <label class="form-label">Adresse</label>
                <input type="text" class="form-control" @bind="_item.Adresse" />
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Montant à payer</label>
                    <MudNumericField @bind-Value="_item.CcAmountToPay" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Montant payé</label>
                    <MudNumericField @bind-Value="_item.CcAmountPay" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="@OnSave">
            <i class="bi bi-check-lg me-1"></i>Enregistrer
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? SupplierId { get; set; }

    Supplier _item = new();

    protected override async Task OnInitializedAsync()
    {
        if (SupplierId.HasValue)
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var existing = await ctx.Suppliers.FindAsync(SupplierId.Value);
            if (existing != null) _item = existing;
        }
    }

    void Cancel() => MudDialog.Close();

    async Task OnSave()
    {
        if (string.IsNullOrWhiteSpace(_item.SupplierName))
        {
            Snackbar.Add("Le nom est obligatoire", Severity.Warning);
            return;
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            _item.UserLogin = "Admin";

            if (SupplierId.HasValue)
            {
                ctx.Suppliers.Update(_item);
            }
            else
            {
                _item.CreationDate = DateOnly.FromDateTime(DateTime.Today);
                ctx.Suppliers.Add(_item);
            }

            await ctx.SaveChangesAsync();
            Snackbar.Add(_item.SupplierName, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }
}
