@using MudBlazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column gap-3">
            <div class="alert alert-info">
                Montant restant à payer : <strong>@MontantRest.ToString("N2") $</strong>
            </div>

            <div>
                <label class="form-label">Montant du paiement</label>
                <MudNumericField @bind-Value="_montant" T="decimal" Min="0.01m" Max="@MontantRest"
                                 Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="0.00" />
            </div>

            <div>
                <label class="form-label">Mode de paiement</label>
                <MudSelect T="string" @bind-Value="_mode" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                    @foreach (var m in _modes)
                    {
                        <MudSelectItem T="string" Value="@m">@m</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div>
                <label class="form-label">Note (optionnel)</label>
                <textarea class="form-control" @bind="_note" rows="2"></textarea>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="@OnPay" disabled="@(_montant <= 0)">
            <i class="bi bi-credit-card me-1"></i>@(_montant >= MontantRest ? "Payer le solde" : "Paiement partiel")
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int CommandeId { get; set; }
    [Parameter] public int FactId { get; set; }
    [Parameter] public decimal MontantRest { get; set; }

    decimal _montant;
    string _mode = "Espèces";
    string? _note;
    List<string> _modes = new() { "Espèces", "Virement", "Mobile Money", "Chèque", "Autre" };

    protected override void OnInitialized()
    {
        _montant = MontantRest; // Par défaut, paiement total
    }

    void Cancel() => MudDialog.Close();

    async Task OnPay()
    {
        if (_montant <= 0 || _montant > MontantRest) return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            using var tx = await ctx.Database.BeginTransactionAsync();

            // 1) Insérer le paiement
            var payment = new Payment
            {
                IdFact = FactId,
                Date = DateOnly.FromDateTime(DateTime.Today),
                Amount = _montant,
                Note = $"{_mode}" + (string.IsNullOrWhiteSpace(_note) ? "" : $" — {_note}"),
                DateSys = DateTime.Now,
                User = "Admin"
            };
            ctx.Payments.Add(payment);
            await ctx.SaveChangesAsync();

            // 2) Mettre à jour la commande
            var commande = await ctx.Commandes.FindAsync(CommandeId);
            if (commande != null)
            {
                commande.MontantPaye += _montant;
                commande.MontantRest = commande.MontantTotal - commande.MontantPaye;
                if (commande.MontantRest < 0) commande.MontantRest = 0;
            }

            // 3) Mettre à jour le statut de la facture
            var facture = await ctx.Facts.FindAsync(FactId);
            if (facture != null)
            {
                var totalPaye = await ctx.Payments
                    .Where(p => p.IdFact == FactId)
                    .SumAsync(p => p.Amount);

                if (totalPaye >= (facture.TotalApresReduction ?? facture.Total ?? 0))
                    facture.Status = 2; // Payée
                else
                    facture.Status = 1; // Validée (paiement partiel)
            }

            await ctx.SaveChangesAsync();
            await tx.CommitAsync();

            Snackbar.Add($"{_montant:N2} $ — {_mode}", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }
}
