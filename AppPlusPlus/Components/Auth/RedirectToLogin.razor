@inject NavigationManager Nav

<div style="padding:1rem;" class="rz-color-secondary">Redirection vers la page de connexion…</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;

        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var currentPath = string.IsNullOrWhiteSpace(relative) ? "/" : "/" + relative;
        var encoded = Uri.EscapeDataString(currentPath);
        Nav.NavigateTo($"/login?returnUrl={encoded}", forceLoad: true);
    }
}
