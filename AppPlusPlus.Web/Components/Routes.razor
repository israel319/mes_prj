<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Features.Shared.NotFound)">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                <AppPlusPlus.Web.Components.Auth.RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
    </Found>
</Router>
