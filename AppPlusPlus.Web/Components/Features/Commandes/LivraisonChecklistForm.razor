@* ──────────────────────────────────────────────────────────────
   Dialog : Créer une livraison à partir d'une commande.
   Affiche la liste des articles commandés sous forme de checklist.
   L'utilisateur coche ce qu'il livre et ajuste les quantités.
   ────────────────────────────────────────────────────────────── *@
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        @if (_commande == null)
        {
            <div class="d-flex flex-column align-items-center" style="padding:2rem;">
                <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement...</span></div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                <h6 class="mb-0">
                    Commande N° @_commande.CommandeId — @(_commande.Customer?.CustomerName ?? "Client")
                </h6>

                <label class="form-label">Porteur (livreur)</label>
                <input type="text" class="form-control" @bind="_porteur" placeholder="Nom du livreur…" />

                <span class="small text-secondary mb-0">
                    Cochez les articles à livrer et ajustez la quantité si nécessaire :
                </span>

                <MudDataGrid Items="@_lines" T="CheckLine" Dense="true" Hover="true" Bordered="true" Elevation="0">
                    <Columns>
                        <TemplateColumn Title="" Sortable="false">
                            <CellTemplate>
                                <MudCheckBox @bind-Value="context.Item.Selected" T="bool" Dense="true" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Article">
                            <CellTemplate>
                                @(context.Item.ArticleDesc ?? context.Item.ArticleId ?? "—")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Commandé">
                            <CellTemplate>
                                @((context.Item.QteCommande ?? 0).ToString("N0"))
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Déjà livré">
                            <CellTemplate>
                                @((context.Item.QteLivree).ToString("N0"))
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="À livrer">
                            <CellTemplate>
                                <MudNumericField @bind-Value="context.Item.QteLivraison" T="decimal" Min="0"
                                                 Max="@(context.Item.QteRestante)" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width:80px;" />
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="P.U.">
                            <CellTemplate>
                                @((context.Item.Pu ?? 0).ToString("N2"))
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>

                <div class="d-flex justify-content-between align-items-center">
                    <span class="small mb-0">
                        <strong>@_lines.Count(l => l.Selected)</strong> article(s) sélectionné(s)
                    </span>
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="OnSave" disabled="@(!_lines.Any(l => l.Selected && l.QteLivraison > 0))">
            <i class="bi bi-truck me-1"></i>Créer la livraison
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int CommandeId { get; set; }

    Commande? _commande;
    string? _porteur;
    List<CheckLine> _lines = new();
    string _currentLogin = "";

    void Cancel() => MudDialog.Close();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        await using var ctx = await DbFactory.CreateDbContextAsync();

        _commande = await ctx.Commandes
            .Include(c => c.Customer)
            .Include(c => c.Details)
            .FirstOrDefaultAsync(c => c.CommandeId == CommandeId);

        if (_commande == null) return;

        // Calculer les quantités déjà livrées par CommandeDetail
        var dejaLivre = await ctx.LivraisonDetails
            .Where(ld => ld.CommandDetailId != null
                         && ctx.CommandeDetails
                              .Where(cd => cd.CommandeId == CommandeId)
                              .Select(cd => cd.Id)
                              .Contains(ld.CommandDetailId.Value))
            .GroupBy(ld => ld.CommandDetailId)
            .Select(g => new { CmdDetailId = g.Key, Total = g.Sum(x => x.Qte ?? 0) })
            .ToListAsync();

        var dejaMap = dejaLivre.ToDictionary(x => x.CmdDetailId!.Value, x => x.Total);

        // Charger descriptions articles
        var articleIds = _commande.Details.Select(d => d.ArticleId).Where(a => a != null).Distinct().ToList();
        var articles = await ctx.Articles
            .Where(a => articleIds.Contains(a.IdArticle))
            .ToDictionaryAsync(a => a.IdArticle, a => a.Description);

        foreach (var d in _commande.Details)
        {
            var livree = dejaMap.GetValueOrDefault(d.Id);
            var restante = (d.Qte ?? 0) - livree;
            if (restante <= 0) continue; // déjà entièrement livré

            _lines.Add(new CheckLine
            {
                CommandeDetailId = d.Id,
                ArticleId = d.ArticleId,
                ArticleDesc = d.ArticleId != null && articles.TryGetValue(d.ArticleId, out var desc) ? desc : d.ArticleId,
                QteCommande = d.Qte,
                QteLivree = livree,
                QteRestante = restante,
                QteLivraison = restante, // par défaut : livrer tout le reste
                Pu = d.Pu,
                Selected = true // coché par défaut
            });
        }
    }

    async Task OnSave()
    {
        var selected = _lines.Where(l => l.Selected && l.QteLivraison > 0).ToList();
        if (!selected.Any()) return;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            var livraison = new Livraison
            {
                CommandeId = CommandeId,
                ClientId = _commande!.CustomerId,
                Porteur = _porteur,
                Status = 0, // En attente
                Date = DateTime.Now,
                DateSys = DateTime.Now,
                UserLogin = _currentLogin
            };
            ctx.Livraisons.Add(livraison);
            await ctx.SaveChangesAsync(); // génère LivraisonId

            foreach (var line in selected)
            {
                ctx.LivraisonDetails.Add(new LivraisonDetail
                {
                    LivraisonId = livraison.LivraisonId,
                    CommandDetailId = line.CommandeDetailId,
                    ArticleId = line.ArticleId,
                    Qte = line.QteLivraison,
                    MontantPaye = line.QteLivraison * (line.Pu ?? 0),
                    Date = DateTime.Now,
                    UserLogin = _currentLogin,
                    CreationDate = DateTime.Now
                });
            }
            await ctx.SaveChangesAsync();

            // ── Mettre à jour QtePrise / QteRest dans les lignes de commande ──
            var cmdDetails = await ctx.CommandeDetails
                .Where(d => d.CommandeId == CommandeId)
                .ToListAsync();

            foreach (var line in selected)
            {
                var cd = cmdDetails.FirstOrDefault(d => d.Id == line.CommandeDetailId);
                if (cd != null)
                {
                    cd.QtePrise = (cd.QtePrise ?? 0) + line.QteLivraison;
                    cd.QteRest  = (cd.Qte ?? 0) - (cd.QtePrise ?? 0);
                    if (cd.QteRest < 0) cd.QteRest = 0;
                }
            }

            // ── Mettre à jour le statut de la commande ──
            var commande = await ctx.Commandes.FindAsync(CommandeId);
            if (commande != null)
            {
                var toutLivre = cmdDetails.All(d => (d.QteRest ?? 0) <= 0);
                commande.Status = toutLivre ? 2 : 1; // 2 = Livrée, 1 = En cours
            }

            await ctx.SaveChangesAsync();

            Snackbar.Add($"Livraison N° {livraison.LivraisonId} — {selected.Count} article(s)", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }

    // ── Modèle interne pour la checklist ──
    class CheckLine
    {
        public int CommandeDetailId { get; set; }
        public string? ArticleId { get; set; }
        public string? ArticleDesc { get; set; }
        public decimal? QteCommande { get; set; }
        public decimal QteLivree { get; set; }
        public decimal QteRestante { get; set; }
        public decimal QteLivraison { get; set; }
        public decimal? Pu { get; set; }
        public bool Selected { get; set; }
    }
}
