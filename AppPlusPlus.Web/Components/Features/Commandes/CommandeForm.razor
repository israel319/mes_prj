@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column gap-3" style="min-width:650px;">
            @* ── En-tête ── *@
            <label class="form-label">Client</label>
            <MudAutocomplete T="int?" @bind-Value="_item.CustomerId" SearchFunc="@SearchCustomer"
                             ToStringFunc="@(v => _customers.Find(c => c.CustomerId == v)?.CustomerName ?? "")"
                             Placeholder="Sélectionner un client..." Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" />

            <label class="form-label">Description</label>
            <input type="text" class="form-control" @bind="_item.CommandeDescription" />

            @* ── Lignes articles ── *@
            <h6 class="fw-semibold" style="margin-top:0.5rem;">
                Articles
            </h6>

            <MudDataGrid Items="@_lines" T="CmdeLine" Dense="true" Hover="true" Bordered="true" Elevation="0">
                <Columns>
                    <TemplateColumn Title="Article">
                        <CellTemplate>
                            <MudAutocomplete T="string" Value="context.Item.ArticleId" ValueChanged="@(v => { context.Item.ArticleId = v; RecalcTotal(); })"
                                             SearchFunc="@SearchArticle"
                                             ToStringFunc="@(v => _articles.Find(a => a.IdArticle == v)?.Description ?? "")"
                                             Placeholder="Article..." Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" />
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Qté">
                        <CellTemplate>
                            <MudNumericField T="decimal?" Value="context.Item.Qte" ValueChanged="@(v => { context.Item.Qte = v; RecalcTotal(); })"
                                             Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="P.U.">
                        <CellTemplate>
                            <MudNumericField T="decimal?" Value="context.Item.Pu" ValueChanged="@(v => { context.Item.Pu = v; RecalcTotal(); })"
                                             Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Sous-total">
                        <CellTemplate>
                            <span class="fw-medium">@(((context.Item.Qte ?? 0) * (context.Item.Pu ?? 0)).ToString("N2"))</span>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="" Sortable="false">
                        <CellTemplate>
                            <button class="btn btn-link text-danger p-0 border-0" @onclick="@(() => { _lines.Remove(context.Item); RecalcTotal(); })" title="Retirer"><i class="bi bi-x-lg"></i></button>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>

            <div class="d-flex justify-content-between align-items-center">
                <button class="btn btn-light btn-sm" @onclick="@AddLine"><i class="bi bi-plus-lg me-1"></i> Ajouter un article</button>
                <h6 class="fw-bold">
                    Total : @_total.ToString("N2")
                </h6>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="OnSave">
            <i class="bi bi-check-lg me-1"></i>Enregistrer
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? CommandeId { get; set; }

    Commande _item = new();
    List<Customer> _customers = new();
    List<Article> _articles = new();
    List<CmdeLine> _lines = new();
    decimal _total;
    string _currentLogin = "";

    void Cancel() => MudDialog.Close();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        await using var ctx = await DbFactory.CreateDbContextAsync();

        _customers = await ctx.Customers.OrderBy(c => c.CustomerName).ToListAsync();
        _articles = await ctx.Articles.OrderBy(a => a.Description).ToListAsync();

        if (CommandeId.HasValue)
        {
            var existing = await ctx.Commandes
                .Include(c => c.Details)
                .FirstOrDefaultAsync(c => c.CommandeId == CommandeId.Value);

            if (existing != null)
            {
                _item = existing;
                _lines = existing.Details.Select(d => new CmdeLine
                {
                    ExistingId = d.Id,
                    ArticleId = d.ArticleId,
                    Qte = d.Qte,
                    Pu = d.Pu
                }).ToList();
            }
        }

        RecalcTotal();
    }

    void AddLine()
    {
        _lines.Add(new CmdeLine());
    }

    void RecalcTotal()
    {
        _total = _lines.Sum(l => (l.Qte ?? 0) * (l.Pu ?? 0));
    }

    private Task<IEnumerable<int?>> SearchCustomer(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_customers.Select(c => (int?)c.CustomerId));
        return Task.FromResult(_customers
            .Where(c => c.CustomerName != null && c.CustomerName.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(c => (int?)c.CustomerId));
    }

    private Task<IEnumerable<string>> SearchArticle(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_articles.Select(a => a.IdArticle));
        return Task.FromResult(_articles
            .Where(a => a.Description != null && a.Description.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(a => a.IdArticle));
    }

    async Task OnSave()
    {
        if (_item.CustomerId is null or 0)
        {
            Snackbar.Add("Le client est obligatoire", Severity.Warning);
            return;
        }

        var validLines = _lines.Where(l => !string.IsNullOrEmpty(l.ArticleId) && (l.Qte ?? 0) > 0).ToList();

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            RecalcTotal();
            _item.MontantTotal = _total;
            _item.MontantRest = _total - _item.MontantPaye;
            _item.UserLogin = _currentLogin;
            _item.CreationDate ??= DateTime.Now;

            if (CommandeId.HasValue)
            {
                ctx.Commandes.Update(_item);

                // Supprimer les anciennes lignes
                var oldDetails = await ctx.CommandeDetails
                    .Where(d => d.CommandeId == CommandeId.Value).ToListAsync();
                ctx.CommandeDetails.RemoveRange(oldDetails);
            }
            else
            {
                _item.Status = 0; // Nouvelle
                ctx.Commandes.Add(_item);
            }

            await ctx.SaveChangesAsync(); // Obtenir CommandeId si nouveau

            // Ajouter les lignes articles
            foreach (var line in validLines)
            {
                ctx.CommandeDetails.Add(new CommandeDetail
                {
                    CommandeId = _item.CommandeId,
                    ArticleId = line.ArticleId,
                    Qte = line.Qte,
                    Pu = line.Pu,
                    QteRest = line.Qte, // tout reste à livrer
                    QtePrise = 0,
                    Status = 0
                });
            }

            await ctx.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }

    class CmdeLine
    {
        public int? ExistingId { get; set; }
        public string? ArticleId { get; set; }
        public decimal? Qte { get; set; }
        public decimal? Pu { get; set; }
    }
}
