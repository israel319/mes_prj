@page "/profile"
@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ILocalisationService LocalisationService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>@AppSettings.AppName — Profil</PageTitle>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center" style="min-height:300px;">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement…</span></div>
    </div>
}
else if (_user == null)
{
    <div class="card mx-auto mt-4" style="max-width:720px;">
        <div class="card-body text-center py-5">
            <i class="bi bi-exclamation-triangle" style="font-size:42px;color:#f59e0b;"></i>
            <h5 class="fw-bold mt-3">Utilisateur non trouvé</h5>
            <p class="text-muted">Veuillez vous reconnecter.</p>
        </div>
    </div>
}
else
{
    <!-- En-tête -->
    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
        <div class="hub-icon" style="background:#d4f5ef;color:#00B193;">
            <i class="bi bi-person fs-4"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0 fs-5">Mon Profil</h2>
            <small class="text-muted">Informations personnelles, activité et sécurité</small>
        </div>
    </div>

    <!-- Profile Header -->
    <div class="card mb-2">
        <div class="card-body d-flex flex-wrap align-items-center gap-4">
            <MudAvatar Style="width:96px;height:96px;font-size:36px;" Color="Color.Primary">@_initials</MudAvatar>
            <div class="flex-fill">
                <h5 class="fw-bold mb-1">@(_user.Name ?? _user.Login)</h5>
                <p class="text-muted mb-2">@(_user.Role?.DescriptionRole ?? "Utilisateur")</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge" style="background:#253C45;">@(_user.Role?.DescriptionRole ?? "User")</span>
                    @if (_user.Activated == true)
                    {
                        <span class="badge bg-success">Actif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactif</span>
                    }
                    @foreach (var loc in _localisations)
                    {
                        <span class="badge" style="background:#00B193;">@loc</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="card">
        <ul class="nav nav-tabs">
            <li class="nav-item"><button class="nav-link @(_selectedTab == 0 ? "active" : "")" @onclick="@(() => _selectedTab = 0)"><i class="bi bi-person me-1"></i>Informations</button></li>
            <li class="nav-item"><button class="nav-link @(_selectedTab == 1 ? "active" : "")" @onclick="@(() => _selectedTab = 1)"><i class="bi bi-key me-1"></i>Permissions</button></li>
            <li class="nav-item"><button class="nav-link @(_selectedTab == 2 ? "active" : "")" @onclick="@(() => _selectedTab = 2)"><i class="bi bi-shield-lock me-1"></i>Sécurité</button></li>
        </ul>

        @if (_selectedTab == 0)
        {
            <div class="card-body">
                <!-- Informations personnelles -->
                <div style="max-width:720px;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Login</label>
                                <input type="text" value="@_user.Login" class="form-control" disabled />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Nom complet</label>
                                <input type="text" @bind="_profileName" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Email</label>
                                <input type="email" @bind="_profileEmail" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Rôle</label>
                                <input type="text" value="@(_user.Role?.DescriptionRole ?? "-")" class="form-control" disabled />
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Localisations assignées</label>
                                @if (_localisations.Any())
                                {
                                    <div class="d-flex flex-wrap gap-1 p-2 border" style="min-height:38px;">
                                        @foreach (var loc in _localisations)
                                        {
                                            <span class="badge" style="background:#00B193;">@loc</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <input type="text" value="Non assigné" class="form-control" disabled />
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Statut</label>
                                <input type="text" value="@(_user.Activated == true ? "Actif" : "Inactif")" class="form-control" disabled />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button class="btn btn-primary" @onclick="OnSaveProfile" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg me-1"></i>
                            }
                            Enregistrer
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (_selectedTab == 1)
        {
            <div class="card-body">
                <!-- Permissions -->
                <div style="max-width:720px;">
                    <h6 class="fw-bold mb-2">Mes permissions</h6>
                    @if (_activities.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var activity in _activities)
                            {
                                <div class="list-group-item d-flex align-items-center gap-3 px-0 py-3">
                                    <i class="bi bi-check-circle" style="font-size:20px;color:#00B193;"></i>
                                    <div class="flex-fill">
                                        <div class="fw-medium">@(activity.Activity?.DescriptionActivity ?? "Activité")</div>
                                        <small class="text-muted">@(activity.Activity?.Fonction?.DescriptionFonction ?? "")</small>
                                    </div>
                                    @if (activity.IsGranted)
                                    {
                                        <span class="badge bg-success">Accordé</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Refusé</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">Aucune permission spécifique assignée</MudAlert>
                    }
                </div>
            </div>
        }

        @if (_selectedTab == 2)
        {
            <div class="card-body">
                <!-- Sécurité -->
                <div style="max-width:720px;">
                    <h6 class="fw-bold mb-2">Changer le mot de passe</h6>

                    <div class="mb-2">
                        <label class="form-label">Mot de passe actuel</label>
                        <input type="password" @bind="_currentPassword" class="form-control" />
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Nouveau mot de passe</label>
                                <input type="password" @bind="_newPassword" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-2">
                                <label class="form-label">Confirmer le mot de passe</label>
                                <input type="password" @bind="_confirmPassword" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button class="btn btn-primary" @onclick="OnChangePassword" disabled="@_changingPassword">
                            @if (_changingPassword)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            else
                            {
                                <i class="bi bi-lock me-1"></i>
                            }
                            Mettre à jour
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private bool _saving;
    private bool _changingPassword;
    private int _selectedTab;

    private User? _user;
    private List<string> _localisations = new();
    private List<UserActivity> _activities = new();
    private string _initials = "";

    // Profile fields
    private string _profileName = "";
    private string _profileEmail = "";

    // Security fields
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUserData();
    }

    private async Task LoadUserData()
    {
        _loading = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal.Identity?.IsAuthenticated != true)
        {
            _loading = false;
            return;
        }

        var login = principal.FindFirst("login")?.Value
            ?? principal.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(login))
        {
            _loading = false;
            return;
        }

        await using var ctx = await DbFactory.CreateDbContextAsync();

        _user = await ctx.Users
            .Include(u => u.Role)
            .FirstOrDefaultAsync(u => u.Login.ToLower() == login.ToLower());

        if (_user != null)
        {
            // Load user localisations via ILocalisationService (always fetch actual assignments for display)
            var userLocIds = await LocalisationService.GetUserLocalisationIdsAsync(_user.Login, false);
            var allLocs = await LocalisationService.GetAllLocalisationsAsync();
            _localisations = allLocs
                .Where(l => userLocIds.Contains(l.IdLocalisation))
                .Select(l => l.DescriptionLocalisation ?? "")
                .Where(s => !string.IsNullOrEmpty(s))
                .ToList();

            // Load activities with includes
            _activities = await ctx.UserActivities
                .Include(a => a.Activity)
                    .ThenInclude(act => act!.Fonction)
                .Where(a => a.UserLogin == _user.Login)
                .OrderBy(a => a.Activity!.DescriptionActivity)
                .ToListAsync();

            // Set profile fields
            _profileName = _user.Name ?? "";
            _profileEmail = _user.Email ?? "";

            // Generate initials
            _initials = GetInitials(_user.Name ?? _user.Login);
        }

        _loading = false;
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();

        return name.Length >= 2 ? name.Substring(0, 2).ToUpper() : name.ToUpper();
    }

    private async Task OnSaveProfile()
    {
        if (_user == null) return;

        _saving = true;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var user = await ctx.Users.FirstOrDefaultAsync(u => u.Login == _user.Login);

            if (user != null)
            {
                user.Name = _profileName;
                user.Email = _profileEmail;
                await ctx.SaveChangesAsync();

                _user.Name = _profileName;
                _user.Email = _profileEmail;
                _initials = GetInitials(_profileName);

                Snackbar.Add("Profil mis à jour avec succès.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur: {ex.Message}", Severity.Error);
        }

        _saving = false;
    }

    private async Task OnChangePassword()
    {
        if (_user == null) return;

        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            Snackbar.Add("Veuillez saisir votre mot de passe actuel.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add("Veuillez saisir un nouveau mot de passe.", Severity.Warning);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Les mots de passe ne correspondent pas.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 4)
        {
            Snackbar.Add("Le mot de passe doit contenir au moins 4 caractères.", Severity.Warning);
            return;
        }

        _changingPassword = true;

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var user = await ctx.Users.FirstOrDefaultAsync(u => u.Login == _user.Login);

            if (user != null)
            {
                // Verify current password
                if (user.Password != _currentPassword)
                {
                    Snackbar.Add("Mot de passe actuel incorrect.", Severity.Error);
                    _changingPassword = false;
                    return;
                }

                user.Password = _newPassword;
                await ctx.SaveChangesAsync();

                _currentPassword = "";
                _newPassword = "";
                _confirmPassword = "";

                Snackbar.Add("Mot de passe mis à jour avec succès.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur: {ex.Message}", Severity.Error);
        }

        _changingPassword = false;
    }
}
