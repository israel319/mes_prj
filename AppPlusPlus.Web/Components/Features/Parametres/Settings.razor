@page "/settings"
@rendermode InteractiveServer
@using MudBlazor
@inject ISnackbar Snackbar
@inject IShopProfileService ShopProfileService

<PageTitle>@AppSettings.AppName — Paramètres</PageTitle>

<div class="stg-page">
    <!-- Main card -->
    <div class="stg-card">

        <!-- ═══ GÉNÉRAL ═══ -->
        <div class="stg-section-header">
            <i class="ti ti-settings stg-section-icon"></i>
            <span class="stg-section-title">Général</span>
            <span class="stg-section-line"></span>
        </div>
        <div class="stg-rows">
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-language"></i></div>
                    <div>
                        <p class="stg-row-label">Langue de l'application</p>
                        <p class="stg-row-desc">Choisir la langue d'affichage</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.Langue" T="string" Style="width:160px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var l in _langues)
                        {
                            <MudSelectItem T="string" Value="l">@l</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-world"></i></div>
                    <div>
                        <p class="stg-row-label">Fuseau horaire</p>
                        <p class="stg-row-desc">Définir votre fuseau horaire local</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.Fuseau" T="string" Style="width:240px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var f in _fuseaux)
                        {
                            <MudSelectItem T="string" Value="f">@f</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-calendar"></i></div>
                    <div>
                        <p class="stg-row-label">Format de date</p>
                        <p class="stg-row-desc">Personnaliser l'affichage des dates</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.FormatDate" T="string" Style="width:160px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var df in _dateFormats)
                        {
                            <MudSelectItem T="string" Value="df">@df</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
        </div>

        <!-- ═══ PROFIL DU SHOP / FACTURE ═══ -->
        <div class="stg-section-header">
            <i class="ti ti-building-store stg-section-icon"></i>
            <span class="stg-section-title">Profil du shop / Facture</span>
            <span class="stg-section-line"></span>
        </div>
        <div class="stg-rows">
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-building-store"></i></div>
                    <div>
                        <p class="stg-row-label">Nom du shop</p>
                        <p class="stg-row-desc">Affiché dans l'interface et sur la facture</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <input type="text" @bind="_settings.AppName" maxlength="50" class="form-control stg-input" placeholder="App++" />
                </div>
            </div>
            <div class="stg-row stg-row--tall">
                <div class="stg-row-left" style="align-items:flex-start;">
                    <div class="stg-row-icon"><i class="ti ti-photo"></i></div>
                    <div>
                        <p class="stg-row-label">Photo / logo du shop</p>
                        <p class="stg-row-desc">Upload un fichier image ou colle une URL</p>
                    </div>
                </div>
                <div class="stg-row-ctrl" style="max-width:340px;">
                    <label class="logo-upload-zone @(_logoUploading ? "uploading" : "")">
                        <InputFile OnChange="@OnLogoFileSelected" accept="image/*" style="display:none;" />
                        @if (_logoUploading)
                        {
                            <i class="ti ti-hourglass" style="font-size:1.1rem;"></i>
                            <span>Chargement…</span>
                        }
                        else if (!string.IsNullOrWhiteSpace(_settings.PhotoShop))
                        {
                            <img src="@_settings.PhotoShop" alt="Logo" style="max-height:60px;max-width:180px;object-fit:contain;" />
                            <span style="font-size:0.72rem;color:#7a8f99;">Cliquer pour changer</span>
                        }
                        else
                        {
                            <i class="ti ti-photo-plus" style="font-size:1.8rem;color:#7a8f99;"></i>
                            <span style="font-size:0.78rem;color:#7a8f99;">Cliquer pour uploader<br/><em>PNG, JPG, WEBP — max 2 Mo</em></span>
                        }
                    </label>
                    @if (!string.IsNullOrWhiteSpace(_logoError))
                    {
                        <small class="text-danger d-block">@_logoError</small>
                    }
                    <input type="text" @bind="_settings.PhotoShop" class="form-control stg-input mt-1" style="font-size:0.78rem;"
                           placeholder="ou coller une URL https://…" />
                    @if (!string.IsNullOrWhiteSpace(_settings.PhotoShop))
                    {
                        <button class="btn btn-danger btn-sm mt-1" @onclick="@(() => { _settings.PhotoShop = null; _logoError = null; })"><i class="ti ti-trash me-1"></i>Supprimer</button>
                    }
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-map-pin"></i></div>
                    <div>
                        <p class="stg-row-label">Adresse ligne 1</p>
                        <p class="stg-row-desc">Affichée en bas de la facture</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <input type="text" @bind="_settings.Adresse1" maxlength="250" class="form-control stg-input" style="width:320px;" placeholder="Ex: Avenue ..., Ville ..." />
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-map-pin"></i></div>
                    <div>
                        <p class="stg-row-label">Adresse ligne 2</p>
                        <p class="stg-row-desc">Complément d'adresse</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <input type="text" @bind="_settings.Adresse2" maxlength="250" class="form-control stg-input" style="width:320px;" placeholder="Ex: Commune, Référence..." />
                </div>
            </div>
        </div>

        <!-- ═══ NOTIFICATIONS ═══ -->
        <div class="stg-section-header">
            <i class="ti ti-bell stg-section-icon"></i>
            <span class="stg-section-title">Notifications</span>
            <span class="stg-section-line"></span>
        </div>
        <div class="stg-rows">
            @foreach (var notif in _notifSettings)
            {
                <div class="stg-row">
                    <div class="stg-row-left">
                        <div class="stg-row-icon"><i class="ti @notif.Icon"></i></div>
                        <div>
                            <p class="stg-row-label">@notif.Title</p>
                            <p class="stg-row-desc">@notif.Description</p>
                        </div>
                    </div>
                    <div class="stg-row-ctrl">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch"
                                   checked="@notif.Enabled"
                                   @onchange="@((ChangeEventArgs e) => notif.Enabled = (bool)(e.Value ?? false))" />
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ═══ APPARENCE ═══ -->
        <div class="stg-section-header">
            <i class="ti ti-palette stg-section-icon"></i>
            <span class="stg-section-title">Apparence</span>
            <span class="stg-section-line"></span>
        </div>
        <div class="stg-rows">
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-palette"></i></div>
                    <div>
                        <p class="stg-row-label">Thème</p>
                        <p class="stg-row-desc">Choisir le thème de l'interface</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.Theme" T="string" Style="width:160px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var t in _themes)
                        {
                            <MudSelectItem T="string" Value="t">@t</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-layout-distribute-horizontal"></i></div>
                    <div>
                        <p class="stg-row-label">Disposition du menu</p>
                        <p class="stg-row-desc">Emplacement principal de navigation</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.LayoutPreference" T="string" Style="width:160px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var mode in _layoutModes)
                        {
                            <MudSelectItem T="string" Value="mode">@mode</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
            @if (_settings.LayoutPreference != IAppSettingsService.LAYOUT_TOPBAR)
            {
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-layout-sidebar"></i></div>
                    <div>
                        <p class="stg-row-label">Sidebar compacte</p>
                        <p class="stg-row-desc">Réduire la largeur de la barre latérale</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" @bind="_settings.SidebarCompacte" />
                    </div>
                </div>
            </div>
            }
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-list"></i></div>
                    <div>
                        <p class="stg-row-label">Densité d'affichage</p>
                        <p class="stg-row-desc">Ajuster l'espacement des éléments</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.Densite" T="string" Style="width:160px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var dens in _densites)
                        {
                            <MudSelectItem T="string" Value="dens">@dens</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
        </div>

        <!-- ═══ DONNÉES & CONFIDENTIALITÉ ═══ -->
        <div class="stg-section-header">
            <i class="ti ti-shield-lock stg-section-icon"></i>
            <span class="stg-section-title">Données &amp; Confidentialité</span>
            <span class="stg-section-line"></span>
        </div>
        <div class="stg-rows stg-rows--last">
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-device-floppy"></i></div>
                    <div>
                        <p class="stg-row-label">Sauvegarde automatique</p>
                        <p class="stg-row-desc">Sauvegarder automatiquement les formulaires en cours</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" @bind="_settings.AutoSave" />
                    </div>
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-chart-bar"></i></div>
                    <div>
                        <p class="stg-row-label">Collecte de données analytiques</p>
                        <p class="stg-row-desc">Partager des données d'usage anonymes</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" @bind="_settings.Analytics" />
                    </div>
                </div>
            </div>
            <div class="stg-row">
                <div class="stg-row-left">
                    <div class="stg-row-icon"><i class="ti ti-clock"></i></div>
                    <div>
                        <p class="stg-row-label">Rétention des logs</p>
                        <p class="stg-row-desc">Durée de conservation des journaux d'activité</p>
                    </div>
                </div>
                <div class="stg-row-ctrl">
                    <MudSelect @bind-Value="_settings.RetentionLogs" T="string" Style="width:160px;" Margin="Margin.Dense" Dense="true">
                        @foreach (var r in _retentionOptions)
                        {
                            <MudSelectItem T="string" Value="r">@r</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>
        </div>
    </div>

    <!-- Sticky footer -->
    <div class="stg-footer">
        <button class="stg-footer-reset" @onclick="@OnReset">
            <i class="ti ti-refresh me-1"></i>Réinitialiser
        </button>
        <div class="stg-footer-right">
            <button class="stg-footer-cancel">Annuler</button>
            <button class="stg-footer-save" @onclick="@OnSave">
                <i class="ti ti-device-floppy me-1"></i>Enregistrer les paramètres
            </button>
        </div>
    </div>
</div>

@code {
    class SettingsModel
    {
        public string AppName { get; set; } = "App++";
        public string? PhotoShop { get; set; }
        public string? Adresse1 { get; set; }
        public string? Adresse2 { get; set; }
        public string Langue { get; set; } = "Français";
        public string Fuseau { get; set; } = "Europe/Paris (UTC+1)";
        public string FormatDate { get; set; } = "DD/MM/YYYY";
        public string Theme { get; set; } = "Clair";
        public string LayoutPreference { get; set; } = IAppSettingsService.LAYOUT_SIDEBAR;
        public bool SidebarCompacte { get; set; }
        public string Densite { get; set; } = "Normal";
        public bool AutoSave { get; set; } = true;
        public bool Analytics { get; set; }
        public string RetentionLogs { get; set; } = "30 jours";
    }

    class NotifSetting
    {
        public string Icon { get; set; } = "ti-bell";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public bool Enabled { get; set; }
    }

    SettingsModel _settings = new();
    bool   _logoUploading;
    string? _logoError;

    async Task OnLogoFileSelected(InputFileChangeEventArgs e)
    {
        _logoError = null;
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024)
        {
            _logoError = "Le fichier est trop grand (max 2 Mo).";
            return;
        }
        if (!file.ContentType.StartsWith("image/"))
        {
            _logoError = "Seuls les fichiers image sont acceptés.";
            return;
        }
        _logoUploading = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            _settings.PhotoShop = $"data:{file.ContentType};base64,{base64}";
        }
        catch (Exception ex)
        {
            _logoError = $"Erreur lors du chargement : {ex.Message}";
        }
        finally
        {
            _logoUploading = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _settings.AppName = AppSettings.AppName;
        _settings.LayoutPreference = NormalizeLayoutPreference(
            AppSettings.Get(IAppSettingsService.KEY_LAYOUT_PREFERENCE));

        _settings.Theme = AppSettings.Get(IAppSettingsService.KEY_THEME) ?? "Clair";
        _settings.Langue = AppSettings.Get(IAppSettingsService.KEY_LANGUE) ?? "Français";

        var profile = await ShopProfileService.GetAsync();
        _settings.PhotoShop = profile.PhotoShop;
        _settings.Adresse1 = profile.Adresse1;
        _settings.Adresse2 = profile.Adresse2;
    }

    List<NotifSetting> _notifSettings = new()
    {
        new() { Icon = "ti-mail",          Title = "Notifications par email",  Description = "Recevoir les alertes importantes par email",       Enabled = true },
        new() { Icon = "ti-device-mobile", Title = "Notifications push",       Description = "Recevoir des notifications dans le navigateur",    Enabled = true },
        new() { Icon = "ti-volume",        Title = "Son de notification",       Description = "Jouer un son lors d'une nouvelle notification",    Enabled = false },
        new() { Icon = "ti-file-text",     Title = "Résumé quotidien",          Description = "Email récapitulatif chaque matin à 8h",           Enabled = true },
    };

    List<string> _langues = new() { "Français", "English", "Español", "Deutsch" };
    List<string> _fuseaux = new() { "Europe/Paris (UTC+1)", "Europe/London (UTC+0)", "America/New_York (UTC-5)", "Asia/Tokyo (UTC+9)" };
    List<string> _dateFormats = new() { "DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD" };
    List<string> _themes = new() { "Clair", "Sombre", "Système" };
    List<string> _layoutModes = new() { IAppSettingsService.LAYOUT_SIDEBAR, IAppSettingsService.LAYOUT_TOPBAR };
    List<string> _densites = new() { "Compact", "Normal", "Confortable" };
    List<string> _retentionOptions = new() { "7 jours", "30 jours", "90 jours", "1 an", "Illimité" };

    static string NormalizeLayoutPreference(string? layoutPreference)
        => string.Equals(layoutPreference, IAppSettingsService.LAYOUT_TOPBAR, StringComparison.OrdinalIgnoreCase)
            ? IAppSettingsService.LAYOUT_TOPBAR
            : IAppSettingsService.LAYOUT_SIDEBAR;

    async Task OnSave()
    {
        // Sauvegarder le nom de l'application
        if (!string.IsNullOrWhiteSpace(_settings.AppName))
        {
            await AppSettings.SetAsync(IAppSettingsService.KEY_APP_NAME, _settings.AppName.Trim());
        }

        await AppSettings.SetAsync(
            IAppSettingsService.KEY_LAYOUT_PREFERENCE,
            NormalizeLayoutPreference(_settings.LayoutPreference));

        await AppSettings.SetAsync(IAppSettingsService.KEY_THEME, _settings.Theme);
        await AppSettings.SetAsync(IAppSettingsService.KEY_LANGUE, _settings.Langue);

        await ShopProfileService.SaveAsync(_settings.PhotoShop, _settings.Adresse1, _settings.Adresse2);
        Snackbar.Add("Les paramètres ont été enregistrés avec succès.", Severity.Success);
    }

    void OnReset()
    {
        _settings.Langue = "Français";
        _settings.Fuseau = "Europe/Paris (UTC+1)";
        _settings.FormatDate = "DD/MM/YYYY";
        _settings.Theme = "Clair";
        _settings.LayoutPreference = IAppSettingsService.LAYOUT_SIDEBAR;
        _settings.SidebarCompacte = false;
        _settings.Densite = "Normal";
        _settings.AutoSave = true;
        _settings.Analytics = false;
        _settings.RetentionLogs = "30 jours";
        foreach (var n in _notifSettings) n.Enabled = n.Title != "Son de notification";
        Snackbar.Add("Les paramètres par défaut ont été restaurés.", Severity.Info);
    }
}
