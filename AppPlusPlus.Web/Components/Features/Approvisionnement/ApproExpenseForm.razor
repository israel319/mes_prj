@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IApproService ApproService
@inject ILookupService LookupService
@inject AuthenticationStateProvider AuthStateProvider

<EditForm Model="@_item" OnValidSubmit="@OnSubmit">
    <MudDialog>
        <DialogContent>
            <div class="d-flex flex-column gap-3">

                @if (_item.VersementId.HasValue)
                {
                    <div class="alert alert-info mb-0 d-flex align-items-center gap-2">
                        <i class="bi bi-link-45deg"></i>
                        <span>Versement lié à la <strong>clôture N°@_item.VersementId</strong> — certaines infos sont en lecture seule.</span>
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Source</label>
                        <MudSelect T="int" @bind-Value="_item.SourceId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true"
                                   Placeholder="— Sélectionner la source —" Disabled="@_item.VersementId.HasValue">
                            @foreach (var s in _sources)
                            {
                                <MudSelectItem T="int" Value="@s.Id">@s.Sources</MudSelectItem>
                            }
                        </MudSelect>
                        <small class="text-muted">D'où provient l'argent ?</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Caisse de destination</label>
                        <MudSelect T="int?" @bind-Value="_item.CaisseId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true"
                                   Placeholder="— Sélectionner la caisse —">
                            @foreach (var c in _caisses)
                            {
                                <MudSelectItem T="int?" Value="@c.CaisseId">@c.Description</MudSelectItem>
                            }
                        </MudSelect>
                        <small class="text-muted">Dans quelle caisse déposer ?</small>
                    </div>
                </div>

                <div>
                    <label class="form-label fw-semibold">Motif / Description</label>
                    <input type="text" class="form-control" @bind="_item.Description" maxlength="200"
                           placeholder="Ex : Versement recette du jour, remise fournisseur…" />
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Devise</label>
                        <MudSelect T="int?" @bind-Value="_item.CurrencyId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true"
                                   Placeholder="— Devise —">
                            @foreach (var m in _monnaies)
                            {
                                <MudSelectItem T="int?" Value="@m.IdMonais">@m.DescriptionMonais</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Montant USD</label>
                        <MudNumericField @bind-Value="_item.AmountUSD" T="decimal?" Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Placeholder="0.00" Disabled="@_item.VersementId.HasValue" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Montant CDF</label>
                        <MudNumericField @bind-Value="_item.AmountCDF" T="decimal?" Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Placeholder="0.00" Disabled="@_item.VersementId.HasValue" />
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Déposeur</label>
                        <input type="text" class="form-control" @bind="_item.Depositeur" maxlength="100"
                               placeholder="Nom de la personne qui dépose" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Commentaire</label>
                        <input type="text" class="form-control" @bind="_item.Comment" maxlength="200"
                               placeholder="Remarques (optionnel)" />
                    </div>
                </div>
            </div>
        </DialogContent>
        <DialogActions>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>Enregistrer
            </button>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? ExpenseId { get; set; }

    ApproExpense _item = new();
    List<ExpenseSource> _sources = new();
    List<Caisse> _caisses = new();
    List<Money> _monnaies = new();
    string _currentLogin = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        _sources = await LookupService.GetExpenseSourcesAsync();
        _caisses = await LookupService.GetCaissesAsync();
        _monnaies = await LookupService.GetMoneysAsync();

        if (ExpenseId.HasValue)
        {
            var existing = await ApproService.GetApproExpenseByIdAsync(ExpenseId.Value);
            if (existing != null) _item = existing;
        }
    }

    void Cancel() => MudDialog.Close();

    async Task OnSubmit()
    {
        _item.UserLogin = _currentLogin;
        _item.CreationDate = DateTime.Now;
        if (ExpenseId.HasValue)
            await ApproService.UpdateApproExpenseAsync(_item);
        else
            await ApproService.AddApproExpenseAsync(_item);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
