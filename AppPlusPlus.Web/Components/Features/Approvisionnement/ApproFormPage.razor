@page "/stock/appro/nouveau"
@page "/stock/appro/modifier/{ApproId:int}"
@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@AppSettings.AppName — @(_isEdit ? "Modifier l'approvisionnement" : "Nouvel approvisionnement")</PageTitle>

<div class="lov-card" style="max-width:820px; margin:40px auto;">
    <div class="lov-form-header">
        <h5 style="font-weight:700; font-size:1.25rem;">@(_isEdit ? "Modifier l'approvisionnement" : "Nouvel approvisionnement")</h5>
        <div class="d-flex" style="gap:0.5rem;">
            <button type="button" class="btn btn-sm btn-save-teal d-flex align-items-center gap-1"
                    @onclick="OnSave" disabled="@(!_lines.Any())">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    style="padding:6px 16px; border-radius:6px; font-size:13px; font-weight:500;"
                    @onclick="OnCancel">
                <i class="bi bi-arrow-left"></i> Annuler
            </button>
        </div>
    </div>
    <div class="lov-form-body" style="padding:28px 32px 32px;">
        @* ── En-tête Appro ── *@
        <div class="row g-4">
            <div class="col-4">
                <label class="form-label">Référence</label>
                <input type="text" class="form-control" @bind="_appro.Reference" placeholder="REF-001" />
            </div>
            <div class="col-4">
                <label class="form-label">Fournisseur</label>
                <MudAutocomplete T="int?" @bind-Value="_appro.SupplierId"
                                 SearchFunc="@SearchSuppliers"
                                 ToStringFunc="@(id => _suppliers.FirstOrDefault(s => s.SupplierId == id)?.SupplierName ?? "")"
                                 Placeholder="Choisir"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true"
                                 CoerceText="true" CoerceValue="true" />
            </div>
            <div class="col-4">
                <label class="form-label">Date</label>
                <MudDatePicker @bind-Date="_dateValue" DateFormat="dd/MM/yyyy"
                               Variant="Variant.Outlined" Margin="Margin.Dense" />
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-6">
                <label class="form-label">Localisation</label>
                <MudSelect T="int?" @bind-Value="_selectedLocalisationId"
                           Placeholder="Choisir"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                    @foreach (var loc in _localisations)
                    {
                        <MudSelectItem T="int?" Value="@loc.IdLocalisation">@loc.DescriptionLocalisation</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="col-6">
                <label class="form-label">Commentaire</label>
                <input type="text" class="form-control" @bind="_appro.Commentaire" placeholder="Optionnel" />
            </div>
        </div>

        <hr class="my-3" />

        @* ── Lignes d'articles ── *@
        <div class="d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-list-ul me-1"></i>Articles</h6>
            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddLine">
                <i class="bi bi-plus-lg me-1"></i>Ajouter ligne
            </button>
        </div>

        @if (_lines.Any())
        {
            <div class="table-responsive mt-2" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th style="width: 35%">Article</th>
                            <th style="width: 15%">Qté</th>
                            <th style="width: 15%">PA</th>
                            <th style="width: 15%">PV</th>
                            <th style="width: 15%">Bén.</th>
                            <th style="width: 5%"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in _lines)
                        {
                            <tr>
                                <td>
                                    <MudAutocomplete T="string" Value="@line.IdArticle"
                                                     ValueChanged="@(v => OnArticleChanged(line, v))"
                                                     SearchFunc="@SearchArticles"
                                                     ToStringFunc="@(id => _articles.FirstOrDefault(a => a.IdArticle == id)?.Description ?? id ?? "")"
                                                     Placeholder="Sélectionner..."
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                                     CoerceText="true" CoerceValue="true" />
                                </td>
                                <td>
                                    <MudNumericField @bind-Value="line.Qte" T="decimal" Min="1"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </td>
                                <td>
                                    <MudNumericField @bind-Value="line.PA" T="decimal?" Min="0"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </td>
                                <td>
                                    <MudNumericField Value="@line.PV" T="decimal?" ReadOnly="true"
                                                     Variant="Variant.Filled" Margin="Margin.Dense" />
                                </td>
                                <td class="text-end align-middle">
                                    @if (line.PA.HasValue && line.PV.HasValue)
                                    {
                                        var ben = (line.PV.Value - line.PA.Value) * line.Qte;
                                        <span class="badge @(ben >= 0 ? "bg-success" : "bg-danger")">@ben.ToString("N0")</span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(line)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end gap-3 mt-2">
                <span class="fw-bold">Total articles: @_lines.Count</span>
                <span class="fw-bold">Qté totale: @_lines.Sum(l => l.Qte).ToString("N0")</span>
                @if (_lines.All(l => l.PA.HasValue && l.PV.HasValue))
                {
                    var totalBen = _lines.Sum(l => (l.PV!.Value - l.PA!.Value) * l.Qte);
                    <span class="fw-bold @(totalBen >= 0 ? "text-success" : "text-danger")">Bénéfice total: @totalBen.ToString("N0")</span>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0 mt-2">
                <i class="bi bi-info-circle me-1"></i>
                Cliquez sur "Ajouter ligne" pour ajouter des articles à cet approvisionnement.
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int? ApproId { get; set; }
    [SupplyParameterFromQuery] public string? PreselectedArticleId { get; set; }
    [SupplyParameterFromQuery] public int? PreselectedLocalisationId { get; set; }

    bool _isEdit;
    Appro _appro = new();
    DateTime? _dateValue = DateTime.Today;
    int? _selectedLocalisationId;

    List<Article> _articles = new();
    List<Supplier> _suppliers = new();
    List<Localisation> _localisations = new();
    List<ApproDetailLine> _lines = new();
    string _currentLogin = "";

    async Task OnCancel()
    {
        await JS.InvokeVoidAsync("appNavigation.backOrFallback", "/stock");
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        await using var ctx = await DbFactory.CreateDbContextAsync();
        _articles = await ctx.Articles.OrderBy(a => a.Description).ToListAsync();
        _suppliers = await ctx.Suppliers.OrderBy(s => s.SupplierName).ToListAsync();
        _localisations = await ctx.Localisations.OrderBy(l => l.DescriptionLocalisation).ToListAsync();

        if (ApproId.HasValue)
        {
            _isEdit = true;
            var existing = await ctx.Appros
                .Include(a => a.Details)
                .FirstOrDefaultAsync(a => a.Id == ApproId.Value);
            if (existing != null)
            {
                _appro = existing;
                _dateValue = _appro.Date.ToDateTime(TimeOnly.MinValue);
                _selectedLocalisationId = _appro.LocalisationId;

                foreach (var detail in existing.Details)
                {
                    _lines.Add(new ApproDetailLine
                    {
                        Id = detail.Id,
                        IdArticle = detail.IdArticle,
                        Qte = detail.Qte,
                        PA = detail.PA,
                        PV = detail.PV
                    });
                }
            }
        }
        else
        {
            if (PreselectedLocalisationId.HasValue)
                _selectedLocalisationId = PreselectedLocalisationId;

            if (!string.IsNullOrEmpty(PreselectedArticleId))
            {
                var art = _articles.FirstOrDefault(a => a.IdArticle == PreselectedArticleId);
                _lines.Add(new ApproDetailLine
                {
                    IdArticle = PreselectedArticleId,
                    Qte = 1,
                    PV = art != null ? (decimal?)art.Price : null
                });
            }
        }
    }

    private Task<IEnumerable<string>> SearchArticles(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_articles.Select(a => a.IdArticle));
        return Task.FromResult(_articles
            .Where(a => a.Description != null && a.Description.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(a => a.IdArticle));
    }

    private Task<IEnumerable<int?>> SearchSuppliers(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_suppliers.Select(s => (int?)s.SupplierId));
        return Task.FromResult(_suppliers
            .Where(s => s.SupplierName != null && s.SupplierName.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(s => (int?)s.SupplierId));
    }

    void AddLine()
    {
        _lines.Add(new ApproDetailLine { Qte = 1 });
    }

    void RemoveLine(ApproDetailLine line)
    {
        _lines.Remove(line);
    }

    void OnArticleChanged(ApproDetailLine line, string value)
    {
        line.IdArticle = value;
        var art = _articles.FirstOrDefault(a => a.IdArticle == value);
        if (art != null)
        {
            line.PV = (decimal?)art.Price;
        }
    }

    async Task OnSave()
    {
        if (!_selectedLocalisationId.HasValue)
        {
            Snackbar.Add("Sélectionnez une localisation", Severity.Warning);
            return;
        }
        if (!_lines.Any())
        {
            Snackbar.Add("Ajoutez au moins un article", Severity.Warning);
            return;
        }
        if (_lines.Any(l => string.IsNullOrEmpty(l.IdArticle)))
        {
            Snackbar.Add("Tous les articles doivent être sélectionnés", Severity.Warning);
            return;
        }
        if (_lines.Any(l => l.Qte <= 0))
        {
            Snackbar.Add("Les quantités doivent être > 0", Severity.Warning);
            return;
        }
        if (_lines.Any(l => !l.PA.HasValue))
        {
            Snackbar.Add("Le prix d'achat (PA) est obligatoire pour tous les articles", Severity.Warning);
            return;
        }
        if (_lines.Any(l => l.PA.HasValue && l.PV.HasValue && l.PA.Value > l.PV.Value))
        {
            Snackbar.Add("Le prix d'achat ne peut pas être supérieur au prix de vente (perte interdite)", Severity.Error);
            return;
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var userName = _currentLogin;
            var now = DateTime.Now;
            var today = DateOnly.FromDateTime(_dateValue ?? DateTime.Today);

            _appro.Date = today;
            _appro.DateSys = now;
            _appro.User = userName;
            _appro.Cumputer = Environment.MachineName;
            _appro.LocalisationId = _selectedLocalisationId;
            _appro.Commentaire = string.IsNullOrEmpty(_appro.Commentaire) ? "Approvisionnement" : _appro.Commentaire;

            var firstLine = _lines.First();
            _appro.IdArticle = firstLine.IdArticle;
            _appro.Qte = _lines.Sum(l => l.Qte);
            _appro.PA = _lines.Average(l => l.PA ?? 0);
            _appro.PV = _lines.Average(l => l.PV ?? 0);
            _appro.Ben = (_appro.PV ?? 0) - (_appro.PA ?? 0);
            _appro.BenTotal = _lines.Sum(l => ((l.PV ?? 0) - (l.PA ?? 0)) * l.Qte);
            _appro.StatusId = 1;

            if (!ApproId.HasValue)
                ctx.Appros.Add(_appro);
            else
                ctx.Appros.Update(_appro);

            await ctx.SaveChangesAsync();

            if (ApproId.HasValue)
            {
                var oldDetails = await ctx.ApproDetails.Where(d => d.IdAppro == _appro.Id).ToListAsync();
                ctx.ApproDetails.RemoveRange(oldDetails);
                await ctx.SaveChangesAsync();
            }

            foreach (var line in _lines)
            {
                var detail = new ApproDetail
                {
                    IdAppro = _appro.Id,
                    IdArticle = line.IdArticle,
                    IdLocalisation = _selectedLocalisationId!.Value,
                    Qte = line.Qte,
                    PA = line.PA,
                    PV = line.PV,
                    Ben = (line.PV ?? 0) - (line.PA ?? 0),
                    BenTotal = ((line.PV ?? 0) - (line.PA ?? 0)) * line.Qte,
                    DateSys = now,
                    User = userName,
                    Cumputer = Environment.MachineName
                };
                ctx.ApproDetails.Add(detail);
                await ctx.SaveChangesAsync();

                var stock = await ctx.Stocks.FirstOrDefaultAsync(s =>
                    s.IdArticle == line.IdArticle && s.IdLocalisation == _selectedLocalisationId!.Value);

                decimal qteAvant = stock?.Qte ?? 0;
                decimal qteApres = qteAvant + line.Qte;

                if (stock != null)
                {
                    stock.Qte = qteApres;
                    stock.DateSys = today;
                    stock.UserLogin = userName;
                }
                else
                {
                    stock = new Stock
                    {
                        IdArticle = line.IdArticle,
                        IdLocalisation = _selectedLocalisationId!.Value,
                        Qte = line.Qte,
                        Seuil = 0,
                        DateSys = today,
                        UserLogin = userName
                    };
                    ctx.Stocks.Add(stock);
                }
                await ctx.SaveChangesAsync();

                var mouvement = new MouvementStock
                {
                    IdArticle = line.IdArticle,
                    IdLocalisation = _selectedLocalisationId!.Value,
                    TypeMouvement = TypesMouvement.ENTREE,
                    Quantite = line.Qte,
                    QteAvant = qteAvant,
                    QteApres = qteApres,
                    DateMouvement = now,
                    TypeDocument = TypesDocument.APPRO,
                    IdDocument = _appro.Id,
                    IdDocumentDetail = detail.Id,
                    Reference = _appro.Reference,
                    PrixUnitaire = line.PA,
                    Observation = $"Approvisionnement - {_appro.Supplier?.SupplierName ?? "Direct"}",
                    CreePar = userName,
                    DateCreation = now
                };
                ctx.MouvementsStock.Add(mouvement);

                var article = await ctx.Articles.FindAsync(line.IdArticle);
                if (article != null)
                {
                    article.Qte = (article.Qte ?? 0) + line.Qte;
                    if (line.PV.HasValue && line.PV.Value > 0)
                        article.Price = (double)line.PV.Value;
                }
            }

            await ctx.SaveChangesAsync();
            Snackbar.Add($"Approvisionnement enregistré ({_lines.Count} article(s))", Severity.Success);
            Navigation.NavigateTo("/stock");
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }

    class ApproDetailLine
    {
        public int Id { get; set; }
        public string IdArticle { get; set; } = "";
        public decimal Qte { get; set; }
        public decimal? PA { get; set; }
        public decimal? PV { get; set; }
    }
}
