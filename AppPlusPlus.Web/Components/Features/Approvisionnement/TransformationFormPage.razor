@page "/stock/transformation/nouveau"
@page "/stock/transformation/modifier/{TransformationId:int}"
@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject ITransformationService TransformationService
@inject ICatalogueService CatalogueService
@inject ILocalisationService LocalisationService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@AppSettings.AppName — @(_isEdit ? "Modifier la transformation" : "Nouvelle transformation")</PageTitle>

<div class="lov-card" style="max-width:620px; margin:40px auto;">
    <div class="lov-form-header">
        <h5 style="font-weight:700; font-size:1.25rem;">@(_isEdit ? "Modifier la transformation" : "Nouvelle transformation")</h5>
        <div class="d-flex" style="gap:0.5rem;">
            <button type="button" class="btn btn-sm btn-save-teal d-flex align-items-center gap-1"
                    @onclick="@OnSubmit">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    style="padding:6px 16px; border-radius:6px; font-size:13px; font-weight:500;"
                    @onclick="@OnCancel">
                <i class="bi bi-arrow-left"></i> Annuler
            </button>
        </div>
    </div>
    <div class="lov-form-body" style="padding:28px 32px 32px;">
        <div class="row g-4">
            <div class="col-6">
                <label class="form-label">Article source</label>
                <MudAutocomplete T="string" @bind-Value="_item.FromArticleId" SearchFunc="@SearchArticle"
                                 ToStringFunc="@(v => _articles.Find(a => a.IdArticle == v)?.Description ?? "")"
                                 Placeholder="Choisir" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                 CoerceText="true" CoerceValue="true" />
            </div>
            <div class="col-6">
                <label class="form-label">Localisation source</label>
                <MudSelect T="int?" @bind-Value="_item.FromLocalisationId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true"
                           Placeholder="Choisir">
                    @foreach (var loc in _localisations)
                    {
                        <MudSelectItem T="int?" Value="@((int?)loc.IdLocalisation)">@loc.DescriptionLocalisation</MudSelectItem>
                    }
                </MudSelect>
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-6">
                <label class="form-label">Article destination</label>
                <MudAutocomplete T="string" @bind-Value="_item.ToArticleId" SearchFunc="@SearchArticle"
                                 ToStringFunc="@(v => _articles.Find(a => a.IdArticle == v)?.Description ?? "")"
                                 Placeholder="Choisir" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                                 CoerceText="true" CoerceValue="true" />
            </div>
            <div class="col-6">
                <label class="form-label">Localisation destination</label>
                <MudSelect T="int?" @bind-Value="_item.ToLocalisationId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true"
                           Placeholder="Choisir">
                    @foreach (var loc in _localisations)
                    {
                        <MudSelectItem T="int?" Value="@((int?)loc.IdLocalisation)">@loc.DescriptionLocalisation</MudSelectItem>
                    }
                </MudSelect>
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-4">
                <label class="form-label">Qté source</label>
                <MudNumericField @bind-Value="_item.Qte" T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="0" />
            </div>
            <div class="col-4">
                <label class="form-label">Qté destination</label>
                <MudNumericField @bind-Value="_item.ToQte" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="0" />
            </div>
            <div class="col-4">
                <label class="form-label">Date</label>
                <MudDatePicker @bind-Date="_dateValue" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-12">
                <label class="form-label">Commentaire</label>
                <textarea class="form-control" @bind="_item.Comment" rows="2" placeholder="Optionnel"></textarea>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? TransformationId { get; set; }

    bool _isEdit;
    Transformation _item = new() { Date = DateTime.Now };
    DateTime? _dateValue = DateTime.Now;
    List<Article> _articles = new();
    List<Localisation> _localisations = new();
    string _currentLogin = "";

    private Task<IEnumerable<string>> SearchArticle(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_articles.Select(a => a.IdArticle));
        return Task.FromResult(_articles
            .Where(a => a.Description != null && a.Description.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(a => a.IdArticle));
    }

    async Task OnCancel()
    {
        await JS.InvokeVoidAsync("appNavigation.backOrFallback", "/stock");
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        _articles = (await CatalogueService.GetArticlesAsync()).OrderBy(a => a.Description).ToList();
        _localisations = (await LocalisationService.GetAllLocalisationsAsync()).OrderBy(l => l.DescriptionLocalisation).ToList();

        if (TransformationId.HasValue)
        {
            _isEdit = true;
            var existing = await TransformationService.GetByIdAsync(TransformationId.Value);
            if (existing != null)
            {
                _item = existing;
                _dateValue = _item.Date;
            }
        }
    }

    async Task OnSubmit()
    {
        _item.Date = _dateValue ?? DateTime.Now;
        _item.UserLogin = _currentLogin;
        _item.DateSys = DateTime.Now;
        _item.Computer = Environment.MachineName;
        if (_isEdit)
            await TransformationService.UpdateAsync(_item);
        else
            await TransformationService.AddAsync(_item);
        Navigation.NavigateTo("/stock");
    }
}
