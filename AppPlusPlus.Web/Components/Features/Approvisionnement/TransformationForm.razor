@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <div class="d-flex flex-column gap-3">

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Article source</label>
                    <MudAutocomplete T="string" @bind-Value="_item.FromArticleId" SearchFunc="@SearchArticle"
                                     ToStringFunc="@(v => _articles.Find(a => a.IdArticle == v)?.Description ?? "")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Localisation source</label>
                    <MudSelect T="int?" @bind-Value="_item.FromLocalisationId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true">
                        @foreach (var loc in _localisations)
                        {
                            <MudSelectItem T="int?" Value="@((int?)loc.IdLocalisation)">@loc.DescriptionLocalisation</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Article destination</label>
                    <MudAutocomplete T="string" @bind-Value="_item.ToArticleId" SearchFunc="@SearchArticle"
                                     ToStringFunc="@(v => _articles.Find(a => a.IdArticle == v)?.Description ?? "")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Localisation destination</label>
                    <MudSelect T="int?" @bind-Value="_item.ToLocalisationId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true">
                        @foreach (var loc in _localisations)
                        {
                            <MudSelectItem T="int?" Value="@((int?)loc.IdLocalisation)">@loc.DescriptionLocalisation</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Qté source</label>
                    <MudNumericField @bind-Value="_item.Qte" T="decimal" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Qté destination</label>
                    <MudNumericField @bind-Value="_item.ToQte" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Date</label>
                    <MudDatePicker @bind-Date="_dateValue" DateFormat="dd/MM/yyyy" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
            </div>

            <label class="form-label">Commentaire</label>
            <textarea class="form-control" @bind="_item.Comment" rows="2"></textarea>
        </div>
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="OnSubmit">
            <i class="bi bi-check-lg me-1"></i>Enregistrer
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int? TransformationId { get; set; }

    Transformation _item = new() { Date = DateTime.Now };
    DateTime? _dateValue = DateTime.Now;
    List<Article> _articles = new();
    List<Localisation> _localisations = new();
    string _currentLogin = "";

    void Cancel() => MudDialog.Close();

    private Task<IEnumerable<string>> SearchArticle(string value, CancellationToken ct)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult(_articles.Select(a => a.IdArticle));
        return Task.FromResult(_articles
            .Where(a => a.Description != null && a.Description.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(a => a.IdArticle));
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        await using var ctx = await DbFactory.CreateDbContextAsync();
        _articles = await ctx.Articles.OrderBy(a => a.Description).ToListAsync();
        _localisations = await ctx.Localisations.OrderBy(l => l.DescriptionLocalisation).ToListAsync();

        if (TransformationId.HasValue)
        {
            var existing = await ctx.Transformations.FindAsync(TransformationId.Value);
            if (existing != null)
            {
                _item = existing;
                _dateValue = _item.Date;
            }
        }
    }

    async Task OnSubmit()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        _item.Date = _dateValue ?? DateTime.Now;
        _item.UserLogin = _currentLogin;
        _item.DateSys = DateTime.Now;
        _item.Computer = Environment.MachineName;
        if (TransformationId.HasValue)
            ctx.Transformations.Update(_item);
        else
            ctx.Transformations.Add(_item);
        await ctx.SaveChangesAsync();
        MudDialog.Close(DialogResult.Ok(true));
    }
}
