@using MudBlazor
@inject ICatalogueService CatalogueService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <div class="lov-form-header">
            <h5>@(_isEdit ? "Modifier la localisation" : "Nouvelle localisation")</h5>
            <div class="d-flex" style="gap:0.5rem;">
                <button type="button" class="btn btn-primary btn-sm" @onclick="Submit">
                    <i class="bi bi-check-lg me-1"></i>@(_isEdit ? "Modifier" : "Ajouter")
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Cancel">
                    <i class="bi bi-arrow-left me-1"></i>Annuler
                </button>
            </div>
        </div>
        <div class="lov-form-body">
            <div class="lov-field">
                <label class="form-label">Description *</label>
                <input type="text" class="form-control" @bind="_model.DescriptionLocalisation" maxlength="50"
                       placeholder="Nom de la localisation" />
            </div>
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Localisation? Model { get; set; }

    private Localisation _model = new();
    private bool _isEdit;

    protected override void OnInitialized()
    {
        if (Model != null)
        {
            _isEdit = true;
            _model = new Localisation
            {
                IdLocalisation = Model.IdLocalisation,
                DescriptionLocalisation = Model.DescriptionLocalisation
            };
        }
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_model.DescriptionLocalisation)) return;

        if (_isEdit)
        {
            await CatalogueService.UpdateLocalisationAsync(_model);
            Snackbar.Add("Localisation modifiée.", Severity.Success);
        }
        else
        {
            await CatalogueService.AddLocalisationAsync(_model);
            Snackbar.Add("Localisation ajoutée.", Severity.Success);
        }

        MudDialog.Close();
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
