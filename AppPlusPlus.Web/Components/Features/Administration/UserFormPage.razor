@page "/admin/utilisateur/nouveau"
@page "/admin/utilisateur/modifier/{UserLogin}"
@rendermode InteractiveServer
@using MudBlazor
@inject IUserAdminService UserAdminService
@inject ILocalisationService LocalisationService
@inject ISnackbar Snackbar
@inject IRoleService RoleService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@AppSettings.AppName — @(_isEdit ? "Modifier l'utilisateur" : "Nouvel utilisateur")</PageTitle>

<div class="lov-card" style="max-width:620px; margin:40px auto;">
    <div class="lov-form-header">
        <h5 style="font-weight:700; font-size:1.25rem;">@(_isEdit ? "Modifier l'utilisateur" : "Nouvel utilisateur")</h5>
        <div class="d-flex" style="gap:0.5rem;">
            <button type="button" class="btn btn-sm btn-save-teal d-flex align-items-center gap-1"
                    @onclick="@OnSubmit">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    style="padding:6px 16px; border-radius:6px; font-size:13px; font-weight:500;"
                    @onclick="@OnCancel">
                <i class="bi bi-arrow-left"></i> Annuler
            </button>
        </div>
    </div>
    <div class="lov-form-body" style="padding:28px 32px 32px;">
        <div class="row g-4">
            <div class="col-6">
                <label class="form-label">Login</label>
                <input type="text" class="form-control" @bind="_user.Login" maxlength="50" readonly="@_isEdit"
                       placeholder="Identifiant" />
            </div>
            <div class="col-6">
                <label class="form-label">Mot de passe</label>
                <input type="password" class="form-control" @bind="_user.Password"
                       placeholder="********" />
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-6">
                <label class="form-label">Nom complet</label>
                <input type="text" class="form-control" @bind="_user.Name" maxlength="50"
                       placeholder="Prénom et nom" />
            </div>
            <div class="col-6">
                <label class="form-label">Email</label>
                <input type="text" class="form-control" @bind="_user.Email" maxlength="50"
                       placeholder="email@exemple.com" />
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-6">
                <label class="form-label">Rôle</label>
                <MudSelect T="int?" @bind-Value="_user.RoleId" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                           Placeholder="Choisir">
                    @foreach (var role in _roles)
                    {
                        <MudSelectItem T="int?" Value="@role.RoleId">@role.DescriptionRole</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="col-6">
                <label class="form-label">Actif</label>
                <MudSwitch @bind-Value="_activated" T="bool" Color="Color.Primary" />
            </div>
        </div>

        <fieldset class="lov-fieldset mt-4">
            <legend>Localisations assignées</legend>
            @if (_localisations.Any())
            {
                <div class="d-flex flex-wrap gap-4">
                    @foreach (var loc in _localisations)
                    {
                        <MudCheckBox T="bool"
                                     Value="@IsLocalisationSelected(loc.IdLocalisation)"
                                     ValueChanged="@((bool val) => OnLocalisationToggle(loc.IdLocalisation, val))"
                                     Color="Color.Primary" Dense="true"
                                     Label="@loc.DescriptionLocalisation" />
                    }
                </div>
            }
            else
            {
                <span class="text-muted" style="font-size:0.8rem;">Aucune localisation disponible</span>
            }
            <p class="lov-fieldset-count">@_selectedLocalisations.Count localisation(s) sélectionnée(s)</p>
        </fieldset>
    </div>
</div>

@code {
    [Parameter] public string? UserLogin { get; set; }

    bool _isEdit;
    bool _activated = true;
    List<Role> _roles = new();
    List<Localisation> _localisations = new();
    HashSet<int> _selectedLocalisations = new();
    User _user = new() { Activated = true };

    bool IsLocalisationSelected(int locId) => _selectedLocalisations.Contains(locId);

    void OnLocalisationToggle(int locId, bool selected)
    {
        if (selected)
            _selectedLocalisations.Add(locId);
        else
            _selectedLocalisations.Remove(locId);
    }

    async Task OnCancel()
    {
        await JS.InvokeVoidAsync("appNavigation.backOrFallback", "/administration");
    }

    protected override async Task OnInitializedAsync()
    {
        _roles = await UserAdminService.GetActiveRolesAsync();
        _localisations = await LocalisationService.GetAllLocalisationsAsync();

        if (!string.IsNullOrEmpty(UserLogin))
        {
            _isEdit = true;
            var existing = await UserAdminService.GetUserByLoginAsync(UserLogin);
            if (existing != null)
            {
                _user = existing;
                _activated = _user.Activated ?? true;

                var userLocIds = await LocalisationService.GetUserLocalisationIdsAsync(UserLogin, false);
                _selectedLocalisations = userLocIds.ToHashSet();
            }
        }
        else if (_roles.Any())
        {
            _user.RoleId = _roles.First().RoleId;
        }
    }

    async Task OnSubmit()
    {
        if (string.IsNullOrWhiteSpace(_user.Login))
        {
            Snackbar.Add("Le login est obligatoire.", Severity.Warning);
            return;
        }

        _user.Activated = _activated;

        if (_isEdit)
        {
            await UserAdminService.UpdateUserAsync(_user, _selectedLocalisations);
        }
        else
        {
            var exists = await UserAdminService.UserExistsAsync(_user.Login);
            if (exists)
            {
                Snackbar.Add("Ce login existe déjà.", Severity.Error);
                return;
            }

            await UserAdminService.CreateUserAsync(_user, _selectedLocalisations);

            if (_user.RoleId.HasValue)
            {
                await RoleService.SetDefaultPermissionsForRoleAsync(_user.RoleId.Value, overwrite: false);
            }
        }

        Navigation.NavigateTo("/administration");
    }
}
