    /* ════════════════════════════════════════════════════════════
       TRANSFORMATION
       ════════════════════════════════════════════════════════════ */

    async Task LoadTransformations()
    {
        _transLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();

        var transQuery = ctx.Transformations.AsQueryable();

        // Filter by user's localisations if not admin
        if (_currentUserLocalisations.Any())
        {
            transQuery = transQuery.Where(t =>
                (t.FromLocalisationId.HasValue && _currentUserLocalisations.Contains(t.FromLocalisationId.Value)) ||
                (t.ToLocalisationId.HasValue && _currentUserLocalisations.Contains(t.ToLocalisationId.Value)));
        }

        _transData = await transQuery.OrderByDescending(t => t.Date).ToListAsync();
        _transLoading = false;
    }

    async Task OnAddTrans()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters();
        var dialog = await DialogService.ShowAsync<TransformationForm>("Nouvelle transformation", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadTransformations();
    }

    async Task OnEditTrans(Transformation item)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters { ["TransformationId"] = item.TransformationId };
        var dialog = await DialogService.ShowAsync<TransformationForm>("Modifier la transformation", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadTransformations();
    }

    async Task OnDeleteTrans(Transformation item)
    {
        var confirm = await DialogService.ShowMessageBox("Confirmation",
            $"Supprimer la transformation N° {item.TransformationId} ?",
            yesText: "Supprimer", cancelText: "Annuler");
        if (confirm == true)
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            ctx.Transformations.Remove(item);
            await ctx.SaveChangesAsync();
            _transData.Remove(item);
            Snackbar.Add("Transformation supprimée", Severity.Success);
        }
    }

