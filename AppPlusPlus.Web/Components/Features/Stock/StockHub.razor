    async Task OnEditAppro(int approId)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var parameters = new DialogParameters { ["ApproId"] = approId };
        var dialog = await DialogService.ShowAsync<ApproForm>("Modifier l'appro", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadAppros();
    }

    async Task OnDeleteAppro(ApproRow item)
    {
        var confirm = await DialogService.ShowMessageBox("Confirmation",
            $"Supprimer l'appro N° {item.Id} ?",
            yesText: "Supprimer", cancelText: "Annuler");
        if (confirm == true)
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var entity = await ctx.Appros.FindAsync(item.Id);
            if (entity != null)
            {
                ctx.Appros.Remove(entity);
                await ctx.SaveChangesAsync();
            }
            _approData.Remove(item);
            Snackbar.Add("Appro supprimé", Severity.Success);
        }
    }

