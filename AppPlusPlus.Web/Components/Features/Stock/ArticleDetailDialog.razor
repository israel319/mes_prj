@using MudBlazor
@inject IStockService StockService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@Article?.Description</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (Article != null)
        {
            <!-- Info article -->
            <MudGrid Class="mb-4" Spacing="2">
                <MudItem xs="4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Code</MudText>
                    <MudText Typo="Typo.body1"><b>@Article.IdArticle</b></MudText>
                </MudItem>
                <MudItem xs="4">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Prix</MudText>
                    <MudText Typo="Typo.body1"><b>@Article.Price.ToString("N0") Fc</b></MudText>
                </MudItem>
                @if (!string.IsNullOrWhiteSpace(Article.DescriptionI))
                {
                    <MudItem xs="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Description longue</MudText>
                        <MudText Typo="Typo.body2">@Article.DescriptionI</MudText>
                    </MudItem>
                }
            </MudGrid>

            <MudDivider Class="mb-3" />

            <!-- Stocks par localisation -->
            <MudText Typo="Typo.subtitle1" Class="mb-2"><b>Stock par localisation</b></MudText>

            @if (Stocks == null || !Stocks.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Cet article n'est associé à aucune localisation.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Bordered="true" Striped="true" Style="border-radius:8px;overflow:hidden;">
                    <thead>
                        <tr style="background:#f5f5f5;">
                            <th>Localisation</th>
                            <th style="text-align:center;">Stock</th>
                            <th style="text-align:center;">Seuil</th>
                            <th style="text-align:center;">État</th>
                            <th style="text-align:center;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stock in Stocks)
                        {
                            var couleur = stock.Qte <= 0 ? Color.Error : stock.Qte <= stock.Seuil ? Color.Warning : Color.Success;
                            <tr>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                        @stock.LocalisationName
                                    </MudChip>
                                </td>
                                <td style="text-align:center;">
                                    <MudText Color="@couleur" Typo="Typo.body2" Style="font-weight:700;">
                                        @if (stock.Qte <= 0)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" Class="me-1" />
                                        }
                                        @stock.Qte
                                    </MudText>
                                </td>
                                <td style="text-align:center;">
                                    <div class="d-flex align-center justify-center gap-1">
                                        <MudNumericField @bind-Value="stock.Seuil" T="int" Min="0"
                                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                                         Immediate="true"
                                                         Style="width:80px;" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Save"
                                                       Color="Color.Success" Size="Size.Small"
                                                       OnClick="@(() => OnSaveSeuil(stock))" />
                                    </div>
                                </td>
                                <td style="text-align:center;">
                                    @if (stock.Qte <= 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Rupture</MudChip>
                                    }
                                    else if (stock.Qte <= stock.Seuil)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Bas</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">OK</MudChip>
                                    }
                                </td>
                                <td style="text-align:center;">
                                    <MudIconButton Icon="@Icons.Material.Filled.AddShoppingCart"
                                                   Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => OnApproLocation(stock))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#f5f5f5;">
                            <td><strong>Total</strong></td>
                            <td style="text-align:center;"><strong>@Stocks.Sum(s => s.Qte)</strong></td>
                            <td colspan="3"></td>
                        </tr>
                    </tfoot>
                </MudSimpleTable>
            }
        }
    </DialogContent>
    <DialogActions>
        <div class="d-flex justify-space-between w-100 px-2 pb-2" style="width:100%;">
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="@OnDeleteArticle">Supprimer</MudButton>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" OnClick="@Cancel">Fermer</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="@OnEditArticle">Modifier</MudButton>
            </div>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public Article? Article { get; set; }

    [Parameter]
    public List<StockLocationInfo>? Stocks { get; set; }

    [Parameter]
    public List<Localisation>? Localisations { get; set; }

    void Cancel() => MudDialog?.Cancel();

    void OnEditArticle()
    {
        MudDialog?.Close(DialogResult.Ok(true));
        Navigation.NavigateTo($"/gestion/article/modifier/{Article?.IdArticle}");
    }

    async Task OnDeleteArticle()
    {
        var confirm = await DialogService.ShowMessageBox("Confirmation",
            $"Supprimer l'article « {Article?.Description} » et tous ses stocks ?",
            yesText: "Supprimer", cancelText: "Annuler");

        if (confirm == true && Article != null)
        {
            try
            {
                await StockService.DeleteArticleWithStocksAsync(Article.IdArticle);
                Snackbar.Add("Article supprimé", Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur lors de la suppression : {ex.Message}", Severity.Error);
            }
        }
    }

    void OnApproLocation(StockLocationInfo stock)
    {
        MudDialog.Close();
        Navigation.NavigateTo($"/stock/appro/nouveau?PreselectedArticleId={Article?.IdArticle}&PreselectedLocalisationId={stock.IdLocalisation}");
    }

    async Task OnSaveSeuil(StockLocationInfo stock)
    {
        try
        {
            if (stock.StockId <= 0)
            {
                Snackbar.Add($"Erreur : identifiant stock invalide ({stock.StockId})", Severity.Error);
                return;
            }
            await StockService.UpdateSeuilAsync(stock.StockId, stock.Seuil);
            Snackbar.Add($"Seuil mis à jour pour {stock.LocalisationName} : {stock.Seuil}", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
    }

    async Task RefreshStockData()
    {
        if (Article == null) return;

        var stocks = await StockService.GetStocksByArticleAsync(Article.IdArticle);
        var locs = Localisations ?? new List<Localisation>();

        Stocks = stocks
            .Select(s => new StockLocationInfo
            {
                StockId = s.Id,
                IdLocalisation = s.IdLocalisation,
                LocalisationName = locs.FirstOrDefault(l => l.IdLocalisation == s.IdLocalisation)?.DescriptionLocalisation ?? "?",
                Qte = (int)s.Qte,
                Seuil = s.Seuil
            })
            .OrderBy(s => s.LocalisationName)
            .ToList();

        StateHasChanged();
    }
}
