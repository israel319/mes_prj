@page "/"
@using MudBlazor
@using AppPlusPlus.Application.DTOs.Dashboard
@rendermode InteractiveServer
@inject IDashboardService DashboardService
@inject NavigationManager Navigation

<PageTitle>@AppSettings.AppName — Tableau de bord</PageTitle>

@if (!_loaded)
{
    <div class="d-flex align-items-center justify-content-center" style="min-height:400px;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Chargement…</span>
        </div>
    </div>
}
else
{
<div class="w-100">
    <!-- ═══════════════ EN-TÊTE ═══════════════ -->
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-2">
        <div>
            <h1 class="fs-3 mb-1 fw-bold">Tableau de bord</h1>
            <p class="text-muted small mb-0">
                Vue d'ensemble de l'activité · @DateTime.Today.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))
            </p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" @onclick="@(() => Navigation.NavigateTo("/vente/facturation"))">
                <i class="ti ti-plus me-1"></i> Nouvelle facture
            </button>
            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => Navigation.NavigateTo("/rapports"))">
                <i class="ti ti-chart-bar me-1"></i> Rapports
            </button>
        </div>
    </div>

    <!-- ═══════════════ 4 KPI PRINCIPAUX (style InApp) ═══════════════ -->
    <div class="row g-3 mb-2">
        @foreach (var kpi in _kpis)
        {
            <div class="col-lg-3 col-12">
                <div class="card kpi-card @KpiVariantClass(kpi.Color) p-4">
                    <div class="d-flex gap-3">
                        <div class="icon-shape icon-md rounded-3" style="@($"background:{kpi.Color};color:#fff;")">
                            <i class="ti @kpi.TablerIcon fs-4"></i>
                        </div>
                        <div>
                            <h2 class="mb-2 fs-6">@kpi.Label</h2>
                            <h3 class="fw-bold mb-0" style="@kpi.ValueStyle">@kpi.Value</h3>
                            @if (!string.IsNullOrEmpty(kpi.Trend))
                            {
                                <p class="mb-0 small" style="@($"color:{kpi.Color};")">
                                    <i class="ti @(kpi.TrendUp ? "ti-trending-up" : "ti-trending-down") me-1"></i>@kpi.Trend depuis le mois dernier
                                </p>
                            }
                            else
                            {
                                <p class="text-muted mb-0 small">@kpi.SubLabel</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ═══════════════ 3 CARTES MÉTRIQUES (style InApp) ═══════════════ -->
    <div class="row g-3 mb-2">
        <div class="col-lg-4 col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h3 class="fw-bold h4">@(_totalRevenueYear.ToString("N0")) Fc</h3>
                            <span class="text-muted">Revenus @DateTime.Today.Year</span>
                        </div>
                        <i class="ti ti-report-analytics fs-1 text-primary"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">Total annuel</span>
                        <a href="/rapports" class="link-primary text-decoration-underline">Voir</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h3 class="fw-bold h4">@(_factsMonthCount) factures</h3>
                            <span class="text-muted">Ce mois-ci</span>
                        </div>
                        <i class="ti ti-file-text fs-1 text-success"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">Factures émises</span>
                        <a href="/vente" class="link-primary text-decoration-underline">Voir</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h3 class="fw-bold h4">@(_cmdsEnAttente) en attente</h3>
                            <span class="text-muted">Commandes</span>
                        </div>
                        <i class="ti ti-shopping-cart fs-1 text-warning"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center small">
                        <span class="text-muted">À traiter</span>
                        <a href="/commandes" class="link-primary text-decoration-underline">Voir</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════ GRAPHIQUES : Revenus + Statuts factures ═══════════════ -->
    <div class="row g-3 mb-2">
        <!-- Graphique revenus mensuels -->
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center bg-transparent px-4 py-3">
                    <h3 class="h5 mb-0">Ventes vs Approvisionnements</h3>
                    <span class="badge bg-info-subtle text-info border border-info">@($"{_totalRevenueYear:N0} Fc")</span>
                </div>
                <div class="card-body p-4">
                    <MudChart ChartType="ChartType.Bar" ChartSeries="@_barSeries" XAxisLabels="@_barLabels"
                              Width="100%" Height="260px" ChartOptions="@_barOptions" />
                </div>
            </div>
        </div>

        <!-- Répartition statuts factures (Donut) -->
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center bg-transparent px-4 py-3">
                    <h3 class="h5 mb-0">Statuts des factures (ce mois)</h3>
                </div>
                <div class="card-body p-4">
                    <MudChart ChartType="ChartType.Donut" InputData="@_donutData" InputLabels="@_donutLabels"
                              Width="260px" Height="260px" />
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════ TOP ARTICLES + STOCK FAIBLE + DERNIÈRES VENTES (style InApp) ═══════════════ -->
    <div class="row g-3 mb-2">
        <!-- Top articles vendus -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
                    <h4 class="mb-0 h5">Top articles vendus</h4>
                    <span class="small text-muted">Ce mois</span>
                </div>
                <ul class="list-group list-group-flush">
                    @if (!_topArticles.Any())
                    {
                        <li class="list-group-item text-center text-muted py-5">
                            <i class="ti ti-inbox d-block mb-2" style="font-size:32px;"></i>
                            Aucune vente ce mois
                        </li>
                    }
                    else
                    {
                        @foreach (var a in _topArticles.Take(5))
                        {
                            <li class="list-group-item d-flex align-items-center gap-3">
                                <div class="icon-shape icon-sm @(a.Rank == 1 ? "bg-warning" : a.Rank == 2 ? "bg-secondary" : a.Rank == 3 ? "bg-danger-subtle" : "bg-light") text-white"
                                     style="@(a.Rank <= 3 ? "" : "color:var(--bs-secondary-color) !important;")">
                                    <span class="fw-bold" style="font-size:12px;">@a.Rank</span>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1">@a.Description</p>
                                    <div class="d-flex align-items-center gap-2 text-muted">
                                        <small class="fw-semibold">@a.Montant.ToString("N0") Fc </small>
                                        <small>•</small>
                                        <small>@a.QteVendue.ToString("N0") unités</small>
                                    </div>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <!-- Alertes stock faible -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
                    <h4 class="mb-0 h5">Stock faible</h4>
                    @if (_lowStockArticles.Any())
                    {
                        <span class="badge bg-warning-subtle text-warning border border-warning">@_lowStockArticles.Count</span>
                    }
                </div>
                <ul class="list-group list-group-flush">
                    @if (!_lowStockArticles.Any())
                    {
                        <li class="list-group-item text-center py-5">
                            <i class="ti ti-circle-check d-block mb-2 text-success" style="font-size:32px;"></i>
                            <span class="text-muted">Tous les stocks sont bons</span>
                        </li>
                    }
                    else
                    {
                        @foreach (var a in _lowStockArticles.Take(5))
                        {
                            <li class="list-group-item d-flex align-items-center gap-3">
                                <div class="icon-shape icon-sm bg-light">
                                    <i class="ti ti-box-seam" style="color:var(--bs-secondary-color);"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1">@a.Description</p>
                                    <small class="text-muted">Seuil : @a.Seuil</small>
                                </div>
                                <div class="d-flex flex-column align-items-center">
                                    <span class="fw-semibold text-primary">@a.Qte.ToString("N0")</span>
                                    <small class="text-muted">En stock</small>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <!-- Dernières ventes -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center px-4 py-3">
                    <h4 class="mb-0 h5">Dernières ventes</h4>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo("/vente"))">
                        <i class="ti ti-eye me-1"></i> Tout voir
                    </button>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var f in _recentFacts.Take(5))
                    {
                        <li class="list-group-item d-flex align-items-center gap-3">
                            <div class="icon-shape icon-sm bg-light">
                                <i class="ti ti-receipt" style="color:var(--bs-secondary-color);"></i>
                            </div>
                            <div class="flex-grow-1">
                                <p class="mb-1">@f.Client</p>
                                <div class="d-flex align-items-center gap-2 text-muted">
                                    <small class="fw-semibold">@f.Total.ToString("N0") Fc</small>
                                    <small>•</small>
                                    <small>@f.Date.ToString("dd/MM/yyyy")</small>
                                </div>
                            </div>
                            <span class="badge @GetStatusBadgeClass(f.StatusLabel)">@f.StatusLabel</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- ═══════════════ STATISTIQUES RAPIDES + RACCOURCIS ═══════════════ -->
    <div class="row g-3 mb-2">
        <!-- Statistiques rapides -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-transparent px-4 py-3">
                    <h4 class="mb-0 h5">Statistiques rapides</h4>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var stat in _quickStats)
                    {
                        <li class="list-group-item d-flex align-items-center justify-content-between px-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="icon-shape icon-sm rounded-2 quick-stat-icon" style="@($"background:{stat.BgColor};color:{stat.Color};")">
                                    <i class="ti @stat.TablerIcon"></i>
                                </div>
                                <span>@stat.Label</span>
                            </div>
                            <span class="fw-bold">@stat.Value</span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Raccourcis rapides -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-transparent px-4 py-3">
                    <h4 class="mb-0 h5">Accès rapides</h4>
                </div>
                <div class="card-body p-4">
                    <div class="row g-2">
                        @foreach (var shortcut in _shortcuts)
                        {
                            <div class="col-md-6">
                                <button class="btn btn-light border w-100 d-flex align-items-center gap-2 py-3 px-3"
                                        @onclick="@(() => Navigation.NavigateTo(shortcut.Path))">
                                    <i class="ti @shortcut.TablerIcon fs-5 text-primary"></i>
                                    <span>@shortcut.Label</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}

@code {
    /* ───── Records pour l'affichage (UI concerns) ───── */
    record KpiData(string Label, string Value, string SubLabel, string TablerIcon,
                   string Color, string BgColor, string ValueStyle = "",
                   string Trend = "", bool TrendUp = true);

    record QuickStat(string Label, string Value, string TablerIcon, string Color, string BgColor);
    record ShortcutItem(string Label, string TablerIcon, string Path);

    /* ───── State ───── */
    bool _loaded;
    List<KpiData> _kpis = new();
    decimal _totalRevenueYear;
    int _factsMonthCount;
    int _cmdsEnAttente;
    List<StockAlertDto> _lowStockArticles = new();
    List<TopArticleDto> _topArticles = new();
    List<RecentFactDto> _recentFacts = new();
    List<QuickStat> _quickStats = new();
    List<ShortcutItem> _shortcuts = new();

    /* ───── MudChart: Bar ───── */
    string[] _barLabels = Array.Empty<string>();
    List<ChartSeries> _barSeries = new();
    ChartOptions _barOptions = new() { YAxisTicks = 5 };

    /* ───── MudChart: Donut ───── */
    double[] _donutData = Array.Empty<double>();
    string[] _donutLabels = Array.Empty<string>();

    string GetStatusBadgeClass(string status) => status switch
    {
        "Nouvelle" => "bg-primary-subtle text-primary",
        "Validée"  => "bg-info-subtle text-info",
        "Payée"    => "bg-success-subtle text-success",
        "Annulée"  => "bg-danger-subtle text-danger",
        _          => "bg-light text-muted"
    };

    string KpiVariantClass(string color) => color switch
    {
        "#00B193" => "kpi-card--green",
        "#3b82f6" => "kpi-card--blue",
        "#253C45" => "kpi-card--teal",
        "#f59e0b" => "kpi-card--amber",
        _         => ""
    };

    /* ───── Chargement ───── */
    protected override async Task OnInitializedAsync()
    {
        var data = await DashboardService.GetDashboardDataAsync();

        /* ═══ KPI ═══ */
        _kpis = new()
        {
            new("Ventes aujourd'hui", data.VentesToday.ToString("N0") + " Fc", $"{data.FactsTodayCount} facture(s)",
                "ti-report-analytics", "#00B193", "#d4f5ef"),
            new("Appros du mois", data.TotalApprosMonth.ToString("N0") + " Fc", $"{data.ApprosMonthCount} approvisionnement(s)",
                "ti-truck-delivery", "#3b82f6", "#dbeafe"),
            new("Bénéfice", data.Benefice.ToString("N0") + " Fc", "(PV − PA) × Qté",
                "ti-coins", "#253C45", "#e8edef",
                data.Benefice >= 0 ? "" : "color:#A61B0C;"),
            new("Ventes du mois", data.VentesMois.ToString("N0") + " Fc", "Chiffre d'affaires mensuel",
                "ti-receipt", "#f59e0b", "#fef3c7", "", data.TrendVente, data.TrendVenteUp),
        };

        /* ═══ Metric cards ═══ */
        _totalRevenueYear = data.TotalRevenueYear;
        _factsMonthCount = data.FactsMonthCount;
        _cmdsEnAttente = data.CmdsEnAttente;

        /* ═══ Bar chart ═══ */
        _barLabels = data.RevenueData.Select(r => r.Month).ToArray();
        _barSeries = new()
        {
            new ChartSeries { Name = "Ventes", Data = data.RevenueData.Select(r => (double)r.Ventes).ToArray() },
            new ChartSeries { Name = "Appros", Data = data.RevenueData.Select(r => (double)r.Appros).ToArray() },
        };

        /* ═══ Donut chart ═══ */
        _donutData = data.StatusData.Select(s => (double)s.Count).ToArray();
        _donutLabels = data.StatusData.Select(s => s.Label).ToArray();

        /* ═══ Lists ═══ */
        _topArticles = data.TopArticles;
        _lowStockArticles = data.LowStockArticles;
        _recentFacts = data.RecentFacts;

        /* ═══ Statistiques rapides ═══ */
        _quickStats = new()
        {
            new("Clients enregistrés", data.TotalClients.ToString(), "ti-users", "#00B193", "#d4f5ef"),
            new("Clients permanents", data.ClientsPermanents.ToString(), "ti-heart", "#00B193", "#d4f5ef"),
            new("Articles en catalogue", data.TotalArticles.ToString(), "ti-box-seam", "#3b82f6", "#dbeafe"),
            new("Factures ce mois", data.FactsMonthCount.ToString(), "ti-file-text", "#f59e0b", "#fef3c7"),
            new("Commandes totales", data.TotalCommandes.ToString(), "ti-shopping-cart", "#253C45", "#e8edef"),
            new("Bénéfice net mois", data.Benefice.ToString("N0") + " Fc", "ti-trending-up", data.Benefice >= 0 ? "#00B193" : "#A61B0C", data.Benefice >= 0 ? "#d4f5ef" : "#fee2e2"),
        };

        /* ═══ Raccourcis ═══ */
        _shortcuts = new()
        {
            new("Nouvelle facture",  "ti-plus",            "/vente/facturation"),
            new("Gestion stock",     "ti-box-seam",        "/stock"),
            new("Commandes",         "ti-shopping-cart",    "/commandes"),
            new("Rapports",          "ti-chart-bar",        "/rapports"),
            new("Administration",    "ti-settings-2",       "/administration"),
            new("Paramètres",        "ti-adjustments",      "/settings"),
        };

        _loaded = true;
    }
}
