@page "/localisation/{Id:int}"
@rendermode InteractiveServer
@using AppPlusPlus.Application.DTOs.Stock
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ILocalisationService LocalisationService
@inject IUserAdminService UserAdminService
@inject IStockService StockService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>@AppSettings.AppName — @(_localisation?.DescriptionLocalisation ?? "Localisation")</PageTitle>

@if (_loading)
{
    <div class="d-flex align-items-center justify-content-center" style="min-height:300px;">
        <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement…</span></div>
    </div>
}
else if (_localisation == null)
{
    <div class="card mx-auto mt-4" style="max-width:720px;">
        <div class="card-body text-center py-5">
            <i class="bi bi-exclamation-triangle" style="font-size:42px;color:#f59e0b;"></i>
            <h5 class="fw-bold mt-3">Localisation introuvable</h5>
            <p class="text-muted">Cette localisation n'existe pas ou a été supprimée.</p>
            <button class="btn btn-primary mt-3" @onclick="@(() => Navigation.NavigateTo("/admin"))">
                <i class="bi bi-arrow-left me-2"></i>Retour
            </button>
        </div>
    </div>
}
else
{
    <!-- En-tête -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-2">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => Navigation.NavigateTo("/admin"))">
                <i class="bi bi-arrow-left"></i>
            </button>
            <div class="hub-icon hub-icon-badge">
                <i class="bi bi-geo-alt"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0 fs-4">@_localisation.DescriptionLocalisation</h2>
                <small class="text-muted">Gestion du stock et des utilisateurs de cette localisation</small>
            </div>
        </div>
    </div>

    <!-- Résumé en cartes -->
    <div class="row g-3 mb-2">
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-people" style="font-size:24px;color:var(--mud-palette-primary);"></i>
                    <h3 class="fw-bold mb-0 mt-2">@_users.Count</h3>
                    <small class="text-muted">Utilisateurs</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-box-seam" style="font-size:24px;color:#00B193;"></i>
                    <h3 class="fw-bold mb-0 mt-2">@_stockArticles.Count</h3>
                    <small class="text-muted">Articles</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-circle" style="font-size:24px;color:#dc2626;"></i>
                    <h3 class="fw-bold mb-0 mt-2" style="color:#dc2626;">@_stockArticles.Count(a => a.Qte <= 0)</h3>
                    <small class="text-muted">En rupture</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle" style="font-size:24px;color:#f59e0b;"></i>
                    <h3 class="fw-bold mb-0 mt-2" style="color:#f59e0b;">@_stockArticles.Count(a => a.Qte > 0 && a.Qte <= a.Seuil)</h3>
                    <small class="text-muted">Stock bas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Onglets -->
    <div class="card">
        <ul class="nav nav-tabs">
            <li class="nav-item">
                <button class="nav-link @(_tab == 0 ? "active" : "")" @onclick="@(async () => await OnTabChange(0))">
                    <i class="bi bi-box-seam me-1"></i>Articles (@_stockArticles.Count)
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_tab == 1 ? "active" : "")" @onclick="@(async () => await OnTabChange(1))">
                    <i class="bi bi-people me-1"></i>Utilisateurs (@_users.Count)
                </button>
            </li>
        </ul>

        @if (_tab == 0)
        {
            <!-- Tab Articles -->
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                    <input type="text" class="form-control" placeholder="Rechercher un article..."
                           style="max-width:300px;" @bind="_articleSearch" @bind:event="oninput" />
                    <button class="btn btn-primary btn-sm" @onclick="OnAddArticle">
                        <i class="bi bi-plus-lg me-1"></i>Nouvel article
                    </button>
                </div>

                <MudDataGrid T="StockArticleDto" Items="@FilteredArticles" Dense="true" Hover="true" Striped="true"
                             RowClick="@OnArticleRowClick" RowStyle="cursor:pointer;">
                    <Columns>
                        <PropertyColumn Property="x => x.IdArticle" Title="Code" />
                        <PropertyColumn Property="x => x.Description" Title="Description" />
                        <TemplateColumn Title="Stock" Sortable="true">
                            <CellTemplate>
                                @{
                                    var qte = (int)context.Item.Qte;
                                    var seuil = context.Item.Seuil;
                                    var couleur = qte <= 0 ? "#dc2626" : qte <= seuil ? "#f59e0b" : "#16a34a";
                                }
                                <span style="font-weight:600;color:@couleur;">
                                    @if (qte <= 0)
                                    {
                                        <i class="bi bi-exclamation-circle me-1"></i>
                                    }
                                    else if (qte <= seuil)
                                    {
                                        <i class="bi bi-exclamation-triangle me-1"></i>
                                    }
                                    @qte
                                </span>
                            </CellTemplate>
                        </TemplateColumn>
                        <PropertyColumn Property="x => x.Seuil" Title="Seuil" />
                        <PropertyColumn Property="x => x.Price" Title="Prix" Format="N0" />
                        <TemplateColumn Title="État">
                            <CellTemplate>
                                @{
                                    var qte = (int)context.Item.Qte;
                                    var seuil = context.Item.Seuil;
                                }
                                @if (qte <= 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Rupture</MudChip>
                                }
                                else if (qte <= seuil)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Stock bas</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">OK</MudChip>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="StockArticleDto" />
                    </PagerContent>
                </MudDataGrid>
            </div>
        }
        else
        {
            <!-- Tab Utilisateurs -->
            <div class="card-body">
                @if (_users.Any())
                {
                    <MudDataGrid T="User" Items="@_users" Dense="true" Hover="true" Striped="true">
                        <Columns>
                            <PropertyColumn Property="x => x.Login" Title="Login" />
                            <PropertyColumn Property="x => x.Name" Title="Nom" />
                            <PropertyColumn Property="x => x.Email" Title="Email" />
                            <TemplateColumn Title="Rôle">
                                <CellTemplate>
                                    @(context.Item.Role?.DescriptionRole ?? "-")
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Statut">
                                <CellTemplate>
                                    @if (context.Item.Activated == true)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Actif</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">Inactif</MudChip>
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <PagerContent>
                            <MudDataGridPager T="User" />
                        </PagerContent>
                    </MudDataGrid>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Aucun utilisateur assigné à cette localisation</MudAlert>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private bool _loading = true;
    private int _tab;
    private Localisation? _localisation;
    private List<User> _users = new();
    private List<StockArticleDto> _stockArticles = new();
    private string _articleSearch = "";

    private IEnumerable<StockArticleDto> FilteredArticles => string.IsNullOrWhiteSpace(_articleSearch)
        ? _stockArticles
        : _stockArticles.Where(a =>
            (a.IdArticle?.Contains(_articleSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (a.Description?.Contains(_articleSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        _localisation = await LocalisationService.GetLocalisationByIdAsync(Id);

        if (_localisation != null)
        {
            _users = await UserAdminService.GetUsersByLocalisationAsync(Id);
            _stockArticles = await StockService.GetStockArticleViewAsync(Id);
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedTab = await JS.InvokeAsync<int>("tabNavigation.getTab", $"localisation-{Id}", 0);
                if (savedTab != _tab)
                {
                    _tab = savedTab;
                    StateHasChanged();
                }
            }
            catch { }
        }
    }

    async Task OnTabChange(int tabIndex)
    {
        _tab = tabIndex;
        try
        {
            await JS.InvokeVoidAsync("tabNavigation.saveTab", $"localisation-{Id}", tabIndex);
        }
        catch { }
    }

    private async Task OnArticleRowClick(DataGridRowClickEventArgs<StockArticleDto> args)
    {
        var dto = args.Item;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var article = await ctx.Articles.FirstOrDefaultAsync(a => a.IdArticle == dto.IdArticle);
        if (article == null) return;

        var localisations = await ctx.Localisations.OrderBy(l => l.DescriptionLocalisation).ToListAsync();
        var locDict = localisations.ToDictionary(l => l.IdLocalisation, l => l.DescriptionLocalisation ?? "?");
        var stocks = (await ctx.Stocks
            .Where(s => s.IdArticle == dto.IdArticle)
            .ToListAsync())
            .Select(s => new StockLocationInfo
            {
                StockId = s.Id,
                IdLocalisation = s.IdLocalisation,
                LocalisationName = locDict.GetValueOrDefault(s.IdLocalisation, "?"),
                Qte = (int)s.Qte,
                Seuil = s.Seuil
            })
            .OrderBy(s => s.LocalisationName)
            .ToList();

        var parameters = new DialogParameters
        {
            { "Article", article },
            { "Stocks", stocks },
            { "Localisations", localisations }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ArticleDetailDialog>(article.Description ?? article.IdArticle, parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled) await LoadData();
    }

    private void OnAppro(StockArticleDto article)
    {
        Navigation.NavigateTo($"/stock/appro/nouveau?PreselectedArticleId={article.IdArticle}&PreselectedLocalisationId={Id}");
    }

    private void OnAddArticle()
    {
        Navigation.NavigateTo($"/gestion/article/nouveau?localisationId={Id}");
    }

    private void OnEditArticle(StockArticleDto article)
    {
        Navigation.NavigateTo($"/gestion/article/modifier/{article.IdArticle}");
    }
}
