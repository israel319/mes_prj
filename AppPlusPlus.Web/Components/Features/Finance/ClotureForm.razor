@using AppPlusPlus.Application.DTOs.Finance
@inject IClotureService ClotureService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <div class="d-flex justify-content-center py-4">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                <div class="alert alert-info mb-0">
                    <strong>@LocalisationName</strong> — Journée du @_dateCloture.ToString("dd/MM/yyyy")
                </div>

                <!-- Récapitulatif -->
                <div class="row g-2">
                    <div class="col-4">
                        <div class="card">
                            <div class="card-body text-center py-2">
                                <small class="text-muted">Factures payées</small>
                                <h6 class="fw-bold mb-0">@_nbFactures</h6>
                                <small style="color:#00B193;">@_totalFactures.ToString("N2")</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card">
                            <div class="card-body text-center py-2">
                                <small class="text-muted">Paiements</small>
                                <h6 class="fw-bold mb-0">@_nbPaiements</h6>
                                <small style="color:#00B193;">@_totalPaiements.ToString("N2")</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card" style="border-color:#00B193 !important;">
                            <div class="card-body text-center py-2">
                                <small class="text-muted fw-bold">TOTAL</small>
                                <h5 class="fw-bold mb-0" style="color:#00B193;">@_montantTotal.ToString("N2")</h5>
                            </div>
                        </div>
                    </div>
                </div>

                @if (_dejaCloture)
                {
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Une clôture existe déjà pour cette date et localisation.
                    </div>
                }

                @if (_montantTotal == 0)
                {
                    <div class="alert alert-secondary mb-0">
                        Aucune opération trouvée pour cette journée.
                    </div>
                }

                <div>
                    <label class="form-label">Destination des fonds *</label>
                    <MudSelect T="string" @bind-Value="_modeVersement" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        @foreach (var m in _modes)
                        {
                            <MudSelectItem T="string" Value="@m">@m</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <div>
                    <label class="form-label">Observation (optionnel)</label>
                    <textarea class="form-control" @bind="_observation" rows="2"></textarea>
                </div>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">Annuler</button>
        <button type="button" class="btn btn-primary" @onclick="@OnCloture"
                disabled="@(_loading || _dejaCloture || _montantTotal == 0 || string.IsNullOrEmpty(_modeVersement))">
            <i class="bi bi-check-circle me-1"></i>Clôturer la journée
        </button>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int LocalisationId { get; set; }
    [Parameter] public string LocalisationName { get; set; } = "";
    [Parameter] public string UserLogin { get; set; } = "";

    bool _loading = true;
    bool _dejaCloture;

    int _nbFactures;
    decimal _totalFactures;
    int _nbPaiements;
    decimal _totalPaiements;
    decimal _montantTotal;
    int _totalOperations;

    DateOnly _dateCloture = DateOnly.FromDateTime(DateTime.Today);
    string _modeVersement = "Caisse";
    string? _observation;
    List<string> _modes = new() { "Caisse", "Banque", "Mobile Money", "Chèque", "Autre" };

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        var summary = await ClotureService.GetClotureSummaryAsync(_dateCloture, LocalisationId);
        _dejaCloture = summary.DejaClotureExiste;
        _nbFactures = summary.NbFactures;
        _totalFactures = summary.TotalFactures;
        _nbPaiements = summary.NbPaiements;
        _totalPaiements = summary.TotalPaiements;

        // Total = on prend le montant des paiements (plus précis car inclut les partiels)
        _montantTotal = _totalPaiements > 0 ? _totalPaiements : _totalFactures;
        _totalOperations = _nbFactures + _nbPaiements;

        _loading = false;
    }

    void Cancel() => MudDialog.Close();

    async Task OnCloture()
    {
        if (_montantTotal == 0 || _dejaCloture || string.IsNullOrEmpty(_modeVersement)) return;

        try
        {
            var existe = await ClotureService.ClotureExistsAsync(_dateCloture, LocalisationId);

            if (existe)
            {
                Snackbar.Add("Cette clôture existe déjà.", Severity.Warning);
                return;
            }

            var versement = new Versement
            {
                DateCloture = _dateCloture,
                HeureCloture = DateTime.Now,
                LocalisationId = LocalisationId,
                TypeOperation = "Journalière",
                Montant = _montantTotal,
                ModeVersement = _modeVersement,
                NombreOperations = _totalOperations,
                Observation = _observation,
                UserLogin = UserLogin,
                DateSys = DateTime.Now
            };

            await ClotureService.CreateClotureAsync(versement);

            Snackbar.Add($"Clôture enregistrée — {_montantTotal:N2} vers {_modeVersement}", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }
}
