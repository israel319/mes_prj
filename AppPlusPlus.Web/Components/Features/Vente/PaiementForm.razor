@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IPaymentService PaymentService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <div class="lov-form-header">
            <h5>Paiement</h5>
            <div class="d-flex" style="gap:0.5rem;">
                <button type="button" class="btn btn-primary btn-sm" @onclick="@OnPay" disabled="@(_montant <= 0)">
                    <i class="bi bi-credit-card me-1"></i>@(_montant >= MontantRest ? "Payer le solde" : "Paiement partiel")
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Cancel">
                    <i class="bi bi-arrow-left me-1"></i>Annuler
                </button>
            </div>
        </div>
        <div class="lov-form-body">
            <div class="alert alert-info">
                Montant restant à payer : <strong>@MontantRest.ToString("N2")</strong>
            </div>

            <div class="lov-field">
                <label class="form-label">Montant du paiement</label>
                <MudNumericField @bind-Value="_montant" T="decimal" Min="0.01m" Max="@MontantRest"
                                 Format="N2" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="0.00" />
            </div>

            <div class="lov-field">
                <label class="form-label">Mode de paiement</label>
                <MudSelect T="string" @bind-Value="_mode" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                    @foreach (var m in _modes)
                    {
                        <MudSelectItem T="string" Value="@m">@m</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div class="lov-field">
                <label class="form-label">Note (optionnel)</label>
                <textarea class="form-control" @bind="_note" rows="2" placeholder="Référence, mode…"></textarea>
            </div>
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int CommandeId { get; set; }
    [Parameter] public int FactId { get; set; }
    [Parameter] public decimal MontantRest { get; set; }

    decimal _montant;
    string _mode = "Espèces";
    string? _note;
    string _currentLogin = "";
    List<string> _modes = new() { "Espèces", "Virement", "Mobile Money", "Chèque", "Autre" };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        _montant = MontantRest; // Par défaut, paiement total
    }

    void Cancel() => MudDialog.Close();

    async Task OnPay()
    {
        if (_montant <= 0 || _montant > MontantRest) return;

        try
        {
            var note = $"{_mode}" + (string.IsNullOrWhiteSpace(_note) ? "" : $" — {_note}");
            var result = await PaymentService.RecordPaymentAsync(FactId, CommandeId, _montant, _mode, note, _currentLogin);

            if (!result.Success)
            {
                Snackbar.Add(result.Message, Severity.Error);
                return;
            }

            Snackbar.Add($"{_montant:N2} — {_mode}", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }
}
