    async Task LoadClotures()
    {
        _clotureLoading = true;
        _clotureData = await ClotureService.GetCloturesByLocalisationsAsync(_currentUserLocalisations);
        _clotureLoading = false;
        ApplyClotureFilter();
    }

    void ApplyClotureFilter()
    {
        _clotureFiltered = _clotureData.Where(v =>
        {
            if (_clotureLocFilter.HasValue && v.LocalisationId != _clotureLocFilter.Value)
                return false;
            return true;
        }).ToList();
    }

    async Task OnCloturer()
    {
        if (!_canFacturationWrite) return;
        if (!_userLocalisations.Any())
        {
            Snackbar.Add("Aucune localisation assignée.", Severity.Warning);
            return;
        }

        // Sélectionner la localisation (si une seule, directement)
        int selectedLocId;
        string selectedLocName;

        if (_userLocalisations.Count == 1)
        {
            selectedLocId = _userLocalisations[0].IdLocalisation;
            selectedLocName = _userLocalisations[0].DescriptionLocalisation ?? "—";
        }
        else
        {
            // TODO: pour multi-localisation, utiliser la première pour l'instant
            // On pourrait ajouter un sélecteur ici
            selectedLocId = _userLocalisations[0].IdLocalisation;
            selectedLocName = _userLocalisations[0].DescriptionLocalisation ?? "—";
        }

        // Confirmation
        var confirm = await DialogService.ShowMessageBox(
            "Clôture journalière",
            $"Clôturer la journée du {DateOnly.FromDateTime(DateTime.Today):dd/MM/yyyy} pour {selectedLocName} ?",
            yesText: "Continuer",
            cancelText: "Annuler");

        if (confirm != true) return;

        // Ouvrir le dialog de clôture
        var parameters = new DialogParameters<ClotureForm>
        {
            { x => x.LocalisationId, selectedLocId },
            { x => x.LocalisationName, selectedLocName },
            { x => x.UserLogin, _login }
        };
        var options = new MudBlazor.DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ClotureForm>(
            $"Clôture — {selectedLocName}", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadClotures();
            await LoadFactures();
        }
    }
