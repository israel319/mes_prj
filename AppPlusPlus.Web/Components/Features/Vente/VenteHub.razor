    async Task OnPayerLivraison(Livraison liv)
    {
        if (!_canLivraisonWrite)
        {
            Snackbar.Add("Paiement livraison non autorisé.", Severity.Warning);
            return;
        }

        var montant = liv.Details.Sum(d => d.MontantPaye ?? 0);
        var confirm = await DialogService.ShowMessageBox(
            "Paiement de la livraison",
            $"Payer la livraison N° {liv.LivraisonId} ?\n" +
            $"Client : {liv.Customer?.CustomerName ?? "—"}\n" +
            $"Montant : {montant:N2}\n\n" +
            "Une facture sera automatiquement générée.",
            yesText: "Payer & Facturer",
            cancelText: "Annuler");

        if (confirm != true) return;

        var result = await LivraisonService.PayerLivraisonAsync(liv.LivraisonId, _login);
        if (result.Success)
        {
            Snackbar.Add(result.Message, Severity.Success);
            await LoadLivraisons();
        }
        else
        {
            Snackbar.Add(result.Message, Severity.Error);
        }
    }

    async Task OnDeleteLivraison(Livraison item)
    {
        if (!_canLivraisonDelete)
        {
            Snackbar.Add("Suppression livraison non autorisée.", Severity.Warning);
            return;
        }

        var confirm = await DialogService.ShowMessageBox(
            "Confirmation",
            $"Supprimer la livraison N° {item.LivraisonId} ?",
            yesText: "Supprimer",
            cancelText: "Annuler");
        if (confirm == true)
        {
            await LivraisonService.DeleteLivraisonAsync(item.LivraisonId);
            Snackbar.Add("Livraison supprimée", Severity.Success);
            await LoadLivraisons();
        }
    }

