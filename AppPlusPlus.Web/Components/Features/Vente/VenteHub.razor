    async Task OnMarquerLivree(Livraison item)
    {
        if (!_canLivraisonWrite)
        {
            Snackbar.Add("Action non autorisée.", Severity.Warning);
            return;
        }

        await LivraisonService.MarkLivraisonDeliveredAsync(item.LivraisonId);
        await LoadLivraisons();
