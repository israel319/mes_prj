@page "/vente/facturation"
@page "/vente/facturation/{IdFacture:int}"
@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject MudBlazor.IDialogService Dialog
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject INumberToWordsConverter NumberToWords
@inject IClotureService ClotureService
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<PageTitle>Facturation</PageTitle>

<div class="fact-shell">
    <!-- ═══ Header ═══ -->
    <div class="fact-header">
        <div class="fact-header-left">
            <button class="fact-back-btn" @onclick="@(() => Navigation.NavigateTo("/vente"))">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" />
            </button>
            <div class="fact-header-brand">
                <div class="fact-header-icon">
                    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" />
                </div>
                <div>
                    <p class="fact-header-label">@(_isEdit ? "Modifier" : "Nouvelle")</p>
                    <p class="fact-header-title">Facture @(_isEdit ? $"N°{_facture.Id}" : "")</p>
                </div>
            </div>
        </div>
        <div class="fact-header-right">
            @if (_isEdit)
            {
                <span class="fact-badge-mono">FAC-@_facture.Id</span>
            }
            <span class="fact-badge-draft">
                @(DateTime.Today.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("fr-FR")))
            </span>
        </div>
    </div>

    <!-- ═══ Two-column body ═══ -->
    <div class="fact-body">

        <!-- ── LEFT : Articles ── -->
        <div class="fact-left">

            <!-- Client bar -->
            <div class="fact-client-bar">
                @if (!string.IsNullOrEmpty(_facture.DescriptionName))
                {
                    <div class="fact-client-pill">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:15px;" />
                        <span class="fact-client-pill-name">@_facture.DescriptionName</span>
                        @if (!string.IsNullOrEmpty(_facture.Telephone))
                        {
                            <span class="fact-client-pill-phone">@_facture.Telephone</span>
                        }
                        <button class="fact-client-pill-x" @onclick="RetirerClient">
                            <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:14px;" />
                        </button>
                    </div>
                }
                else
                {
                    <div class="fact-client-search">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="font-size:16px;color:var(--rz-text-tertiary-color,#9ca3af);flex-shrink:0;" />
                        <MudAutocomplete T="Customer" Value="_selectedCustomer"
                                         ValueChanged="@OnClientSelected"
                                         SearchFunc="@SearchCustomers"
                                         ToStringFunc="@(c => c?.Contact ?? "")"
                                         Placeholder="Rechercher un client…"
                                         Style="flex:1;border:none;background:transparent;"
                                         CoerceText="true" CoerceValue="true">
                            <ItemTemplate>
                                <div style="display:flex;align-items:center;gap:6px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Phone" Style="font-size:14px;opacity:.5;" />
                                    <strong>@context.Contact</strong>
                                    <span style="opacity:.5;font-size:12px;">— @context.CustomerName</span>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                        <button class="btn btn-primary btn-sm" style="flex-shrink:0;" @onclick="OnAddCustomer" title="Nouveau client">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                }
            </div>

            <!-- Search bar -->
            <div class="fact-search-bar">
                <div class="fact-search-wrapper">
                    <div class="fact-search-icon-wrap">
                        <MudIcon Icon="@Icons.Material.Filled.Search" Style="font-size:18px;color:var(--rz-text-tertiary-color,#9ca3af);" />
                    </div>
                    <input type="text" @bind="_barcode" @bind:event="oninput" @bind:after="UpdateSearchResults"
                           @onkeydown="OnSearchKeyDown" @onfocusout="OnSearchBlur"
                           @ref="_barcodeInputRef" autocomplete="off"
                           placeholder="Rechercher un produit…"
                           class="fact-search-input" />
                    @if (_searchOpen)
                    {
                        <div class="fact-suggestions">
                            @foreach (var p in _searchResults)
                            {
                                var product = p;
                                <button class="fact-suggestion-item" @onmousedown="@(async () => await SelectProduct(product))">
                                    <div class="fact-suggestion-left">
                                        <div class="fact-suggestion-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" />
                                        </div>
                                        <div>
                                            <div class="fact-suggestion-name">@p.Description</div>
                                            <div class="fact-suggestion-meta">@p.IdArticle · Stock: @((p.Qte ?? 0).ToString("N0"))</div>
                                        </div>
                                    </div>
                                    <span class="fact-suggestion-price">@MontantAfficheDouble((double)p.Price).ToString("N0") @DeviseLabel</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Articles list -->
            <div class="fact-items-area">
                @if (!_details.Any())
                {
                    <div class="fact-empty">
                        <div class="fact-empty-circle">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" />
                        </div>
                        <p class="fact-empty-title">Aucun article ajouté</p>
                        <p class="fact-empty-hint">Recherchez ou scannez un produit pour commencer</p>
                    </div>
                }
                else
                {
                    <div class="fact-items-list">
                        @{ int rowIdx = 0; }
                        @foreach (var item in _details)
                        {
                            rowIdx++;
                            var current = item;
                            <div class="fact-item-card">
                                <div class="fact-item-main">
                                    <span class="fact-item-idx">@rowIdx</span>
                                    <div class="fact-item-info">
                                        <p class="fact-item-name">@item.Description</p>
                                        <p class="fact-item-meta">
                                            <span class="fact-code-chip">@item.IdArticle</span>
                                            <span>@MontantAfficheDouble(item.Pu).ToString("N2") @DeviseLabel / unité</span>
                                        </p>
                                    </div>
                                </div>
                                <div class="fact-item-actions">
                                    <div class="fact-qty">
                                        <button class="fact-qty-btn" disabled="@(item.Qte <= 1)"
                                                @onclick="@(async () => await ModifierQteAsync(current, -1))">
                                            <MudIcon Icon="@Icons.Material.Filled.Remove" />
                                        </button>
                                        <span class="fact-qty-val">@item.Qte.ToString("N0")</span>
                                        <button class="fact-qty-btn"
                                                @onclick="@(async () => await ModifierQteAsync(current, 1))">
                                            <MudIcon Icon="@Icons.Material.Filled.Add" />
                                        </button>
                                    </div>
                                    <span class="fact-item-total">@MontantAfficheDouble(item.Total).ToString("N2") @DeviseLabel</span>
                                    <button class="fact-del-btn" @onclick="@(() => Supprimer(current))">
                                        <MudIcon Icon="@Icons.Material.Filled.Delete" />
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- ── RIGHT : Sidebar ── -->
        <div class="fact-right">
            <!-- Config section -->
            <div class="fact-sb-section">
                <div class="fact-sb-two-cols">
                    <div>
                        <span class="fact-sb-label">Devise</span>
                        <MudSelect @bind-Value="_selectedMoneyId" T="int" Style="width:100%;">
                            @foreach (var m in _monnaies)
                            {
                                <MudSelectItem T="int" Value="m.IdMonais">@m.DescriptionMonais</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    <div>
                        <span class="fact-sb-label">Paiement</span>
                        <MudSelect @bind-Value="_modePaiement" T="string" Style="width:100%;">
                            @foreach (var mode in _modesPaiement)
                            {
                                <MudSelectItem T="string" Value="mode">@mode</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                </div>
            </div>

            <!-- Reduction -->
            <div class="fact-sb-section">
                <span class="fact-sb-label">Réduction</span>
                <div style="display:flex;flex-direction:column;gap:8px;">
                    <MudSelect Value="_selectedReductionId" ValueChanged="@OnReductionDropdownChanged" T="int?"
                               Clearable="true" Placeholder="Choisir…" Style="width:100%;">
                        @foreach (var r in _reductions)
                        {
                            <MudSelectItem T="int?" Value="@((int?)r.Key)">@r.Value</MudSelectItem>
                        }
                    </MudSelect>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <MudNumericField Value="_facture.Reduction" T="decimal?" Min="0" Max="100" Placeholder="0" Style="flex:1;"
                                         ValueChanged="@((decimal? v) => { _facture.Reduction = v; _selectedReductionId = null; Recalculer(); })" />
                        <span class="fact-pct-badge">%</span>
                    </div>
                </div>
            </div>

            <!-- Totals -->
            <div class="fact-sb-section fact-sb-totals">
                <div class="fact-sb-row">
                    <span>Articles</span>
                    <span style="font-weight:500;">@_details.Count</span>
                </div>
                <div class="fact-sb-row">
                    <span>Sous-total</span>
                    <span style="font-weight:500;">@(MontantAffiche(_facture.Total ?? 0).ToString("N2")) @DeviseLabel</span>
                </div>
                @if ((_facture.Reduction ?? 0) > 0)
                {
                    <div class="fact-sb-row">
                        <span>Réduction (@((_facture.Reduction ?? 0).ToString("0.##"))%)</span>
                        <span style="font-weight:500;color:#dc2626;">-@MontantAffiche(ReductionMontant).ToString("N2") @DeviseLabel</span>
                    </div>
                }
                <div class="fact-sb-divider"></div>
                <div class="fact-sb-row fact-sb-net">
                    <span>Net à payer</span>
                    <span class="fact-net-amount">@(MontantAffiche(_facture.TotalApresReduction ?? 0).ToString("N2")) @DeviseLabel</span>
                </div>
                <div class="fact-amount-words">
                    @NumberToWords.Convert(
                        MontantAffiche(_facture.TotalApresReduction ?? 0),
                        IsUsd ? "dollars" : "francs",
                        IsUsd ? "cents" : "centimes")
                </div>
                @if (!IsUsd && _facture.Taux > 0)
                {
                    <div class="fact-amount-equiv">
                        Équiv. USD (taux @_facture.Taux.ToString("N0")) : <strong>@(Math.Round((_facture.TotalApresReduction ?? 0) / _facture.Taux, 2).ToString("N2")) $</strong>
                    </div>
                }
                @if (IsUsd && _facture.Taux > 0)
                {
                    <div class="fact-amount-equiv">
                        Équiv. FC (taux @_facture.Taux.ToString("N0")) : <strong>@((_facture.TotalApresReduction ?? 0).ToString("N2")) FC</strong>
                    </div>
                }
            </div>

            <!-- Actions pinned to bottom -->
            <div class="fact-sb-actions">
                <button type="button" class="btn btn-primary" style="width:100%;height:44px;font-weight:600;justify-content:center;"
                        @onclick="@ImprimerFacture" disabled="@(_saving || !_details.Any())">
                    <i class="bi bi-receipt me-1"></i>Valider la facture
                </button>
                <button type="button" class="btn btn-outline-secondary" style="width:100%;justify-content:center;"
                        @onclick="@Brouillon" disabled="@_saving">
                    <i class="bi bi-floppy me-1"></i>Brouillon
                </button>
                <button type="button" class="btn btn-secondary" style="width:100%;justify-content:center;"
                        @onclick="@Annuler">
                    <i class="bi bi-x-lg me-1"></i>Annuler
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? IdFacture { get; set; }

    bool _isEdit => IdFacture.HasValue;

    // ── En-tête facture (T_Facts) ──
    Fact _facture = new()
    {
        DescriptionName = "",
        Date = DateOnly.FromDateTime(DateTime.Today),
        Taux = 2800,
        Reduction = 0,
        Status = 0,
        Type = 0,
        DateSys = DateTime.Now,
        User = "",
        Cumputer = Environment.MachineName,
    };
    DateTime? _dateValue = DateTime.Today;
    int? _selectedLocalisation;
    bool _saving = false;
    bool _scannerProcessing = false;

    // ── Auth / Localisation filtering ──
    string _currentLogin = "";
    bool _isAdmin;
    List<int> _currentUserLocalisations = new();

    // ── Suggestions produits (recherche temps réel) ──
    bool _searchOpen;
    IEnumerable<Article> _searchResults = Enumerable.Empty<Article>();

    // ── Client (recherche par numéro) ──
    List<Customer> _allCustomers = new();
    Customer? _selectedCustomer;
    int? _selectedCustomerId;

    string _barcode = "";
    string _modePaiement = "Cash";
    List<string> _modesPaiement = new() { "Cash", "Carte", "Mobile Money", "Virement" };

    // ── Devise (T_Moneys) ──
    List<Money> _monnaies = new();
    int _selectedMoneyId = 2; // défaut CDF
    bool IsUsd => _monnaies.FirstOrDefault(m => m.IdMonais == _selectedMoneyId)?.DescriptionMonais == "USD";
    string DeviseLabel => IsUsd ? "$" : "FC";
    /// <summary>Convertit un montant FC en montant affiché selon la devise sélectionnée.</summary>
    decimal MontantAffiche(decimal montantFC) =>
        IsUsd && _facture.Taux > 0
            ? Math.Round(montantFC / _facture.Taux, 2)
            : montantFC;
    double MontantAfficheDouble(double montantFC) =>
        IsUsd && _facture.Taux > 0
            ? Math.Round(montantFC / (double)_facture.Taux, 2)
            : montantFC;

    List<KeyValuePair<int, string>> _types = new()
    {
        new(0, "Facture"),
        new(1, "Proforma"),
    };

    // ── Données chargées depuis la BD ──
    List<Localisation> _localisations = new();
    List<Article> _catalogue = new();
    List<KeyValuePair<int, string>> _reductions = new();
    int? _selectedReductionId;

    // ── Lignes de détail (T_Fact_Details) ──
    List<FactDetailLine> _details = new();
    ElementReference _barcodeInputRef;

    decimal ReductionMontant => (_facture.Total ?? 0) * (_facture.Reduction ?? 0) / 100m;

    void OnReductionDropdownChanged(int? val)
    {
        _selectedReductionId = val;
        if (_selectedReductionId.HasValue)
        {
            var item = _reductions.FirstOrDefault(r => r.Key == _selectedReductionId.Value);
            // Parse the numeric value from the description like "10%"
            var valeur = _reductionValues.GetValueOrDefault(_selectedReductionId.Value, 0);
            _facture.Reduction = valeur;
        }
        else
        {
            _facture.Reduction = 0;
        }
        Recalculer();
    }
    Dictionary<int, int> _reductionValues = new();

    async Task<IEnumerable<Customer>> SearchCustomers(string filter, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(filter))
            return Enumerable.Empty<Customer>();

        await using var ctx = await DbFactory.CreateDbContextAsync();
        return await ctx.Customers
            .Where(c => c.Contact != null && c.Contact.Contains(filter))
            .OrderBy(c => c.Contact)
            .Take(20)
            .ToListAsync(ct);
    }

    void OnClientSelected(Customer? customer)
    {
        _selectedCustomer = customer;
        if (customer != null)
        {
            _selectedCustomerId = customer.CustomerId;
            _facture.DescriptionName = customer.CustomerName ?? "";
            _facture.Telephone = customer.Contact;
            _facture.Email = customer.Email;
            _facture.Adresse = customer.Adress;
        }
        else
        {
            _selectedCustomerId = null;
            _facture.DescriptionName = "";
            _facture.Telephone = null;
            _facture.Email = null;
            _facture.Adresse = null;
        }
    }

    // ── Recherche produit temps réel ──
    void UpdateSearchResults()
    {
        if (string.IsNullOrWhiteSpace(_barcode) || _barcode.Length < 2)
        {
            _searchOpen = false;
            _searchResults = Enumerable.Empty<Article>();
            return;
        }
        _searchResults = _catalogue
            .Where(a => a.IdArticle.Contains(_barcode, StringComparison.OrdinalIgnoreCase) ||
                        a.Description.Contains(_barcode, StringComparison.OrdinalIgnoreCase))
            .Take(8);
        _searchOpen = _searchResults.Any();
    }

    async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _searchOpen = false; await OnScanner(); }
        else if (e.Key == "Escape") _searchOpen = false;
    }

    async Task OnSearchBlur()
    {
        if (_saving || _scannerProcessing) return;

        // Petit délai pour laisser le mousedown d'une suggestion se déclencher d'abord
        await Task.Delay(200);

        if (_saving || _scannerProcessing) return;

        _searchOpen = false;
        if (!string.IsNullOrWhiteSpace(_barcode))
            await OnScanner();
        StateHasChanged();
    }

    async Task SelectProduct(Article product)
    {
        _barcode = product.IdArticle;
        _searchOpen = false;
        await OnScanner();
    }

    void RetirerClient()
    {
        _selectedCustomerId = null;
        _selectedCustomer = null;
        _facture.DescriptionName = "";
        _facture.Telephone = null;
        _facture.Email = null;
        _facture.Adresse = null;
    }

    void OnAddCustomer()
    {
        Navigation.NavigateTo("/commandes/client/nouveau?returnUrl=/vente/facturation");
    }

    protected override async Task OnInitializedAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();

        // ── Résoudre l'utilisateur connecté ──
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _currentLogin = user.FindFirst("login")?.Value
                ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
            _isAdmin = AppFunctions.Normalize(user.FindFirst(ClaimTypes.Role)?.Value) == "administrateur";

            if (!_isAdmin && !string.IsNullOrEmpty(_currentLogin))
            {
                _currentUserLocalisations = await ctx.UserLocalisations
                    .Where(ul => ul.UserId != null
                        && ul.UserId.ToLower() == _currentLogin.ToLower()
                        && ul.Activate == true
                        && ul.LocalisationId.HasValue)
                    .Select(ul => ul.LocalisationId!.Value)
                    .ToListAsync();
            }
        }

        _facture.User = _currentLogin;

        // Les clients sont chargés dynamiquement via SearchCustomers (recherche par numéro)
        _allCustomers = await ctx.Customers.ToListAsync();

        // Charger l'ID du client anonyme (IsPermanent = false, ou « Client Anonyme »)
        var anon = _allCustomers.FirstOrDefault(c => c.IsPermanent == false)
                ?? _allCustomers.FirstOrDefault(c => c.CustomerName == "Client Anonyme");
        _anonymousCustomerId = anon?.CustomerId ?? 0;

        // Charger les localisations (filtrées pour non-admin)
        if (_isAdmin || !_currentUserLocalisations.Any())
        {
            _localisations = await ctx.Localisations.OrderBy(l => l.DescriptionLocalisation).ToListAsync();
        }
        else
        {
            _localisations = await ctx.Localisations
                .Where(l => _currentUserLocalisations.Contains(l.IdLocalisation))
                .OrderBy(l => l.DescriptionLocalisation)
                .ToListAsync();
        }

        // Pré-sélectionner la première localisation par défaut
        if (_localisations.Any())
        {
            _selectedLocalisation = _localisations[0].IdLocalisation;
        }

        // Charger les monnaies (devises)
        _monnaies = await ctx.Moneys.OrderBy(m => m.IdMonais).ToListAsync();

        // Charger le catalogue d'articles (filtré par localisation pour non-admin)
        if (_isAdmin || !_currentUserLocalisations.Any())
        {
            _catalogue = await ctx.Articles.OrderBy(a => a.Description).ToListAsync();
        }
        else
        {
            var articleIdsWithStock = await ctx.Stocks
                .Where(s => _currentUserLocalisations.Contains(s.IdLocalisation))
                .Select(s => s.IdArticle)
                .Distinct()
                .ToListAsync();

            _catalogue = await ctx.Articles
                .Where(a => articleIdsWithStock.Contains(a.IdArticle))
                .OrderBy(a => a.Description)
                .ToListAsync();
        }

        // Charger les réductions prédéfinies
        var reductionList = await ctx.Reductions.OrderBy(r => r.Valeur).ToListAsync();
        _reductions = reductionList.Select(r => new KeyValuePair<int, string>(r.IdReduction, $"{r.DescriptionReduction} ({r.Valeur}%)")).ToList();
        _reductionValues = reductionList.ToDictionary(r => r.IdReduction, r => r.Valeur ?? 0);

        // Charger le taux du jour (le plus récent)
        var taux = await ctx.TauxChanges.OrderByDescending(t => t.Id).FirstOrDefaultAsync();
        if (taux != null)
            _facture.Taux = taux.TauxValue;

        // ── Mode édition : charger la facture existante ──
        if (IdFacture.HasValue)
        {
            var existing = await ctx.Facts
                .Include(f => f.Details)
                .FirstOrDefaultAsync(f => f.Id == IdFacture.Value);

            if (existing != null && existing.Status == 0) // brouillon uniquement
            {
                _facture = existing;
                _dateValue = existing.Date.ToDateTime(TimeOnly.MinValue);
                _selectedMoneyId = existing.MoneyId ?? 2; // récupérer la devise sauvegardée
                _details = existing.Details.Select(d => new FactDetailLine
                {
                    IdArticle = d.IdArticle ?? "",
                    Description = _catalogue.FirstOrDefault(a => a.IdArticle == d.IdArticle)?.Description ?? d.IdArticle ?? "",
                    Pu = d.Pu ?? 0,
                    Qte = d.Qte ?? 0,
                    Localisationid = d.Localisationid,
                }).ToList();
            }
            else
            {
                Snackbar.Add("Seuls les brouillons peuvent être modifiés.", Severity.Warning);
                Navigation.NavigateTo("/vente");
                return;
            }
        }

        Recalculer();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FocusBarcodeInputAsync();
        }
    }

    async Task FocusBarcodeInputAsync()
    {
        try
        {
            await _barcodeInputRef.FocusAsync();
        }
        catch
        {
            // Ignore si le DOM n'est pas encore prêt
        }
    }

    void Recalculer()
    {
        _facture.Total = (decimal)_details.Sum(d => d.Pu * d.Qte);
        var reduction = (_facture.Reduction ?? 0) / 100m;
        _facture.TotalApresReduction = _facture.Total - (_facture.Total * reduction);
        _facture.TotalReduit = _facture.Total * reduction;

        // Forcer le rafraîchissement en créant une nouvelle référence de liste
        _details = _details.ToList();
    }

    async Task OnScanner()
    {
        if (_scannerProcessing) return;
        _scannerProcessing = true;

        try
        {
        if (string.IsNullOrWhiteSpace(_barcode)) return;
        var code = _barcode.Trim();

        // ── Résoudre l'article (catalogue local pour les infos, mais stock = BD) ──
        var article = _catalogue.FirstOrDefault(a => a.IdArticle == code)
                   ?? _catalogue.FirstOrDefault(a => a.Description.Contains(code, StringComparison.OrdinalIgnoreCase));

        // Si pas trouvé → chercher par code-barres dans T_Stock
        if (article == null)
        {
            await using var ctxLookup = await DbFactory.CreateDbContextAsync();
            var stock = await ctxLookup.Stocks
                .FirstOrDefaultAsync(s => s.CodeBar == code);
            if (stock != null)
                article = _catalogue.FirstOrDefault(a => a.IdArticle == stock.IdArticle);
        }

        if (article == null)
        {
            Snackbar.Add($"Code ou nom \"{code}\" non trouvé dans le catalogue.", Severity.Warning);
            _barcode = "";
            await FocusBarcodeInputAsync();
            return;
        }

        // ── Vérifier le stock DIRECTEMENT EN BD (pas le catalogue local) ──
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var artDb = await ctx.Articles.AsNoTracking()
            .FirstOrDefaultAsync(a => a.IdArticle == article.IdArticle);
        var stockBd = (double)(artDb?.Qte ?? 0);
        var dejaEnLigne = _details.Where(d => d.IdArticle == article.IdArticle).Sum(d => d.Qte);

        if (artDb?.CanInsertAfter0 != true && stockBd <= 0)
        {
            Snackbar.Add($"L'article « {article.Description} » est en rupture de stock (stock BD: {stockBd:N0}). Vente impossible.", Severity.Error);
            _barcode = "";
            await FocusBarcodeInputAsync();
            return;
        }

        if (artDb?.CanInsertAfter0 != true && dejaEnLigne + 1 > stockBd)
        {
            Snackbar.Add($"Stock réel de « {article.Description} » : {stockBd:N0}. Déjà en facture: {dejaEnLigne:N0}. Impossible d'ajouter.", Severity.Error);
            _barcode = "";
            await FocusBarcodeInputAsync();
            return;
        }

        if (stockBd > 0 && _selectedLocalisation.HasValue)
        {
            var stockRec = await ctx.Stocks.AsNoTracking()
                .FirstOrDefaultAsync(s => s.IdArticle == article.IdArticle && s.IdLocalisation == _selectedLocalisation.Value);
            if (stockRec != null && stockRec.Seuil > 0 && stockBd <= stockRec.Seuil)
            {
                Snackbar.Add($"L'article « {article.Description} » a un stock bas ({stockBd:N0} restant, seuil: {stockRec.Seuil}).", Severity.Warning);
            }
        }

        // ── Ajouter ou incrémenter ──
        var existant = _details.FirstOrDefault(d => d.IdArticle == article.IdArticle);
        if (existant != null)
        {
            existant.Qte++;
        }
        else
        {
            _details.Add(new FactDetailLine
            {
                IdArticle = article.IdArticle,
                Description = article.Description,
                Pu = article.Price,
                Qte = 1,
                StockDispo = stockBd,
                Localisationid = _selectedLocalisation,
            });
        }
        Recalculer();
        _barcode = "";
        await FocusBarcodeInputAsync();
        }
        finally
        {
            _scannerProcessing = false;
        }
    }

    async Task ModifierQteAsync(FactDetailLine ligne, int delta)
    {
        var nouvelleQte = Math.Max(1, ligne.Qte + delta);

        // Vérifier le stock DIRECTEMENT EN BD
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var artDb = await ctx.Articles.AsNoTracking()
            .FirstOrDefaultAsync(a => a.IdArticle == ligne.IdArticle);
        var stockBd = (double)(artDb?.Qte ?? 0);
        var autresLignes = _details.Where(d => d.IdArticle == ligne.IdArticle && d != ligne).Sum(d => d.Qte);

        if (artDb?.CanInsertAfter0 != true && nouvelleQte + autresLignes > stockBd)
        {
            Snackbar.Add($"Stock réel (BD) de « {ligne.Description} » : {stockBd:N0}. Déjà {autresLignes:N0} sur d'autres lignes.", Severity.Error);
            return;
        }
        ligne.Qte = nouvelleQte;
        ligne.StockDispo = stockBd; // Mettre à jour le stock affiché
        Recalculer();
    }

    void Supprimer(FactDetailLine ligne)
    {
        _details.Remove(ligne);
        Recalculer();
    }

    void Annuler()
    {
        Navigation.NavigateTo("/vente");
    }

    /// <summary>Enregistre la facture en brouillon (Status = 0) sans imprimer.</summary>
    async Task Brouillon()
    {
        await Enregistrer(status: 0, stayOnPage: false);
    }

    /// <summary>Enregistre la facture (Status = 1) puis lance l'impression directe et reste sur la page.</summary>
    async Task ImprimerFacture()
    {
        var id = await Enregistrer(status: 1, stayOnPage: true);
        if (id > 0)
        {
            // Imprimer via iframe cachée
            await JS.InvokeVoidAsync("printFacture", id);

            // Réinitialiser pour une nouvelle facture
            ResetFormForNewInvoice();
        }
    }

    void ResetFormForNewInvoice()
    {
        _facture = new Fact
        {
            DescriptionName = "",
            Date = DateOnly.FromDateTime(DateTime.Today),
            Taux = _facture.Taux, // Garder le taux actuel
            Reduction = 0,
            Status = 0,
            Type = 0,
            DateSys = DateTime.Now,
            User = _currentLogin,
            Cumputer = Environment.MachineName,
        };
        _details.Clear();
        _selectedCustomer = null;
        _selectedCustomerId = null;
        _selectedReductionId = null;
        _barcode = "";
        Recalculer();
        StateHasChanged();
    }

    /// <summary>ID du client anonyme en base (chargé au démarrage).</summary>
    int _anonymousCustomerId;

    /// <summary>Persiste la facture dans la BD et retourne l'Id créé/mis à jour (0 si échec).</summary>
    async Task<int> Enregistrer(int status, bool stayOnPage = false)
    {
        // S'assurer qu'un code-barres déjà saisi est traité avant l'enregistrement
        if (!_scannerProcessing && !string.IsNullOrWhiteSpace(_barcode))
        {
            _searchOpen = false;
            await OnScanner();
        }

        if (!_details.Any())
        {
            Snackbar.Add("Ajoutez au moins un article.", Severity.Warning);
            return 0;
        }

        _saving = true;
        try
        {
            _facture.Status = status;
            _facture.Date = DateOnly.FromDateTime(_dateValue ?? DateTime.Today);
            _facture.DateSys = DateTime.Now;

            // ── Devise et montant en lettres ──
            _facture.MoneyId = _selectedMoneyId;
            _facture.MontantEnLettres = NumberToWords.Convert(
                MontantAffiche(_facture.TotalApresReduction ?? _facture.Total ?? 0),
                IsUsd ? "dollars" : "francs",
                IsUsd ? "cents" : "centimes");

            // ── Client : connu ou anonyme ──
            if (_selectedCustomerId.HasValue)
            {
                _facture.CustomerId = _selectedCustomerId.Value;
            }
            else
            {
                _facture.CustomerId = _anonymousCustomerId;
                if (string.IsNullOrWhiteSpace(_facture.DescriptionName))
                    _facture.DescriptionName = "Client Anonyme";
            }

            // Construire la description articles pour T_Facts.Description_Article
            _facture.DescriptionArticle = string.Join(" | ",
                _details.Select(d => $"{d.Description} x{d.Qte}"));

            await using var ctx = await DbFactory.CreateDbContextAsync();

            // ── Vérification période active ──
            var periode = await ctx.Periodes.FirstOrDefaultAsync(p => p.Activated == true);
            if (periode == null || periode.FromDate == null || periode.ToDate == null)
            {
                Snackbar.Add("Aucune période active n'est définie. Veuillez créer une période avant d'effectuer cette opération.", Severity.Error);
                return 0;
            }
            var today = DateTime.Today;
            if (today < periode.FromDate.Value.Date || today > periode.ToDate.Value.Date)
            {
                Snackbar.Add("La date du jour n'est pas comprise dans la période active.", Severity.Error);
                return 0;
            }

            // ── Vérification clôture journalière ──
            var hasClosed = await ClotureService.HasUserClosedTodayAsync(_currentLogin, _currentUserLocalisations);
            if (hasClosed)
            {
                Snackbar.Add("Vous avez déjà clôturé la journée. Aucune transaction n'est possible.", Severity.Error);
                return 0;
            }

            // ══════ VÉRIFICATION CONCURRENTE DU STOCK DIRECTEMENT EN BD ══════
            // Utilise une transaction SERIALIZABLE + verrouillage (UPDLOCK, ROWLOCK)
            // pour garantir qu'aucune autre transaction ne modifie le stock entre la lecture et l'écriture.
            using var transaction = await ctx.Database.BeginTransactionAsync(System.Data.IsolationLevel.Serializable);
            try
            {
                if (status == 1) // Vérification stock uniquement pour les factures validées
                {
                    foreach (var d in _details)
                    {
                        // Lecture du stock avec verrouillage exclusif pour empêcher les lectures concurrentes
                        var artDb = await ctx.Articles
                            .FromSqlRaw("SELECT * FROM T_Arts WITH (UPDLOCK, ROWLOCK) WHERE Id_Article = {0}", d.IdArticle)
                            .FirstOrDefaultAsync();

                        if (artDb == null)
                        {
                            Snackbar.Add($"L'article « {d.Description} » n'existe plus dans la base de données.", Severity.Error);
                            await transaction.RollbackAsync();
                            return 0;
                        }

                        var stockBd = (double)(artDb.Qte ?? 0);
                        if (artDb.CanInsertAfter0 != true && d.Qte > stockBd)
                        {
                            Snackbar.Add($"Stock réel de « {d.Description} » : {stockBd:N0}. Demandé : {d.Qte:N0}. Un autre utilisateur a peut-être déjà vendu cet article.", Severity.Error);
                            await transaction.RollbackAsync();
                            return 0;
                        }
                    }
                }

            if (_isEdit)
            {
                // Nettoyer les propriétés de navigation peuplées par EF fixup
                // dans le DbContext initial pour éviter les conflits de tracking
                _facture.Customer = null;
                _facture.Commande = null;
                _facture.Livraison = null;
                _facture.Money = null;
                _facture.Payments = new List<Payment>();
                _facture.Details = new List<FactDetail>();

                // Mode édition : mettre à jour la facture existante
                ctx.Facts.Attach(_facture);
                ctx.Entry(_facture).State = EntityState.Modified;

                // Supprimer les anciens détails et recréer
                var oldDetails = await ctx.FactDetails.Where(d => d.IdFact == _facture.Id).ToListAsync();
                ctx.FactDetails.RemoveRange(oldDetails);

                foreach (var d in _details)
                {
                    ctx.FactDetails.Add(new FactDetail
                    {
                        IdFact = _facture.Id,
                        IdArticle = d.IdArticle,
                        Qte = d.Qte,
                        Pu = d.Pu,
                        Status = status >= 1 ? 1 : 0,
                        Localisationid = d.Localisationid ?? _selectedLocalisation,
                    });
                }
            }
            else
            {
                // Mode création
                _facture.Details = _details.Select(d => new FactDetail
                {
                    IdArticle = d.IdArticle,
                    Qte = d.Qte,
                    Pu = d.Pu,
                    Status = status >= 1 ? 1 : 0,
                    Localisationid = d.Localisationid ?? _selectedLocalisation,
                }).ToList();

                ctx.Facts.Add(_facture);
            }

            // ── Déduire le stock des articles vendus (uniquement si Status = 1 = facture validée) ──
            // Le stock a déjà été vérifié et verrouillé ci-dessus dans la transaction
            if (status == 1)
            {
                foreach (var d in _details)
                {
                    var art = await ctx.Articles
                        .FromSqlRaw("SELECT * FROM T_Arts WITH (UPDLOCK, ROWLOCK) WHERE Id_Article = {0}", d.IdArticle)
                        .FirstOrDefaultAsync();
                    if (art != null)
                    {
                        art.Qte = (art.Qte ?? 0) - (decimal)d.Qte;
                        if (art.Qte < 0) art.Qte = 0;
                        art.DateEditing = DateOnly.FromDateTime(DateTime.Today);
                    }
                }
            }

            await ctx.SaveChangesAsync();

            // ── Insertion automatique du paiement (uniquement facture validée) ──
            if (status == 1)
            {
                ctx.Payments.Add(new Payment
                {
                    IdFact  = _facture.Id,
                    Date    = _facture.Date,
                    Amount  = _facture.TotalApresReduction ?? _facture.Total ?? 0,
                    Note    = $"Paiement auto — {_modePaiement}",
                    DateSys = DateTime.Now,
                    User    = _facture.User
                });
                _facture.Status = 2; // Payée
                await ctx.SaveChangesAsync();
            }

            await transaction.CommitAsync();
            } // fin du bloc try transaction
            catch
            {
                await transaction.RollbackAsync();
                throw;
            }

            var label = status == 0 ? "Brouillon enregistré" : "Facture validée & payée";
            Snackbar.Add($"N°{_facture.Id} — Client: {_facture.DescriptionName} — Total: {_facture.TotalApresReduction:N2}", Severity.Success);

            if (!stayOnPage)
                Navigation.NavigateTo("/vente");
            return _facture.Id;
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Impossible d'enregistrer la facture : {msg}", Severity.Error);
            return 0;
        }
        finally
        {
            _saving = false;
        }
    }

    /// <summary>Ligne de détail affichée dans le DataGrid — correspond aux champs de T_Fact_Details.</summary>
    class FactDetailLine
    {
        public string IdArticle { get; set; } = "";
        public string Description { get; set; } = "";
        public double Pu { get; set; }
        public double Qte { get; set; } = 1;
        public double StockDispo { get; set; }
        public int? Localisationid { get; set; }
        public double Total => Pu * Qte;
    }
}
