@page "/vente/facture/print/{IdFacture:int}"
@page "/vente/facture/print/{IdFacture:int}/{AutoPrint:bool}"
@rendermode InteractiveServer
@inject IFacturationService FacturationService
@inject IJSRuntime JS
@inject IShopProfileService ShopProfileService
@inject INumberToWordsConverter NumberToWords
@inject NavigationManager Navigation

<PageTitle>Facture N°@IdFacture</PageTitle>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;height:60vh;">
        <p>Chargement...</p>
    </div>
}
else if (_facture == null)
{
    <div style="display:flex;justify-content:center;align-items:center;height:60vh;">
        <p style="color:red;font-size:1.2rem;">Facture N°@IdFacture introuvable.</p>
    </div>
}
else
{
    <!-- Boutons (masqués à l'impression) -->
    <div class="no-print btn-bar">
        <button class="btn-print" onclick="window.print()">
            <span class="btn-icon">&#128424;</span> Imprimer
        </button>
        <button class="btn-fermer" @onclick="Fermer">
            ✕ Fermer
        </button>
    </div>

    <div class="ticket-wrapper">
        <div class="ticket">

            <!-- ═══════ EN-TÊTE ═══════ -->
            <div class="ticket-header">
                <span>@_facture.DateSys.ToString("dd/MM/yyyy HH:mm")</span>
                <span class="ticket-label">Impression</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(_shopPhotoSrc))
            {
                <div class="ticket-logo">
                    <img src="@_shopPhotoSrc" alt="Logo" />
                </div>
            }

            <div class="ticket-shop">@_shopName</div>

            @if (!string.IsNullOrWhiteSpace(_shopAdresse1))
            {
                <div class="ticket-address">@_shopAdresse1</div>
            }
            @if (!string.IsNullOrWhiteSpace(_shopAdresse2))
            {
                <div class="ticket-address">@_shopAdresse2</div>
            }

            <div class="ticket-num">N° : @_facture.Id.ToString("D6")</div>

            <!-- ═══════ INFOS FACTURE ═══════ -->
            <div class="ticket-sep"></div>
            <div class="ticket-info">@_facture.DateSys.ToString("dd/MM/yyyy HH:mm:ss")</div>
            @if (!string.IsNullOrEmpty(_facture.DescriptionName))
            {
                <div class="ticket-info">Client : @_facture.DescriptionName</div>
            }
            <div class="ticket-info">Caissier : @_facture.User</div>
            <div class="ticket-sep"></div>

            <!-- ═══════ EN-TÊTE COLONNES ═══════ -->
            <table class="ticket-table">
                <thead>
                    <tr>
                        <th class="col-qty">Qté</th>
                        <th class="col-desc">Désignation</th>
                        <th class="col-pu">P.U.</th>
                        <th class="col-tot">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in _details)
                    {
                        var lineTotal = (d.Pu ?? 0) * (d.Qte ?? 0);
                        <tr>
                            <td class="col-qty">@((d.Qte ?? 0).ToString("N0"))</td>
                            <td class="col-desc">@(d.Article?.Description ?? d.IdArticle)</td>
                            <td class="col-pu">@(MontantPrint((decimal)(d.Pu ?? 0)).ToString("N2"))</td>
                            <td class="col-tot">@(MontantPrint((decimal)lineTotal).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- ═══════ TOTAL ═══════ -->
            <div class="ticket-sep-bold"></div>

            @if ((_facture.Reduction ?? 0) > 0)
            {
                var redMontant = (_facture.Total ?? 0) * (_facture.Reduction ?? 0) / 100m;
                <div class="ticket-total-line">
                    <span>Réduction (@((_facture.Reduction ?? 0))%)</span>
                    <span>- @(MontantPrint(redMontant).ToString("N2"))</span>
                </div>
            }

            <div class="ticket-grand-total">
                <span>Total @_deviseLabel :</span>
                <span>@(MontantPrint(_facture.TotalApresReduction ?? _facture.Total ?? 0).ToString("N2"))</span>
            </div>

            <div class="ticket-words">
                @(string.IsNullOrEmpty(_facture.MontantEnLettres)
                    ? NumberToWords.Convert(
                        MontantPrint(_facture.TotalApresReduction ?? _facture.Total ?? 0),
                        _isUsd ? "dollars" : "francs",
                        _isUsd ? "cents" : "centimes")
                    : _facture.MontantEnLettres)
            </div>

            @if (!_isUsd && _facture.Taux > 0)
            {
                var enUsd = Math.Round((_facture.TotalApresReduction ?? _facture.Total ?? 0) / _facture.Taux, 2);
                <div class="ticket-equiv">Équiv. USD : @enUsd.ToString("N2") $</div>
            }
            @if (_isUsd && _facture.Taux > 0)
            {
                <div class="ticket-equiv">Équiv. FC : @((_facture.TotalApresReduction ?? _facture.Total ?? 0).ToString("N2")) FC</div>
            }

            <!-- ═══════ PIED DE PAGE ═══════ -->
            <div class="ticket-sep"></div>
            <div class="ticket-footer">Merci d'avoir passé chez nous, à une prochaine !</div>

            <!-- Motif bas de ticket -->
            <div class="ticket-cut">✂ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─</div>
        </div>
    </div>
}

<style>
    /* ── Page / fond ── */
    .btn-bar {
        text-align: center;
        padding: 18px 0 8px;
    }

    .btn-print,
    .btn-fermer {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 600;
        border-radius: 6px;
        cursor: pointer;
        transition: all .15s ease;
        border: none;
    }

    .btn-print {
        background: #1976d2;
        color: #fff;
        box-shadow: 0 2px 6px rgba(25,118,210,.35);
    }

    .btn-print:hover {
        background: #1565c0;
        box-shadow: 0 4px 12px rgba(25,118,210,.45);
    }

    .btn-icon { font-size: 16px; }

    .btn-fermer {
        background: #e0e0e0;
        color: #333;
        margin-left: 10px;
    }

    .btn-fermer:hover {
        background: #bdbdbd;
    }

    /* ── Wrapper ticket : effet papier ── */
    .ticket-wrapper {
        display: flex;
        justify-content: center;
        padding: 12px 0 40px;
    }

    .ticket {
        width: 80mm;
        padding: 6mm 5mm 4mm;
        font-family: 'Courier New', Courier, monospace;
        font-size: 12px;
        color: #000;
        background: #fff;
        line-height: 1.45;
        border: 1px solid #ddd;
        border-radius: 2px;
        box-shadow: 0 4px 24px rgba(0,0,0,.12), 0 1px 4px rgba(0,0,0,.08);
    }

    /* ── En-tête ── */
    .ticket-header {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: #555;
        margin-bottom: 8px;
    }

    .ticket-label { font-style: italic; }

    .ticket-logo {
        text-align: center;
        margin-bottom: 4px;
    }

    .ticket-logo img {
        max-height: 40px;
        max-width: 50mm;
        object-fit: contain;
    }

    .ticket-shop {
        text-align: center;
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin: 4px 0 2px;
    }

    .ticket-address {
        text-align: center;
        font-size: 10.5px;
        color: #333;
        line-height: 1.3;
    }

    .ticket-num {
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        margin: 8px 0 4px;
        letter-spacing: 0.5px;
    }

    /* ── Séparateurs ── */
    .ticket-sep {
        border: none;
        border-top: 1px dashed #999;
        margin: 7px 0;
    }

    .ticket-sep-bold {
        border: none;
        border-top: 2.5px solid #000;
        margin: 8px 0 6px;
    }

    /* ── Infos facture ── */
    .ticket-info {
        font-size: 11px;
        margin: 2px 0;
        color: #222;
    }

    /* ── Tableau articles ── */
    .ticket-table {
        width: 100%;
        border-collapse: collapse;
        margin: 6px 0;
        font-size: 11px;
    }

    .ticket-table thead th {
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 3px 0 4px;
        border-bottom: 1px solid #999;
        color: #444;
    }

    .ticket-table tbody td {
        padding: 3px 0;
        vertical-align: top;
    }

    .ticket-table tbody tr:last-child td {
        padding-bottom: 4px;
    }

    .col-qty  { width: 28px; text-align: center; }
    .col-desc { text-align: left; padding-left: 4px !important; word-break: break-word; }
    .col-pu   { text-align: right; white-space: nowrap; padding-right: 6px !important; }
    .col-tot  { text-align: right; white-space: nowrap; font-weight: 600; }

    /* ── Totaux ── */
    .ticket-total-line {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        margin: 2px 0;
        color: #333;
    }

    .ticket-grand-total {
        display: flex;
        justify-content: space-between;
        font-size: 15px;
        font-weight: 900;
        margin: 6px 0 4px;
        letter-spacing: 0.3px;
    }

    .ticket-words {
        font-size: 10px;
        font-style: italic;
        text-align: center;
        margin: 4px 0;
        color: #333;
    }

    .ticket-equiv {
        font-size: 10px;
        text-align: center;
        margin: 2px 0;
        color: #444;
    }

    /* ── Pied de page ── */
    .ticket-footer {
        text-align: center;
        font-size: 10.5px;
        margin: 6px 0 2px;
        font-style: italic;
        color: #333;
    }

    .ticket-cut {
        text-align: center;
        font-size: 10px;
        color: #aaa;
        margin-top: 10px;
        letter-spacing: 1px;
    }

    /* ── Impression 80mm ── */
    @@media print {
        @@page {
            size: 80mm auto;
            margin: 0;
        }

        /* Masquer TOUT sauf le ticket */
        .no-print,
        .btn-bar,
        .ticket-cut { display: none !important; }

        /* Masquer tous les éléments MudBlazor / layout */
        .mud-layout { all: initial !important; display: block !important; }

        .mud-drawer,
        .mud-drawer-overlay,
        .mud-appbar,
        .mud-main-content > *:not(:last-child),
        .rz-header,
        .tb,
        .breadcrumb-bar,
        nav:not(.ticket nav),
        header,
        footer,
        .mud-overlay {
            display: none !important;
            width: 0 !important;
            height: 0 !important;
            overflow: hidden !important;
        }

        /* Reset complet du body */
        html, body {
            margin: 0 !important;
            padding: 0 !important;
            background: #fff !important;
            width: 80mm !important;
            min-width: 0 !important;
            overflow: visible !important;
        }

        /* Reset des conteneurs MudBlazor */
        .mud-layout,
        .mud-main-content,
        #app,
        #blazor-error-ui {
            margin: 0 !important;
            padding: 0 !important;
            width: 80mm !important;
            min-width: 0 !important;
            max-width: 80mm !important;
        }

        .mud-main-content {
            margin-left: 0 !important;
            padding-top: 0 !important;
        }

        /* Ticket : on prend toute la place */
        .ticket-wrapper {
            display: block !important;
            padding: 0 !important;
            margin: 0 !important;
            width: 80mm !important;
        }

        .ticket {
            width: 80mm !important;
            max-width: 80mm !important;
            margin: 0 !important;
            padding: 2mm 3mm !important;
            box-sizing: border-box !important;
            border: none !important;
            box-shadow: none !important;
            border-radius: 0 !important;
            font-size: 11px !important;
        }

        /* S'assurer que les couleurs s'impriment */
        .ticket * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        /* En-tête colonnes bien visible à l'impression */
        .ticket-table thead th {
            font-size: 9px !important;
            color: #000 !important;
            border-bottom: 1px solid #000 !important;
        }

        /* Séparateurs bien visibles */
        .ticket-sep { border-top-color: #000 !important; }
        .ticket-sep-bold { border-top: 2px solid #000 !important; }

        /* Total bien gras */
        .ticket-grand-total {
            font-size: 13px !important;
            font-weight: 900 !important;
        }
    }
</style>

@code {
    [Parameter] public int IdFacture { get; set; }
    [Parameter] public bool AutoPrint { get; set; }

    bool _loading = true;
    bool _printed;
    Fact? _facture;
    List<FactDetail> _details = new();
    string _shopName = "App++";
    string? _shopPhotoSrc;
    string? _shopAdresse1;
    string? _shopAdresse2;

    bool _isUsd => _facture?.Money?.DescriptionMonais == "USD";
    string _deviseLabel => _isUsd ? "$" : "FC";

    decimal MontantPrint(decimal montantFC) =>
        _isUsd && _facture!.Taux > 0
            ? Math.Round(montantFC / _facture.Taux, 2)
            : montantFC;

    protected override async Task OnInitializedAsync()
    {
        var shopProfile = await ShopProfileService.GetAsync();
        _shopName = shopProfile.AppNameSetting?.Value ?? "App++";
        _shopPhotoSrc = shopProfile.PhotoShop;
        _shopAdresse1 = shopProfile.Adresse1;
        _shopAdresse2 = shopProfile.Adresse2;

        var fact = await FacturationService.GetFactureWithDetailsAsync(IdFacture);
        if (fact != null)
        {
            _facture = fact;
            _details = fact.Details.ToList();
        }

        _loading = false;
    }

    void Fermer() => Navigation.NavigateTo("/vente/facturation");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && AutoPrint && !_printed && _facture != null)
        {
            _printed = true;
            await Task.Delay(300);
            await JS.InvokeVoidAsync("eval", "window.print();");
        }
    }
}
