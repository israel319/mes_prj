@page "/admin/fournisseur/nouveau"
@page "/admin/fournisseur/modifier/{SupplierId:int}"
@rendermode InteractiveServer
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject ISupplierService SupplierService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@AppSettings.AppName — @(_isEdit ? "Modifier le fournisseur" : "Nouveau fournisseur")</PageTitle>

<div class="lov-card" style="max-width:620px; margin:40px auto;">
    <div class="lov-form-header">
        <h5 style="font-weight:700; font-size:1.25rem;">@(_isEdit ? "Modifier le fournisseur" : "Nouveau fournisseur")</h5>
        <div class="d-flex" style="gap:0.5rem;">
            <button type="button" class="btn btn-sm btn-save-teal d-flex align-items-center gap-1"
                    @onclick="@OnSave">
                <i class="bi bi-check-lg"></i> Enregistrer
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    style="padding:6px 16px; border-radius:6px; font-size:13px; font-weight:500;"
                    @onclick="@OnCancel">
                <i class="bi bi-arrow-left"></i> Annuler
            </button>
        </div>
    </div>
    <div class="lov-form-body" style="padding:28px 32px 32px;">
        <div class="row g-4">
            <div class="col-4">
                <label class="form-label">N° Fournisseur</label>
                <input type="text" class="form-control" @bind="_item.SupplierNumber" placeholder="FRN-001" />
            </div>
            <div class="col-8">
                <label class="form-label">Nom *</label>
                <input type="text" class="form-control" @bind="_item.SupplierName" placeholder="Nom du fournisseur" />
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-6">
                <label class="form-label">Contact / Téléphone</label>
                <input type="text" class="form-control" @bind="_item.Contact" placeholder="+243 ..." />
            </div>
            <div class="col-6">
                <label class="form-label">Email</label>
                <input type="text" class="form-control" @bind="_item.Email" placeholder="email@exemple.com" />
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-12">
                <label class="form-label">Adresse</label>
                <input type="text" class="form-control" @bind="_item.Adresse" placeholder="Adresse du fournisseur" />
            </div>
        </div>
        <div class="row g-4 mt-1">
            <div class="col-6">
                <label class="form-label">Montant à payer</label>
                <MudNumericField @bind-Value="_item.CcAmountToPay" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="0.00" />
            </div>
            <div class="col-6">
                <label class="form-label">Montant payé</label>
                <MudNumericField @bind-Value="_item.CcAmountPay" T="decimal?" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="0.00" />
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? SupplierId { get; set; }

    bool _isEdit;
    Supplier _item = new();
    string _currentLogin = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authUser = authState.User;
        if (authUser.Identity?.IsAuthenticated == true)
        {
            _currentLogin = authUser.FindFirst("login")?.Value
                ?? authUser.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "";
        }

        if (SupplierId.HasValue)
        {
            _isEdit = true;
            var existing = await SupplierService.GetByIdAsync(SupplierId.Value);
            if (existing != null) _item = existing;
        }
    }

    async Task OnCancel()
    {
        await JS.InvokeVoidAsync("appNavigation.backOrFallback", "/administration");
    }

    async Task OnSave()
    {
        if (string.IsNullOrWhiteSpace(_item.SupplierName))
        {
            Snackbar.Add("Le nom est obligatoire", Severity.Warning);
            return;
        }

        try
        {
            _item.UserLogin = _currentLogin;

            if (_isEdit)
            {
                await SupplierService.UpdateAsync(_item);
            }
            else
            {
                _item.CreationDate = DateOnly.FromDateTime(DateTime.Today);
                await SupplierService.AddAsync(_item);
            }

            Snackbar.Add(_item.SupplierName, Severity.Success);
            Navigation.NavigateTo("/administration");
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
    }
}
