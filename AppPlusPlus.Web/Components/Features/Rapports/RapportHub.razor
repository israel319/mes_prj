    /* ════════════════════ HISTORIQUE — LOGIQUE ════════════════════ */

    async Task LoadHistorique()
    {
        _histoLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var from = DateOnly.FromDateTime(_histoFrom ?? new DateTime(DateTime.Today.Year, 1, 1));
        var to = DateOnly.FromDateTime(_histoTo ?? DateTime.Today);
        var articles = await ctx.Articles.ToDictionaryAsync(a => a.IdArticle, a => a.Description ?? a.IdArticle);

        var facts = await ctx.Facts.Where(f => f.Date >= from && f.Date <= to && f.Status != 0).OrderByDescending(f => f.DateSys).ToListAsync();
        var venteRows = facts.Select(f => {
            var (lbl, st) = f.Status switch { 0 => ("Brouillon", Color.Default), 1 => ("Validée", Color.Info), 2 => ("Payée", Color.Success), 3 => ("Annulée", Color.Error), _ => ("—", Color.Secondary) };
            return new HistoRow { DateOp = f.DateSys, Date = f.Date, Type = "Vente", Reference = $"F-{f.Id:D6}", Description = f.DescriptionName + (string.IsNullOrEmpty(f.DescriptionArticle) ? "" : $" — {f.DescriptionArticle}"), Montant = f.TotalApresReduction ?? f.Total ?? 0, StatusCode = f.Status, StatusLabel = lbl, StatusStyle = st, Utilisateur = f.User, FactId = f.Id };
        });

        var appros = await ctx.Appros.Where(a => a.Date >= from && a.Date <= to).OrderByDescending(a => a.DateSys).ToListAsync();
        var approRows = appros.Select(a => new HistoRow { DateOp = a.DateSys, Date = a.Date, Type = "Appro", Reference = $"A-{a.Id:D6}", Description = articles.GetValueOrDefault(a.IdArticle, a.IdArticle), Montant = (a.PA ?? 0) * a.Qte, StatusCode = 1, StatusLabel = "Effectué", StatusStyle = Color.Success, Utilisateur = a.User, FactId = null });

        _histoData = venteRows.Concat(approRows).OrderByDescending(r => r.DateOp).Select((r, i) => { r.RowId = i; return r; }).ToList();
        _histoLoading = false;
    }

