    /* ════════════════════ COMMANDES — LOGIQUE ════════════════════ */

    async Task LoadCommandes()
    {
        _cmdLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var from = _cmdFrom.HasValue ? DateOnly.FromDateTime(_cmdFrom.Value) : (DateOnly?)null;
        var to = _cmdTo.HasValue ? DateOnly.FromDateTime(_cmdTo.Value) : (DateOnly?)null;
        var query = ctx.Cmds.Include(c => c.Supplier).Include(c => c.Details).AsQueryable();
        if (from.HasValue) query = query.Where(c => c.DateCommande >= from.Value);
        if (to.HasValue) query = query.Where(c => c.DateCommande <= to.Value);
        var cmds = await query.OrderByDescending(c => c.DateCommande).ToListAsync();

        var articleIds = cmds.SelectMany(c => c.Details).Select(d => d.IdArticle).Where(id => id != null).Distinct().ToList();
        var articleNames = articleIds.Any()
            ? await ctx.Articles.Where(a => articleIds.Contains(a.IdArticle)).ToDictionaryAsync(a => a.IdArticle, a => a.Description ?? a.IdArticle)
            : new Dictionary<string, string>();

        _cmdData = cmds.Select(c =>
        {
            var arts = c.Details.Select(d => new CmdArticleInfo { Name = articleNames.GetValueOrDefault(d.IdArticle ?? "", d.IdArticle ?? "?") ?? d.IdArticle ?? "?", QteOrder = (decimal)(d.QteOrder ?? 0), QteReceived = (decimal)(d.QteReceive ?? 0) }).ToList();
            return new CmdRptRow { Id = c.Id, Fournisseur = c.Supplier?.SupplierName ?? "—", DateCommande = c.DateCommande, Status = c.Status ?? 0, User = c.User ?? "—", NbArticles = arts.Count, TotalOrder = arts.Sum(a => a.QteOrder), TotalReceived = arts.Sum(a => a.QteReceived), Articles = arts };
        }).ToList();
        _cmdLoading = false;
    }

    Func<CmdRptRow, int, string> CmdRowStyle => (item, _) => item.Status == 3 ? "opacity:0.5;" : "";

