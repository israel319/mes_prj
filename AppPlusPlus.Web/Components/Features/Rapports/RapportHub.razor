@page "/rapports"
@using MudBlazor
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ILocalisationService LocalisationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject MudBlazor.IDialogService DialogService
@inject ISnackbar Snackbar
@using System.Security.Claims

<PageTitle>@AppSettings.AppName — Rapports</PageTitle>

@if (!_loaded)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height:200px;"><div class="spinner-border text-primary" role="status"></div></div>
}
else
{
<div class="report-shell">
<!-- En-tête -->
<div class="d-flex flex-wrap align-items-center justify-content-between mb-2 report-header">
    <div class="d-flex align-items-center gap-3">
        <div class="hub-icon report-icon">
            <i class="bi bi-bar-chart fs-4"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0 fs-5">Rapports & Analyses</h2>
            <small class="text-muted">Bilans, statistiques de ventes, stock, commandes et historique</small>
        </div>
    </div>
</div>

<!-- Onglets -->
<div class="card report-tabs-shell">
    <ul class="nav nav-tabs">
        <li class="nav-item"><button class="nav-link @(_tab == 0 ? "active" : "")" @onclick="@(() => _tab = 0)"><i class="bi bi-graph-up me-1"></i>Bilan</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 1 ? "active" : "")" @onclick="@(() => _tab = 1)"><i class="bi bi-graph-up-arrow me-1"></i>Ventes</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 2 ? "active" : "")" @onclick="@(() => _tab = 2)"><i class="bi bi-box-seam me-1"></i>Stock</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 3 ? "active" : "")" @onclick="@(() => _tab = 3)"><i class="bi bi-list-check me-1"></i>Commandes</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 4 ? "active" : "")" @onclick="@(() => _tab = 4)"><i class="bi bi-graph-down me-1"></i>Appro & Bénéfice</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 5 ? "active" : "")" @onclick="@(() => _tab = 5)"><i class="bi bi-calendar3 me-1"></i>Ventes mensuelles</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 6 ? "active" : "")" @onclick="@(() => _tab = 6)"><i class="bi bi-arrow-left-right me-1"></i>Ventes & Appro</button></li>
        <li class="nav-item"><button class="nav-link @(_tab == 7 ? "active" : "")" @onclick="@(() => _tab = 7)"><i class="bi bi-clock-history me-1"></i>Historique</button></li>
    </ul>

            @* ══════════════════ BILAN ══════════════════ *@
            @if (_tab == 0)
            {
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                    <div class="d-flex gap-2 align-items-center flex-wrap report-toolbar">
                        <MudToggleGroup T="string" Value="_bilanPeriode" ValueChanged="@((string v) => { _bilanPeriode = v; OnBilanPeriodeChanged(); })" Color="Color.Primary" Size="Size.Small" SelectionMode="SelectionMode.SingleSelection">
                            <MudToggleItem Value="@("jour")" Text="Journalier" />
                            <MudToggleItem Value="@("semaine")" Text="Hebdomadaire" />
                            <MudToggleItem Value="@("mois")" Text="Mensuel" />
                        </MudToggleGroup>
                        <MudDatePicker @bind-Date="_bilanFrom" DateFormat="dd/MM/yyyy" Style="width:140px;" />
                        <span class="text-muted">—</span>
                        <MudDatePicker @bind-Date="_bilanTo" DateFormat="dd/MM/yyyy" Style="width:140px;" />
                        <button class="btn btn-info btn-sm" @onclick="@LoadBilan"><i class="bi bi-arrow-clockwise me-1"></i>Actualiser</button>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="@ExportBilanExcel" disabled="@(!_bilanRows.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                        <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                        <button class="btn btn-warning btn-sm" @onclick="@SendBilanEmail" disabled="@(!_bilanRows.Any())"><i class="bi bi-envelope me-1"></i>Envoyer par email</button>
                    </div>
                </div>

                <div class="row g-3 mb-2">
                    <div class="col-sm-12 col-md-3">
                        <div class="card report-kpi-card"><div class="card-body text-center">
                            <i class="bi bi-receipt" style="font-size:32px;color:var(--bs-primary);"></i>
                            <h5 class="mb-0">@_bilanNbFactures</h5>
                            <small class="text-muted">Factures</small>
                        </div></div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="card report-kpi-card"><div class="card-body text-center">
                            <i class="bi bi-currency-dollar" style="font-size:32px;color:var(--bs-success);"></i>
                            <h5 class="mb-0">@_bilanTotalVentes.ToString("N2")</h5>
                            <small class="text-muted">Ventes</small>
                        </div></div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="card report-kpi-card"><div class="card-body text-center">
                            <i class="bi bi-truck" style="font-size:32px;color:var(--bs-info);"></i>
                            <h5 class="mb-0">@_bilanTotalAppros.ToString("N2")</h5>
                            <small class="text-muted">Approvisionnements</small>
                        </div></div>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <div class="card report-kpi-card"><div class="card-body text-center">
                            <i class="bi bi-graph-up-arrow" style="@($"font-size:32px;color:{(_bilanBenefice >= 0 ? "var(--bs-success)" : "var(--bs-danger)")};")" ></i>
                            <h5 class="mb-0" style="@($"color:{(_bilanBenefice >= 0 ? "var(--bs-success)" : "var(--bs-danger)")};")">@_bilanBenefice.ToString("N2")</h5>
                            <small class="text-muted">Bénéfice</small>
                        </div></div>
                    </div>
                </div>

                <h6 class="fw-semibold mb-2">@_bilanTitre</h6>

                <div class="card"><div class="card-body p-0">
                    <MudDataGrid @ref="_bilanGrid" Items="@_bilanRows" T="BilanRow" Loading="@_bilanLoading" Dense="true">
                        <Columns>
                            <PropertyColumn Property="@(x => x.Date)" Title="Date" Style="width:110px;" Format="dd/MM/yyyy" />
                            <TemplateColumn T="BilanRow" Title="Type" Style="width:110px;">
                                <CellTemplate>
                                    @{ var r = context.Item; }
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(r.Type == "Vente" ? Color.Success : r.Type == "Appro" ? Color.Info : r.Type == "Transfert" ? Color.Warning : Color.Default)">@r.Type</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.Reference)" Title="Réf." Style="width:90px;" />
                            <PropertyColumn Property="@(x => x.Description)" Title="Description" />
                            <PropertyColumn Property="@(x => x.Qte)" Title="Qté" Style="width:70px; text-align:center;" Format="N0" />
                            <PropertyColumn Property="@(x => x.Montant)" Title="Montant" Style="width:120px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Utilisateur)" Title="Utilisateur" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_bilanRows.Any())
                {
                    <div class="d-flex justify-content-end mt-2 gap-3">
                        <small class="text-muted">@_bilanRows.Count lignes</small>
                        <small class="fw-bold" style="color:#00B193;">Total : @_bilanRows.Sum(r => r.Montant).ToString("N2")</small>
                    </div>
                }
            </div>
            }

            @* ══════════════════ VENTES ══════════════════ *@
            @if (_tab == 1)
            {
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="d-flex gap-2 align-items-center">
                        <span class="text-muted">Du</span>
                        <MudDatePicker @bind-Date="_venteFrom" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                        <span class="text-muted">Au</span>
                        <MudDatePicker @bind-Date="_venteTo" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                        <button class="btn btn-info btn-sm" @onclick="@LoadVentes"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="@ExportVenteExcel" disabled="@(!_venteData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                        <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                    </div>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_venteData" T="RptVenteVm" Loading="@_venteLoading">
                        <Columns>
                            <PropertyColumn Property="@(x => x.NumFacture)" Title="N° Facture" Style="width:100px;" />
                            <PropertyColumn Property="@(x => x.Client)" Title="Client" />
                            <PropertyColumn Property="@(x => x.Article)" Title="Article" />
                            <PropertyColumn Property="@(x => x.Qte)" Title="Qté" Style="width:80px; text-align:center;" Format="N2" />
                            <PropertyColumn Property="@(x => x.PU)" Title="PU" Style="width:100px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.TotalLigne)" Title="Total ligne" Style="width:120px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Total)" Title="Total facture" Style="width:120px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Reduction)" Title="% Réd." Style="width:80px; text-align:center;" Format="N0" />
                            <PropertyColumn Property="@(x => x.Taux)" Title="Taux" Style="width:80px; text-align:right;" Format="N0" />
                            <PropertyColumn Property="@(x => x.Date)" Title="Date" Style="width:110px;" Format="dd/MM/yyyy" />
                            <PropertyColumn Property="@(x => x.Utilisateur)" Title="Établie par" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_venteData.Any())
                {
                    <div class="d-flex justify-content-end mt-2 gap-3">
                        <small class="text-muted">@_venteData.Count lignes</small>
                        <small class="fw-bold" style="color:#00B193;">Total : @_venteData.Sum(v => (decimal)v.TotalLigne).ToString("N2")</small>
                    </div>
                }
            </div>
            }

            @* ══════════════════ STOCK ══════════════════ *@
            @if (_tab == 2)
            {
            <div class="card-body">
                <div class="d-flex justify-content-end gap-2 mb-2">
                    <button class="btn btn-primary btn-sm" @onclick="@ExportStockExcel" disabled="@(!_stockData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_stockData" T="Article" Loading="@_stockLoading">
                        <Columns>
                            <PropertyColumn Property="@(x => x.IdArticle)" Title="Code" Style="width:120px;" />
                            <PropertyColumn Property="@(x => x.Description)" Title="Article" />
                            <PropertyColumn Property="@(x => x.Price)" Title="Prix" Style="width:100px; text-align:right;" Format="N2" />
                            <TemplateColumn T="Article" Title="Stock" Style="width:90px; text-align:center;">
                                <CellTemplate>
                                    @{ var s = context.Item; }
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@((s.Qte ?? 0) <= s.Soeuil ? Color.Error : Color.Success)">@((s.Qte ?? 0).ToString())</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.Soeuil)" Title="Seuil" Style="width:80px; text-align:center;" />
                            <PropertyColumn Property="@(x => x.TotalPrice)" Title="Valeur stock" Style="width:130px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.User)" Title="Utilisateur" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_stockData.Any())
                {
                    <div class="d-flex justify-content-end mt-2 gap-3">
                        <small class="text-muted">@_stockData.Count articles</small>
                        <small class="fw-bold" style="color:#00B193;">Valeur totale : @_stockData.Sum(a => a.TotalPrice ?? 0).ToString("N2")</small>
                    </div>
                }
            </div>
            }

            @* ══════════════════ COMMANDES ══════════════════ *@
            @if (_tab == 3)
            {
            <div class="card-body">
                <div class="d-flex justify-content-start gap-2 align-items-center mb-2">
                    <span class="text-muted">Du</span>
                    <MudDatePicker @bind-Date="_cmdFrom" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                    <span class="text-muted">Au</span>
                    <MudDatePicker @bind-Date="_cmdTo" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                    <button class="btn btn-info btn-sm" @onclick="@LoadCommandes"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                    <div style="flex:1;"></div>
                    <button class="btn btn-primary btn-sm" @onclick="@ExportCmdExcel" disabled="@(!_cmdData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_cmdData" T="CmdRptRow" Loading="@_cmdLoading" Dense="true" RowStyleFunc="@CmdRowStyle">
                        <Columns>
                            <PropertyColumn Property="@(x => x.Id)" Title="N°" Style="width:60px;" />
                            <PropertyColumn Property="@(x => x.Fournisseur)" Title="Fournisseur" Style="width:160px;" />
                            <TemplateColumn T="CmdRptRow" Title="Articles" Style="width:250px;" Sortable="false">
                                <CellTemplate>
                                    @{ var r = context.Item; }
                                    @foreach (var art in r.Articles)
                                    {
                                        <div style="font-size:0.85rem; line-height:1.5;">
                                            <strong>@art.Name</strong>
                                            <span style="color:var(--mud-palette-text-secondary);"> — Cmd: @art.QteOrder.ToString("N0")</span>
                                            @if (art.QteReceived > 0)
                                            {
                                                <span style="color:var(--mud-palette-success);"> ✓ Reçu: @art.QteReceived.ToString("N0")</span>
                                            }
                                        </div>
                                    }
                                    @if (!r.Articles.Any())
                                    {
                                        <span style="color:var(--mud-palette-text-secondary);">Aucun article</span>
                                    }
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.NbArticles)" Title="Nb Art." Style="width:80px; text-align:center;" />
                            <TemplateColumn T="CmdRptRow" Title="Réception" Style="width:130px; text-align:center;" Sortable="false">
                                <CellTemplate>
                                    @{ var r = context.Item; }
                                    @if (r.TotalOrder > 0)
                                    {
                                        var pct = (int)(r.TotalReceived / r.TotalOrder * 100);
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudProgressLinear Value="@pct" Max="100" Style="width:70px;height:16px;" />
                                            <MudText Typo="Typo.caption" Class="ma-0">@pct%</MudText>
                                        </MudStack>
                                    }
                                    else { <span>—</span> }
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.DateCommande)" Title="Date cmd" Style="width:110px;" Format="dd/MM/yyyy" />
                            <TemplateColumn T="CmdRptRow" Title="Statut" Style="width:110px; text-align:center;">
                                <CellTemplate>
                                    @{ var r = context.Item; }
                                    @{ var (label, style) = r.Status switch { 0 => ("Nouvelle", Color.Default), 1 => ("En cours", Color.Warning), 2 => ("Reçue", Color.Success), 3 => ("Annulée", Color.Error), _ => ("—", Color.Secondary) }; }
                                    <MudChip T="string" Size="Size.Small" Color="@style">@label</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.User)" Title="Utilisateur" Style="width:100px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_cmdData.Any())
                {
                    <div class="card mt-4"><div class="card-body">
                        <div class="row">
                            <div class="col"><span><strong>Total :</strong> @_cmdData.Count</span></div>
                            <div class="col"><span><strong>Nouvelles :</strong> @_cmdData.Count(r => r.Status == 0)</span></div>
                            <div class="col"><span><strong>En cours :</strong> @_cmdData.Count(r => r.Status == 1)</span></div>
                            <div class="col"><span><strong>Reçues :</strong> @_cmdData.Count(r => r.Status == 2)</span></div>
                            <div class="col"><span><strong>Annulées :</strong> @_cmdData.Count(r => r.Status == 3)</span></div>
                        </div>
                    </div></div>
                }
            </div>
            }

            @* ══════════════════ APPRO & BÉNÉFICE ══════════════════ *@
            @if (_tab == 4)
            {
            <div class="card-body">
                <div class="d-flex justify-content-start gap-2 align-items-center mb-2">
                    <span class="text-muted">Du</span>
                    <MudDatePicker @bind-Date="_benFrom" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                    <span class="text-muted">Au</span>
                    <MudDatePicker @bind-Date="_benTo" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                    <button class="btn btn-info btn-sm" @onclick="@LoadApproBen"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                    <div style="flex:1;"></div>
                    <button class="btn btn-primary btn-sm" @onclick="@ExportBenExcel" disabled="@(!_benData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_benData" T="ApproBenRow" Loading="@_benLoading">
                        <Columns>
                            <PropertyColumn Property="@(x => x.Id)" Title="N°" Style="width:70px;" />
                            <PropertyColumn Property="@(x => x.ArticleName)" Title="Article" />
                            <PropertyColumn Property="@(x => x.Qte)" Title="Qté" Style="width:80px; text-align:center;" Format="N2" />
                            <PropertyColumn Property="@(x => x.PA)" Title="PA" Style="width:100px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.PV)" Title="PV" Style="width:100px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Ben)" Title="Bén. unit." Style="width:100px; text-align:right;" Format="N2" />
                            <TemplateColumn T="ApproBenRow" Title="Bén. total" Style="width:120px; text-align:right;">
                                <CellTemplate>
                                    @{ var a = context.Item; }
                                    <MudText Style="@((a.BenTotal) >= 0 ? "color:var(--mud-palette-success);" : "color:var(--mud-palette-error);")" Class="ma-0">
                                        @(a.BenTotal.ToString("N2"))
                                    </MudText>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.Date)" Title="Date" Style="width:110px;" Format="dd/MM/yyyy" />
                            <PropertyColumn Property="@(x => x.User)" Title="Utilisateur" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_benData.Any())
                {
                    <div class="d-flex justify-content-end mt-2 gap-3">
                        <small class="text-muted">@_benData.Count lignes</small>
                        <small class="fw-bold" style="color:#00B193;">Bénéfice total : @_benData.Sum(b => b.BenTotal).ToString("N2")</small>
                    </div>
                }
            </div>
            }

            @* ══════════════════ VENTES MENSUELLES ══════════════════ *@
            @if (_tab == 5)
            {
            <div class="card-body">
                <div class="d-flex justify-content-start gap-2 align-items-center mb-2">
                    <span class="text-muted">Mois</span>
                    <MudDatePicker @bind-Date="_vmMois" DateFormat="MM/yyyy" Style="width:150px;" />
                    <button class="btn btn-info btn-sm" @onclick="@LoadVenteMois"><i class="bi bi-funnel me-1"></i>Afficher</button>
                    <div style="flex:1;"></div>
                    <button class="btn btn-primary btn-sm" @onclick="@ExportVmExcel" disabled="@(!_vmData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                </div>
                <div class="row g-3 mb-2">
                    <div class="col-3">
                        <div class="card"><div class="card-body text-center">
                            <i class="bi bi-receipt" style="font-size:32px;color:var(--bs-primary);"></i>
                            <h5 class="mb-0">@_vmTotalFactures</h5>
                            <small class="text-muted">Factures</small>
                        </div></div>
                    </div>
                    <div class="col-3">
                        <div class="card"><div class="card-body text-center">
                            <i class="bi bi-currency-dollar" style="font-size:32px;color:var(--bs-success);"></i>
                            <h5 class="mb-0">@_vmTotalMontant.ToString("N2")</h5>
                            <small class="text-muted">Total ventes</small>
                        </div></div>
                    </div>
                    <div class="col-3">
                        <div class="card"><div class="card-body text-center">
                            <i class="bi bi-percent" style="font-size:32px;color:var(--bs-info);"></i>
                            <h5 class="mb-0">@_vmTotalReduction.ToString("N2")</h5>
                            <small class="text-muted">Total réductions</small>
                        </div></div>
                    </div>
                    <div class="col-3">
                        <div class="card"><div class="card-body text-center">
                            <i class="bi bi-wallet2" style="font-size:32px;color:var(--bs-warning);"></i>
                            <h5 class="mb-0">@_vmTotalNet.ToString("N2")</h5>
                            <small class="text-muted">Net à payer</small>
                        </div></div>
                    </div>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_vmData" T="Fact" Loading="@_vmLoading">
                        <Columns>
                            <PropertyColumn Property="@(x => x.Id)" Title="N° Facture" Style="width:100px;" />
                            <PropertyColumn Property="@(x => x.DescriptionName)" Title="Client" />
                            <PropertyColumn Property="@(x => x.Total)" Title="Total" Style="width:120px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Reduction)" Title="Réduction" Style="width:100px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.TotalApresReduction)" Title="Net à payer" Style="width:130px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Date)" Title="Date" Style="width:110px;" Format="dd/MM/yyyy" />
                            <TemplateColumn T="Fact" Title="Statut" Style="width:100px;">
                                <CellTemplate>
                                    @{ var v = context.Item; }
                                    @{ var (label, style) = v.Status switch { 0 => ("Brouillon", Color.Warning), 1 => ("Validée", Color.Info), 2 => ("Payée", Color.Success), 3 => ("Annulée", Color.Error), _ => ("Inconnu", Color.Default) }; }
                                    <MudChip T="string" Size="Size.Small" Color="@style">@label</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.User)" Title="Utilisateur" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
            </div>
            }

            @* ══════════════════ VENTES & APPRO ══════════════════ *@
            @if (_tab == 6)
            {
            <div class="card-body">
                <div class="d-flex justify-content-start gap-2 align-items-center mb-2">
                    <span class="text-muted">Du</span>
                    <MudDatePicker @bind-Date="_vaFrom" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                    <span class="text-muted">Au</span>
                    <MudDatePicker @bind-Date="_vaTo" DateFormat="dd/MM/yyyy" Style="width:150px;" />
                    <button class="btn btn-info btn-sm" @onclick="@LoadVenteAppro"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                    <div style="flex:1;"></div>
                    <button class="btn btn-primary btn-sm" @onclick="@ExportVaExcel" disabled="@(!_vaData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    <button class="btn btn-secondary btn-sm" @onclick="@(() => JS.InvokeVoidAsync("print"))"><i class="bi bi-printer me-1"></i>Imprimer</button>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_vaData" T="MouvementRow" Loading="@_vaLoading">
                        <Columns>
                            <PropertyColumn Property="@(x => x.IdArticle)" Title="Code" Style="width:120px;" />
                            <PropertyColumn Property="@(x => x.Description)" Title="Article" />
                            <PropertyColumn Property="@(x => x.Qte)" Title="Qté" Style="width:80px; text-align:center;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Pu)" Title="PU" Style="width:100px; text-align:right;" Format="N2" />
                            <PropertyColumn Property="@(x => x.Date)" Title="Date" Style="width:110px;" Format="dd/MM/yyyy" />
                            <TemplateColumn T="MouvementRow" Title="Mouvement" Style="width:110px;">
                                <CellTemplate>
                                    @{ var v = context.Item; }
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(v.Mouvement == "Entrée" ? Color.Success : Color.Error)">@v.Mouvement</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.Utilisateur)" Title="Utilisateur" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_vaData.Any())
                {
                    <div class="d-flex justify-content-end mt-2 gap-3">
                        <small class="text-muted">@_vaData.Count mouvements</small>
                        <small class="fw-bold" style="color:var(--bs-success);">Entrées : @_vaData.Where(m => m.Mouvement == "Entrée").Sum(m => m.Qte * m.Pu).ToString("N2")</small>
                        <small class="fw-bold" style="color:var(--bs-danger);">Sorties : @_vaData.Where(m => m.Mouvement == "Sortie").Sum(m => m.Qte * m.Pu).ToString("N2")</small>
                    </div>
                }
            </div>
            }

            @* ══════════════════ HISTORIQUE ══════════════════ *@
            @if (_tab == 7)
            {
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <span class="text-muted">Du</span>
                        <MudDatePicker @bind-Date="_histoFrom" DateFormat="dd/MM/yyyy" Style="width:140px;" />
                        <span class="text-muted">Au</span>
                        <MudDatePicker @bind-Date="_histoTo" DateFormat="dd/MM/yyyy" Style="width:140px;" />
                        <MudSelect T="string" @bind-Value="_histoTypeFilter" Placeholder="Tous les types" Clearable="true" Style="width:160px;">
                            @foreach (var opt in _histoTypeOptions)
                            {
                                <MudSelectItem T="string" Value="@opt.Key">@opt.Value</MudSelectItem>
                            }
                        </MudSelect>
                        <button class="btn btn-info btn-sm" @onclick="@LoadHistorique"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="@ExportHistoExcel" disabled="@(!_histoData.Any())"><i class="bi bi-file-earmark-excel me-1"></i>Exporter</button>
                </div>
                <div class="row g-3 mb-2">
                    <div class="col-sm-12 col-md-4">
                        <div class="card"><div class="card-body text-center">
                            <h6 class="mb-0" style="color:var(--bs-success);">@_histoData.Count(r => r.Type == "Vente")</h6>
                            <small class="text-muted">Ventes</small>
                        </div></div>
                    </div>
                    <div class="col-sm-12 col-md-4">
                        <div class="card"><div class="card-body text-center">
                            <h6 class="mb-0" style="color:var(--bs-info);">@_histoData.Count(r => r.Type == "Appro")</h6>
                            <small class="text-muted">Approvisionnements</small>
                        </div></div>
                    </div>
                    <div class="col-sm-12 col-md-4">
                        <div class="card"><div class="card-body text-center">
                            <h6 class="mb-0">@_histoData.Count</h6>
                            <small class="text-muted">Total mouvements</small>
                        </div></div>
                    </div>
                </div>
                <div class="card"><div class="card-body p-0">
                    <MudDataGrid Items="@_histoFiltered" T="HistoRow" Loading="@_histoLoading" Dense="true"
                                    Style="cursor:pointer;"
                                    RowClick="@OnHistoRowClick">
                        <Columns>
                            <PropertyColumn Property="@(x => x.DateOp)" Title="Date" Style="width:140px;" Format="dd/MM/yyyy HH:mm" />
                            <TemplateColumn T="HistoRow" Title="Type" Style="width:110px;">
                                <CellTemplate>
                                    @{ var r = context.Item; }
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(r.Type == "Vente" ? Color.Success : r.Type == "Appro" ? Color.Info : Color.Default)">@r.Type</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.Reference)" Title="Réf." Style="width:100px;" />
                            <PropertyColumn Property="@(x => x.Description)" Title="Description" />
                            <PropertyColumn Property="@(x => x.Montant)" Title="Montant" Style="width:120px; text-align:right;" Format="N2" />
                            <TemplateColumn T="HistoRow" Title="Statut" Style="width:100px;">
                                <CellTemplate>
                                    @{ var r = context.Item; }
                                    <MudChip T="string" Size="Size.Small" Color="@r.StatusStyle">@r.StatusLabel</MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="@(x => x.Utilisateur)" Title="Utilisateur" Style="width:110px;" />
                        </Columns>
                    </MudDataGrid>
                </div></div>
                @if (_histoFiltered.Any())
                {
                    <div class="d-flex justify-content-end mt-2 gap-3">
                        <small class="text-muted">@_histoFiltered.Count() lignes</small>
                        <small class="fw-bold" style="color:#00B193;">Total : @_histoFiltered.Sum(h => h.Montant).ToString("N2")</small>
                    </div>
                }
            </div>
            }

</div>
</div>
}

@code {
    /* ── Hub ── */
    int _tab;
    bool _loaded;
    List<int> _currentUserLocalisations = new();

    /* ════════════════════ BILAN ════════════════════ */
    MudDataGrid<BilanRow>? _bilanGrid;
    List<BilanRow> _bilanRows = new();
    bool _bilanLoading;
    string _bilanPeriode = "jour";
    DateTime? _bilanFrom = DateTime.Today;
    DateTime? _bilanTo = DateTime.Today;
    string _bilanTitre = "";
    int _bilanNbFactures;
    decimal _bilanTotalVentes;
    decimal _bilanTotalAppros;
    decimal _bilanBenefice;

    class BilanRow
    {
        public int RowId { get; set; }
        public DateOnly Date { get; set; }
        public string Type { get; set; } = "";
        public string Reference { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Qte { get; set; }
        public decimal Montant { get; set; }
        public string Utilisateur { get; set; } = "";
    }

    /* ════════════════════ VENTES ════════════════════ */
    DateTime? _venteFrom = new DateTime(2026, 1, 1);
    DateTime? _venteTo = DateTime.Today;
    bool _venteLoading;
    List<RptVenteVm> _venteData = new();

    record RptVenteVm(int NumFacture, string Client, string Article,
                      double Qte, double PU, double TotalLigne,
                      decimal Total, decimal Reduction, decimal Taux,
                      DateOnly Date, string Utilisateur);

    /* ════════════════════ STOCK ════════════════════ */
    List<Article> _stockData = new();
    bool _stockLoading;

    /* ════════════════════ COMMANDES ════════════════════ */
    List<CmdRptRow> _cmdData = new();
    bool _cmdLoading;
    DateTime? _cmdFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _cmdTo = DateTime.Today;

    class CmdRptRow
    {
        public int Id { get; set; }
        public string Fournisseur { get; set; } = "";
        public DateOnly? DateCommande { get; set; }
        public int Status { get; set; }
        public string User { get; set; } = "";
        public int NbArticles { get; set; }
        public decimal TotalOrder { get; set; }
        public decimal TotalReceived { get; set; }
        public List<CmdArticleInfo> Articles { get; set; } = new();
    }

    class CmdArticleInfo
    {
        public string Name { get; set; } = "";
        public decimal QteOrder { get; set; }
        public decimal QteReceived { get; set; }
    }

    /* ════════════════════ APPRO & BÉNÉFICE ════════════════════ */
    List<ApproBenRow> _benData = new();
    bool _benLoading;
    DateTime? _benFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _benTo = DateTime.Today;

    class ApproBenRow
    {
        public int Id { get; set; }
        public string ArticleName { get; set; } = "";
        public decimal Qte { get; set; }
        public decimal PA { get; set; }
        public decimal PV { get; set; }
        public decimal Ben { get; set; }
        public decimal BenTotal { get; set; }
        public DateOnly Date { get; set; }
        public string User { get; set; } = "";
    }

    /* ════════════════════ VENTES MENSUELLES ════════════════════ */
    List<Fact> _vmData = new();
    bool _vmLoading;
    DateTime? _vmMois = DateTime.Today;
    int _vmTotalFactures;
    decimal _vmTotalMontant;
    decimal _vmTotalReduction;
    decimal _vmTotalNet;

    /* ════════════════════ VENTES & APPRO ════════════════════ */
    List<MouvementRow> _vaData = new();
    bool _vaLoading;
    DateTime? _vaFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _vaTo = DateTime.Today;

    class MouvementRow
    {
        public int RowId { get; set; }
        public string IdArticle { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Qte { get; set; }
        public decimal Pu { get; set; }
        public DateOnly Date { get; set; }
        public string Mouvement { get; set; } = "";
        public string Utilisateur { get; set; } = "";
    }

    /* ════════════════════ HISTORIQUE ════════════════════ */
    List<HistoRow> _histoData = new();
    bool _histoLoading;
    DateTime? _histoFrom = new DateTime(DateTime.Today.Year, 1, 1);
    DateTime? _histoTo = DateTime.Today;
    string? _histoTypeFilter;

    List<KeyValuePair<string, string>> _histoTypeOptions = new()
    {
        new("Vente", "Ventes"),
        new("Appro", "Approvisionnements"),
    };

    IEnumerable<HistoRow> _histoFiltered =>
        _histoTypeFilter is null ? _histoData : _histoData.Where(r => r.Type == _histoTypeFilter);

    class HistoRow
    {
        public int RowId { get; set; }
        public DateTime DateOp { get; set; }
        public DateOnly Date { get; set; }
        public string Type { get; set; } = "";
        public string Reference { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Montant { get; set; }
        public int StatusCode { get; set; }
        public string StatusLabel { get; set; } = "";
        public Color StatusStyle { get; set; } = Color.Default;
        public string Utilisateur { get; set; } = "";
        public int? FactId { get; set; }
    }

    /* ════════════════════════════════════════════════════════════
       INIT
       ════════════════════════════════════════════════════════════ */

    protected override async Task OnInitializedAsync()
    {
        // Fetch user's assigned localisations via service
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var login = user.FindFirst("login")?.Value
                ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var isAdmin = AppFunctions.Normalize(user.FindFirst(ClaimTypes.Role)?.Value) == "administrateur";

            if (!string.IsNullOrEmpty(login))
            {
                _currentUserLocalisations = await LocalisationService.GetUserLocalisationIdsAsync(login, isAdmin);
            }
        }

        SetBilanPeriodDates();
        await Task.WhenAll(
            LoadBilan(),
            LoadVentes(),
            LoadStock(),
            LoadCommandes(),
            LoadApproBen(),
            LoadVenteMois(),
            LoadVenteAppro(),
            LoadHistorique()
        );
        _loaded = true;
    }

    /* ════════════════════ BILAN — LOGIQUE ════════════════════ */

    void OnBilanPeriodeChanged()
    {
        SetBilanPeriodDates();
        _ = LoadBilan();
    }

    void SetBilanPeriodDates()
    {
        var today = DateTime.Today;
        switch (_bilanPeriode)
        {
            case "jour":
                _bilanFrom = today; _bilanTo = today; break;
            case "semaine":
                int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
                _bilanFrom = today.AddDays(-diff); _bilanTo = _bilanFrom.Value.AddDays(6); break;
            case "mois":
                _bilanFrom = new DateTime(today.Year, today.Month, 1);
                _bilanTo = _bilanFrom.Value.AddMonths(1).AddDays(-1); break;
        }
    }

    async Task LoadBilan()
    {
        _bilanLoading = true;
        StateHasChanged();
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var from = DateOnly.FromDateTime(_bilanFrom ?? DateTime.Today);
        var to = DateOnly.FromDateTime(_bilanTo ?? DateTime.Today);

        _bilanTitre = _bilanPeriode switch
        {
            "jour" => $"Bilan journalier — {from:dd/MM/yyyy}",
            "semaine" => $"Bilan hebdomadaire — {from:dd/MM/yyyy} au {to:dd/MM/yyyy}",
            "mois" => $"Bilan mensuel — {from:MMMM yyyy}",
            _ => "Bilan"
        };

        var articles = await ctx.Articles.ToDictionaryAsync(a => a.IdArticle, a => a.Description ?? a.IdArticle);

        var facts = await ctx.Facts
            .Where(f => f.Date >= from && f.Date <= to && f.Status != 3 && f.Status != 0)
            .Include(f => f.Details)
            .OrderByDescending(f => f.Date)
            .ToListAsync();

        var venteRows = facts.Select(f =>
        {
            var artNames = f.Details.Any()
                ? string.Join(", ", f.Details.Select(d => articles.GetValueOrDefault(d.IdArticle ?? "", d.IdArticle ?? "")).Where(n => !string.IsNullOrEmpty(n)).Distinct())
                : f.DescriptionArticle;
            return new BilanRow
            {
                Date = f.Date, Type = "Vente", Reference = $"F-{f.Id:D6}",
                Description = f.DescriptionName + (string.IsNullOrEmpty(artNames) ? "" : $" — {artNames}"),
                Qte = (decimal)f.Details.Sum(d => d.Qte ?? 0),
                Montant = f.TotalApresReduction ?? f.Total ?? 0, Utilisateur = f.User
            };
        });

        var appros = await ctx.Appros.Where(a => a.Date >= from && a.Date <= to).OrderByDescending(a => a.Date).ToListAsync();
        var vraisAppros = appros.Where(a => a.StatusId != 1).ToList();
        var transferts = appros.Where(a => a.StatusId == 1).ToList();

        var approRows = vraisAppros.Select(a => new BilanRow
        {
            Date = a.Date, Type = "Appro", Reference = $"A-{a.Id:D6}",
            Description = articles.GetValueOrDefault(a.IdArticle, a.IdArticle),
            Qte = a.Qte, Montant = (a.PA ?? 0) * a.Qte, Utilisateur = a.User
        });

        var transfertRows = transferts.Select(a => new BilanRow
        {
            Date = a.Date, Type = "Transfert", Reference = $"T-{a.Id:D6}",
            Description = articles.GetValueOrDefault(a.IdArticle, a.IdArticle) + $" ({a.Commentaire})",
            Qte = a.Qte, Montant = 0, Utilisateur = a.User
        });

        _bilanRows = venteRows.Concat(approRows).Concat(transfertRows)
            .OrderByDescending(r => r.Date).Select((r, i) => { r.RowId = i; return r; }).ToList();

        _bilanNbFactures = facts.Count;
        _bilanTotalVentes = facts.Sum(f => f.TotalApresReduction ?? f.Total ?? 0);
        _bilanTotalAppros = vraisAppros.Sum(a => (a.PA ?? 0) * a.Qte);
        _bilanBenefice = vraisAppros.Sum(a => a.BenTotal ?? 0);
        _bilanLoading = false;
        StateHasChanged();
    }

    async Task ExportBilanExcel()
    {
        using var workbook = new ClosedXML.Excel.XLWorkbook();
        var ws = workbook.Worksheets.Add("Bilan");
        ws.Cell(1, 1).Value = _bilanTitre; ws.Cell(1, 1).Style.Font.Bold = true; ws.Cell(1, 1).Style.Font.FontSize = 14; ws.Range(1, 1, 1, 7).Merge();
        ws.Cell(3, 1).Value = "Factures"; ws.Cell(3, 2).Value = _bilanNbFactures;
        ws.Cell(4, 1).Value = "Total ventes"; ws.Cell(4, 2).Value = (double)_bilanTotalVentes; ws.Cell(4, 2).Style.NumberFormat.Format = "#,##0.00";
        ws.Cell(5, 1).Value = "Total appros"; ws.Cell(5, 2).Value = (double)_bilanTotalAppros; ws.Cell(5, 2).Style.NumberFormat.Format = "#,##0.00";
        ws.Cell(6, 1).Value = "Bénéfice"; ws.Cell(6, 2).Value = (double)_bilanBenefice; ws.Cell(6, 2).Style.NumberFormat.Format = "#,##0.00";
        ws.Range(3, 1, 6, 1).Style.Font.Bold = true;
        string[] headers = { "Date", "Type", "Réf.", "Description", "Qté", "Montant", "Utilisateur" };
        for (int i = 0; i < headers.Length; i++) { var cell = ws.Cell(8, i + 1); cell.Value = headers[i]; cell.Style.Font.Bold = true; cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#4472C4"); cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.White; }
        int row = 9;
        foreach (var r in _bilanRows) { ws.Cell(row, 1).Value = r.Date.ToString("dd/MM/yyyy"); ws.Cell(row, 2).Value = r.Type; ws.Cell(row, 3).Value = r.Reference; ws.Cell(row, 4).Value = r.Description; ws.Cell(row, 5).Value = (double)r.Qte; ws.Cell(row, 6).Value = (double)r.Montant; ws.Cell(row, 6).Style.NumberFormat.Format = "#,##0.00"; ws.Cell(row, 7).Value = r.Utilisateur; row++; }
        ws.Columns().AdjustToContents();
        using var ms = new System.IO.MemoryStream(); workbook.SaveAs(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        var fileName = $"Bilan_{_bilanPeriode}_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
        await JS.InvokeVoidAsync("eval", $"var a=document.createElement('a');a.href='data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();document.body.removeChild(a);");
    }

    byte[] GenerateBilanExcelBytes()
    {
        using var workbook = new ClosedXML.Excel.XLWorkbook();
        var ws = workbook.Worksheets.Add("Bilan");
        ws.Cell(1, 1).Value = _bilanTitre; ws.Cell(1, 1).Style.Font.Bold = true; ws.Cell(1, 1).Style.Font.FontSize = 14; ws.Range(1, 1, 1, 7).Merge();
        ws.Cell(3, 1).Value = "Factures"; ws.Cell(3, 2).Value = _bilanNbFactures;
        ws.Cell(4, 1).Value = "Total ventes"; ws.Cell(4, 2).Value = (double)_bilanTotalVentes; ws.Cell(4, 2).Style.NumberFormat.Format = "#,##0.00";
        ws.Cell(5, 1).Value = "Total appros"; ws.Cell(5, 2).Value = (double)_bilanTotalAppros; ws.Cell(5, 2).Style.NumberFormat.Format = "#,##0.00";
        ws.Cell(6, 1).Value = "Bénéfice"; ws.Cell(6, 2).Value = (double)_bilanBenefice; ws.Cell(6, 2).Style.NumberFormat.Format = "#,##0.00";
        string[] headers = { "Date", "Type", "Réf.", "Description", "Qté", "Montant", "Utilisateur" };
        for (int i = 0; i < headers.Length; i++) { var cell = ws.Cell(8, i + 1); cell.Value = headers[i]; cell.Style.Font.Bold = true; cell.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.FromHtml("#4472C4"); cell.Style.Font.FontColor = ClosedXML.Excel.XLColor.White; }
        int row = 9;
        foreach (var r in _bilanRows) { ws.Cell(row, 1).Value = r.Date.ToString("dd/MM/yyyy"); ws.Cell(row, 2).Value = r.Type; ws.Cell(row, 3).Value = r.Reference; ws.Cell(row, 4).Value = r.Description; ws.Cell(row, 5).Value = (double)r.Qte; ws.Cell(row, 6).Value = (double)r.Montant; ws.Cell(row, 6).Style.NumberFormat.Format = "#,##0.00"; ws.Cell(row, 7).Value = r.Utilisateur; row++; }
        ws.Columns().AdjustToContents();
        using var ms = new System.IO.MemoryStream(); workbook.SaveAs(ms); return ms.ToArray();
    }

    async Task SendBilanEmail()
    {
        var parameters = new DialogParameters
        {
            ["Subject"] = _bilanTitre,
            ["ExcelBytes"] = GenerateBilanExcelBytes(),
            ["ExcelFileName"] = $"Bilan_{_bilanPeriode}_{DateTime.Now:yyyyMMdd}.xlsx"
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<EmailDialog>("Envoyer le rapport par email", parameters, options);
    }

    /* ════════════════════ VENTES — LOGIQUE ════════════════════ */

    async Task LoadVentes()
    {
        _venteLoading = true;
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var from = _venteFrom.HasValue ? DateOnly.FromDateTime(_venteFrom.Value) : DateOnly.MinValue;
        var to = _venteTo.HasValue ? DateOnly.FromDateTime(_venteTo.Value) : DateOnly.MaxValue;
        _venteData = await ctx.FactDetails
            .Include(d => d.Fact).Include(d => d.Article)
            .Where(d => d.Fact != null && d.Fact.Date >= from && d.Fact.Date <= to && d.Fact.Status != 0)
            .OrderBy(d => d.Fact!.Date).ThenBy(d => d.Fact!.Id)
            .Select(d => new RptVenteVm(d.Fact!.Id, d.Fact.DescriptionName, d.Article != null ? d.Article.Description : (d.IdArticle ?? ""),
                d.Qte ?? 0, d.Pu ?? 0, (d.Qte ?? 0) * (d.Pu ?? 0), d.Fact.TotalApresReduction ?? d.Fact.Total ?? 0, d.Fact.Reduction ?? 0, d.Fact.Taux, d.Fact.Date, d.Fact.User))
            .ToListAsync();
        _venteLoading = false;
    }

    async Task ExportVenteExcel()
    {
        using var workbook = new ClosedXML.Excel.XLWorkbook();
