<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@3.35.0/dist/tabler-icons.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&amp;display=block" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="appliweb-logo-v2.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    <ReconnectModal />
    <script>
        window.appNavigation = {
            backOrFallback: function (fallbackUrl) {
                try {
                    const referrer = document.referrer || "";
                    const sameOriginReferrer = referrer.startsWith(window.location.origin);
                    if (window.history.length > 1 && sameOriginReferrer) {
                        window.history.back();
                        return;
                    }
                } catch (e) {
                }
                window.location.href = fallbackUrl || "/";
            }
        };

        // Navigation avec onglet
        window.tabNavigation = {
            saveTab: function(hubName, tabIndex) {
                try {
                    localStorage.setItem('hub_tab_' + hubName, tabIndex);
                } catch { }
            },
            getTab: function(hubName, defaultTab = 0) {
                try {
                    const val = localStorage.getItem('hub_tab_' + hubName);
                    return val ? parseInt(val) : defaultTab;
                } catch {
                    return defaultTab;
                }
            },
            clearTab: function(hubName) {
                try {
                    localStorage.removeItem('hub_tab_' + hubName);
                } catch { }
            }
        };

        // Fix: Fermer le dropdown MudAutocomplete après sélection d'un élément
        (function () {
            document.addEventListener('click', function (e) {
                var listItem = e.target.closest('.mud-list-item-clickable');
                if (!listItem) return;
                // Laisser Blazor traiter la sélection, puis blur pour fermer le popover
                setTimeout(function () {
                    var focused = document.activeElement;
                    if (focused && focused.tagName === 'INPUT') {
                        var autocomplete = focused.closest('.mud-autocomplete');
                        if (autocomplete) {
                            focused.blur();
                        }
                    }
                }, 150);
            }, true);
        })();

        // Impression rapport : montre toutes les lignes, imprime, puis restaure la pagination
        window.printReport = function () {
            // Expand all MudDataGrid rows by setting a huge page size
            var pagerSelects = document.querySelectorAll('.mud-table-pagination .mud-select-input');
            var originalValues = [];
            pagerSelects.forEach(function(sel, i) {
                originalValues[i] = sel.textContent;
            });
            // Click "All" or set rows per page very high — simpler: hide pagination and show all via CSS
            document.body.classList.add('print-all-rows');
            setTimeout(function() {
                window.print();
                document.body.classList.remove('print-all-rows');
            }, 100);
        };

        // Impression directe d'une facture via iframe cachée
        window.printFacture = function (id) {
            var iframe = document.createElement('iframe');
            iframe.style.position = 'absolute';
            iframe.style.width = '0';
            iframe.style.height = '0';
            iframe.style.border = 'none';
            iframe.style.left = '-9999px';
            iframe.src = '/vente/facture/print/' + id + '/true';
            document.body.appendChild(iframe);

            // Nettoyer l'iframe après l'impression
            iframe.onload = function() {
                setTimeout(function() {
                    document.body.removeChild(iframe);
                }, 5000);
            };
        };
    </script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
